#!/bin/sh
# astral-sync - Index generator and repository sync tool for AOHARU/ASURA
# Scans a recipes directory, builds astral.index, optionally signs it,
# and optionally commits + pushes to the GitHub repo that GitHub Pages serves.
#
# Usage: astral-sync [command] [options]
# Run 'astral-sync help' for full usage.

set -eu

VERSION="1.1.6"
RECIPES_DIR="${RECIPES_DIR:-./recipes}"
OUTPUT_DIR="${OUTPUT_DIR:-.}"
INDEX_FILE="${OUTPUT_DIR}/astral.index"
GPG_KEY="${GPG_KEY:-}"
AUTO_PUSH="${AUTO_PUSH:-0}"
REPO_NAME="${REPO_NAME:-AOHARU}"
DRY_RUN="${DRY_RUN:-0}"
PARALLEL_JOBS="${PARALLEL_JOBS:-8}"
DOWNLOAD_RETRIES="${DOWNLOAD_RETRIES:-3}"
JOB_DELAY="${JOB_DELAY:-0}"
VERBOSE="${VERBOSE:-0}"
FIX_CHECKSUMS="${FIX_CHECKSUMS:-0}"

# Checksum state file ÔÇö tracks which packages have been verified
# Lives beside the index so it can be committed alongside it
CHECKSUM_STATE="${OUTPUT_DIR}/.astral-checksum-state"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

err()   { printf "${RED}[error]${NC} %s\n" "$*" >&2; exit 1; }
warn()  { printf "${YELLOW}[warn]${NC}  %s\n" "$*" >&2; }
info()  { printf "%s\n" "$*"; }
ok()    { printf "${GREEN}Ôťô${NC} %s\n" "$*"; }
step()  { printf "${CYAN}Ôćĺ${NC} %s\n" "$*"; }
vinfo() { [ "$VERBOSE" -eq 1 ] && printf "  %s\n" "$*" >&2 || true; }

usage() {
    cat <<USAGE
astral-sync v$VERSION

Usage: astral-sync <command> [options]

ÔöüÔöüÔöü Index Commands ÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöüÔöü

  generate              Scan recipes and write astral.index
  sign [--key <id>]     Sign astral.index with GPG
  verify                Verify astral.index.sig
