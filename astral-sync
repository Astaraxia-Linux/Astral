}

# ============================================================
# RECIPE SCANNING
# ============================================================

# Extract version from a .stars recipe file
# Handles v1, v2, v3 formats
extract_version_from_stars() {
    _sf="$1"

    # v3: Version = "x.y.z" inside $PKG.Metadata block
    # v2: VERSION = "x.y.z" inside $PKG.Metadata block
    # v1: VERSION="x.y.z" at top level
    _ver=$(grep -E '^\s*(Version|VERSION)\s*=\s*"[^"]*"' "$_sf" 2>/dev/null \
        | head -n1 \
        | sed 's/.*=\s*"\([^"]*\)".*/\1/')

    # Fall back to version= without quotes (v1 bare assignment)
    if [ -z "$_ver" ]; then
        _ver=$(grep -E '^VERSION=' "$_sf" 2>/dev/null \
            | head -n1 \
            | sed 's/VERSION="\([^"]*\)"/\1/; s/VERSION=\([^ ]*\)/\1/')
    fi

    printf '%s' "${_ver:-unknown}"
}

# Extract arch from a .stars recipe file
# Falls back to "any" if not specified (source packages are arch-agnostic by default)
extract_arch_from_stars() {
    _sf="$1"

    _arch=$(grep -E '^\s*(Arch|ARCH|Architecture)\s*=\s*"[^"]*"' "$_sf" 2>/dev/null \
        | head -n1 \
        | sed 's/.*=\s*"\([^"]*\)".*/\1/')

    printf '%s' "${_arch:-any}"
}

# Get version from a directory-format recipe (legacy)
extract_version_from_dir() {
    _dir="$1"
    if [ -f "$_dir/version" ]; then
        cat "$_dir/version"
    elif [ -f "$_dir/build" ]; then
        grep -E '^VERSION=' "$_dir/build" 2>/dev/null \
            | head -n1 \
            | sed 's/VERSION="\([^"]*\)"/\1/; s/VERSION=\([^ ]*\)/\1/' \
            || printf 'unknown'
    else
        printf 'unknown'
    fi
}

# Scan the recipes directory and emit lines: category pkg arch version
# Handles both sharded layout (category/s/pkg/) and legacy (category/pkg/, category/pkg.stars)
scan_recipes() {
    _dir="$1"

    [ -d "$_dir" ] || err "Recipes directory not found: $_dir"

    # Helper: parse a single .stars file and emit: category pkgname arch version
    _emit_stars_record() {
        _sf="$1"; _cat="$2"
        _basename=$(basename "$_sf" .stars)
        _arch_from_name="" _ver_from_name="" _pkgname=""
        case "$_basename" in
            *-any|*-x86_64|*-aarch64|*-armv7h|*-i686|*-riscv64)
                _arch_from_name=$(printf '%s' "$_basename" | sed 's/.*-//')
                _without_arch=$(printf '%s' "$_basename" | sed 's/-[^-]*$//')
                _last=$(printf '%s' "$_without_arch" | sed 's/.*-//')
                case "$_last" in
                    git|[0-9]*|v[0-9]*)
                        _ver_from_name="$_last"
                        _pkgname=$(printf '%s' "$_without_arch" | sed 's/-[^-]*$//') ;;
                    *) _pkgname="$_without_arch" ;;
                esac ;;
            *) _pkgname="$_basename" ;;
        esac
        _ver=$(extract_version_from_stars "$_sf")
        [ -z "$_ver" ] || [ "$_ver" = "unknown" ] && _ver="${_ver_from_name:-unknown}"
        _arch=$(extract_arch_from_stars "$_sf")
        [ "$_arch" = "any" ] && [ -n "$_arch_from_name" ] && _arch="$_arch_from_name"
        vinfo "found: $_cat/$_pkgname | $_arch | $_ver (from $_basename.stars)"
        printf '%s %s %s %s\n' "$_cat" "$_pkgname" "$_arch" "$_ver"
    }

    find "$_dir" -mindepth 1 -maxdepth 1 -type d | sort | while read -r catdir; do
        _category=$(basename "$catdir")

        # Skip hidden dirs and non-category dirs
        case "$_category" in
            .*|_*) continue ;;
        esac

        # ÔöÇÔöÇ Sharded layout: category/s/pkg/ ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ
        find "$catdir" -mindepth 1 -maxdepth 1 -type d | sort | while read -r sharddir; do
            _shard=$(basename "$sharddir")
            # Single lowercase letter = shard dir; skip everything else
            case "$_shard" in [a-z]) ;; *) continue ;; esac
            # pkg dirs inside the shard
            find "$sharddir" -mindepth 1 -maxdepth 1 -type d | sort | while read -r pkgdir; do
                # .stars files inside the pkg dir
                find "$pkgdir" -maxdepth 1 -type f -name "*.stars" 2>/dev/null | sort | \
                while read -r sf; do _emit_stars_record "$sf" "$_category"; done
                # Expanded dir-format (build script present)
                if [ -f "$pkgdir/build" ]; then
                    _pkgname=$(basename "$pkgdir")
                    _ver=$(extract_version_from_dir "$pkgdir")
                    _arch="any"
                    vinfo "found: $_category/$_pkgname | $_arch | $_ver (sharded dir)"
                    printf '%s %s %s %s\n' "$_category" "$_pkgname" "$_arch" "$_ver"
                fi
            done
        done

        # ÔöÇÔöÇ Legacy layout: category/pkgname-ver-arch.stars ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ
        find "$catdir" -maxdepth 1 -type f -name "*.stars" 2>/dev/null | sort | \
        while read -r sf; do _emit_stars_record "$sf" "$_category"; done

        # ÔöÇÔöÇ Legacy dir-format: category/pkg/ with a build file ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ
        find "$catdir" -maxdepth 1 -type d 2>/dev/null | sort | while read -r pkgdir; do
            [ "$pkgdir" = "$catdir" ] && continue
            _pn=$(basename "$pkgdir")
            # Skip single-letter shard dirs (already handled above)
            case "$_pn" in [a-z]) continue ;; esac
            [ -f "$pkgdir/build" ] || continue
            _ver=$(extract_version_from_dir "$pkgdir")
            _arch="any"
            vinfo "found: $_category/$_pn | $_arch | $_ver (legacy dir)"
            printf '%s %s %s %s\n' "$_category" "$_pn" "$_arch" "$_ver"
        done
    done
}

# ============================================================
# INDEX GENERATION
# ============================================================

cmd_generate() {
    step "Scanning recipes: $RECIPES_DIR"

    # Collect all entries grouped by category
    _tmpfile=$(mktemp "${TMPDIR:-/tmp}/astral-sync-scan.XXXXXX")

    scan_recipes "$RECIPES_DIR" > "$_tmpfile"

    _total=$(wc -l < "$_tmpfile" | tr -d ' ')
    info "  found $_total packages"

    if [ "$DRY_RUN" -eq 1 ]; then
        info "[dry-run] Would write index to: $INDEX_FILE"
        info "[dry-run] Contents would be:"
        awk '
        {
            cat=$1; pkg=$2; arch=$3; ver=$4
            if (cat != prev_cat) {
                if (prev_cat != "") {
                    print "# " prev_cat " (" cat_count " package" (cat_count==1?"":"s") ")"
                    print prev_cat ": {"
                    for (i=1; i<=cat_count; i++) print lines[i]
                    print "}"
                    print ""
                }
                prev_cat=cat; cat_count=0
            }
            cat_count++
            lines[cat_count]="  " pkg " | " arch " | " ver
        }
        END {
            if (prev_cat != "") {
                print "# " prev_cat " (" cat_count " package" (cat_count==1?"":"s") ")"
                print prev_cat ": {"
                for (i=1; i<=cat_count; i++) print lines[i]
                print "}"
            }
        }' "$_tmpfile"
        rm -f "$_tmpfile"
        return 0
    fi

    mkdir -p "$OUTPUT_DIR"

    # Write the index
    {
        printf '# Astral Repository Index v2.0\n'
        printf '# Format: category/package | arch | version\n'
        printf '# Generated by astral-sync v%s on %s\n' "$VERSION" "$(date -u '+%Y-%m-%d %H:%M UTC')"
        printf '# Repository: %s\n' "$REPO_NAME"
        printf '# Packages: %s\n' "$_total"
        printf '\n'

        awk '
        {
            cat=$1; pkg=$2; arch=$3; ver=$4
            if (cat != prev_cat) {
                if (prev_cat != "") {
                    print "# " prev_cat " (" cat_count " package" (cat_count==1?"":"s") ")"
                    print prev_cat ": {"
                    for (i=1; i<=cat_count; i++) print lines[i]
                    print "}"
                    print ""
                }
                prev_cat=cat; cat_count=0
            }
            cat_count++
            lines[cat_count]="  " pkg " | " arch " | " ver
        }
        END {
            if (prev_cat != "") {
                print "# " prev_cat " (" cat_count " package" (cat_count==1?"":"s") ")"
                print prev_cat ": {"
                for (i=1; i<=cat_count; i++) print lines[i]
                print "}"
            }
        }' "$_tmpfile"
    } > "$INDEX_FILE"

    rm -f "$_tmpfile"

    ok "Index written: $INDEX_FILE ($_total packages)"
}

# ============================================================
# SIGNING
# ============================================================

cmd_sign() {
    [ -f "$INDEX_FILE" ] || err "Index file not found: $INDEX_FILE -- run 'generate' first"

    if [ -z "$GPG_KEY" ]; then
        warn "No GPG key specified (--key or GPG_KEY env var)"
        warn "Index will not be signed. Astral will warn users about missing signature."
        return 0
    fi

    command -v gpg >/dev/null 2>&1 || err "gpg not found -- cannot sign index"

    _sigfile="${INDEX_FILE}.sig"

    if [ "$DRY_RUN" -eq 1 ]; then
        info "[dry-run] Would sign $INDEX_FILE with key $GPG_KEY"
        info "[dry-run] Signature would be written to: $_sigfile"
        return 0
    fi

    step "Signing with key: $GPG_KEY"
    gpg --detach-sign --armor --default-key "$GPG_KEY" \
        --output "$_sigfile" "$INDEX_FILE" \
        || err "GPG signing failed"

    ok "Signature: $_sigfile"
}

# ============================================================
# VERIFY
# ============================================================

cmd_verify() {
    [ -f "$INDEX_FILE" ] || err "Index file not found: $INDEX_FILE"

    _sigfile="${INDEX_FILE}.sig"
    [ -f "$_sigfile" ] || err "Signature file not found: $_sigfile"

    command -v gpg >/dev/null 2>&1 || err "gpg not found"

    step "Verifying signature..."
    if gpg --verify "$_sigfile" "$INDEX_FILE" 2>&1; then
        ok "Signature verified"
    else
        err "Signature verification FAILED"
    fi
}

# ============================================================
# GIT PUSH
# ============================================================

cmd_push() {
    command -v git >/dev/null 2>&1 || err "git not found"

    # Check we're in a git repo
    git -C "$OUTPUT_DIR" rev-parse --git-dir >/dev/null 2>&1 \
        || err "Output directory is not a git repository: $OUTPUT_DIR"

    _sigfile="${INDEX_FILE}.sig"
    _files="$INDEX_FILE"
    [ -f "$_sigfile" ] && _files="$_files $_sigfile"

    if [ "$DRY_RUN" -eq 1 ]; then
        info "[dry-run] Would run:"
        info "  git -C $OUTPUT_DIR add $_files"
        info "  git -C $OUTPUT_DIR commit -m 'astral-sync: regenerate index'"
        info "  git -C $OUTPUT_DIR push"
        return 0
    fi

    _pkg_count=$(grep -c '|' "$INDEX_FILE" 2>/dev/null || true)
    _pkg_count="${_pkg_count:-0}"

    git -C "$OUTPUT_DIR" add $_files
    git -C "$OUTPUT_DIR" diff --cached --quiet && {
        info "Nothing to commit ÔÇö index is up to date"
        return 0
    }
    git -C "$OUTPUT_DIR" commit -m "astral-sync: regenerate index (${_pkg_count} packages)"
    git -C "$OUTPUT_DIR" push

    ok "Pushed to remote"
}

# ============================================================
# STATUS
# ============================================================

cmd_status() {
    printf "${BOLD}astral-sync${NC} v%s\n\n" "$VERSION"

    printf "${BLUE}Paths${NC}\n"
    printf "  recipes  %s\n" "$RECIPES_DIR"
    printf "  output   %s\n" "$OUTPUT_DIR"
    printf "  index    %s\n" "$INDEX_FILE"
    printf "\n"

    printf "${BLUE}Index${NC}\n"
    if [ -f "$INDEX_FILE" ]; then
        _pkg_count=$(grep -c '|' "$INDEX_FILE" 2>/dev/null || printf 0)
        _cat_count=$(grep -c ': {' "$INDEX_FILE" 2>/dev/null || printf 0)
        _mtime=$(stat -c '%y' "$INDEX_FILE" 2>/dev/null | cut -d. -f1             || stat -f '%Sm' "$INDEX_FILE" 2>/dev/null || printf 'unknown')
        _sigfile="${INDEX_FILE}.sig"
        if [ -f "$_sigfile" ]; then _signed="${GREEN}yes${NC}"; else _signed="${YELLOW}no${NC}"; fi
        printf "  packages    %s\n" "$_pkg_count"
        printf "  categories  %s\n" "$_cat_count"
        printf "  generated   %s\n" "$_mtime"
        printf "  signed      %b\n" "$_signed"
    else
        printf "  ${YELLOW}not generated yet${NC} ÔÇö run: astral-sync generate\n"
    fi
    printf "\n"

    printf "${BLUE}Recipes${NC}\n"
    if [ -d "$RECIPES_DIR" ]; then
        _stars=$(find "$RECIPES_DIR" -name "*.stars" 2>/dev/null | wc -l | tr -d ' ')
        _dirs=$(find "$RECIPES_DIR" -mindepth 2 -maxdepth 3 -type d 2>/dev/null \
            -exec sh -c '[ -f "$1/build" ] && echo y' _ {} \; | wc -l | tr -d ' ')
        printf "  .stars  %s\n" "$_stars"
        printf "  dir     %s\n" "$_dirs"
    else
        printf "  ${RED}not found${NC}: %s\n" "$RECIPES_DIR"
    fi
    printf "\n"

    printf "${BLUE}Checksums${NC}\n"
    if [ -f "$CHECKSUM_STATE" ]; then
        _verified=$(grep -c "checksum-ok:" "$CHECKSUM_STATE" 2>/dev/null || printf 0)
        printf "  verified  %s packages\n" "$_verified"
    else
        printf "  not run yet ÔÇö run: astral-sync checksum\n"
    fi
}


# ============================================================
# CHECKSUM VERIFICATION
# ============================================================

# Extract all source URLs from a .stars recipe file
extract_sources_from_stars() {
    _sf="$1"
    # Match lines inside $PKG.Sources block that look like URLs
    awk '
        /\$PKG\.Sources[[:space:]]*:/{in_block=1; next}
        in_block && /^\}[[:space:]]*$/{in_block=0; next}
        in_block && /https?:\/\//{
            # Extract the URL ÔÇö handle: urls = "...", "...", or bare URL line
            line=$0
            gsub(/^[[:space:]]+/, "", line)
            gsub(/^urls[[:space:]]*=[[:space:]]*"/, "", line)
            gsub(/".*$/, "", line)
            gsub(/^"/, "", line)
            if (length(line) > 0) print line
        }
    ' "$_sf"
}

# Extract checksums block from a .stars recipe file
# Outputs: algo:hash filename
extract_checksums_from_stars() {
    _sf="$1"
    awk '
        /\$PKG\.Checksums[[:space:]]*:/{in_block=1; next}
        in_block && /^\}[[:space:]]*$/{in_block=0; next}
        in_block && NF>0 {
            line=$0
            gsub(/^[[:space:]]+/, "", line)
            if (length(line) > 0) print line
        }
    ' "$_sf"
}

# Check if a package is already marked verified in the state file
checksum_is_done() {
    _cpkg="$1"
    [ -f "$CHECKSUM_STATE" ] || return 1
    grep -F "checksum-ok: ${_cpkg} " "$CHECKSUM_STATE" >/dev/null 2>&1
}

# Mark a package as verified in the state file
checksum_mark_done() {
    _cpkg="$1"
    _cver="$2"
    printf "# checksum-ok: %s version=%s ts=%s\n"         "$_cpkg" "$_cver" "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"         >> "$CHECKSUM_STATE"
}

# Replace a wrong checksum in-place inside a .stars file
# Usage: fix_checksum_in_stars <file> <algo> <old_hash> <new_hash> <filename>
fix_checksum_in_stars() {
    _fix_sf="$1"
    _fix_algo="$2"
    _fix_old="$3"
    _fix_new="$4"
    _fix_fname="$5"

    # Build the old and new checksum line patterns
    # Handles both "algo:hash filename" and bare "hash filename" formats
    case "$_fix_algo" in
        sha256|sha512|md5)
            _old_line="${_fix_algo}:${_fix_old}  ${_fix_fname}"
            _new_line="${_fix_algo}:${_fix_new}  ${_fix_fname}"
            # Also handle bare hash format (no algo: prefix)
            _old_bare="${_fix_old}  ${_fix_fname}"
            _new_bare="${_fix_new}  ${_fix_fname}"
            ;;
    esac

    # Try exact replacement first (algo:hash format)
    if grep -qF "$_old_line" "$_fix_sf" 2>/dev/null; then
        sed -i "s|${_fix_algo}:${_fix_old}  ${_fix_fname}|${_fix_algo}:${_fix_new}  ${_fix_fname}|g" "$_fix_sf"
        return 0
    fi

    # Try bare hash format
    if grep -qF "$_old_bare" "$_fix_sf" 2>/dev/null; then
        sed -i "s|${_fix_old}  ${_fix_fname}|${_fix_new}  ${_fix_fname}|g" "$_fix_sf"
        return 0
    fi

    # Fallback: find any line containing the old hash in the Checksums block and replace hash portion
    sed -i "/\$PKG\.Checksums/,/^}/{
        s|\(.*\)${_fix_old}\(.*${_fix_fname}\)|\1${_fix_new}\2|g
    }" "$_fix_sf"
}

# Verify one .stars file's sources against its checksums
# Returns 0 if all pass (or all fixed), 1 if any fail unfixed
verify_stars_checksums() {
    _sf="$1"
    _label="$2"   # category/pkg for display
    _tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/astral-chksum.XXXXXX")
    _ok=0

    # Get checksums from recipe
    _checksums=$(extract_checksums_from_stars "$_sf")
    if [ -z "$_checksums" ]; then
        warn "  [$_label] No checksums block found ÔÇö skipping"
        rm -rf "$_tmpdir"
        return 0
    fi

    # Get source URLs
    _urls=$(extract_sources_from_stars "$_sf")
    if [ -z "$_urls" ]; then
        # Git-only recipe (no URLs to download)
        vinfo "[$_label] No HTTP sources ÔÇö skipping (git-only recipe)"
        rm -rf "$_tmpdir"
        return 0
    fi

    # Download each source and verify
    printf '%s
' "$_urls" | while IFS= read -r _url; do
        [ -z "$_url" ] && continue
        # Skip git:// and bare git sources
        case "$_url" in git+*|*.git) continue ;; esac

        _fname=$(basename "$_url" | sed 's/#.*//')
        _dest="$_tmpdir/$_fname"

        vinfo "  [$_label] Ôćĺ downloading: $_fname"
        if ! curl -fsSL -A "Mozilla/5.0 (X11; Linux x86_64; rv:124.0) Gecko/20100101 Firefox/124.0" --retry "$DOWNLOAD_RETRIES" --retry-delay 2 --retry-max-time 20 --connect-timeout 10 -o "$_dest" "$_url" 2>/dev/null; then
            warn "  [$_label] ÔťŚ Failed to download: $_url"
            printf 'DOWNLOAD_FAILED\n' > "$_tmpdir/.failed"
            continue
        fi

        # Find matching checksum entry ÔÇö use temp file to avoid subshell scope loss
        _match_file="$_tmpdir/.matched_${_fname}"
        printf '%s
' "$_checksums" | while IFS= read -r _cline; do
            [ -z "$_cline" ] && continue
            # Format: algo:hash filename  OR  hash  filename
            case "$_cline" in
                sha256:*)
                    _algo="sha256"
                    _hash=$(printf '%s' "$_cline" | cut -d: -f2 | awk '{print $1}')
                    _cfile=$(printf '%s' "$_cline" | awk '{print $2}')
                    ;;
                sha512:*)
                    _algo="sha512"
                    _hash=$(printf '%s' "$_cline" | cut -d: -f2 | awk '{print $1}')
                    _cfile=$(printf '%s' "$_cline" | awk '{print $2}')
                    ;;
                md5:*)
                    _algo="md5"
                    _hash=$(printf '%s' "$_cline" | cut -d: -f2 | awk '{print $1}')
                    _cfile=$(printf '%s' "$_cline" | awk '{print $2}')
                    ;;
                *)
                    # Bare hash: assume sha256
                    _algo="sha256"
                    _hash=$(printf '%s' "$_cline" | awk '{print $1}')
                    _cfile=$(printf '%s' "$_cline" | awk '{print $2}')
                    ;;
            esac

            [ "$_cfile" = "$_fname" ] || continue
            printf '%s\n' "$_algo" > "$_match_file"

            # Compute actual hash
            case "$_algo" in
                sha256) _actual=$(sha256sum "$_dest" 2>/dev/null | awk '{print $1}') ;;
                sha512) _actual=$(sha512sum "$_dest" 2>/dev/null | awk '{print $1}') ;;
                md5)    _actual=$(md5sum    "$_dest" 2>/dev/null | awk '{print $1}') ;;
            esac

            if [ "$_actual" = "$_hash" ]; then
                : # checksum ok ÔÇö reported at job level
            else
                warn "  [$_label] ÔťŚ MISMATCH (${_algo}): $_fname"
                warn "    expected: $_hash"
                warn "    actual:   $_actual"
                if [ "$FIX_CHECKSUMS" -eq 1 ]; then
                    if [ "$DRY_RUN" -eq 1 ]; then
                        info "  [$_label] [dry-run] Would update ${_algo} checksum in: $(basename \"$_sf\")"
                        info "    old: ${_algo}:${_hash}  ${_fname}"
                        info "    new: ${_algo}:${_actual}  ${_fname}"
                    else
                        fix_checksum_in_stars "$_sf" "$_algo" "$_hash" "$_actual" "$_fname"
                        ok "  [$_label] Ôć╗ fixed ${_algo} checksum in $(basename \"$_sf\")"
                        printf 'FIXED\n' > "$_tmpdir/.fixed"
                    fi
                else
                    printf 'FAIL\n' > "$_tmpdir/.failed"
                fi
            fi
        done

        if [ ! -f "$_match_file" ]; then
            warn "  [$_label] ÔÜá No checksum entry for: $_fname"
        fi
    done

    # Check if any file wrote FAIL or FIXED
    # If we fixed checksums, treat as success (return 0)
    # If we have failures and didn't fix, return 1
    if [ -f "$_tmpdir/.fixed" ]; then
        _ok=0  # Successfully fixed = success
    elif [ -f "$_tmpdir/.failed" ]; then
        _ok=1
    fi

    rm -rf "$_tmpdir"
    return $_ok
}

cmd_checksum() {
    command -v curl >/dev/null 2>&1 || err "curl is required for checksum verification"
    command -v sha256sum >/dev/null 2>&1 || err "sha256sum is required"

    info "Starting checksum verification (parallel jobs: $PARALLEL_JOBS)..."
    [ "$FIX_CHECKSUMS" -eq 1 ] && info "Mode: auto-fix mismatched checksums in .stars files"
    info "State file: $CHECKSUM_STATE"
    info ""

    _cdir=$(mktemp -d "${TMPDIR:-/tmp}/astral-sync-counts.XXXXXX")

    # Collect file list without pipe so we stay in parent shell
    find "$RECIPES_DIR" -mindepth 2 -maxdepth 4 -name "*.stars" 2>/dev/null | sort \
        > "$_cdir/filelist"

    _total=$(wc -l < "$_cdir/filelist" | tr -d ' ')
    _running=0

    # Kill all background jobs cleanly on Ctrl-C
    trap 'kill -- -$$ 2>/dev/null; rm -rf "$_cdir"; exit 130' INT TERM


    while IFS= read -r _sf; do
        _category=$(printf '%s' "$_sf" | sed "s|^${RECIPES_DIR}/||" | cut -d/ -f1)
        _basename=$(basename "$_sf" .stars)
        _pkgname=$(printf '%s' "$_basename" | sed 's/-[0-9][^-]*-[^-]*$//;s/-git-[^-]*$//')
        _label="${_category}/${_pkgname}"
        _key=$(printf '%s' "$_label" | tr '/' '_')

        # Already verified? Record and skip without backgrounding
        if checksum_is_done "$_label"; then
            vinfo "[$_label] already verified ÔÇö skipping"
            printf 'skip
' > "$_cdir/${_key}.result"
            continue
        fi

        if [ "$DRY_RUN" -eq 1 ]; then
            info "  [dry-run] Would verify: $_label"
            continue
        fi

        # Background job ÔÇö buffer output, print ONE line per package atomically
        [ "${JOB_DELAY:-0}" != "0" ] && sleep "$JOB_DELAY"
        (
            _out="$_cdir/${_key}.out"
            if { verify_stars_checksums "$_sf" "$_label"; } > "$_out" 2>&1; then
                _ver=$(extract_version_from_stars "$_sf")
                # Write state immediately (atomic append) so Ctrl-C doesn't lose progress
                checksum_mark_done "$_label" "$_ver"
                printf 'pass\n' > "$_cdir/${_key}.result"
                if grep 'Ôć╗' "$_out" >/dev/null 2>&1; then
                    printf "${YELLOW}Ôć╗${NC}  %-45s ${YELLOW}(fixed)${NC}\n" "$_label"
                else
                    printf "${GREEN}Ôťô${NC}  %s\n" "$_label"
                fi
            else
                printf 'fail\n' > "$_cdir/${_key}.result"
                grep -v '^[[:space:]]*$' "$_out" || true
                printf "${RED}ÔťŚ${NC}  %s\n" "$_label"
            fi
        ) &

        _running=$((_running + 1))
        if [ "$_running" -ge "$PARALLEL_JOBS" ]; then
            wait
            _running=0
        fi
    done < "$_cdir/filelist"

    # Wait for remaining jobs
    wait

    # Tally results and write checksum state serially (no race)
    _pass=0; _fail=0; _skip=0
    for _r in "$_cdir"/*.result; do
        [ -f "$_r" ] || continue
        _val=$(cat "$_r")
        case "$_val" in
            pass)
                _pass=$((_pass + 1))
                ;;
            fail:*) _fail=$((_fail + 1)) ;;
            skip)   _skip=$((_skip + 1)) ;;
        esac
    done

    trap - INT TERM
    rm -rf "$_cdir"

    info "ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ"
    info "Checksum verification complete"
    info "  Total:    $_total"
    info "  Skipped:  $_skip (already verified)"
    info "  Passed:   $_pass"
    [ "$FIX_CHECKSUMS" -eq 1 ] \
        && info "  Fixed:    (mismatches auto-corrected in .stars files)" \
        || info "  Failed:   $_fail"
    info "ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ"

    [ "$_fail" -gt 0 ] && return 1
    return 0
}

