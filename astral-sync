# Return the single-letter shard directory for a package name (matches astral's shard_for)
shard_for() { printf '%s' "$1" | cut -c1 | tr 'A-Z' 'a-z'; }

# Extract category from a .stars recipe file
extract_category_from_stars() {
    _sf="$1"
    grep -E '^\s*Category\s*=\s*"[^"]*"' "$_sf" 2>/dev/null \
        | head -n1 \
        | sed 's/.*=\s*"\([^"]*\)".*/\1/'
}

# Organize flat recipes into proper category/shard/pkg structure
# Example: nano-8.6-any.stars Ôćĺ recipes/app-editors/n/nano/nano-8.6-any.stars
cmd_migrate_organize() {
    [ -d "$RECIPES_DIR" ] || err "Recipes directory not found: $RECIPES_DIR"
    
    info "Organizing recipes into sharded structure..."
    [ "$DRY_RUN" -eq 1 ] && info "Mode: dry-run (no changes)"
    info ""
    
    _moved=0
    _skipped=0
    _failed=0
    
    # Find all .stars files (flat or partially organized)
    find "$RECIPES_DIR" -name "*.stars" 2>/dev/null | sort | while IFS= read -r _sf; do
        _basename=$(basename "$_sf" .stars)
        
        # Extract package name from filename (strip version-arch suffix)
        # nano-8.6-any Ôćĺ nano
        # rust-1.85.0-x86_64 Ôćĺ rust
        _pkgname=$(printf '%s' "$_basename" | sed 's/-[0-9][^-]*-[^-]*$//;s/-git-[^-]*$//')
        
        # Get category from recipe metadata
        _category=$(extract_category_from_stars "$_sf")
        if [ -z "$_category" ]; then
            warn "[$_basename] No category found in recipe ÔÇö skipping"
            _failed=$((_failed + 1))
            continue
        fi
        
        # Get shard (first letter)
        _shard=$(shard_for "$_pkgname")
        
        # Build target path
        _target_dir="$RECIPES_DIR/$_category/$_shard/$_pkgname"
        _target_file="$_target_dir/$(basename "$_sf")"
        
        # Check if already in correct location
        if [ "$_sf" = "$_target_file" ]; then
            vinfo "[$_basename] Already organized ÔÇö skipping"
            _skipped=$((_skipped + 1))
            continue
        fi
        
        # Move file
        if [ "$DRY_RUN" -eq 1 ]; then
            info "[$_basename] Would move:"
            info "  From: $_sf"
            info "  To:   $_target_file"
        else
            mkdir -p "$_target_dir"
            if mv "$_sf" "$_target_file" 2>/dev/null; then
                ok "[$_basename] Moved to $_category/$_shard/$_pkgname/"
                _moved=$((_moved + 1))
            else
                warn "[$_basename] Failed to move"
                _failed=$((_failed + 1))
            fi
        fi
    done
    
    info ""
    info "ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ"
    info "Organization complete"
    info "  Moved:    $_moved"
    info "  Skipped:  $_skipped (already organized)"
    info "  Failed:   $_failed"
    info "ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ"
    
    [ "$_failed" -gt 0 ] && return 1
    return 0
}

# ============================================================
# ARGUMENT PARSING
# ============================================================

COMMAND=""

while [ $# -gt 0 ]; do
    case "$1" in
        generate|sign|verify|push|sync|status|list|diff|migrate|migrate-organize|checksum|checksum-reset|empty-checksums|help)
            COMMAND="$1"
            shift
            ;;
        -r|--recipes)
            [ $# -gt 1 ] || err "--recipes requires an argument"
            RECIPES_DIR="$2"; shift 2
            ;;
        -o|--output)
            [ $# -gt 1 ] || err "--output requires an argument"
            OUTPUT_DIR="$2"
            INDEX_FILE="$OUTPUT_DIR/astral.index"
            shift 2
            ;;
        -k|--key)
            [ $# -gt 1 ] || err "--key requires an argument"
            GPG_KEY="$2"; shift 2
            ;;
        -p|--push)
            AUTO_PUSH=1; shift
            ;;
        -f|--fix)
            FIX_CHECKSUMS=1; shift
            ;;
        -n|--dry-run)
            DRY_RUN=1; shift
            ;;
        -v|--verbose)
            VERBOSE=1; shift
            ;;
        -V|--version)
            printf 'astral-sync v%s\n' "$VERSION"; exit 0
            ;;
        -h|--help|help)
            usage
            ;;
        -j|--jobs)
            [ $# -gt 1 ] || err "--jobs requires an argument"
            PARALLEL_JOBS="$2"; shift 2
            ;;
        -r|--retries)
            [ $# -gt 1 ] || err "--retries requires an argument"
            DOWNLOAD_RETRIES="$2"; shift 2
            ;;
        -d|--delay)
            [ $# -gt 1 ] || err "--delay requires an argument"
            JOB_DELAY="$2"; shift 2
            ;;
        *)
            err "Unknown option: $1"
            ;;
    esac
done

[ -z "$COMMAND" ] && usage

case "$COMMAND" in
    generate)
        cmd_generate
        [ "$AUTO_PUSH" -eq 1 ] && cmd_sign && cmd_push
        ;;
    sign)
        cmd_sign
        ;;
    verify)
        cmd_verify
        ;;
    push)
        cmd_push
        ;;
    sync)
        cmd_generate
        cmd_sign
        cmd_push
        ;;
    list)
        cmd_list "${1:-}"
        ;;
    diff)
        cmd_diff
        ;;
    migrate)
        cmd_migrate
        ;;
    migrate-organize)
        cmd_migrate_organize
        ;;
    checksum)
        cmd_checksum
        ;;
    checksum-reset)
        cmd_checksum_reset
        ;;
    empty-checksums)
        cmd_empty_checksums
        ;;
    status)
        cmd_status
        ;;
    help)
        usage
        ;;
esac
