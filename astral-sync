# ============================================================

# Move recipes from flat layout (category/pkg.stars or category/pkg/)
# to sharded layout (category/s/pkg/pkg-ver-arch.stars).
cmd_migrate() {
    [ -d "$RECIPES_DIR" ] || err "Recipes directory not found: $RECIPES_DIR"

    _moved=0; _skipped=0

    find "$RECIPES_DIR" -mindepth 1 -maxdepth 1 -type d | sort | while read -r catdir; do
        _cat=$(basename "$catdir")
        case "$_cat" in .*|_*) continue ;; esac

        # Legacy flat .stars: category/pkg.stars or category/pkgname-ver-arch.stars
        find "$catdir" -maxdepth 1 -type f -name "*.stars" 2>/dev/null | while read -r sf; do
            _basename=$(basename "$sf" .stars)
            # Try to parse pkgname from filename
            case "$_basename" in
                *-any|*-x86_64|*-aarch64|*-armv7h|*-i686|*-riscv64)
                    _arch=$(printf '%s' "$_basename" | sed 's/.*-//')
                    _wo=$(printf '%s' "$_basename" | sed 's/-[^-]*$//')
                    _last=$(printf '%s' "$_wo" | sed 's/.*-//')
                    case "$_last" in
                        git|[0-9]*|v[0-9]*)
                            _pkgname=$(printf '%s' "$_wo" | sed 's/-[^-]*$//') ;;
                        *) _pkgname="$_wo" ;;
                    esac ;;
                *) _pkgname="$_basename" ;;
            esac
            _shard=$(printf '%s' "$_pkgname" | cut -c1 | tr 'A-Z' 'a-z')
            _dest_dir="$catdir/$_shard/$_pkgname"
            # Already sharded?
            [ "${sf#$catdir/$_shard/}" != "$sf" ] && { _skipped=$((_skipped+1)); continue; }
            if [ "$DRY_RUN" -eq 1 ]; then
                info "  [dry-run] $sf Ôćĺ $_dest_dir/$(basename "$sf")"
            else
                mkdir -p "$_dest_dir"
                mv "$sf" "$_dest_dir/$(basename "$sf")"
                _moved=$((_moved+1))
                vinfo "moved: $_cat/$_pkgname"
            fi
        done

        # Legacy directory-based recipes: category/pkg/ with build file
        find "$catdir" -maxdepth 1 -type d 2>/dev/null | while read -r pkgdir; do
            [ "$pkgdir" = "$catdir" ] && continue
            _pn=$(basename "$pkgdir")
            case "$_pn" in [a-z]) continue ;; esac  # already a shard dir
            [ -f "$pkgdir/build" ] || continue
            _shard=$(printf '%s' "$_pn" | cut -c1 | tr 'A-Z' 'a-z')
            _dest_dir="$catdir/$_shard/$_pn"
            if [ "$DRY_RUN" -eq 1 ]; then
                info "  [dry-run] $pkgdir/ Ôćĺ $_dest_dir/"
            else
                mkdir -p "$(dirname "$_dest_dir")"
                mv "$pkgdir" "$_dest_dir"
                _moved=$((_moved+1))
                vinfo "moved dir: $_cat/$_pn"
            fi
        done
    done

    if [ "$DRY_RUN" -eq 1 ]; then
        info "Dry run complete ÔÇö no files moved"
    else
        ok "Migration complete"
    fi
}

