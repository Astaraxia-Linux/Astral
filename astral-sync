cmd_list() {
    _filter="${1:-}"
    [ -f "$INDEX_FILE" ] || err "Index not found: $INDEX_FILE ÔÇö run 'astral-sync generate' first"

    _count=0
    _cur_cat=""
    while IFS='|' read -r _entry _arch _ver; do
        [ -z "$_entry" ] && continue
        case "$_entry" in '#'*|'  '*) continue ;; esac
        _entry=$(printf '%s' "$_entry" | tr -d ' ')
        _arch=$(printf '%s' "$_arch" | tr -d ' ')
        _ver=$(printf '%s' "$_ver" | tr -d ' ')
        [ -z "$_entry" ] && continue
        _cat=$(printf '%s' "$_entry" | cut -d/ -f1)
        _pkg=$(printf '%s' "$_entry" | cut -d/ -f2)
        [ -n "$_filter" ] && [ "$_cat" != "$_filter" ] && continue
        if [ "$_cat" != "$_cur_cat" ]; then
            [ -n "$_cur_cat" ] && printf "\n"
            printf "${BOLD}%s${NC}\n" "$_cat"
            _cur_cat="$_cat"
        fi
        printf "  %-30s %s\n" "$_pkg" "$_ver"
        _count=$((_count + 1))
    done < "$INDEX_FILE"
    printf "\n%d package(s)\n" "$_count"
}

