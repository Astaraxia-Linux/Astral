# Check if a recipe has empty or TODO checksums
has_empty_checksums() {
    _sf="$1"
    # Check if Checksums block is missing, empty, or has only TODO/comments
    _chk=$(extract_checksums_from_stars "$_sf")
    
    # If no checksums at all, it's empty
    [ -z "$_chk" ] && return 0
    
    # If only has TODO or comments, it's empty
    printf '%s\n' "$_chk" | grep -qE '^(#|//|/\*)' && return 0
    printf '%s\n' "$_chk" | grep -iq 'TODO' && return 0
    
    # Has real checksums
    return 1
}

# Add checksums to a recipe file
add_checksums_to_stars() {
    _sf="$1"
    _label="$2"
    _tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/astral-empty-chk.XXXXXX")
    _fixed=0
    
    # Get source URLs
    _urls=$(extract_sources_from_stars "$_sf")
    if [ -z "$_urls" ]; then
        # Git-only recipe, skip
        vinfo "[$_label] No HTTP sources ÔÇö skipping (git-only)"
        rm -rf "$_tmpdir"
        return 0
    fi
    
    # Download each source and compute checksum
    _new_checksums=""
    printf '%s\n' "$_urls" | while IFS= read -r _url; do
        [ -z "$_url" ] && continue
        case "$_url" in git+*|*.git) continue ;; esac
        
        _fname=$(basename "$_url" | sed 's/#.*//')
        _dest="$_tmpdir/$_fname"
        
        info "  [$_label] Ôćĺ downloading: $_fname"
        if ! curl -fsSL -A "Mozilla/5.0 (X11; Linux x86_64; rv:124.0) Gecko/20100101 Firefox/124.0" --retry "$DOWNLOAD_RETRIES" --retry-delay 2 --retry-max-time 20 --connect-timeout 10 -o "$_dest" "$_url" 2>/dev/null; then
            warn "  [$_label] ÔťŚ Failed to download: $_url"
            printf 'FAIL\n' > "$_tmpdir/.failed"
            continue
        fi
        
        # Calculate sha256
        _hash=$(sha256sum "$_dest" 2>/dev/null | awk '{print $1}')
        printf "    sha256:%s %s\n" "$_hash" "$_fname" >> "$_tmpdir/.checksums"
    done
    
    # Check if download failed
    if [ -f "$_tmpdir/.failed" ]; then
        rm -rf "$_tmpdir"
        return 1
    fi
    
    # Read computed checksums
    if [ ! -f "$_tmpdir/.checksums" ]; then
        rm -rf "$_tmpdir"
        return 0
    fi
    
    _new_checksums=$(cat "$_tmpdir/.checksums")
    
    # Replace the Checksums block in the recipe
    # Strategy: Find the block, replace everything inside it
    if [ "$DRY_RUN" -eq 1 ]; then
        info "  [$_label] [dry-run] Would add checksums:"
        printf '%s\n' "$_new_checksums" | sed 's/^/      /'
    else
        # Create a temp file with the new recipe
        _tmpfile="$_tmpdir/recipe.new"
        awk -v checksums="$_new_checksums" '
            /\$PKG\.Checksums[[:space:]]*:/ {
                print $0
                in_block=1
                next
            }
            in_block && /^\}/ {
                # Print new checksums
                print checksums
                print $0
                in_block=0
                next
            }
            in_block {
                # Skip old content (TODO, comments, empty lines)
                next
            }
            {print}
        ' "$_sf" > "$_tmpfile"
        
        # Replace original file
        mv "$_tmpfile" "$_sf"
        ok "  [$_label] Ôťô added checksums to $(basename "$_sf")"
        _fixed=1
    fi
    
    rm -rf "$_tmpdir"
    return 0
}

