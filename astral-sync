cmd_diff() {
    [ -f "$INDEX_FILE" ] || err "Index not found: $INDEX_FILE ÔÇö run 'astral-sync generate' first"

    _tmp_new=$(mktemp "${TMPDIR:-/tmp}/astral-sync-diff-new.XXXXXX")
    scan_recipes "$RECIPES_DIR" | awk '{print $1"/"$2 " " $4}' | sort > "$_tmp_new"

    # Extract current index entries for comparison
    _tmp_old=$(mktemp "${TMPDIR:-/tmp}/astral-sync-diff-old.XXXXXX")
    grep '|' "$INDEX_FILE" 2>/dev/null | while IFS='|' read -r entry arch ver; do
        entry=$(printf '%s' "$entry" | tr -d ' ')
        ver=$(printf '%s' "$ver" | tr -d ' ')
        [ -n "$entry" ] && printf '%s %s
' "$entry" "$ver"
    done | sort > "$_tmp_old"

    _added=0; _removed=0; _changed=0

    # Removed or changed
    while IFS=' ' read -r pkg ver; do
        [ -z "$pkg" ] && continue
        _new_ver=$(grep "^$pkg " "$_tmp_new" | awk '{print $2}')
        if [ -z "$_new_ver" ]; then
            printf "${RED}  - %s${NC} (%s)\n" "$pkg" "$ver"
            _removed=$((_removed + 1))
        elif [ "$_new_ver" != "$ver" ]; then
            printf "${YELLOW}  ~ %s${NC} %s Ôćĺ %s\n" "$pkg" "$ver" "$_new_ver"
            _changed=$((_changed + 1))
        fi
    done < "$_tmp_old"

    # Added
    while IFS=' ' read -r pkg ver; do
        [ -z "$pkg" ] && continue
        grep -q "^$pkg " "$_tmp_old" || {
            printf "${GREEN}  + %s${NC} (%s)\n" "$pkg" "$ver"
            _added=$((_added + 1))
        }
    done < "$_tmp_new"

    rm -f "$_tmp_new" "$_tmp_old"

    if [ $((_added + _removed + _changed)) -eq 0 ]; then
        ok "Index is up to date ÔÇö no changes"
    else
        printf "\n  ${GREEN}+%d added${NC}  ${YELLOW}~%d changed${NC}  ${RED}-%d removed${NC}\n"             "$_added" "$_changed" "$_removed"
    fi
}

