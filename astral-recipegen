generate_from_git() {
    pkg_name="$1"; git_url="$2"; git_branch="${3:-main}"; format="${4:-$OUTPUT_FORMAT}"
    command -v git >/dev/null 2>&1 || err "git is not installed"

    info "╔════════════════════════════════════════════════════════════════╗"
    info "║          Generating Recipe from Git Repository                ║"
    info "╚════════════════════════════════════════════════════════════════╝"
    info "  Repository: $git_url  Branch: $git_branch"; info ""

    temp_dir=$(mktemp -d "$TMPDIR/astral-git.XXXXXX")
    trap "rm -rf '$temp_dir'" EXIT
    step "Cloning..."
    git clone --branch "$git_branch" --depth 1 "$git_url" "$temp_dir/repo" 2>&1 || err "Clone failed"

    # Run detect inside a subshell so the cd does not change the parent CWD
    version=$(  cd "$temp_dir/repo" && git describe --tags --abbrev=0 2>/dev/null | sed 's/^[vV]//' || git -C "$temp_dir/repo" rev-parse --short HEAD)
    build_system=$(detect_build_system "$temp_dir/repo")
    step "Version: $version | Build: $build_system"; info ""

    [ -t 0 ] || exec </dev/tty 2>/dev/null || true
    printf "Category (default: app-misc): ";      read -r category; [ -z "$category" ] && category="app-misc"
    printf "Description: ";                        read -r description; [ -z "$description" ] && description="$pkg_name"
    printf "Homepage [$git_url]: ";                read -r homepage; [ -z "$homepage" ] && homepage="$git_url"
    printf "Build dependencies [%s]: " "$(bdeps_for "$build_system")"; read -r bdeps_in
    [ -z "$bdeps_in" ] && bdeps_in="git $(bdeps_for "$build_system")"
    printf "Runtime dependencies: ";               read -r rdeps_in

    output_file="${OUTPUT_FILE:-${RECIPES_DIR}/${category}/$(shard_for "$pkg_name")/${pkg_name}/${pkg_name}-git-any.stars}"

    generate_v3_from_data "$pkg_name" "git" "$description" "$homepage" \
        "$category" "" "$bdeps_in" "$rdeps_in" "" \
        "git+${git_url}#branch=${git_branch}" \
        "# git sources don't use checksums" \
        "$(build_cmds_git "$build_system" "$pkg_name")" \
        "$(package_cmds_git "$build_system" "$pkg_name")" "" "" "$output_file"

    ok "Git recipe: $output_file"
    info "  Tip: pin to commit with git+$git_url#commit=HASH"
    rm -rf "$temp_dir"; trap - EXIT
}

# ─────────────────────────────────────────────────────────────────────────────
# FROM-PKGBUILD  (FIXED actually extracts build() and package() bodies)
# ─────────────────────────────────────────────────────────────────────────────

convert_from_pkgbuild() {
    pb="$1"; format="${2:-$OUTPUT_FORMAT}"
    [ ! -f "$pb" ] && err "PKGBUILD not found: $pb"

    info "╔════════════════════════════════════════════════════════════════╗"
    info "║          Converting Arch PKGBUILD → .stars                    ║"
    info "╚════════════════════════════════════════════════════════════════╝"; info ""

    # Temporary file for extracted data
    tmpdata=$(mktemp "$TMPDIR/astral-pkgbuild.XXXXXX")
    trap "rm -f '$tmpdata'" EXIT

    # Use bash to source and dump variables/functions via declare
    if ! bash -c "
        set -eu
        source '$pb' >/dev/null 2>&1 || { echo 'ERROR: Failed to source PKGBUILD' >&2; exit 1; }
        # Scalars
        declare -p pkgname pkgver pkgdesc url license 2>/dev/null || true
        # Arrays
        declare -p depends makedepends optdepends source sha256sums sha512sums md5sums 2>/dev/null || true
        # Functions
        declare -f build package
    " > "$tmpdata" 2>/dev/null; then
        err "Failed to parse PKGBUILD with bash (syntax error or unsupported feature)"
    fi

    # Helper to extract quoted strings from a 'declare -a' line
    extract_quoted_from_declare() {
        printf '%s' "$1" | grep -o '"[^"]*"' | sed 's/"//g' | tr '\n' ' '
    }

    # Parse the output
    pkgname=; pkgver=; pkgdesc=; url=; license=
    depends_raw=; makedepends_raw=; optdepends_raw=; source_raw=
    sha256sums_raw=; sha512sums_raw=; md5sums_raw=
    build_body=; package_body=
    state=""; _fn_depth=0
    while IFS= read -r line; do
        case "$line" in
            # Eval ALL scalar declare lines so _pkgname, _url, etc. work too
            "declare -- "*) eval "${line#declare -- }" 2>/dev/null || true ;;
            "declare -a depends="*)     depends_raw=$(extract_quoted_from_declare "$line") ;;
            "declare -a makedepends="*) makedepends_raw=$(extract_quoted_from_declare "$line") ;;
            "declare -a optdepends="*)  optdepends_raw=$(extract_quoted_from_declare "$line") ;;
            "declare -a source="*)      source_raw=$(extract_quoted_from_declare "$line") ;;
            "declare -a sha256sums="*)  sha256sums_raw=$(extract_quoted_from_declare "$line") ;;
            "declare -a sha512sums="*)  sha512sums_raw=$(extract_quoted_from_declare "$line") ;;
            "declare -a md5sums="*)     md5sums_raw=$(extract_quoted_from_declare "$line") ;;
            "build ()"*)   state="build";   _fn_depth=0; continue ;;
            "package ()"*) state="package"; _fn_depth=0; continue ;;
        esac
        # Collect function bodies with proper brace-depth tracking
        if [ -n "$state" ]; then
            case "$line" in
                # Opening brace skip the outer { at depth 0
                '{'*) _fn_depth=$((_fn_depth + 1))
                      [ "$_fn_depth" -eq 1 ] && continue ;;
                # Closing brace if it closes the function, stop collecting
                '}'*) _fn_depth=$((_fn_depth - 1))
                      if [ "$_fn_depth" -le 0 ]; then
                          state=""; _fn_depth=0; continue
                      fi ;;
            esac
            # Append line + real newline (POSIX sh $'\n' is bash-only)
            if [ "$state" = "build" ]; then
                build_body="${build_body}${line}
"
            elif [ "$state" = "package" ]; then
                package_body="${package_body}${line}
"
            fi
        fi
    done < "$tmpdata"
    rm -f "$tmpdata"
    trap - EXIT

    # source entries use "alias::url" format (alias is the local filename, url is the download URL).
    # If no :: separator, the whole entry is the URL and basename is the local filename.
    _src_entry=$(printf '%s' "$source_raw" | awk '{print $1}')
    _expand_src() {
        printf '%s' "$1" | sed \
            -e "s/\${pkgname}/$pkgname/g" \
            -e "s/\$pkgname/$pkgname/g"   \
            -e "s/\${pkgver}/$pkgver/g"   \
            -e "s/\$pkgver/$pkgver/g"
    }
    # URL = part after :: (or the whole entry if no ::)
    primary_src=$(_expand_src "$(printf '%s' "$_src_entry" | sed 's/^[^:]*:://')")
    # Local filename = alias before :: (or URL basename if no ::)
    case "$_src_entry" in
        *::*) _src_fname=$(_expand_src "$(printf '%s' "$_src_entry" | sed 's/::.*//')") ;;
        *)    _src_fname=$(basename -- "$primary_src") ;;
    esac

    # Map dependencies
    bdepends=$(map_dep_list "$makedepends_raw")
    rdepends=$(map_dep_list "$depends_raw")
    optdepends=$(printf '%s\n' "$optdepends_raw" | tr ' ' '\n' | sed 's/:.*//' | tr '\n' ' ')

    # Build checksum block, pairing each hash with the correct local filename
    _chk_fname_for() {
        # arg1 = space-separated source_raw, arg2 = 1-based index
        _raw=$(printf '%s' "$1" | tr ' ' '\n' | sed -n "${2}p")
        _raw=$(_expand_src "$_raw")
        case "$_raw" in
            *::*) printf '%s' "$_raw" | sed 's/::.*//' ;;
            *)    basename -- "$_raw" ;;
        esac
    }
    checksum_block=""
    if [ -n "$sha256sums_raw" ]; then
        _idx=0
        for _hash in $sha256sums_raw; do
            _idx=$((_idx + 1))
            [ "$_hash" = "SKIP" ] && continue
            _f=$(_chk_fname_for "$source_raw" "$_idx")
            checksum_block="${checksum_block}    sha256:${_hash} ${_f}
"
        done
    elif [ -n "$sha512sums_raw" ]; then
        _idx=0
        for _hash in $sha512sums_raw; do
            _idx=$((_idx + 1))
            [ "$_hash" = "SKIP" ] && continue
            _f=$(_chk_fname_for "$source_raw" "$_idx")
            checksum_block="${checksum_block}    sha512:${_hash} ${_f}
"
        done
    elif [ -n "$md5sums_raw" ]; then
        _idx=0
        for _hash in $md5sums_raw; do
            _idx=$((_idx + 1))
            [ "$_hash" = "SKIP" ] && continue
            _f=$(_chk_fname_for "$source_raw" "$_idx")
            checksum_block="${checksum_block}    md5:${_hash} ${_f}
"
        done
    fi
    checksum_out="$checksum_block"

    # Adapt build/package scripts
    # declare -f already emits 4-space indented lines. Don't add more.
    # Strip trailing semicolons (bash adds them to every statement in declare -f).
    # Strip trailing blank lines from each body.
    build_body=$(printf '%s\n' "$build_body" | adapt_build_script \
        | sed 's/[[:space:]]*;[[:space:]]*$//' \
        | sed '/^[[:space:]]*$/d')
    package_body=$(printf '%s\n' "$package_body" | adapt_build_script \
        | sed 's/[[:space:]]*;[[:space:]]*$//' \
        | sed '/^[[:space:]]*$/d')
    [ -z "$build_body" ]   && build_body="    # No build() in source PKGBUILD"
    [ -z "$package_body" ] && package_body="    # Could not extract package() review PKGBUILD manually"

    # Category heuristic (same as before)
    category="app-misc"
    case "$pkgname" in
        lib*|*-lib|*-libs)          category="lib" ;;
        python-*|python3-*)         category="dev-python" ;;
        perl-*)                     category="dev-perl" ;;
        ruby-*)                     category="dev-ruby" ;;
        nodejs-*)                   category="dev-nodejs" ;;
        *kernel*|linux*)            category="sys-kernel" ;;
        xorg-*|*-x11*|*wayland*)   category="x11-libs" ;;
        gst-*|*gstreamer*)          category="media-libs" ;;
        *font*|ttf-*|otf-*)         category="media-fonts" ;;
        vim|neovim|nano|emacs|helix) category="app-editors" ;;
    esac

    info "  Package:  $pkgname $pkgver"
    info "  BDepends: $bdepends"
    info "  RDepends: $rdepends"
    info "  Source:   $primary_src"
    info "  Category: $category"; info ""
    [ -t 0 ] || exec </dev/tty 2>/dev/null || true
    printf "Category [%s]: " "$category"; read -r cat_in; [ -n "$cat_in" ] && category="$cat_in"

    output_file="${OUTPUT_FILE:-${RECIPES_DIR}/${category}/$(shard_for "$pkgname")/${pkgname}/${pkgname}-${pkgver}-any.stars}"

    case "$format" in
        v3) generate_v3_from_data "$pkgname" "$pkgver" "$pkgdesc" "$url" \
                "$category" "" "$bdepends" "$rdepends" "$optdepends" \
                "$primary_src" "$checksum_out" "$build_body" "$package_body" \
                "" "" "$output_file" ;;
        v2) generate_v2_from_data "$pkgname" "$pkgver" "$pkgdesc" "$url" \
                "$category" "$makedepends_raw $depends_raw" "" "" "" \
                "$primary_src" "$checksum_out" "$build_body" "$package_body" \
                "" "" "$output_file" ;;
        v1) generate_v1_from_data "$pkgname" "$pkgver" "$pkgdesc" "$url" \
                "$makedepends_raw $depends_raw" "$primary_src" "$checksum_out" \
                "$build_body" "$package_body" "" "" "$output_file" ;;
    esac

    ok "Converted: $output_file"
    warn "Review build/package sections shell variables may need adaptation."
    [ -n "$license" ] && info "  License: $license"
}

# ─────────────────────────────────────────────────────────────────────────────
# FROM-EBUILD  (NEW Gentoo)
# ─────────────────────────────────────────────────────────────────────────────

convert_from_ebuild() {
    eb="$1"; format="${2:-$OUTPUT_FORMAT}"
    [ ! -f "$eb" ] && err "ebuild not found: $eb"

    info "╔════════════════════════════════════════════════════════════════╗"
    info "║          Converting Gentoo ebuild → .stars                    ║"
    info "╚════════════════════════════════════════════════════════════════╝"; info ""

    filename=$(basename -- "$eb" .ebuild)
    pkgver=$(printf '%s' "$filename" | grep -oE '[0-9]+(\.[0-9]+)+[a-z]?(_p[0-9]+)?(-r[0-9]+)?$')
    pkgname=$(printf '%s' "$filename" | sed "s/-$pkgver$//")

    # Multi-line ebuild variable extractor.
    # Handles: VAR="single line", VAR="\nmulti\nline\n", VAR="val" with spaces.
    _ebuild_var() {
        awk -v var="$1" '
            $0 ~ ("^" var "[[:space:]]*=") {
                sub(/^[^=]*=[[:space:]]*/, "")      # strip "VAR ="
                if (/^".*"[[:space:]]*$/) {          # full value on one line
                    gsub(/^"|"[[:space:]]*$/, "")
                    print; exit
                }
                if (/^"/) { sub(/^"/, ""); in_v=1 } # opening multi-line quote
                if ($0 != "") printf "%s ", $0
                if (!in_v) { printf "\n"; exit }
                next
            }
            in_v {
                if (/"[[:space:]]*$/) {              # closing quote
                    sub(/"[[:space:]]*$/, "")
                    if ($0 != "") printf "%s", $0
                    printf "\n"; in_v=0; exit
                }
                printf "%s ", $0
            }
        ' "$2"
    }

    # Expand Gentoo variables and mirror:// schemes in a URI
    _expand_ebuild_uri() {
        printf '%s' "$1" | sed \
            -e "s/\${PN}/$pkgname/g"  -e "s/\\\$PN\b/$pkgname/g"  \
            -e "s/\${PV}/$pkgver/g"   -e "s/\\\$PV\b/$pkgver/g"   \
            -e "s/\${P}/${pkgname}-${pkgver}/g"                     \
            -e "s|mirror://gnu/|https://ftp.gnu.org/gnu/|g"         \
            -e "s|mirror://sourceforge/|https://downloads.sourceforge.net/|g" \
            -e "s|mirror://kernel/|https://www.kernel.org/pub/|g"   \
            -e "s|mirror://cpan/|https://cpan.metacpan.org/authors/id/|g"
    }

    # Strip Gentoo dep syntax: USE conditionals, category prefixes, USE flags,
    # version operators, and noise tokens. Returns space-separated plain names.
    _strip_ebuild_deps() {
        _ebuild_var "$1" "$eb" | tr -d '"' |
            sed 's/[!?][a-zA-Z_-]*://g' |
            sed 's/[a-zA-Z][a-zA-Z0-9_+-]*\/\([a-zA-Z][a-zA-Z0-9_+.-]*\)/\1/g' |
            sed 's/\[[^]]*\]//g' |
            sed 's/[><=!][^ ]*//g' |
            tr ' ' '\n' |
            grep -vE '^$|^[()!|$]|^\|\|$' |
            grep -v 'virtual/' |
            sort -u | tr '\n' ' '
    }

    description=$(_ebuild_var DESCRIPTION "$eb" | sed 's/[[:space:]]*$//')
    homepage=$(_ebuild_var HOMEPAGE "$eb" | awk '{print $1}')
    eapi=$(_ebuild_var EAPI "$eb" | tr -d '"')
    license=$(_ebuild_var LICENSE "$eb" | sed 's/[[:space:]]*$//')

    # SRC_URI: grab the first actual https/ftp URL from potentially multi-entry value
    src_uri_raw=$(_ebuild_var SRC_URI "$eb")
    src_uri=$(_expand_ebuild_uri \
        "$(printf '%s' "$src_uri_raw" | tr ' ' '\n' | grep -E '^https?://|^ftp://' | head -n1)")
    # Fallback: expand and take first word
    [ -z "$src_uri" ] && src_uri=$(_expand_ebuild_uri \
        "$(printf '%s' "$src_uri_raw" | tr -s ' ' | awk '{print $1}')")

    # Deps: EAPI 7+ has BDEPEND (build-only). Older EAPI uses DEPEND for both.
    raw_bdep=$(_strip_ebuild_deps BDEPEND)
    raw_dep=$(_strip_ebuild_deps DEPEND)
    raw_rdep=$(_strip_ebuild_deps RDEPEND)

    bdepends=$(map_dep_list "$raw_bdep $raw_dep")
    rdepends=$(map_dep_list "$raw_rdep")
    # If no RDEPEND and no BDEPEND (old EAPI), DEPEND covers runtime too
    if [ -z "$rdepends" ] && [ -z "$raw_bdep" ] && [ -n "$raw_dep" ]; then
        rdepends=$(map_dep_list "$raw_dep")
    fi

    src_configure=$(extract_function_body "src_configure" "$eb" | adapt_build_script)
    src_compile=$(extract_function_body "src_compile" "$eb" | adapt_build_script)
    src_install=$(extract_function_body "src_install" "$eb" | adapt_build_script)

    if [ -z "$src_compile" ]; then
        if grep -q 'inherit.*cmake' "$eb"; then
            src_compile=$(build_cmds_for "cmake" "$pkgname")
        elif grep -q 'inherit.*meson' "$eb"; then
            src_compile=$(build_cmds_for "meson" "$pkgname")
        else
            src_compile=$(build_cmds_for "autotools" "$pkgname")
        fi
    fi
    if [ -z "$src_install" ]; then
        if grep -q 'inherit.*cmake' "$eb"; then
            src_install=$(package_cmds_for "cmake" "$pkgname")
        elif grep -q 'inherit.*meson' "$eb"; then
            src_install=$(package_cmds_for "meson" "$pkgname")
        else
            src_install=$(package_cmds_for "autotools" "$pkgname")
        fi
    fi

    build_body=$(printf '%s\n%s' "$src_configure" "$src_compile" \
        | sed 's/^/    /' \
        | sed 's/[[:space:]]*;[[:space:]]*$//' \
        | sed '/^[[:space:]]*$/d')
    install_body=$(printf '%s\n' "$src_install" \
        | sed 's/^/    /' \
        | sed 's/[[:space:]]*;[[:space:]]*$//' \
        | sed '/^[[:space:]]*$/d')

    gcat=$(dirname "$eb" | xargs basename 2>/dev/null || echo "app-misc")
    case "$gcat" in
        dev-libs|sys-libs) category="lib" ;;
        dev-util)          category="dev-util" ;;
        app-editors)       category="app-editors" ;;
        *)                 category="$gcat" ;;
    esac

    info "  Package: $pkgname $pkgver (EAPI $eapi) | Source: $src_uri"; info ""
    [ -t 0 ] || exec </dev/tty 2>/dev/null || true
    printf "Category [%s]: " "$category"; read -r cat_in; [ -n "$cat_in" ] && category="$cat_in"

    output_file="${OUTPUT_FILE:-${RECIPES_DIR}/${category}/$(shard_for "$pkgname")/${pkgname}/${pkgname}-${pkgver}-any.stars}"
    chk_hint="    # Run: astral-recipegen checksum $src_uri"

    case "$format" in
        v3) generate_v3_from_data "$pkgname" "$pkgver" "$description" "$homepage" \
                "$category" "" "$bdepends" "$rdepends" "" \
                "$src_uri" "$chk_hint" "$build_body" "$install_body" "" "" "$output_file" ;;
        v2) generate_v2_from_data "$pkgname" "$pkgver" "$description" "$homepage" \
                "$category" "$bdepends $rdepends" "" "" "" \
                "$src_uri" "$chk_hint" "$build_body" "$install_body" "" "" "$output_file" ;;
        v1) generate_v1_from_data "$pkgname" "$pkgver" "$description" "$homepage" \
                "$bdepends $rdepends" "$src_uri" "$chk_hint" \
                "$build_body" "$install_body" "" "" "$output_file" ;;
    esac

    ok "Converted: $output_file"
    warn "Gentoo eclasses not emulated review build section."
    [ -n "$license" ] && info "  License: $license"
}

# ─────────────────────────────────────────────────────────────────────────────
# FROM-SPEC  (NEW RPM)
# ─────────────────────────────────────────────────────────────────────────────

convert_from_spec() {
    spec="$1"; format="${2:-$OUTPUT_FORMAT}"
    [ ! -f "$spec" ] && err ".spec not found: $spec"

    info "╔════════════════════════════════════════════════════════════════╗"
    info "║          Converting RPM .spec → .stars                        ║"
    info "╚════════════════════════════════════════════════════════════════╝"; info ""

    _get() { grep -iE "^$1:[[:space:]]" "$spec" | head -n1 | sed "s/^[^:]*:[[:space:]]*//"; }

    pkgname=$(_get Name);    pkgver=$(_get Version)
    release=$(_get Release | sed 's/%{?dist}//'); summary=$(_get Summary)
    url=$(_get URL);          license_s=$(_get License)
    source0=$(_get 'Source0?'); group=$(_get Group || echo "")

    expand_macros() {
        printf '%s' "$1" | sed \
            -e "s/%{name}/$pkgname/g"   \
            -e "s/%{version}/$pkgver/g" \
            -e "s/%{release}/$release/g" \
            -e "s/%{?dist}//g"
    }
    pkgname=$(expand_macros "$pkgname"); pkgver=$(expand_macros "$pkgver")
    source0=$(expand_macros "$source0")

    strip_ver() { printf '%s' "$1" | sed 's/[><=!][^,]*//g' | tr -s ' '; }
    bdepends=$(map_dep_list "$(strip_ver "$(grep -i '^BuildRequires:' "$spec" | sed 's/BuildRequires:[[:space:]]*//' | tr '\n' ' ')")")
    rdepends=$(map_dep_list "$(strip_ver "$(grep -iE '^Requires:[[:space:]]' "$spec" | grep -v '^#' | sed 's/Requires:[[:space:]]*//' | tr '\n' ' ')")")

    extract_spec_section() {
        awk -v s="%$1" 'tolower($0) ~ "^"tolower(s)"[[:space:]]*$" { in_s=1; next }
            in_s && /^%[a-z]/ && !/^%[{]/ { in_s=0 }
            in_s { print }' "$spec" \
            | adapt_build_script \
            | sed 's/^/    /' \
            | sed 's/[[:space:]]*;[[:space:]]*$//' \
            | sed '/^[[:space:]]*$/d'
    }

    build_body=$(extract_spec_section "build")
    install_body=$(extract_spec_section "install")
    post_body=$(extract_spec_section "post")
    preun_body=$(extract_spec_section "preun")

    [ -z "$build_body" ]   && build_body=$(build_cmds_for "autotools" "$pkgname" | sed 's/^/    /')
    [ -z "$install_body" ] && install_body=$(package_cmds_for "autotools" "$pkgname" | sed 's/^/    /')

    category="app-misc"
    case "$group" in *Development*) category="dev-util" ;; *Library*) category="lib" ;; *System*) category="sys-apps" ;; esac

    info "  Package: $pkgname $pkgver | Source: $source0"; info ""
    [ -t 0 ] || exec </dev/tty 2>/dev/null || true
    printf "Category [%s]: " "$category"; read -r cat_in; [ -n "$cat_in" ] && category="$cat_in"

    output_file="${OUTPUT_FILE:-${RECIPES_DIR}/${category}/$(shard_for "$pkgname")/${pkgname}/${pkgname}-${pkgver}-any.stars}"
    chk_hint="    # Run: astral-recipegen checksum $source0"

    case "$format" in
        v3) generate_v3_from_data "$pkgname" "$pkgver" "$summary" "$url" \
                "$category" "" "$bdepends" "$rdepends" "" \
                "$source0" "$chk_hint" "$build_body" "$install_body" \
                "$post_body" "$preun_body" "$output_file" ;;
        v2) generate_v2_from_data "$pkgname" "$pkgver" "$summary" "$url" \
                "$category" "$bdepends $rdepends" "" "" "" \
                "$source0" "$chk_hint" "$build_body" "$install_body" \
                "$post_body" "$preun_body" "$output_file" ;;
        v1) generate_v1_from_data "$pkgname" "$pkgver" "$summary" "$url" \
                "$bdepends $rdepends" "$source0" "$chk_hint" \
                "$build_body" "$install_body" "$post_body" "$preun_body" "$output_file" ;;
    esac

    ok "Converted: $output_file"
    warn "RPM macros like %configure, %make_install may need review."
    [ -n "$license_s" ] && info "  License: $license_s"
}

# ─────────────────────────────────────────────────────────────────────────────
# FROM-CARGO  (NEW Rust)
# ─────────────────────────────────────────────────────────────────────────────

convert_from_cargo() {
    cargo_toml="$1"; format="${2:-$OUTPUT_FORMAT}"
    [ ! -f "$cargo_toml" ] && err "Cargo.toml not found: $cargo_toml"

    info "╔════════════════════════════════════════════════════════════════╗"
    info "║          Converting Cargo.toml → .stars                       ║"
    info "╚════════════════════════════════════════════════════════════════╝"; info ""

    in_pkg=0; pkgname=""; pkgver=""; description=""; homepage=""; license_c=""
    while IFS= read -r line; do
        case "$line" in '[package]') in_pkg=1 ;; '['*) in_pkg=0 ;; esac
        [ "$in_pkg" -eq 0 ] && continue
        case "$line" in
            name*)        pkgname=$(strip_value "${line#*=}") ;;
            version*)     pkgver=$(strip_value "${line#*=}") ;;
            description*) description=$(strip_value "${line#*=}") ;;
            homepage*)    homepage=$(strip_value "${line#*=}") ;;
            license*)     license_c=$(strip_value "${line#*=}") ;;
            repository*)  [ -z "$homepage" ] && homepage=$(strip_value "${line#*=}") ;;
        esac
    done < "$cargo_toml"

    [ -z "$pkgname" ] && err "Could not find [package] name in Cargo.toml"
    [ -z "$pkgver"  ] && pkgver="0.1.0"

    src_url="https://static.crates.io/crates/${pkgname}/${pkgname}-${pkgver}.crate"
    build_body="    cargo build --release --locked"
    pkg_body="    install -Dm755 target/release/${pkgname} \"\$PKGDIR/usr/bin/${pkgname}\""

    grep -q '^\[\[bin\]\]' "$cargo_toml" 2>/dev/null && \
        warn "Multiple [[bin]] targets only '$pkgname' installed. Review package section."

    category="app-misc"
    case "$pkgname" in *-rs|lib*) category="dev-rust" ;; esac

    info "  Crate: $pkgname $pkgver | Source: $src_url"; info ""
    [ -t 0 ] || exec </dev/tty 2>/dev/null || true
    printf "Category [%s]: " "$category"; read -r cat_in; [ -n "$cat_in" ] && category="$cat_in"

    output_file="${OUTPUT_FILE:-${RECIPES_DIR}/${category}/$(shard_for "$pkgname")/${pkgname}/${pkgname}-${pkgver}-any.stars}"
    chk_hint="    # Run: astral-recipegen checksum $src_url"

    case "$format" in
        v3) generate_v3_from_data "$pkgname" "$pkgver" "${description:-Rust crate: $pkgname}" "$homepage" \
                "$category" "" "rust cargo" "" "" "$src_url" "$chk_hint" \
                "$build_body" "$pkg_body" "" "" "$output_file" ;;
        v2) generate_v2_from_data "$pkgname" "$pkgver" "${description:-Rust crate: $pkgname}" "$homepage" \
                "$category" "rust cargo" "" "" "" "$src_url" "$chk_hint" \
                "$build_body" "$pkg_body" "" "" "$output_file" ;;
        v1) generate_v1_from_data "$pkgname" "$pkgver" "${description:-Rust crate: $pkgname}" "$homepage" \
                "rust cargo" "$src_url" "$chk_hint" "$build_body" "$pkg_body" \
                "" "" "$output_file" ;;
    esac

    ok "Converted: $output_file"
    [ -n "$license_c" ] && info "  License: $license_c"
}

