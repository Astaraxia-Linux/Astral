# SHARED HELPERS
# ─────────────────────────────────────────────────────────────────────────────

strip_value() { printf '%s' "$1" | sed "s/^[[:space:]]*//;s/[[:space:]]*$//;s/^['\"]//;s/['\"]$//"; }

# Extract a bash/sh array variable into space-separated words.
# Handles single-line and multi-line: depends=('foo' 'bar' "baz>=1")
extract_bash_array() {
    var="$1"; file="$2"
    awk -v var="$var" '
        $0 ~ "^"var"[[:space:]]*=[(]" { in_arr=1; sub(/.*[(]/, "") }
        in_arr {
            sub(/#.*/, "")
            gsub(/[()'"'"'"]/, " ")
            printf "%s ", $0
            if (/[)]/) { in_arr=0 }
        }
    ' "$file" | tr -s ' \t\n' ' ' | sed 's/^ //;s/ $//'
}

# Extract a shell function body (everything between first { and matching }).
extract_function_body() {
    func="$1"; file="$2"
    awk -v fn="$func" '
        /^[[:space:]]*(function[[:space:]]+)?'"$func"'[[:space:]]*[(][)]/ { in_fn=1; depth=0; next }
        in_fn && /[{]/ { depth++ }
        in_fn && /[}]/ {
            depth--
            if (depth <= 0) { in_fn=0; next }
        }
        in_fn { print }
    ' "$file"
}

# Adapt Arch/Gentoo/RPM variable names to Astral equivalents in build scripts.
# IMPORTANT: do NOT wrap replacements in quotes bash's declare -f already
# emits the surrounding quotes. Adding them here produces ""$PKGDIR"".
adapt_build_script() {
    sed \
        -e 's/\$pkgdir\b/$PKGDIR/g'      \
        -e 's/\${pkgdir}/$PKGDIR/g'      \
        -e 's/\$srcdir\b/$SRCDIR/g'      \
        -e 's/\${srcdir}/$SRCDIR/g'      \
        -e 's/\$pkgname\b/$PKG_NAME/g'   \
        -e 's/\${pkgname}/$PKG_NAME/g'   \
        -e 's/\$pkgver\b/$PKG_VERSION/g' \
        -e 's/\${pkgver}/$PKG_VERSION/g' \
        -e 's/\$D\b/$PKGDIR/g'           \
        -e 's/\${D}/$PKGDIR/g'           \
        -e 's/\$PN\b/$PKG_NAME/g'        \
        -e 's/\$PV\b/$PKG_VERSION/g'     \
        -e 's/\$S\b/$SRCDIR\/$PKG_NAME-$PKG_VERSION/g'
}

map_dep_name() {
    case "$1" in
        glibc|libc6|glibc-devel) printf 'glibc' ;;
        pkgconfig|pkg-config)     printf 'pkgconf' ;;
        python3|python-base)      printf 'python' ;;
        nodejs)                   printf 'nodejs' ;;
        *)                        printf '%s' "$1" ;;
    esac
}

map_dep_list() {
    result=""
    for dep in $1; do
        [ -z "$dep" ] && continue
        base=$(printf '%s' "$dep" | sed 's/[>=<!].*//' | sed 's/:.*//')
        mapped=$(map_dep_name "$base")
        result="$result $mapped"
    done
    printf '%s' "${result# }"
}

bdeps_for() {
    case "$1" in
        autotools) echo "gcc make autoconf automake libtool pkgconf" ;;
        cmake)     echo "gcc make cmake" ;;
        meson)     echo "gcc meson ninja pkgconf" ;;
        python)    echo "python python-build python-setuptools" ;;
        cargo)     echo "rust cargo" ;;
        go)        echo "go" ;;
        npm)       echo "nodejs npm" ;;
        make)      echo "gcc make" ;;
        *)         echo "gcc make" ;;
    esac
}

build_cmds_for() {
    sys="$1"; name="${2:-PACKAGE_NAME}"; ver="${3:-VERSION}"
    # Source dir is typically "name-version" for tarballs, just "name" for git
    srcdir="${name}-${ver}"
    case "$sys" in
        autotools) printf '    cd %s\n    ./configure          \\\n        --prefix=/usr\n    make -j${JOBS:-$(nproc)}\n' "$srcdir" ;;
        cmake)     printf '    cd %s\n    cmake -B build              \\\n        -DCMAKE_BUILD_TYPE=Release \\\n        -DCMAKE_INSTALL_PREFIX=/usr \\\n        -DCMAKE_C_FLAGS="$CFLAGS" \\\n        -DCMAKE_CXX_FLAGS="$CXXFLAGS" \\\n        -DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS"\n    cmake --build build -j${JOBS:-$(nproc)}\n' "$srcdir" ;;
        meson)     printf '    cd %s\n    meson setup build    \\\n        --prefix=/usr        \\\n        --buildtype=release  \\\n        -Dc_args="$CFLAGS"   \\\n        -Dcpp_args="$CXXFLAGS" \\\n        -Dc_link_args="$LDFLAGS"\n    ninja -C build -j${JOBS:-$(nproc)}\n' "$srcdir" ;;
        python)    printf '    cd %s\n    python3 -m build --wheel --no-isolation\n' "$srcdir" ;;
        cargo)     printf '    cd %s\n    cargo build --release --locked\n' "$srcdir" ;;
        go)        printf '    cd %s\n    go build -o %s ./...\n' "$srcdir" "${name}" ;;
        npm)       printf '    cd %s\n    npm ci\n    npm run build\n' "$srcdir" ;;
        make)      printf '    cd %s\n    make -j${JOBS:-$(nproc)}\n' "$srcdir" ;;
        *)         printf '    cd %s\n    # TODO: add build commands\n' "$srcdir" ;;
    esac
}

package_cmds_for() {
    sys="$1"; name="${2:-PACKAGE_NAME}"; ver="${3:-VERSION}"
    srcdir="${name}-${ver}"
    case "$sys" in
        autotools) printf '    cd %s\n    make DESTDIR="$PKGDIR" install\n' "$srcdir" ;;
        cmake)     printf '    cd %s\n    DESTDIR="$PKGDIR" cmake --install build\n' "$srcdir" ;;
        meson)     printf '    cd %s\n    DESTDIR="$PKGDIR" ninja -C build install\n' "$srcdir" ;;
        python)    printf '    cd %s\n    pip install --root="$PKGDIR" --no-deps dist/*.whl\n' "$srcdir" ;;
        cargo)     printf '    cd %s\n    install -Dm755 target/release/%s "$PKGDIR/usr/bin/%s"\n' "$srcdir" "${name}" "${name}" ;;
        go)        printf '    cd %s\n    install -Dm755 %s "$PKGDIR/usr/bin/%s"\n' "$srcdir" "${name}" "${name}" ;;
        npm)       printf '    cd %s\n    npm install --global --prefix="$PKGDIR/usr"\n' "$srcdir" ;;
        make)      printf '    cd %s\n    make DESTDIR="$PKGDIR" install\n' "$srcdir" ;;
        *)         printf '    cd %s\n    # TODO: add install commands\n' "$srcdir" ;;
    esac
}

