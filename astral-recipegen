# DETECTION
# ─────────────────────────────────────────────────────────────────────────────

detect_recipe_version() {
    recipe_file="$1"
    if [ -f "$recipe_file" ]; then
        if head -n 5 "$recipe_file" | grep -qE '^\$PKG\.Version[[:space:]]*=[[:space:]]*"3"'; then
            echo "v3"
        elif head -n 20 "$recipe_file" | grep -qE '^\$PKG\.'; then
            echo "v2"
        elif grep -qE '^@[A-Z_]+$' "$recipe_file"; then
            echo "v1"
        else
            echo "unknown"
        fi
    elif [ -d "$recipe_file" ]; then
        echo "directory"
    else
        echo "notfound"
    fi
}

detect_build_system() {
    dir="${1:-.}"
    if   [ -f "$dir/configure.ac" ] || [ -f "$dir/configure.in" ] || [ -f "$dir/configure" ]; then
        echo "autotools"
    elif [ -f "$dir/CMakeLists.txt" ]; then echo "cmake"
    elif [ -f "$dir/meson.build" ];    then echo "meson"
    elif [ -f "$dir/Cargo.toml" ];     then echo "cargo"
    elif [ -f "$dir/go.mod" ];         then echo "go"
    elif [ -f "$dir/pyproject.toml" ]; then echo "python"
    elif [ -f "$dir/setup.py" ];       then echo "python"
    elif [ -f "$dir/package.json" ];   then echo "npm"
    elif [ -f "$dir/build.sh" ];       then echo "custom"
    elif [ -f "$dir/Makefile" ] || [ -f "$dir/makefile" ] || [ -f "$dir/GNUmakefile" ]; then
        echo "make"
    else
        echo "unknown"
    fi
}

