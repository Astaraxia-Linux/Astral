# ─────────────────────────────────────────────────────────────────────────────
# AUTO  (v2.1.0 base + local directory support)
# ─────────────────────────────────────────────────────────────────────────────

generate_auto() {
    pkg_name="$1"; source_arg="$2"; format="${3:-$OUTPUT_FORMAT}"
    info "╔════════════════════════════════════════════════════════════════╗"
    info "║          Auto-Detecting Build System & Dependencies           ║"
    info "╚════════════════════════════════════════════════════════════════╝"; info ""

    checksum=""; filename=""; temp_dir=""

    if [ -d "$source_arg" ]; then
        src_dir="$source_arg"; source_url=""
        step "Using local directory: $src_dir"
    else
        source_url="$source_arg"
        temp_dir=$(mktemp -d "$TMPDIR/astral-auto.XXXXXX")
        trap "rm -rf '$temp_dir'" EXIT
        filename=$(basename -- "$source_url" | sed 's/?.*//')
        step "Downloading: $filename"
        curl -fSL "$source_url" -o "$temp_dir/$filename" || err "Download failed"
        # Extract inside a subshell so the cd does not change the parent CWD
        ( cd "$temp_dir" && case "$filename" in
            *.tar.gz|*.tgz)  tar -xzf "$filename" ;;
            *.tar.bz2|*.tbz) tar -xjf "$filename" ;;
            *.tar.xz|*.txz)  tar -xJf "$filename" ;;
            *.zip)            unzip -q  "$filename" ;;
            *)                err "Unknown archive: $filename" ;;
        esac )
        src_dir=$(find "$temp_dir" -maxdepth 1 -type d ! -path "$temp_dir" | head -n1)
        [ -z "$src_dir" ] && err "Could not find extracted directory"
        checksum=$(sha256sum "$temp_dir/$filename" | awk '{print $1}')
    fi

    build_system=$(detect_build_system "$src_dir")
    version=$(printf '%s' "$(basename "$src_dir")" | grep -oE '[0-9]+(\.[0-9]+)+[a-z]?' | head -n1)
    [ -z "$version" ] && version="1.0.0"

    step "Build system: $build_system | Version: $version"; info ""

    [ -t 0 ] || exec </dev/tty 2>/dev/null || true
    printf "Category (default: app-misc): ";  read -r category; [ -z "$category" ] && category="app-misc"
    printf "Description: ";                   read -r description; [ -z "$description" ] && description="$pkg_name"
    printf "Homepage: ";                       read -r homepage

    if [ "$format" = "v3" ]; then
        printf "Build dependencies [%s]: " "$(bdeps_for "$build_system")"; read -r bdeps_in
        [ -z "$bdeps_in" ] && bdeps_in=$(bdeps_for "$build_system")
        printf "Runtime dependencies: "; read -r rdeps_in
        bdepends="$bdeps_in"; rdepends="$rdeps_in"; depends=""
    else
        printf "Dependencies: "; read -r deps_in
        [ -z "$deps_in" ] && deps_in=$(bdeps_for "$build_system")
        depends="$deps_in"; bdepends=""; rdepends=""
    fi

    chk_line=""; [ -n "$checksum" ] && chk_line="    sha256:$checksum $filename"
    output_file="${OUTPUT_FILE:-${RECIPES_DIR}/${category}/$(shard_for "$pkg_name")/${pkg_name}/${pkg_name}-${version}-any.stars}"

    case "$format" in
        v3) generate_v3_from_data "$pkg_name" "$version" "$description" "$homepage" \
                "$category" "" "$bdepends" "$rdepends" "" "${source_url:-}" "$chk_line" \
                "$(build_cmds_for "$build_system" "$pkg_name" "$version")" \
                "$(package_cmds_for "$build_system" "$pkg_name" "$version")" "" "" "$output_file" ;;
        v2) generate_v2_from_data "$pkg_name" "$version" "$description" "$homepage" \
                "$category" "$depends" "" "" "" "${source_url:-}" "$chk_line" \
                "$(build_cmds_for "$build_system" "$pkg_name" "$version")" \
                "$(package_cmds_for "$build_system" "$pkg_name" "$version")" "" "" "$output_file" ;;
        v1) generate_v1_from_data "$pkg_name" "$version" "$description" "$homepage" \
                "$depends" "${source_url:-}" "$chk_line" \
                "$(build_cmds_for "$build_system" "$pkg_name" "$version")" \
                "$(package_cmds_for "$build_system" "$pkg_name" "$version")" "" "" "$output_file" ;;
    esac
    ok "Generated: $output_file"
    [ -n "$temp_dir" ] && { rm -rf "$temp_dir"; trap - EXIT; }
}

