# ─────────────────────────────────────────────────────────────────────────────
# CHECKSUM  (NEW)
# ─────────────────────────────────────────────────────────────────────────────

cmd_checksum() {
    url="$1"; algo="${2:-sha256}"
    [ -z "$url" ] && err "Usage: astral-recipegen checksum <url> [sha256|sha512|md5]"

    step "Downloading: $url"
    tmpfile=$(mktemp "$TMPDIR/astral-checksum.XXXXXX")
    trap "rm -f '$tmpfile'" EXIT
    curl -fsSL -o "$tmpfile" "$url" || err "Download failed: $url"

    filename=$(basename -- "$url" | sed 's/?.*//')
    filesize=$(wc -c < "$tmpfile" | tr -d ' ')

    case "$algo" in
        sha256) hash=$(sha256sum "$tmpfile" | awk '{print $1}') ;;
        sha512) hash=$(sha512sum "$tmpfile" | awk '{print $1}') ;;
        md5)    hash=$(md5sum    "$tmpfile" | awk '{print $1}') ;;
        *)      err "Unknown algorithm: $algo (sha256|sha512|md5)" ;;
    esac

    ok "Downloaded: $filename ($filesize bytes)"; info ""
    info "  Paste into \$PKG.Checksums:"; info ""
    printf '    %s:%s %s\n' "$algo" "$hash" "$filename"; info ""
    rm -f "$tmpfile"; trap - EXIT
}

# ─────────────────────────────────────────────────────────────────────────────
# LINT  (NEW)
# ─────────────────────────────────────────────────────────────────────────────

cmd_lint() {
    recipe="$1"; [ ! -f "$recipe" ] && err "Recipe not found: $recipe"
    info "╔════════════════════════════════════════════════════════════════╗"
    info "║          Linting: $(basename "$recipe")"
    info "╚════════════════════════════════════════════════════════════════╝"; info ""

    errors=0; warnings=0
    le() { printf '\033[1;31m  ✗ ERROR:\033[0m %s\n'  "$*"; errors=$((errors+1)); }
    lw() { printf '\033[1;33m  ⚠ WARN:\033[0m  %s\n'  "$*"; warnings=$((warnings+1)); }
    lo() { printf '\033[1;32m  ✓\033[0m %s\n'          "$*"; }

    content=$(cat "$recipe")

    if printf '%s\n' "$content" | grep -q '^\$PKG\.Version'; then
        ver=$(printf '%s\n' "$content" | grep '^\$PKG\.Version' | head -n1 | sed 's/.*=[[:space:]]*//' | tr -d '"')
        lo "Recipe version: $ver"
    else lw "No \$PKG.Version declaration"; fi

    for field in Version Description Homepage Category; do
        if printf '%s\n' "$content" | grep -qE "$field[[:space:]]*="; then
            val=$(printf '%s\n' "$content" | grep -E "$field[[:space:]]*=" | head -n1 |
                sed 's/.*=[[:space:]]*//' | tr -d '"')
            if [ -z "$val" ]; then lw "Metadata.$field is empty"
            else lo "Metadata.$field = $val"; fi
        else le "Missing Metadata.$field"; fi
    done

    if printf '%s\n' "$content" | grep -q '\$PKG\.Sources'; then
        src=$(printf '%s\n' "$content" | grep 'urls[[:space:]]*=' | head -n1 |
            sed 's/.*=[[:space:]]*//' | tr -d '"')
        case "$src" in
            http://*|https://*|ftp://*|git+*) lo "Source URL: $src" ;;
            *TODO*|*EXAMPLE*|*example.com*)   lw "Source URL looks like a placeholder" ;;
            '')                                le "Source URL is empty" ;;
            *)                                 lw "Unusual source URL: $src" ;;
        esac
    else le "Missing \$PKG.Sources block"; fi

    if printf '%s\n' "$content" | grep -q '\$PKG\.Checksums'; then
        if printf '%s\n' "$content" | grep -qE '(sha256|sha512|md5):[a-fA-F0-9]{32,}'; then
            lo "Checksums present"
        else lw "No valid checksum hash found add before packaging"; fi
    else le "Missing \$PKG.Checksums block"; fi

    for blk in Build Package; do
        if printf '%s\n' "$content" | grep -qF "\$PKG.$blk"; then lo "\$PKG.$blk block present"
        else le "Missing \$PKG.$blk block"; fi
    done

    opens=$(printf '%s\n' "$content" | grep -cE '^\$PKG\.[A-Za-z.]+.*[{]' 2>/dev/null || printf '0')
    closes=$(printf '%s\n' "$content" | grep -c '^};' 2>/dev/null || printf '0')
    if [ "$opens" != "$closes" ]; then le "Mismatched blocks: $opens opened, $closes closed"
    else lo "Block balance OK ($opens blocks)"; fi

    printf '%s\n' "$content" | grep -q '\$PKG\.Depend\.Depends' && \
        lw "Legacy \$PKG.Depend.Depends split into BDepends/RDepends for v3"
    printf '%s\n' "$content" | grep -qE '\$pkgdir|\$srcdir' && \
        lw "PKGBUILD variables (\$pkgdir, \$srcdir) adapt to \$PKGDIR, \$SRCDIR"

    info ""
    if [ "$errors" -eq 0 ] && [ "$warnings" -eq 0 ]; then ok "Clean 0 errors, 0 warnings"
    else printf '  Errors: \033[1;31m%d\033[0m  Warnings: \033[1;33m%d\033[0m\n' "$errors" "$warnings"; fi
    [ "$errors" -gt 0 ] && return 1; return 0
}

# ─────────────────────────────────────────────────────────────────────────────
# SEARCH  (NEW)
# ─────────────────────────────────────────────────────────────────────────────

cmd_search() {
    term="$1"; [ -z "$term" ] && err "Usage: astral-recipegen search <term>"
    info "Searching $RECIPES_DIR for: $term"; info ""

    find "$RECIPES_DIR" -name "*.stars" 2>/dev/null | sort | while read -r r; do
        base=$(basename "$r" .stars); dir=$(dirname "$r" | xargs basename)
        desc=$(grep -iE 'Description[[:space:]]*=' "$r" 2>/dev/null | head -n1 |
            sed 's/.*=[[:space:]]*//' | tr -d '"')
        ver=$(grep -iE '^[[:space:]]*Version[[:space:]]*=' "$r" 2>/dev/null | head -n1 |
            sed 's/.*=[[:space:]]*//' | tr -d '"')
        lc_base=$(printf '%s' "$base" | tr '[:upper:]' '[:lower:]')
        lc_desc=$(printf '%s' "$desc" | tr '[:upper:]' '[:lower:]')
        lc_term=$(printf '%s' "$term" | tr '[:upper:]' '[:lower:]')
        match=0
        case "$lc_base" in *"$lc_term"*) match=1 ;; esac
        case "$lc_desc" in *"$lc_term"*) match=1 ;; esac
        if [ "$match" -eq 1 ]; then
            printf '  \033[1;32m%-35s\033[0m %-12s %s\n' "${dir}/${base}" "$ver" "$desc"
        fi
    done
    info ""
}

# ─────────────────────────────────────────────────────────────────────────────
# BATCH-CONVERT  (NEW)
# ─────────────────────────────────────────────────────────────────────────────

cmd_batch_convert() {
    dir="$1"; target="${2:-v3}"
    [ ! -d "$dir" ] && err "Directory not found: $dir"
    info "Batch converting $dir → $target"; info ""

    find "$dir" -name "*.stars" 2>/dev/null | sort | while read -r r; do
        cur=$(detect_recipe_version "$r")
        if [ "$cur" = "$target" ]; then
            printf '  skip  %s (already %s)\n' "$(basename "$r")" "$target"
            continue
        fi
        printf '  %-40s %s → %s ... ' "$(basename "$r")" "$cur" "$target"
        out="${r%.stars}-${target}.stars"
        if OUTPUT_FILE="$out" migrate_recipe "$r" "$target" > /dev/null 2>&1; then
            printf 'ok\n'
        else
            printf 'FAILED\n'
        fi
    done
    info ""; info "Done."
}

# ─────────────────────────────────────────────────────────────────────────────
# MAIN
# ─────────────────────────────────────────────────────────────────────────────

OUTPUT_FILE=""
OUTPUT_FORMAT="v3"

while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help)    usage ;;
        -v|--version) show_version ;;
        -o|--output)  [ $# -lt 2 ] && err "Missing arg for $1"; OUTPUT_FILE="$2"; shift 2 ;;
        -f|--format)  [ $# -lt 2 ] && err "Missing arg for $1"; OUTPUT_FORMAT="$2"; shift 2 ;;
        -d|--dir)     [ $# -lt 2 ] && err "Missing arg for $1"; RECIPES_DIR="$2"; shift 2 ;;
        -*)           err "Unknown option: $1" ;;
        *)            break ;;
    esac
done

[ $# -lt 1 ] && usage

command="$1"; shift

case "$command" in
    interactive)
        fmt="${1:-$OUTPUT_FORMAT}"; OUTPUT_FORMAT="$fmt"
        generate_interactive "$fmt" ;;
    auto)
        [ $# -lt 2 ] && err "Usage: astral-recipegen auto <n> <url|dir> [format]"
        generate_auto "$1" "$2" "${3:-$OUTPUT_FORMAT}" ;;
    template)
        [ $# -lt 1 ] && err "Usage: astral-recipegen template <type> [format]"
        generate_template "$1" "${2:-$OUTPUT_FORMAT}" ;;
    git)
        [ $# -lt 2 ] && err "Usage: astral-recipegen git <n> <url> [branch] [format]"
        generate_from_git "$1" "$2" "${3:-main}" "${4:-$OUTPUT_FORMAT}" ;;
    from-pkgbuild)
        [ $# -lt 1 ] && err "Usage: astral-recipegen from-pkgbuild <PKGBUILD> [format]"
        convert_from_pkgbuild "$1" "${2:-$OUTPUT_FORMAT}" ;;
    from-ebuild)
        [ $# -lt 1 ] && err "Usage: astral-recipegen from-ebuild <pkg.ebuild> [format]"
        convert_from_ebuild "$1" "${2:-$OUTPUT_FORMAT}" ;;
    from-spec)
        [ $# -lt 1 ] && err "Usage: astral-recipegen from-spec <pkg.spec> [format]"
        convert_from_spec "$1" "${2:-$OUTPUT_FORMAT}" ;;
    from-cargo)
        [ $# -lt 1 ] && err "Usage: astral-recipegen from-cargo <Cargo.toml> [format]"
        convert_from_cargo "$1" "${2:-$OUTPUT_FORMAT}" ;;
    from-npm)
        [ $# -lt 1 ] && err "Usage: astral-recipegen from-npm <package.json> [format]"
        convert_from_npm "$1" "${2:-$OUTPUT_FORMAT}" ;;
    dir-to-stars)
        [ $# -lt 1 ] && err "Usage: astral-recipegen dir-to-stars <dir> [format]"
        convert_directory_to_stars "$1" "${2:-$OUTPUT_FORMAT}" ;;
    convert|migrate)
        [ $# -lt 1 ] && err "Usage: astral-recipegen $command <recipe> [version]"
        migrate_recipe "$1" "${2:-v3}" ;;
    batch-convert)
        [ $# -lt 1 ] && err "Usage: astral-recipegen batch-convert <dir> [version]"
        cmd_batch_convert "$1" "${2:-v3}" ;;
    checksum)
        [ $# -lt 1 ] && err "Usage: astral-recipegen checksum <url> [algo]"
        cmd_checksum "$1" "${2:-sha256}" ;;
    lint)
        [ $# -lt 1 ] && err "Usage: astral-recipegen lint <recipe.stars>"
        cmd_lint "$1" ;;
    search)
        [ $# -lt 1 ] && err "Usage: astral-recipegen search <term>"
        cmd_search "$1" ;;
    *)
        err "Unknown command: $command. Run with --help for usage." ;;
esac
