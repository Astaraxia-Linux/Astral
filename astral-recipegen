#!/bin/sh
# astral-recipegen - Recipe generator for Astral package manager
# Version: 3.0.0
# Supports: v1 (@SECTION), v2 ($PKG.*), v3 (separated deps)
# Converts: PKGBUILD, ebuild, .spec, Cargo.toml, package.json, directory

set -eu

VERSION="3.0.0"
RECIPES_DIR=${RECIPES_DIR:-/usr/src/astral/recipes}
TMPDIR=${TMPDIR:-/tmp}

err()  { printf '\033[1;31mERROR:\033[0m %s\n'   "$*" >&2; exit 1; }
info() { printf '%s\n' "$*"; }
warn() { printf '\033[1;33mWARN:\033[0m  %s\n'   "$*" >&2; }
ok()   { printf '\033[1;32m✓\033[0m %s\n'         "$*"; }
step() { printf '\033[1;34m→\033[0m %s\n'         "$*"; }

# Return the single-letter shard directory for a package name (matches astral's shard_for).
shard_for() { printf '%s' "$1" | cut -c1 | tr 'A-Z' 'a-z'; }

show_version() {
    cat <<EOF
astral-recipegen v$VERSION
Multi-format recipe generator for Astral package manager
Supports: v1 (@SECTION), v2 (\$PKG.*), v3 (separated deps)
Converts: PKGBUILD, ebuild, .spec, Cargo.toml, package.json
EOF
    exit 0
}

