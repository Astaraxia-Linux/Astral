generate_v3_from_data() {
    pkg_name="$1"; version="$2"; description="$3"; homepage="$4"
    category="$5"; depends="$6"; bdepends="$7"; rdepends="$8"; optional="$9"
    sources="${10}"; checksums="${11}"; build="${12}"; package="${13}"
    post_install="${14}"; post_remove="${15}"; output_file="${16}"

    mkdir -p "$(dirname "$output_file")"
    cat > "$output_file" <<EOF
\$PKG.Version = "3"

\$PKG.Metadata: {
    Version = "$version"
    Description = "$description"
    Homepage = "$homepage"
    Category = "$category"
};

\$PKG.Depend.BDepends: {
EOF
    if [ -n "$bdepends" ]; then
        printf '%s\n' "$bdepends" | tr ' ' '\n' | while read -r dep; do
            [ -z "$dep" ] && continue; echo "    $dep" >> "$output_file"; done
    fi
    printf '};\n\n$PKG.Depend.RDepends: {\n' >> "$output_file"
    if [ -n "$rdepends" ]; then
        printf '%s\n' "$rdepends" | tr ' ' '\n' | while read -r dep; do
            [ -z "$dep" ] && continue; echo "    $dep" >> "$output_file"; done
    fi
    printf '};\n' >> "$output_file"

    # Optional block only written when non-empty
    if [ -n "$optional" ]; then
        _has_opt=0
        for _d in $optional; do [ -n "$_d" ] && _has_opt=1 && break; done
        if [ "$_has_opt" -eq 1 ]; then
            printf '\n$PKG.Depend.Optional: {\n' >> "$output_file"
            printf '%s\n' "$optional" | tr ' ' '\n' | while read -r dep; do
                [ -z "$dep" ] && continue; echo "    $dep" >> "$output_file"; done
            printf '};\n' >> "$output_file"
        fi
    fi

    printf '\n$PKG.Sources: {\n' >> "$output_file"
    if [ -n "$sources" ]; then
        printf '%s\n' "$sources" | while read -r url; do
            [ -z "$url" ] && continue; echo "    urls = \"$url\"" >> "$output_file"; done
    fi
    printf '};\n\n$PKG.Checksums: {\n' >> "$output_file"
    if [ -n "$checksums" ]; then
        printf '%s\n' "$checksums" | awk 'NF{found=NR} {lines[NR]=$0} END{for(i=1;i<=found;i++) print lines[i]}' >> "$output_file"
    fi
    printf '};\n\n$PKG.Build: {\n' >> "$output_file"
    if [ -n "$build" ]; then
        printf '%s\n' "$build" | awk 'NF{found=NR} {lines[NR]=$0} END{for(i=1;i<=found;i++) print lines[i]}' >> "$output_file"
    else echo "    # TODO: add build commands" >> "$output_file"; fi
    printf '};\n\n$PKG.Package: {\n' >> "$output_file"
    if [ -n "$package" ]; then
        printf '%s\n' "$package" | awk 'NF{found=NR} {lines[NR]=$0} END{for(i=1;i<=found;i++) print lines[i]}' >> "$output_file"
    else echo "    # TODO: add install commands" >> "$output_file"; fi
    printf '};\n' >> "$output_file"

    [ -n "$post_install" ] && printf '\n$PKG.PostInstall: {\n%s\n};\n' "$post_install" >> "$output_file"
    [ -n "$post_remove"  ] && printf '\n$PKG.PostRemove: {\n%s\n};\n'  "$post_remove"  >> "$output_file"
}

generate_v2_from_data() {
    pkg_name="$1"; version="$2"; description="$3"; homepage="$4"
    category="$5"; depends="$6"; bdepends="$7"; rdepends="$8"; optional="$9"
    sources="${10}"; checksums="${11}"; build="${12}"; package="${13}"
    post_install="${14}"; post_remove="${15}"; output_file="${16}"

    all_depends=$(printf '%s %s %s' "$depends" "$bdepends" "$rdepends" | tr ' ' '\n' | sort -u | tr '\n' ' ')
    mkdir -p "$(dirname "$output_file")"
    cat > "$output_file" <<EOF
\$PKG.Metadata: {
    VERSION     = "$version"
    DESCRIPTION = "$description"
    HOMEPAGE    = "$homepage"
    CATEGORY    = "$category"
};

\$PKG.Depend {
    \$PKG.Depend.Depends {
EOF
    printf '%s\n' "$all_depends" | tr ' ' '\n' | while read -r dep; do
        [ -z "$dep" ] && continue; echo "        $dep" >> "$output_file"; done
    cat >> "$output_file" <<EOF
    };
};

\$PKG.Sources {
EOF
    printf '%s\n' "$sources" | while read -r url; do
        [ -z "$url" ] && continue; echo "    urls = \"$url\"" >> "$output_file"; done
    cat >> "$output_file" <<EOF
};

\$PKG.Checksums {
$checksums
};

\$PKG.Build {
$build
};

\$PKG.Package {
$package
};
EOF
}

generate_v1_from_data() {
    pkg_name="$1"; version="$2"; description="$3"; homepage="$4"
    depends="$5"; sources="$6"; checksums="$7"; build="$8"; package="$9"
    post_install="${10}"; post_remove="${11}"; output_file="${12}"

    mkdir -p "$(dirname "$output_file")"
    cat > "$output_file" <<EOF
VERSION="$version"
DESCRIPTION="$description"
HOMEPAGE="$homepage"

@DEPENDS
$depends

@SOURCES
$sources

@CHECKSUMS
$checksums

@BUILD
$build

@PACKAGE
$package
EOF
}

# ─────────────────────────────────────────────────────────────────────────────
# PARSERS  (v2.1.0 base, preserved)
# ─────────────────────────────────────────────────────────────────────────────

parse_v1_recipe() {
    file="$1"; output_dir="$2"
    awk '/^VERSION=/    {gsub(/VERSION=|"/,""); print}' "$file" > "$output_dir/version"
    awk '/^DESCRIPTION=/{gsub(/DESCRIPTION=|"/,""); print}' "$file" > "$output_dir/description"
    awk '/^HOMEPAGE=/   {gsub(/HOMEPAGE=|"/,""); print}' "$file" > "$output_dir/homepage"
    awk '/^@DEPENDS$/,/^@[A-Z_]+$|^$/{if(!/^@/) print}' "$file" > "$output_dir/depends"
    awk '/^@SOURCES$/,/^@[A-Z_]+$|^$/{if(!/^@/) print}' "$file" > "$output_dir/sources"
    awk '/^@CHECKSUMS$/,/^@[A-Z_]+$|^$/{if(!/^@/) print}' "$file" > "$output_dir/checksums"
    awk '/^@BUILD$/,/^@[A-Z_]+$|^$/{if(!/^@/) print}' "$file" > "$output_dir/build"
    awk '/^@PACKAGE$/,/^@[A-Z_]+$|^$/{if(!/^@/) print}' "$file" > "$output_dir/package"
}

parse_v2_recipe() {
    file="$1"; output_dir="$2"
    awk '/VERSION[[:space:]]*=/     {gsub(/.*VERSION[[:space:]]*=[[:space:]]*"|".*/,""); print; exit}' "$file" > "$output_dir/version"
    awk '/DESCRIPTION[[:space:]]*=/ {gsub(/.*DESCRIPTION[[:space:]]*=[[:space:]]*"|".*/,""); print; exit}' "$file" > "$output_dir/description"
    awk '/HOMEPAGE[[:space:]]*=/    {gsub(/.*HOMEPAGE[[:space:]]*=[[:space:]]*"|".*/,""); print; exit}' "$file" > "$output_dir/homepage"
    awk '/CATEGORY[[:space:]]*=/    {gsub(/.*CATEGORY[[:space:]]*=[[:space:]]*"|".*/,""); print; exit}' "$file" > "$output_dir/category"
    awk '/\$PKG\.Depend\.BDepends/,/};/{if(!/\$PKG|[{]|}/) print}' "$file" > "$output_dir/bdepends"
    awk '/\$PKG\.Depend\.RDepends/,/};/{if(!/\$PKG|[{]|}/) print}' "$file" > "$output_dir/rdepends"
    awk '/\$PKG\.Depend\.Depends/,/};/ {if(!/\$PKG|[{]|}/) print}' "$file" > "$output_dir/depends"
    awk '/\$PKG\.Build/,/};/{if(!/\$PKG\.Build|^};/) print}'    "$file" > "$output_dir/build"
    awk '/\$PKG\.Package/,/};/{if(!/\$PKG\.Package|^};/) print}' "$file" > "$output_dir/package"
    awk '/\$PKG\.Sources/,/};/{if(/urls[[:space:]]*=/) {gsub(/.*urls[[:space:]]*=[[:space:]]*"|".*/,""); print}}' "$file" > "$output_dir/sources"
}

parse_v3_recipe() { parse_v2_recipe "$@"; }

# ─────────────────────────────────────────────────────────────────────────────
# MIGRATE / CONVERT  (v2.1.0 base, preserved)
# ─────────────────────────────────────────────────────────────────────────────

smart_split_dependencies() {
    deps_list="$1"; output_dir="$2"
    build_tools="gcc g++ clang make cmake meson ninja autoconf automake libtool pkg-config pkgconf bison flex m4 perl python ruby cargo go"
    > "$output_dir/bdepends"; > "$output_dir/rdepends"
    for dep in $deps_list; do
        is_build=0
        for t in $build_tools; do [ "$dep" = "$t" ] && is_build=1 && break; done
        if [ "$is_build" -eq 1 ]; then echo "$dep" >> "$output_dir/bdepends"
        else echo "$dep" >> "$output_dir/rdepends"; fi
    done
}

migrate_recipe() {
    input_file="$1"; target_version="${2:-v3}"
    [ ! -f "$input_file" ] && [ ! -d "$input_file" ] && err "Recipe not found: $input_file"
    current_version=$(detect_recipe_version "$input_file")
    info "  Migrating: $input_file ($current_version → $target_version)"
    [ "$current_version" = "directory" ] && { convert_directory_to_stars "$input_file" "$target_version"; return; }
    [ "$current_version" = "$target_version" ] && { info "Already $target_version: $input_file"; return; }

    temp_dir=$(mktemp -d "$TMPDIR/astral-migrate.XXXXXX")
    trap "rm -rf '$temp_dir'" EXIT

    case "$current_version" in
        v1) parse_v1_recipe "$input_file" "$temp_dir" ;;
        v2) parse_v2_recipe "$input_file" "$temp_dir" ;;
        v3) parse_v3_recipe "$input_file" "$temp_dir" ;;
        *)  err "Cannot migrate from unknown format" ;;
    esac

    pkg_name=$(basename -- "$input_file" .stars)
    version=$(cat "$temp_dir/version" 2>/dev/null || echo "unknown")
    description=$(cat "$temp_dir/description" 2>/dev/null || echo "No description")
    homepage=$(cat "$temp_dir/homepage" 2>/dev/null || echo "")
    category=$(cat "$temp_dir/category" 2>/dev/null || echo "app-misc")
    depends=$(cat "$temp_dir/depends" 2>/dev/null || echo "")
    bdepends=$(cat "$temp_dir/bdepends" 2>/dev/null || echo "")
    rdepends=$(cat "$temp_dir/rdepends" 2>/dev/null || echo "")
    optional=$(cat "$temp_dir/optional" 2>/dev/null || echo "")
    sources=$(cat "$temp_dir/sources" 2>/dev/null || echo "")
    checksums=$(cat "$temp_dir/checksums" 2>/dev/null || echo "")
    build_script=$(cat "$temp_dir/build" 2>/dev/null || echo "")
    package_script=$(cat "$temp_dir/package" 2>/dev/null || echo "")
    post_install=$(cat "$temp_dir/post_install" 2>/dev/null || echo "")
    post_remove=$(cat "$temp_dir/post_remove" 2>/dev/null || echo "")
    output_file="${OUTPUT_FILE:-${input_file%.stars}-${target_version}.stars}"

    case "$target_version" in
        v3)
            if [ -z "$bdepends" ] && [ -z "$rdepends" ] && [ -n "$depends" ]; then
                info "  Splitting dependencies intelligently..."
                smart_split_dependencies "$depends" "$temp_dir"
                bdepends=$(tr '\n' ' ' < "$temp_dir/bdepends")
                rdepends=$(tr '\n' ' ' < "$temp_dir/rdepends")
            fi
            generate_v3_from_data "$pkg_name" "$version" "$description" "$homepage" \
                "$category" "$depends" "$bdepends" "$rdepends" "$optional" \
                "$sources" "$checksums" "$build_script" "$package_script" \
                "$post_install" "$post_remove" "$output_file" ;;
        v2) generate_v2_from_data "$pkg_name" "$version" "$description" "$homepage" \
                "$category" "$depends" "$bdepends" "$rdepends" "$optional" \
                "$sources" "$checksums" "$build_script" "$package_script" \
                "$post_install" "$post_remove" "$output_file" ;;
        v1) generate_v1_from_data "$pkg_name" "$version" "$description" "$homepage" \
                "$depends" "$sources" "$checksums" "$build_script" "$package_script" \
                "$post_install" "$post_remove" "$output_file" ;;
        *)  err "Unknown target version: $target_version" ;;
    esac

    ok "Migrated $current_version → $target_version: $output_file"
    rm -rf "$temp_dir"; trap - EXIT
}

# ─────────────────────────────────────────────────────────────────────────────
# DIR-TO-STARS  (v2.1.0, preserved)
# ─────────────────────────────────────────────────────────────────────────────

convert_directory_to_stars() {
    dir="$1"; output_format="${2:-$OUTPUT_FORMAT}"
    [ ! -d "$dir" ] && err "Directory not found: $dir"
    pkg_name=$(basename -- "$dir")
    info "  Converting directory: $dir → $pkg_name.stars ($output_format)"

    version=$(cat "$dir/version" 2>/dev/null || echo "unknown")
    description=$(head -n1 "$dir/info" 2>/dev/null || echo "No description")
    homepage=$(tail -n1 "$dir/info" 2>/dev/null || echo "")
    depends=$(cat "$dir/depends" 2>/dev/null || echo "")
    bdepends=$(cat "$dir/bdepends" 2>/dev/null || echo "")
    rdepends=$(cat "$dir/rdepends" 2>/dev/null || echo "")
    optional=$(cat "$dir/optional" 2>/dev/null || echo "")
    sources=$(cat "$dir/sources" 2>/dev/null | head -n1 || echo "")
    checksums=$(cat "$dir/checksums" 2>/dev/null || echo "")
    build_script=$(cat "$dir/build" 2>/dev/null || echo "")
    package_script=$(cat "$dir/package" 2>/dev/null || echo "")
    post_install=$(cat "$dir/post_install" 2>/dev/null || echo "")
    post_remove=$(cat "$dir/post_remove" 2>/dev/null || echo "")
    category=$(dirname "$dir" | xargs basename); [ "$category" = "recipes" ] && category="app-misc"
    output_file="${OUTPUT_FILE:-${dir}.stars}"

    case "$output_format" in
        v3) generate_v3_from_data "$pkg_name" "$version" "$description" "$homepage" \
                "$category" "$depends" "$bdepends" "$rdepends" "$optional" \
                "$sources" "$checksums" "$build_script" "$package_script" \
                "$post_install" "$post_remove" "$output_file" ;;
        v2) generate_v2_from_data "$pkg_name" "$version" "$description" "$homepage" \
                "$category" "$depends" "$bdepends" "$rdepends" "$optional" \
                "$sources" "$checksums" "$build_script" "$package_script" \
                "$post_install" "$post_remove" "$output_file" ;;
        v1) generate_v1_from_data "$pkg_name" "$version" "$description" "$homepage" \
                "$depends" "$sources" "$checksums" "$build_script" "$package_script" \
                "$post_install" "$post_remove" "$output_file" ;;
    esac
    ok "Converted: $output_file"
}

