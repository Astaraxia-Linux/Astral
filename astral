# Strip binaries and libraries
strip_binaries() {
    pkgdir="$1"
    pkg="$2"
    
    # Check if stripping is enabled
    if [ "${STRIP_BINARIES:-no}" != "yes" ]; then
        return 0
    fi
    
    info "╭─────────────────────────╮"
    info "│ Stripping Debug Symbols │"
    info "╰─────────────────────────╯"
    info ""
    
    stripped_count=0
    
    # Strip binaries
    find "$pkgdir" -type f -executable 2>/dev/null | while read -r file; do
        if file "$file" | grep -q 'ELF.*executable'; then
            if strip --strip-unneeded "$file" 2>/dev/null; then
                info "  Stripped: $(basename "$file")"
                stripped_count=$((stripped_count + 1))
            fi
        fi
    done
    
    # Strip shared libraries
    find "$pkgdir" -type f -name "*.so*" 2>/dev/null | while read -r file; do
        if file "$file" | grep -q 'ELF.*shared object'; then
            if strip --strip-unneeded "$file" 2>/dev/null; then
                info "  Stripped: $(basename "$file")"
                stripped_count=$((stripped_count + 1))
            fi
        fi
    done
    
    # Strip static libraries
    find "$pkgdir" -type f -name "*.a" 2>/dev/null | while read -r file; do
        if strip --strip-debug "$file" 2>/dev/null; then
            info "  Stripped: $(basename "$file")"
            stripped_count=$((stripped_count + 1))
        fi
    done
    
    if [ $stripped_count -gt 0 ]; then
        info ""
        info "✓ Stripped $stripped_count files"
    else
        info "  No files needed stripping"
    fi
}

# === Lock SIAL ===
# === METHOD 1: flock (Linux, BSD) ===
acquire_lock_flock() {
    lockfile="$1"
    timeout="$2"
    
    # Check if flock exists
    if ! command -v flock >/dev/null 2>&1; then
        return 1
    fi
    
    # Create lock file
    touch "$lockfile" 2>/dev/null || return 1
    
    # Open file descriptor 200 for the lock file
    exec 200>"$lockfile"
    
    # Try to acquire exclusive lock with timeout via fd 200
    if flock -x -w "$timeout" 200; then
        # Lock acquired - write PID to the lock file
        printf '%s\n' $$ > "$lockfile"
        return 0
    else
        # Failed to acquire - close fd
        exec 200>&-
        return 1
    fi
}

# === METHOD 2: lockf (BSD, Solaris) ===
acquire_lock_lockf() {
    lockfile="$1"
    timeout="$2"
    
    if ! command -v lockf >/dev/null 2>&1; then
        return 1
    fi
    
    touch "$lockfile" 2>/dev/null || return 1
    
    # lockf blocks until lock is available
    if lockf -t "$timeout" "$lockfile" sh -c "echo $$ > '$lockfile'"; then
        return 0
    else
        return 1
    fi
}

# === METHOD 3: mkdir atomic (POSIX, works everywhere) ===
# This is the most portable but has limitations
# === METHOD 3: mkdir atomic (POSIX, works everywhere) ===
acquire_lock_mkdir() {
    lockdir="$1.d"
    timeout="$2"
    
    waited=0
    max_wait="$timeout"
    
    while [ $waited -lt "$max_wait" ]; do
        # Atomic mkdir operation
        if mkdir "$lockdir" 2>/dev/null; then
            # Lock acquired!
            
            # Write PID atomically
            printf '%s\n' $$ > "$lockdir/pid.tmp"
            mv "$lockdir/pid.tmp" "$lockdir/pid"
            
            # Write hostname for debugging
            if command -v hostname >/dev/null 2>&1; then
                hostname > "$lockdir/host"
            fi
            
            # Write timestamp
            date +%s > "$lockdir/timestamp"
            
            info "Lock acquired after ${waited}s"
            return 0
        fi
        
        # Lock exists - check if stale
        if [ -f "$lockdir/pid" ]; then
            old_pid=$(cat "$lockdir/pid" 2>/dev/null)
            
            if [ -n "$old_pid" ]; then
                # Check if process still exists
                if ! kill -0 "$old_pid" 2>/dev/null; then
                    # Process doesn't exist - lock is stale
                    warn "Removing stale lock (PID $old_pid no longer exists)"
                    rm -rf "$lockdir"
                    continue  # Try to acquire immediately
                else
                    # Process exists - check lock age
                    if [ -f "$lockdir/timestamp" ]; then
                        lock_time=$(cat "$lockdir/timestamp" 2>/dev/null || echo "0")
                        now_time=$(date +%s)
                        lock_age=$((now_time - lock_time))
                        
                        # If lock is older than 2x timeout, something is wrong
                        if [ $lock_age -gt $((timeout * 2)) ]; then
                            warn "Lock is suspiciously old (${lock_age}s), but process $old_pid still exists"
                            warn "This may indicate a hung process. Consider: kill $old_pid"
                        fi
                        
                        # Show progress every 30 seconds
                        if [ $((waited % 30)) -eq 0 ] && [ $waited -gt 0 ]; then
                            if command -v ps >/dev/null 2>&1; then
                                process_info=$(ps -p "$old_pid" -o comm= 2>/dev/null || printf 'unknown')
                                lock_host=$(cat "$lockdir/host" 2>/dev/null || printf 'unknown')
                                info "Still waiting for lock (held by PID $old_pid [$process_info] on $lock_host, age: ${lock_age}s)..."
                            else
                                info "Still waiting for lock (held by PID $old_pid, age: ${lock_age}s)..."
                            fi
                        fi
                    fi
                fi
            else
                # Corrupt lock (no PID) - remove if old enough
                warn "Found corrupt lock (no PID)"
                if [ -f "$lockdir/timestamp" ]; then
                    lock_time=$(cat "$lockdir/timestamp" 2>/dev/null || echo "0")
                    now_time=$(date +%s)
                    lock_age=$((now_time - lock_time))
                    
                    # Remove corrupt locks older than 60 seconds
                    if [ $lock_age -gt 60 ]; then
                        warn "Removing corrupt lock (age ${lock_age}s)"
                        rm -rf "$lockdir"
                        continue
                    fi
                else
                    # No timestamp either - definitely corrupt, remove it
                    warn "Removing corrupt lock (no timestamp)"
                    rm -rf "$lockdir"
                    continue
                fi
            fi
        else
            # Lock directory exists but no PID file - very corrupt
            warn "Lock directory exists but no PID file - removing"
            rm -rf "$lockdir"
            continue
        fi
        
        # Wait and retry
        sleep 1
        waited=$((waited + 1))
    done
    
    # Timeout reached
    warn "Lock acquisition timeout after ${timeout}s"
    
    # Show final lock status for debugging
    if [ -f "$lockdir/pid" ]; then
        old_pid=$(cat "$lockdir/pid" 2>/dev/null)
        if [ -n "$old_pid" ]; then
            if kill -0 "$old_pid" 2>/dev/null; then
                err "Lock held by active process $old_pid. To force remove: rm -rf $lockdir"
            else
                err "Lock appears stale (PID $old_pid dead) but wasn't removed. Manual cleanup: rm -rf $lockdir"
            fi
        fi
    fi
    
    return 1
}

# === SMART LOCK ACQUISITION ===
acquire_lock() {
    lockfile="${1:-$LOCK_FILE}"
    timeout="${2:-$LOCK_TIMEOUT}"
    
    info "Acquiring package manager lock (timeout: ${timeout}s)..."
    
    # Create lock directory
    lockdir=$(dirname "$lockfile")
    mkdir -p "$lockdir" 2>/dev/null || {
        err "Cannot create lock directory: $lockdir"
        return 1
    }
    
    # Clean up stale lock file from previous attempts
    if [ -f "$lockfile" ]; then
        stale_pid=$(cat "$lockfile" 2>/dev/null | head -1 | tr -dc '0-9')
        if [ -n "$stale_pid" ]; then
            if ! kill -0 "$stale_pid" 2>/dev/null; then
                warn "Removing stale lock file (PID $stale_pid no longer exists)"
                rm -f "$lockfile"
            fi
        fi
    fi
    
    # Try methods in order of preference (flock removed due to issues)
    
    # 1. Try lockf (BSD/Solaris)
    if command -v lockf >/dev/null 2>&1; then
        if acquire_lock_lockf "$lockfile" "$timeout" 2>/dev/null; then
            LOCK_METHOD="lockf"
            info "Lock acquired (method: lockf)"
            return 0
        fi
    fi
    
    # 2. Fallback to mkdir (works everywhere)
    if acquire_lock_mkdir "$lockfile" "$timeout"; then
        LOCK_METHOD="mkdir"
        info "Lock acquired (method: mkdir)"
        return 0
    fi
    
    # Failed to acquire lock
    err "╭────────────────────────────────────────────────────────────────╮"
    err "│              LOCK ACQUISITION FAILED                           │"
    err "├────────────────────────────────────────────────────────────────┤"
    err "│  Timeout:      ${timeout}s                                           "
    err "│  Lock file:    $lockfile                                       "
    err "│                                                                │"
    err "│  Another astral instance may be running.                       │"
    err "│                                                                │"
    err "│  To check lock status:    astral --lock-info                   │"
    err "│  To force remove lock:    rm -rf ${lockfile}*                 │"
    err "╰────────────────────────────────────────────────────────────────╯"
    return 1
}

# === LOCK RELEASE ===
release_lock() {
    lockfile="${1:-$LOCK_FILE}"
    
    case "${LOCK_METHOD:-mkdir}" in
        flock)
            # Close file descriptor 200
            exec 200>&-
            rm -f "$lockfile"
            ;;
        lockf)
            # lockf releases automatically
            rm -f "$lockfile"
            ;;
        mkdir)
            # Remove directory
            rm -rf "${lockfile}.d"
            ;;
    esac
    
    info "Lock released"
}

# === LOCK INFO ===
lock_info() {
    lockfile="${1:-$LOCK_FILE}"
    lockdir="${lockfile}.d"
    
    if [ ! -d "$lockdir" ]; then
        info "No active lock"
        return 0
    fi
    
    if [ -f "$lockdir/pid" ]; then
        lock_pid=$(cat "$lockdir/pid" 2>/dev/null)
        lock_host=$(cat "$lockdir/host" 2>/dev/null || printf 'unknown')
        lock_time=$(cat "$lockdir/timestamp" 2>/dev/null || printf '0')
        now_time=$(date +%s)
        lock_age=$((now_time - lock_time))
        
        info "╭────────────────────────────────────────────────────────────╮"
        info "│                    Active Lock Info                        │"
        info "├────────────────────────────────────────────────────────────┤"
        printf "│  PID:        %-45s │\n" "$lock_pid"
        printf "│  Host:       %-45s │\n" "$lock_host"
        printf "│  Age:        %-45s │\n" "${lock_age}s"
        
        if kill -0 "$lock_pid" 2>/dev/null; then
            if command -v ps >/dev/null 2>&1; then
                process_cmd=$(ps -p "$lock_pid" -o args= 2>/dev/null | cut -c1-40)
                printf "│  Process:    %-45s │\n" "$process_cmd"
            fi
            printf "│  Status:     ${GREEN}ACTIVE${NC}%-38s │\n" ""
        else
            printf "│  Status:     ${RED}STALE${NC}%-39s │\n" ""
        fi
        
        info "╰────────────────────────────────────────────────────────────╯"
    else
        warn "Lock exists but is corrupt (no PID file)"
    fi
}

# === LOCK TESTING ===
test_lock_system() {
    info "╭────────────────────────────────────────────────────────────╮"
    info "│              Lock System Test Suite                       │"
    info "╰────────────────────────────────────────────────────────────╯"
    
    test_lock="/tmp/astral-lock-test-$$"
    passed=0
    failed=0
    
    # Test 1: Basic acquisition
    info "[1/5] Testing basic lock acquisition..."
    if acquire_lock "$test_lock" 5 >/dev/null 2>&1; then
        info "  ✓ PASS: Lock acquired"
        passed=$((passed + 1))
        release_lock "$test_lock"
    else
        warn "  ✗ FAIL: Could not acquire lock"
        failed=$((failed + 1))
    fi
    
    # Test 2: Double acquisition (should fail)
    info "[2/5] Testing double acquisition prevention..."
    acquire_lock "$test_lock" 5 >/dev/null 2>&1
    if acquire_lock "$test_lock" 2 >/dev/null 2>&1; then
        warn "  ✗ FAIL: Double acquisition succeeded (RACE CONDITION!)"
        failed=$((failed + 1))
    else
        info "  ✓ PASS: Double acquisition prevented"
        passed=$((passed + 1))
    fi
    release_lock "$test_lock"
    
    # Test 3: Release and reacquire
    info "[3/5] Testing release and reacquire..."
    acquire_lock "$test_lock" 5 >/dev/null 2>&1
    release_lock "$test_lock"
    if acquire_lock "$test_lock" 5 >/dev/null 2>&1; then
        info "  ✓ PASS: Reacquisition successful"
        passed=$((passed + 1))
        release_lock "$test_lock"
    else
        warn "  ✗ FAIL: Could not reacquire after release"
        failed=$((failed + 1))
    fi
    
    # Test 4: Stale lock detection
    info "[4/5] Testing stale lock cleanup..."
    mkdir -p "${test_lock}.d"
    printf '%s\n' "99999" > "${test_lock}.d/pid"  # Non-existent PID
    printf '%s\n' "$(($(date +%s) - 400))" > "${test_lock}.d/timestamp"  # Old timestamp
    
    if acquire_lock "$test_lock" 5 >/dev/null 2>&1; then
        info "  ✓ PASS: Stale lock cleaned up"
        passed=$((passed + 1))
        release_lock "$test_lock"
    else
        warn "  ✗ FAIL: Stale lock not cleaned"
        failed=$((failed + 1))
        rm -rf "${test_lock}.d"
    fi
    
    # Test 5: Concurrent access simulation
    info "[5/5] Testing concurrent access..."
    (
        acquire_lock "$test_lock" 10 >/dev/null 2>&1
        sleep 2
        release_lock "$test_lock"
    ) &
    child_pid=$!
    
    sleep 1  # Let child acquire lock first
    
    if acquire_lock "$test_lock" 5 >/dev/null 2>&1; then
        info "  ✓ PASS: Lock acquired after concurrent release"
        passed=$((passed + 1))
        release_lock "$test_lock"
    else
        warn "  ✗ FAIL: Could not acquire after concurrent release"
        failed=$((failed + 1))
    fi
    
    wait "$child_pid" 2>/dev/null
    
    # Cleanup
    rm -rf "${test_lock}"*
    
    # Summary
    info ""
    info "╭────────────────────────────────────────────────────────────╮"
    info "│                    Test Results                            │"
    info "├────────────────────────────────────────────────────────────┤"
    printf "│  ${GREEN}Passed: %-49s${NC} │\n" "$passed/5"
    printf "│  ${RED}Failed: %-49s${NC} │\n" "$failed/5"
    info "╰────────────────────────────────────────────────────────────╯"
    
    [ $failed -eq 0 ] && return 0 || return 1
}

