# helper: find recipe path - search subdirectories
recipe_path() {
    _pkg="$1"
    _version="${2:-latest}"  # Default to latest
    _arch="${3:-any}"        # Prefer "any" for source-based

    # Separate category from package name if provided as category/pkg
    _category=""
    case "$_pkg" in
        */*)
            _category="$(dirname "$_pkg")"
            _pkg="$(basename "$_pkg")"
            ;;
    esac

    # Strip -git suffix for filesystem search but remember it
    is_git=0
    _pkg_bare="$_pkg"
    case "$_pkg" in
        *-git)
            _pkg_bare=$(printf '%s' "$_pkg" | sed 's/-git$//')
            is_git=1
            _version="git"
            ;;
    esac

    # === FILESYSTEM FIRST ===
    # Check all reasonable on-disk locations before touching the index.
    # IMPORTANT: always prefer an expanded directory (has a 'build' script) over
    # a raw .stars file, so callers get a usable path directly.
    for _search_name in "$_pkg" "$_pkg_bare"; do
        # Expanded directory recipe at category/pkg/ (most useful — check first)
        if [ -n "$_category" ] && [ -d "$RECIPES_DIR/$_category/$_search_name" ] && \
           [ -f "$RECIPES_DIR/$_category/$_search_name/build" ]; then
            printf '%s\n' "$RECIPES_DIR/$_category/$_search_name"
            return 0
        fi
        # Exact .stars file at category/pkg.stars
        if [ -n "$_category" ] && [ -f "$RECIPES_DIR/$_category/$_search_name.stars" ] && \
           [ -s "$RECIPES_DIR/$_category/$_search_name.stars" ]; then
            printf '%s\n' "$RECIPES_DIR/$_category/$_search_name.stars"
            return 0
        fi
        # Versioned .stars: category/pkg/pkg-VER-ARCH.stars
        # But first check if the expanded dir beside it has a build script
        if [ -n "$_category" ]; then
            _glob=$(find "$RECIPES_DIR/$_category" -maxdepth 2 \
                -name "${_search_name}-*.stars" 2>/dev/null | head -n1)
            if [ -n "$_glob" ]; then
                # Prefer expanded dir in same location
                _expanded_candidate=$(dirname "$_glob")
                if [ -f "$_expanded_candidate/build" ]; then
                    printf '%s\n' "$_expanded_candidate"
                    return 0
                fi
                printf '%s\n' "$_glob"
                return 0
            fi
        fi
    # If no category was given, check package.provided for a canonical alias.
    # This ensures bare names like 'gcc' always resolve to the declared provider
    # (e.g. sys-devel/gcc) even if multiple categories contain a recipe named gcc.
    if [ -z "$_category" ]; then
        _resolved=$(resolve_provided "$_pkg")
        if [ "$_resolved" != "$_pkg" ]; then
            debug "recipe_path: bare '$_pkg' -> provided '$_resolved'"
            recipe_path "$_resolved" "$_version" "$_arch"
            return $?
        fi
    fi

    # Search whole recipes dir without category hint — but first check for
    # ambiguity: if multiple VALID categories match, error loudly instead of
    # silently taking a random result. Only consider proper category/pkg paths
    # (exactly 2 levels deep) that have a build script or .stars file.
    _all_matches=$(find "$RECIPES_DIR" -mindepth 2 -maxdepth 2 -type d -name "$_search_name" 2>/dev/null | \
        while read -r d; do
            { [ -f "$d/build" ] || ls "$d"/*.stars 2>/dev/null | grep -q .; } && printf '%s\n' "$d"
        done)
    _match_count=$(printf '%s\n' "$_all_matches" | grep -c . 2>/dev/null || echo 0)
    if [ "$_match_count" -gt 1 ]; then
        warn "Ambiguous package '$_pkg' — found in multiple categories:"
        printf '%s\n' "$_all_matches" | sed "s|$RECIPES_DIR/||" | while read -r _m; do
            warn "  $_m"
        done
        err "Specify the full category/pkg form, or declare a provider in $PROVIDED_FILE"
    fi
    # Single match (or none) — proceed with the find
        _found=$(find "$RECIPES_DIR" -maxdepth 3 -type d -name "$_search_name" 2>/dev/null | \
            while read -r d; do [ -f "$d/build" ] && printf '%s\n' "$d" && break; done | head -n1)
        _found=$(find "$RECIPES_DIR" -maxdepth 3 \
            \( -name "${_search_name}.stars" -o -name "${_search_name}-*.stars" \) \
            2>/dev/null | while read -r f; do
                [ -s "$f" ] || continue
                # Check if there's an expanded dir beside this .stars
                _exp=$(dirname "$f")
                [ -f "$_exp/build" ] && printf '%s\n' "$_exp" && break
                printf '%s\n' "$f" && break
            done | head -n1)
        if [ -n "$_found" ]; then
            printf '%s\n' "$_found"
            return 0
        fi
    done

    # === INDEX LOOKUP ===
    # Try exact name, then bare name (without -git), then prefix-match for foo-git when searching foo
    for _lookup in "$_pkg" "$_pkg_bare"; do
        available=$(query_index_v2 "$_lookup" "$_arch" "$REPO_CONTEXT")
        [ -z "$available" ] && available=$(query_index_v2 "$_lookup" "any" "$REPO_CONTEXT")
        [ -n "$available" ] && break
    done

    # Fuzzy: scan for index entries that start with the bare pkg name (catches cpufetch-git)
    if [ -z "$available" ]; then
        _idx_file="$INDEX_FILE_AOHARU"
        [ "$REPO_CONTEXT" = "asura" ] && _idx_file="$INDEX_FILE_ASURA"
        available=$(parse_index_v2 "$_idx_file" 2>/dev/null | \
            awk -v base="$_pkg_bare" '{ n=split($1,a,"/"); if (index(a[n], base) == 1) print }' | head -n1)
    fi

    [ -z "$available" ] && return 1

    # Select version
    if [ "$_version" = "latest" ]; then
        selected=$(printf '%s\n' "$available" | grep -v ' git$' | sort -t' ' -k3 -V | tail -n1)
        [ -z "$selected" ] && selected=$(printf '%s\n' "$available" | grep ' git$' | head -n1)
    elif [ "$_version" = "git" ]; then
        selected=$(printf '%s\n' "$available" | grep ' git$' | head -n1)
    else
        selected=$(printf '%s\n' "$available" | grep " $_version$" | head -n1)
    fi

    [ -z "$selected" ] && return 1

    fullpkg=$(printf '%s' "$selected" | awk '{print $1}')
    sel_arch=$(printf '%s' "$selected" | awk '{print $2}')
    sel_ver=$(printf '%s' "$selected" | awk '{print $3}')

    category=$(dirname "$fullpkg")
    pkg_name=$(basename "$fullpkg")

    recipe_name="${pkg_name}-${sel_ver}-${sel_arch}.stars"
    recipe_full="$RECIPES_DIR/$category/$recipe_name"

    if [ -f "$recipe_full" ] && [ -s "$recipe_full" ]; then
        printf '%s\n' "$recipe_full"
        return 0
    fi

    # Recipe not on disk yet — return the expected path so the caller can fetch it
    # (do NOT fetch here; recipe_path is a pure lookup function)
    return 1
}

# === STARS FILE PARSER ===
# Extract sections from .stars file
parse_stars_section() {
    stars_file="$1"
    section_name="$2"  # e.g., "BUILD", "PACKAGE", "SOURCES"

    awk -v section="$section_name" '
        /^@[A-Z_]+$/ {
            in_section = 0
            if ($0 == "@" section) in_section = 1
            next
        }
        in_section { print }
    ' "$stars_file"
}

# Extract metadata (KEY=VALUE lines before first @SECTION)
parse_stars_metadata() {
    stars_file="$1"
    awk '/^@[A-Z_]+$/ { exit } /^[A-Z_]+=/ { print }' "$stars_file"
}


# Get installed version (returns "none" if not installed)
get_installed_ver() {
    requested_pkg="$1"
    pkg_path=$(resolve_installed_path "$requested_pkg") || { printf 'none\n'; return 0; }

    if [ -f "$DB_DIR/$pkg_path/version" ]; then
        cat "$DB_DIR/$pkg_path/version"
    else
