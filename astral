info() { 
    _original_info "$@"
    log_msg "INFO" "$@"
}

warn() { 
    _original_warn "$@"
    log_msg "WARN" "$@"
}

err() {
    message="$*"
    timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    
    printf "${RED}╭────────────────────────────────────────────────────────────────╮${NC}\n" >&2
    printf "${RED}│                          ERROR                                 │${NC}\n" >&2
    printf "${RED}├────────────────────────────────────────────────────────────────┤${NC}\n" >&2
    printf "${RED}│${NC} %s\n" "$message" >&2
    printf "${RED}│${NC}\n" >&2
    
    # Add context
    [ -n "${CURRENT_PKG:-}" ] && printf "${RED}│${NC} Package: %s\n" "$CURRENT_PKG" >&2
    [ -n "${CURRENT_STAGE:-}" ] && printf "${RED}│${NC} Stage: %s\n" "$CURRENT_STAGE" >&2
    [ -n "${CURRENT_RECIPE:-}" ] && printf "${RED}│${NC} Recipe: %s\n" "$CURRENT_RECIPE" >&2
    
    printf "${RED}│${NC} Time: %s\n" "$timestamp" >&2
    printf "${RED}│${NC} PID: %s\n" "$$" >&2
    
    # Suggest action
    printf "${RED}│${NC}\n" >&2
    printf "${RED}│${NC} ${YELLOW}Suggestions:${NC}\n" >&2
    
    case "$message" in
        *"not found"*|*"missing"*)
            printf "${RED}│${NC}   • Check if package is spelled correctly\n" >&2
            printf "${RED}│${NC}   • Run: astral -u to update repository index\n" >&2
            printf "${RED}│${NC}   • Search: astral -s <package>\n" >&2
            ;;
        *"checksum"*|*"signature"*)
            printf "${RED}│${NC}   • Verify file integrity\n" >&2
            printf "${RED}│${NC}   • Re-download: rm -rf $CACHE_SRC/*\n" >&2
            printf "${RED}│${NC}   • Disable check: astral --off checksums\n" >&2
            ;;
        *"build"*|*"compile"*)
            printf "${RED}│${NC}   • Check build logs: tail /var/log/astral/build.log\n" >&2
            printf "${RED}│${NC}   • Resume build: astral --resume <pkg>\n" >&2
            printf "${RED}│${NC}   • Force rebuild: astral -S -f <pkg>\n" >&2
            ;;
        *"dependency"*|*"dep"*)
            printf "${RED}│${NC}   • View tree: astral -D <pkg>\n" >&2
            printf "${RED}│${NC}   • Check deps: astral --DepCheck\n" >&2
            printf "${RED}│${NC}   • Install manually: astral -S <missing-dep>\n" >&2
            ;;
        *"conflict"*|*"collision"*)
            printf "${RED}│${NC}   • Force install: astral -S -f <pkg>\n" >&2
            printf "${RED}│${NC}   • Remove conflicting: astral -R <conflict>\n" >&2
            printf "${RED}│${NC}   • Disable check: astral --off collision\n" >&2
            ;;
    esac
    
    printf "${RED}│${NC}\n" >&2
    printf "${RED}│${NC} View logs: tail -f /var/log/astral/astral.log\n" >&2
    printf "${RED}╰────────────────────────────────────────────────────────────────╯${NC}\n" >&2
    
    log_msg "ERROR" "$message"
    exit 1
}

