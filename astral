monitor_build_performance() {
    pkg="$1"
    start_time=$(date +%s)
    start_mem=$(free -m | awk 'NR==2{print $3}')
    
    info "Performance monitoring started for: $pkg"
    
    # Run build
    build_from_recipe_sandboxed "$pkg"
    result=$?
    
    # Calculate metrics
    end_time=$(date +%s)
    end_mem=$(free -m | awk 'NR==2{print $3}')
    
    duration=$((end_time - start_time))
    mem_used=$((end_mem - start_mem))
    
    info ""
    info "╭────────────────────────────────────────────────────────────────╮"
    info "│                  Build Performance Report                     │"
    info "├────────────────────────────────────────────────────────────────┤"
    printf "│  Package:       %-45s │\n" "$pkg"
    printf "│  Duration:      %-45s │\n" "$(format_duration $duration)"
    printf "│  Memory Used:   %-45s │\n" "${mem_used}MB"
    printf "│  Status:        %-45s │\n" "$([ $result -eq 0 ] && echo 'SUCCESS' || echo 'FAILED')"
    info "╰────────────────────────────────────────────────────────────────╯"
    
    # Store metrics
    metrics_file="$DB_DIR/.build_metrics"
    printf '%s|%s|%d|%d\n' "$(date +%s)" "$pkg" "$duration" "$mem_used" >> "$metrics_file"
    
    return $result
}

format_duration() {
    seconds="$1"
    
    hours=$((seconds / 3600))
    minutes=$(( (seconds % 3600) / 60 ))
    secs=$((seconds % 60))
    
    if [ $hours -gt 0 ]; then
        printf '%dh %dm %ds\n' "$hours" "$minutes" "$secs"
    elif [ $minutes -gt 0 ]; then
        printf '%dm %ds\n' "$minutes" "$secs"
    else
        printf '%ds\n' "$secs"
    fi
}

