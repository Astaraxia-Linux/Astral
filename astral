# === ADVANCED USE FLAG SYSTEM ===
USE_EXPAND="ARCH KERNEL LIBC INIT VIDEO_CARDS INPUT_DEVICES"
USE_ARCH=$(uname -m)
USE_KERNEL="linux"
USE_LIBC="glibc"  # or musl
USE_INIT="systemd"  # or openrc, runit, s6

parse_use_flags() {
    pkg="$1"
    
    # Global USE flags from make.conf
    global_use="$USE_FLAGS"
    
    # Package-specific USE flags from /etc/astral/package.use
    pkg_use=""
    if [ -f /etc/astral/package.use ]; then
        pkg_use=$(grep "^${pkg}[[:space:]]" /etc/astral/package.use | cut -d' ' -f2-)
    fi
    
    # Combine and deduplicate
    combined_use="$global_use $pkg_use"
    
    # Expand USE_EXPAND variables
    expanded_use=""
    for flag in $combined_use; do
        case "$flag" in
            ARCH_*)
                [ "$USE_ARCH" = "${flag#ARCH_}" ] && expanded_use="$expanded_use ${flag#ARCH_}"
                ;;
            KERNEL_*)
                [ "$USE_KERNEL" = "${flag#KERNEL_}" ] && expanded_use="$expanded_use ${flag#KERNEL_}"
                ;;
            *)
                expanded_use="$expanded_use $flag"
                ;;
        esac
    done
    
    printf '%s\n' "$expanded_use" | tr ' ' '\n' | sort -u | tr '\n' ' '
}

use_enabled() {
    flag="$1"
    current_use="$2"
    
    # Check for negative flag
    case "$current_use" in
        *" -${flag} "*|*" -${flag}"|-"${flag} "*) return 1 ;;
        *" ${flag} "*|*" ${flag}"|"${flag} "*) return 0 ;;
    esac
    
    return 1
}

show_use_flags() {
    pkg="${1:-}"
    
    if [ -z "$pkg" ]; then
        info "=== Global USE Flags ==="
        printf '%s\n' "$USE_FLAGS" | tr ' ' '\n' | sort
        info ""
        info "=== USE_EXPAND Variables ==="
        printf "ARCH=%s\n" "$USE_ARCH"
        printf "KERNEL=%s\n" "$USE_KERNEL"
        printf "LIBC=%s\n" "$USE_LIBC"
        printf "INIT=%s\n" "$USE_INIT"
    else
        info "=== USE Flags for $pkg ==="
        active_use=$(parse_use_flags "$pkg")
