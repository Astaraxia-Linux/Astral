horizon_init() {
    mkdir -p "$HORIZON_DIR" "$HORIZON_STATE" "$(dirname "$HORIZON_LOG")"
    
    info "╔════════════════════════════════════════════════════════════════╗"
    info "║                    HORIZON BOOTSTRAP                           ║"
    info "║              Astaraxia Linux From Scratch                      ║"
    info "╚════════════════════════════════════════════════════════════════╝"
    info ""
    info "Downloading Horizon bootstrap scripts..."
    
    # Download stage definitions from GitHub
    for stage in 1 2 3; do
        stage_file="$HORIZON_DIR/stage${stage}.sh"
        stage_url="$HORIZON_REPO/stages/stage${stage}.sh"
        
        info "  → Fetching stage${stage}.sh..."
        
        if curl -fSL "$stage_url" -o "$stage_file" 2>&1; then
            chmod +x "$stage_file"
            info "  ✓ Downloaded stage${stage}.sh"
        else
            err "Failed to download stage${stage}.sh from $stage_url"
        fi
    done
    
    # Download package lists
    for stage in 1 2 3; do
        list_file="$HORIZON_DIR/stage${stage}.list"
        list_url="$HORIZON_REPO/lists/stage${stage}.list"
        
        info "  → Fetching stage${stage}.list..."
        
        if curl -fSL "$list_url" -o "$list_file" 2>&1; then
            info "  ✓ Downloaded stage${stage}.list"
        else
            warn "Failed to download stage${stage}.list (optional)"
        fi
    done
    
    info ""
    info "✓ Horizon initialized at: $HORIZON_DIR"
    info ""
    info "Next steps:"
    info "  1. Set up build environment: export LFS=/mnt/lfs"
    info "  2. Run stage 1: astral -h --stage 1"
}

horizon_check_env() {
    stage="$1"
    
    # Check LFS is set
    [ -z "$LFS" ] && err "LFS not set. Export LFS=/mnt/lfs before starting"
    
    # Check LFS exists
    [ ! -d "$LFS" ] && err "LFS directory doesn't exist: $LFS. Create it first: sudo mkdir -pv $LFS"
    
    # Stage-specific checks
    case "$stage" in
        1)
            # Stage 1: Check host system
            info "Checking host system requirements..."
            
            # Check required tools
            for tool in gcc g++ make bison gawk; do
                if ! command -v "$tool" >/dev/null 2>&1; then
                    err "Required tool not found: $tool"
                fi
            done
            
            # Check disk space (need at least 10GB)
            available=$(df -BG "$LFS" | awk 'NR==2 {print $4}' | sed 's/G//')
            if [ "$available" -lt 10 ]; then
                warn "Low disk space: ${available}GB available (10GB+ recommended)"
            fi
            
            info "✓ Host system check passed"
            ;;
        2)
            # Stage 2: Check stage 1 completed
            if [ ! -f "$HORIZON_STATE/stage1.done" ]; then
                err "Stage 1 not completed. Run: astral -h --stage 1"
            fi
            
            # Check toolchain exists
            if [ ! -d "$LFS/tools" ]; then
                err "Toolchain not found at $LFS/tools"
            fi
            
            info "✓ Stage 1 verification passed"
            ;;
        3)
            # Stage 3: Check stage 2 completed
            if [ ! -f "$HORIZON_STATE/stage2.done" ]; then
                err "Stage 2 not completed. Run: astral -h --stage 2"
            fi
            
            # Check chroot environment ready
            if [ ! -d "$LFS/dev" ] || [ ! -d "$LFS/proc" ]; then
                err "Chroot environment not prepared"
            fi
            
            info "✓ Stage 2 verification passed"
            ;;
    esac
}

