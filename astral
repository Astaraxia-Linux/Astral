    info "│  Verbose output activated                                      │"
    info "╰────────────────────────────────────────────────────────────────╯"
    
    # Enable shell tracing
    set -x
    
    # Redirect all output to debug log
    exec 2>> "$DEBUG_LOG"
    
    # Enable verbose mode
    VERBOSE=1
    export VERBOSE
    
    # Log system information
