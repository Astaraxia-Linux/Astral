            \$PKG.Depend.RDepends:*)
                current_section="rdepends"
                in_block=1
                block_content=""
                info "    → RDepends"
                continue
                ;;
                
            \$PKG.Depend.Depends:*)
                current_section="depends"
                in_block=1
                block_content=""
                info "    → Depends (legacy)"
                continue
                ;;
            \$PKG.Depend.PDepends:*)
                current_section="pdepends"
                in_block=1
                block_content=""
                info "    → PDepends (post-install)"
                continue
                ;;
            
            \$PKG.Depend.IDepends:*)
                current_section="idepends"
                in_block=1
                block_content=""
                info "    → IDepends (install-time)"
                continue
                ;;
                
            \$PKG.Depend.Optional:*)
                current_section="optional"
                in_block=1
                block_content=""
                info "    → Optional"
                continue
                ;;
                
            \$PKG.Sources:*)
                current_section="sources"
                in_block=1
                block_content=""
                info "    → Sources"
                continue
                ;;
                
            \$PKG.Checksums:*)
                current_section="checksums"
                in_block=1
                block_content=""
                info "    → Checksums"
                continue
                ;;
                
            \$PKG.Build*)
                current_section="build"
                in_block=1
                block_content=""
                info "    → Build"
                continue
                ;;
                
            \$PKG.Package:*)
                current_section="package"
                in_block=1
                block_content=""
                info "    → Package"
                continue
                ;;
                
            \$PKG.PreInstall:*)
                current_section="pre_install"
                in_block=1
                ;;
            \$PKG.PreRemove:*)
                current_section="pre_remove"
                in_block=1
                ;;
            \$PKG.PostInstall:*)
                current_section="post_install"
                in_block=1
                block_content=""
                info "    → PostInstall"
                continue
                ;;
                
            \$PKG.PostRemove:*)
                current_section="post_remove"
                in_block=1
                block_content=""
                info "    → PostRemove"
                continue
                ;;
        esac
        
        # Block closing
        if [ "$line" = "};" ] || [ "$line" = "}" ]; then
            in_block=0
            
            if [ -n "$current_section" ]; then
                case "$current_section" in
                    metadata)
                        parse_metadata_block_v3 "$block_content" "$temp_dir"
                        ;;
                    bdepends|rdepends|depends|pdepends|idepends|optional)
                        write_deps_file_v3 "$current_section" "$block_content" "$temp_dir"
                        ;;
                    sources)
                        write_sources_section_v3 "$block_content" "$temp_dir"
                        ;;
                    checksums)
                        write_checksums_section_v3 "$block_content" "$temp_dir"
                        ;;
                    build|package|pre_install|pre_remove|post_install|post_remove)
                        write_script_section_v3 "$current_section" "$block_content" "$temp_dir"
                        ;;
                esac
            fi
            
            block_content=""
            current_section=""
            continue
        fi
        
        # Accumulate content
        if [ $in_block -eq 1 ]; then
            case "$line" in "{") continue ;; esac
            
            if [ -z "$block_content" ]; then
                block_content="$line"
            else
                block_content="$block_content
$line"
            fi
        fi
        
    done < "$stars_file"
}

