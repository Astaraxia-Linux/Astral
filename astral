        if [ $in_block -eq 0 ]; then
            [ -z "$line" ] && continue
            case "$line" in \#*) continue ;; esac
        fi
        
        # Section detection
        case "$line" in
            \$PKG.Version*)
                # Skip version marker
                continue
                ;;
                
            \$PKG.Metadata:*)
                current_section="metadata"
                in_block=1
                block_content=""
                continue
                ;;
                
            \$PKG.Depend.BDepends:*)
