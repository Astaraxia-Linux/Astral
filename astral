enable_debug_mode() {
    DEBUG_MODE=1
    export DEBUG_MODE
    
    mkdir -p "$(dirname "$DEBUG_LOG")"
    
    info "╭────────────────────────────────────────────────────────────────╮"
    info "│                     DEBUG MODE ENABLED                         │"
