horizon_run_stage() {
    stage="$1"
    
    [ ! -d "$HORIZON_DIR" ] && err "Horizon not initialized. Run: astral -h --init"
    
    stage_script="$HORIZON_DIR/stage${stage}.sh"
    stage_list="$HORIZON_DIR/stage${stage}.list"
    
    [ ! -f "$stage_script" ] && err "Stage $stage script not found. Run: astral -h --init"
    
    # Show stage info
    horizon_stage_info "$stage"
    
    info ""
    printf "Start stage $stage? This will take several hours. [y/N]: "
    read -r confirm
    
    case "$confirm" in
        [Yy]|[Yy][Ee][Ss])
            ;;
        *)
            info "Cancelled"
            return 0
            ;;
    esac
    
    # Check environment
    horizon_check_env "$stage"
    
    info ""                                 
    info "╔════════════════════════════════════════════════════════════════╗"
    info "║                  STARTING STAGE $stage BUILD              ║"
    info "╚════════════════════════════════════════════════════════════════╝"
    info ""
    info "Build root: $LFS"
    info "Log file:   $HORIZON_LOG"
    info ""
    
    # Create stage marker
    mkdir -p "$HORIZON_STATE"
    date > "$HORIZON_STATE/stage${stage}.start"
    
    # Execute stage script
    info "Executing stage${stage}.sh..."
    
    if sh "$stage_script" 2>&1 | tee -a "$HORIZON_LOG"; then
        # Mark stage complete
        date > "$HORIZON_STATE/stage${stage}.done"
        
        info ""
        info "╔════════════════════════════════════════════════════════════════╗"
        info "║                  STAGE $stage COMPLETED                        ║"
        info "╚════════════════════════════════════════════════════════════════╝"
        info ""
        
        # Show next steps
        case "$stage" in
            1)
                info "Next: Run stage 2"
                info "  astral -h --stage 2"
                ;;
            2)
                info "Next: Enter chroot and run stage 3"
                info "  astral --chroot $LFS"
                info "  astral -h --stage 3"
                ;;
            3)
                info "Next: Configure bootloader and reboot"
                info "  See: /usr/src/astral/horizon/docs/bootloader.md"
                ;;
        esac
    else
        err "Stage $stage failed. Check logs: $HORIZON_LOG"
    fi
}

