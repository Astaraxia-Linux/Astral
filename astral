# Checks if a package (by DB relative path) is required by any other installed package.
is_pkg_required() {
    target_pkg_path="$1"
    target_pkg=$(basename "$target_pkg_path")

    for other_pkg_dir in "$DB_DIR"/*/* "$DB_DIR"/*; do
        [ -d "$other_pkg_dir" ] || continue
        other_pkg_path=$(printf '%s' "$other_pkg_dir" | sed "s|^${DB_DIR}/||")
        [ "$other_pkg_path" = "$target_pkg_path" ] && continue

        other_deps=$(get_pkg_deps "$other_pkg_path" 2>/dev/null || true)
        if printf '%s\n' "$other_deps" | grep -qE "^${target_pkg_path}$|^${target_pkg}$"; then
            return 0
        fi
    done

    return 1
}

# --- HOST DEPENDENCY DETECTION ---
# Returns 0 if dependency is satisfied by host (binary in PATH or shared lib)
check_host_dependency() {
    dep="$1"

    debug() {
        [ "${ASTRAL_DEBUG:-0}" = "1" ] && warn "[HOST-CHECK] $*"
    }

    debug "Checking host for: $dep"

    # Priority 1: Check config override first (fastest)
    case " $HOST_PROVIDED " in
        *" $dep "*) debug "  ✓ Found in HOST_PROVIDED config"; return 0 ;;
    esac

    # Priority 2: Well-known package → library/binary name mapping
    # Many packages have names that don't match their actual library/binary names
    _dep_resolved="$dep"
    case "$dep" in
        glibc|libc)        _dep_resolved="libc" ;;
        ncurses)           _dep_resolved="libncurses" ;;
        ncurses-libs)      _dep_resolved="libncurses" ;;
        openssl)           _dep_resolved="libssl" ;;
        zlib)              _dep_resolved="libz" ;;
        bzip2)             _dep_resolved="libbz2" ;;
        xz|liblzma)        _dep_resolved="liblzma" ;;
        readline)          _dep_resolved="libreadline" ;;
        pcre)              _dep_resolved="libpcre" ;;
        pcre2)             _dep_resolved="libpcre2-8" ;;
        libffi)            _dep_resolved="libffi" ;;
        expat)             _dep_resolved="libexpat" ;;
        sqlite|sqlite3)    _dep_resolved="libsqlite3" ;;
        libpng)            _dep_resolved="libpng" ;;
        libjpeg|jpeg)      _dep_resolved="libjpeg" ;;
        freetype|freetype2)_dep_resolved="libfreetype" ;;
        fontconfig)        _dep_resolved="libfontconfig" ;;
        linux-headers|linux-api-headers) return 0 ;;  # always host-provided
    esac

    # Priority 3: Check pkg-config (most reliable for libraries)
    if command -v pkg-config >/dev/null 2>&1; then
        if pkg-config --exists "$dep" 2>/dev/null || \
           pkg-config --exists "$_dep_resolved" 2>/dev/null; then
            debug "  ✓ Found via pkg-config"
            return 0
        fi
        debug "  ✗ Not found in pkg-config"
    fi

    # Priority 4: Binary name translation — package name often ≠ binary name
    _dep_bin="$dep"
    case "$dep" in
        texinfo)           _dep_bin="makeinfo" ;;
        autoconf)          _dep_bin="autoconf" ;;
        automake)          _dep_bin="automake" ;;
        libtool)           _dep_bin="libtoolize" ;;
        pkg-config|pkgconf)_dep_bin="pkg-config" ;;
        flex)              _dep_bin="flex" ;;
        bison)             _dep_bin="bison" ;;
        m4)                _dep_bin="m4" ;;
        perl)              _dep_bin="perl" ;;
        python|python3)    _dep_bin="python3" ;;
        python2)           _dep_bin="python2" ;;
        ruby)              _dep_bin="ruby" ;;
        cmake)             _dep_bin="cmake" ;;
        ninja|ninja-build) _dep_bin="ninja" ;;
        meson)             _dep_bin="meson" ;;
        nasm)              _dep_bin="nasm" ;;
        yasm)              _dep_bin="yasm" ;;
        gperf)             _dep_bin="gperf" ;;
        gettext)           _dep_bin="msgfmt" ;;
        diffutils)         _dep_bin="diff" ;;
        findutils)         _dep_bin="find" ;;
        util-linux)        _dep_bin="mount" ;;
        procps|procps-ng)  _dep_bin="ps" ;;
        e2fsprogs)         _dep_bin="mke2fs" ;;
        shadow)            _dep_bin="useradd" ;;
        iproute2)          _dep_bin="ip" ;;
        wget)              _dep_bin="wget" ;;
        curl)              _dep_bin="curl" ;;
        git)               _dep_bin="git" ;;
        rsync)             _dep_bin="rsync" ;;
        patch)             _dep_bin="patch" ;;
        bc)                _dep_bin="bc" ;;
        gzip)              _dep_bin="gzip" ;;
        bzip2-tools|bzip2) _dep_bin="bzip2" ;;
        xz-utils|xz)       _dep_bin="xz" ;;
        unzip)             _dep_bin="unzip" ;;
        zip)               _dep_bin="zip" ;;
        tar)               _dep_bin="tar" ;;
        sed)               _dep_bin="sed" ;;
        awk|gawk)          _dep_bin="awk" ;;
        grep)              _dep_bin="grep" ;;
        which)             _dep_bin="which" ;;
        file)              _dep_bin="file" ;;
        sudo)              _dep_bin="sudo" ;;
        binutils)          _dep_bin="ld" ;;
        gcc)               _dep_bin="gcc" ;;
        g++|gcc-c++)       _dep_bin="g++" ;;
        clang)             _dep_bin="clang" ;;
        make)              _dep_bin="make" ;;
        gmake)             _dep_bin="gmake" ;;
    esac

    # Check translated binary name in PATH
    if command -v "$_dep_bin" >/dev/null 2>&1; then
        debug "  ✓ Found binary '$_dep_bin' in PATH (package: $dep)"
        return 0
    fi
    # Also check original name in PATH
    if [ "$_dep_bin" != "$dep" ] && command -v "$dep" >/dev/null 2>&1; then
        debug "  ✓ Found '$dep' in PATH"
        return 0
    fi
    debug "  ✗ Not in PATH (tried: $dep, $_dep_bin)"

    # Priority 5: Library check using resolved name
    case "$_dep_resolved" in
        lib*)
            debug "  → Checking as shared library: $_dep_resolved"
            if check_shared_library "$_dep_resolved"; then
                debug "  ✓ Found as shared library"
                return 0
            fi
            debug "  ✗ Not found as shared library"
            ;;
        *)
            debug "  → Trying with lib prefix"
            if check_shared_library "lib${_dep_resolved}"; then
                debug "  ✓ Found as lib${_dep_resolved}"
                return 0
            fi
            debug "  ✗ Not found as lib${_dep_resolved}"
            ;;
    esac

    debug "  ✗ NOT FOUND on host"
    return 1
}
check_shared_library() {
    lib_pattern="$1"

    # Method 1: ldconfig cache (fastest, but might be stale)
    if command -v ldconfig >/dev/null 2>&1; then
        # ONLY match actual .so files, not .a or other junk
        if ldconfig -p 2>/dev/null | grep -qE "${lib_pattern}\.so(\.[0-9]+)*[[:space:]]"; then
            return 0
        fi
    fi

    # Method 2: Direct filesystem search - ONLY .so files
    for libdir in /lib /usr/lib /lib64 /usr/lib64 /usr/local/lib /usr/local/lib64; do
        [ -d "$libdir" ] || continue

        # STRICT: Only match .so or .so.X.Y.Z files
        if find "$libdir" -maxdepth 1 \( -name "${lib_pattern}.so" -o -name "${lib_pattern}.so.*" \) 2>/dev/null | grep -q .; then
            return 0
        fi
    done

    return 1
}

show_host_deps() {
    info "=== Host Dependency Analysis ==="

    info ""
    info "Compilers:"
    for tool in gcc g++ cc clang clang++ tcc; do
        if command -v "$tool" >/dev/null 2>&1; then
            version=$("$tool" --version 2>/dev/null | head -n1)
            info "  ✓ $tool: $version"
        else
            info "  ✗ $tool: not found"
        fi
    done

    info ""
    info "Build Tools:"
    for tool in make cmake meson ninja automake autoconf libtool pkg-config; do
        if command -v "$tool" >/dev/null 2>&1; then
            info "  ✓ $tool"
        else
            info "  ✗ $tool"
        fi
    done

    info ""
    info "Common Libraries (via pkg-config):"
    if command -v pkg-config >/dev/null 2>&1; then
        for lib in zlib openssl ncurses readline; do
            if pkg-config --exists "$lib" 2>/dev/null; then
                version=$(pkg-config --modversion "$lib" 2>/dev/null)
                info "  ✓ $lib: $version"
            else
                info "  ✗ $lib: not found"
            fi
        done
    else
        warn "  pkg-config not available"
    fi

    info ""
    info "Library Paths:"
    for libdir in /lib /usr/lib /lib64 /usr/lib64; do
        if [ -d "$libdir" ]; then
            count=$(find "$libdir" -name "*.so*" 2>/dev/null | wc -l)
            info "  $libdir: $count libraries"
        fi
    done

    info ""
