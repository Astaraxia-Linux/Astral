# §5.2 — Structured error output with actionable hints
err_hint() {
    _msg="$1"
    _hint="$2"
    printf '%b[ERROR]%b %s\n' "$RED" "$NC" "$_msg" >&2
    printf '%b Hint:%b %s\n' "$YELLOW" "$NC" "$_hint" >&2
    exit 1
}

# §5.3 — Machine-readable errors for astral-env (ASTRAL_JSON_OUTPUT=1)
err_structured() {
    _code="$1" _msg="$2" _pkg="${3:-}" _hint="${4:-}"
    if [ "${ASTRAL_JSON_OUTPUT:-0}" -eq 1 ]; then
        printf '{"error":{"code":"%s","message":"%s","package":"%s","hint":"%s"}}\n' \
            "$_code" "$_msg" "$_pkg" "$_hint" >&2
    else
        printf '%b[ERROR]%b [%s] %s\n' "$RED" "$NC" "$_code" "$_msg" >&2
        [ -n "$_hint" ] && printf ' Hint: %s\n' "$_hint" >&2
    fi
    exit 1
}

# Named error helpers — call these instead of generic err() for common failures
recipe_not_found_err() {
    _pkg="$1"
    err_hint \
        "Recipe not found: $_pkg" \
        "Try: astral -u (update index), then astral -s $_pkg (search). Is the spelling correct?"
}

dep_failed_err() {
    _pkg="$1" _dep="$2" _reason="$3"
    err_hint \
        "Dependency '$_dep' required by '$_pkg' failed: $_reason" \
        "Check: astral -i $_dep (show info). Force: astral -S --force $_pkg"
}

checksum_mismatch_err() {
