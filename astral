# §11.2 — Cached checksum to avoid re-hashing on build resume
# Uses a .checksum_cache file in the same dir; invalidates if source file is newer.
get_or_compute_checksum() {
    _file="$1"
    _cache="$(dirname "$_file")/.checksum_cache"
    _fname=$(basename "$_file")

    # Try cache first
    if [ -f "$_cache" ]; then
        _cached=$(grep "^$_fname " "$_cache" | awk '{print $2}')
        if [ -n "$_cached" ] && [ "$_cache" -nt "$_file" ]; then
            printf '%s' "$_cached"
            return 0
        fi
    fi

    # Compute and update cache
    _sum=$(sha256sum "$_file" | awk '{print $1}')
    _tmpf="$_cache.tmp"
    grep -v "^$_fname " "$_cache" 2>/dev/null > "$_tmpf" || true
    printf '%s %s\n' "$_fname" "$_sum" >> "$_tmpf"
    mv -f "$_tmpf" "$_cache"
    printf '%s' "$_sum"
}

verify_checksums_and_extract() {
    pkg="$1"
    rpath="$2"
    buildtmp="$3"
    
    checksums_file="$rpath/checksums"
    
    [ ! -f "$checksums_file" ] && {
        info "No checksums file. Extracting only..."
        extract_only "$rpath/sources" "$buildtmp"
        return 0
    }
    
    info "Verifying source integrity with multi-algo support..."
    
    while IFS= read -r line; do
        line=$(printf '%s' "$line" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')
        [ -z "$line" ] && continue
        case "$line" in \#*) continue ;; esac
        
        # Determine algorithm and parse
        if printf '%s' "$line" | grep -q ':'; then
            algo=$(printf '%s' "$line" | cut -d':' -f1 | tr 'A-Z' 'a-z')
            expected_hash=$(printf '%s' "$line" | cut -d':' -f2 | awk '{print $1}')
            filename=$(printf '%s' "$line" | awk '{print $2}')
        else
            algo="sha256"
            expected_hash=$(printf '%s' "$line" | awk '{print $1}')
            filename=$(printf '%s' "$line" | awk '{print $2}')
        fi
        
        [ -z "$expected_hash" ] || [ -z "$filename" ] && continue
        file_path="$buildtmp/$filename"
        
        # Skip directories
        [ -d "$file_path" ] && { info "  ⊚ Skipping directory: $filename"; continue; }
        [ ! -f "$file_path" ] && { warn "File not found: $filename"; continue; }
        
        # Select appropriate checksum tool
        actual_hash=""
        case "$algo" in
            sha256|sha256sum)
                actual_hash=$(portable_sha256sum "$file_path" | awk '{print $1}')
                ;;
            sha512|sha512sum)
                actual_hash=$(portable_sha512sum "$file_path" | awk '{print $1}')
                ;;
            md5|md5sum)
                actual_hash=$(portable_md5sum "$file_path" | awk '{print $1}')
                ;;
            blake2b|b2)
                actual_hash=$(portable_blake2sum "$file_path" | awk '{print $1}')
                ;;
            *)
                warn "Unknown algorithm: $algo, skipping"
                continue
                ;;
        esac
        
        if [ "$actual_hash" = "SKIP" ]; then
            warn "  ⊚ Checksum skipped: $filename (no tool available)"
            continue
        fi
        
        if [ "$actual_hash" != "$expected_hash" ]; then
            err "Checksum mismatch ($algo) for $filename!"
        else
            info "  ✓ Verified ($algo): $filename"
        fi
    done < "$checksums_file"
    
    info "Extraction phase starting..."
    extract_only "$rpath/sources" "$buildtmp"
}

# Portable SHA512
portable_sha512sum() {
    file="$1"
    
    if command -v sha512sum >/dev/null 2>&1; then
        sha512sum "$file" 2>/dev/null && return 0
    fi
    
    if command -v shasum >/dev/null 2>&1; then
        shasum -a 512 "$file" 2>/dev/null && return 0
    fi
    
    if command -v openssl >/dev/null 2>&1; then
        openssl dgst -sha512 "$file" 2>/dev/null | awk '{print $2" "$1}' && return 0
    fi
    
    printf 'SKIP %s\n' "$file"
}

# Portable MD5
portable_md5sum() {
    file="$1"
    
    if command -v md5sum >/dev/null 2>&1; then
        md5sum "$file" 2>/dev/null && return 0
    fi
    
    if command -v md5 >/dev/null 2>&1; then
        md5 -r "$file" 2>/dev/null && return 0
    fi
    
    if command -v openssl >/dev/null 2>&1; then
        openssl dgst -md5 "$file" 2>/dev/null | awk '{print $2" "$1}' && return 0
    fi
    
    printf 'SKIP %s\n' "$file"
}

# Portable BLAKE2
portable_blake2sum() {
    file="$1"
    
    if command -v b2sum >/dev/null 2>&1; then
        b2sum "$file" 2>/dev/null && return 0
    fi
    
    if command -v openssl >/dev/null 2>&1; then
        if openssl list -digest-algorithms 2>/dev/null | grep -iq blake2; then
            openssl dgst -blake2b512 "$file" 2>/dev/null | awk '{print $2" "$1}' && return 0
        fi
    fi
    
    printf 'SKIP %s\n' "$file"
}

portable_cp_r() {
    src="$1"
    dst="$2"
    
    # Method 1: cp -R (most compatible)
    if cp -R "$src" "$dst" 2>/dev/null; then
        return 0
    fi
    
    # Method 2: cp -r (lowercase)
    if cp -r "$src" "$dst" 2>/dev/null; then
        return 0
    fi
    
    # Method 3: cpio fallback
    if command -v cpio >/dev/null 2>&1; then
        ( cd "$src" && find . -print | cpio -pdm "$dst" ) 2>/dev/null && return 0
    fi
    
    # Method 4: tar pipe
    if command -v tar >/dev/null 2>&1; then
        ( cd "$src" && tar -cf - . ) | ( mkdir -p "$dst" && cd "$dst" && tar -xf - )
        return 0
    fi
    
    err "Failed to copy directory: $src -> $dst"
}

# Portable find with maxdepth
portable_find_maxdepth() {
    dir="$1"
    maxdepth="$2"
    shift 2
    
    # Method 1: GNU find with -maxdepth
    if find "$dir" -maxdepth "$maxdepth" "$@" 2>/dev/null | grep -q .; then
        find "$dir" -maxdepth "$maxdepth" "$@" 2>/dev/null
        return 0
    fi
    
    # Method 2: Fallback - manual depth control with awk
    find "$dir" "$@" 2>/dev/null | awk -v max="$maxdepth" -v dir="$dir" '
        BEGIN { dir_len = length(dir) }
        {
            # Count slashes after base directory
            path = substr($0, dir_len + 1)
            gsub(/[^\/]/, "", path)
            depth = length(path)
            if (depth <= max) print
        }
    '
}

# Portable download with multiple tools
portable_download() {
    url="$1"
    output="$2"
    
    # Method 1: curl
    if command -v curl >/dev/null 2>&1; then
        if curl -fSL "$url" -o "$output" 2>/dev/null; then
            return 0
        fi
    fi
    
    # Method 2: wget
    if command -v wget >/dev/null 2>&1; then
        if wget -q "$url" -O "$output" 2>/dev/null; then
            return 0
        fi
    fi
    
    # Method 3: fetch (BSD)
    if command -v fetch >/dev/null 2>&1; then
        if fetch -q -o "$output" "$url" 2>/dev/null; then
            return 0
        fi
    fi
    
    # Method 4: ftp (minimal)
    if command -v ftp >/dev/null 2>&1; then
        if printf 'GET %s %s\nQUIT\n' "$url" "$output" | ftp -V 2>/dev/null; then
            return 0
        fi
    fi
    
    err "Failed to download: $url (no download tool available)"
}

# Portable tar extraction
portable_tar_extract() {
    archive="$1"
    dest="$2"
    
    # Detect compression
    case "$archive" in
        *.tar.gz|*.tgz)
            if command -v tar >/dev/null 2>&1 && tar --version 2>&1 | grep -q GNU; then
                tar -xzf "$archive" -C "$dest" 2>/dev/null && return 0
            fi
            # Fallback: manual gunzip + tar
            if command -v gunzip >/dev/null 2>&1 && command -v tar >/dev/null 2>&1; then
                gunzip -c "$archive" | ( cd "$dest" && tar -xf - )
                return 0
            fi
            ;;
        *.tar.bz2|*.tbz)
            if command -v tar >/dev/null 2>&1 && tar --version 2>&1 | grep -q GNU; then
                tar -xjf "$archive" -C "$dest" 2>/dev/null && return 0
            fi
            if command -v bunzip2 >/dev/null 2>&1 && command -v tar >/dev/null 2>&1; then
                bunzip2 -c "$archive" | ( cd "$dest" && tar -xf - )
                return 0
            fi
            ;;
        *.tar.xz|*.txz)
            if command -v tar >/dev/null 2>&1 && tar --version 2>&1 | grep -q GNU; then
                tar -xJf "$archive" -C "$dest" 2>/dev/null && return 0
            fi
            if command -v xz >/dev/null 2>&1 && command -v tar >/dev/null 2>&1; then
                xz -dc "$archive" | ( cd "$dest" && tar -xf - )
                return 0
            fi
            ;;
        *.tar)
            tar -xf "$archive" -C "$dest" 2>/dev/null && return 0
            ;;
        *.zip)
            if command -v unzip >/dev/null 2>&1; then
                unzip -q "$archive" -d "$dest" 2>/dev/null && return 0
            fi
            ;;
    esac
    
    err "Failed to extract: $archive"
}

# Portable kill -0 (check if process exists)
portable_process_exists() {
    pid="$1"
    
    # Method 1: kill -0
    if kill -0 "$pid" 2>/dev/null; then
        return 0
    fi
    
    # Method 2: ps check
    if command -v ps >/dev/null 2>&1; then
        if ps -p "$pid" >/dev/null 2>&1; then
            return 0
        fi
    fi
    
    # Method 3: /proc check (Linux)
    if [ -d "/proc/$pid" ]; then
        return 0
    fi
    
    return 1
}

# Portable background job waiting
portable_wait_jobs() {
    max_jobs="$1"
    job_pids="$2"
    
    running=0
    new_pids=""
    
    for pid in $job_pids; do
        if portable_process_exists "$pid"; then
            running=$((running + 1))
            new_pids="$new_pids $pid"
        else
            # Job finished, check exit code if possible
            if command -v wait >/dev/null 2>&1; then
                wait "$pid" 2>/dev/null || true
            fi
        fi
    done
    
    # Return updated count and pids
    printf '%d\n' "$running"
    printf '%s\n' "$new_pids"
}


# Helper function for extraction
extract_only() {
    sources_file="$1"
    buildtmp="$2"
    
    [ ! -f "$sources_file" ] && return 0
    
    while IFS= read -r url; do
        url=$(printf '%s' "$url" | grep -E -v '^[[:space:]]*#' | grep -E -v '^[[:space:]]*$' || true)
        [ -z "$url" ] && continue
        
        # Skip Git URLs (already cloned)
        case "$url" in
            git+*|*.git|*.git#*)
                continue
                ;;
        esac
        
        # Get filename
        filename=$(basename "$url")
        dest_file="$buildtmp/$filename"

        # Skip if it's a directory or doesn't exist
        [ ! -f "$dest_file" ] && continue

        info "  → Extracting: $filename"
        
        case "$filename" in
            *.tar.gz|*.tgz)
                tar -xzf "$dest_file" -C "$buildtmp" || err "Extract failed: $filename"
                rm -f "$dest_file"
                ;;
            *.tar.bz2|*.tbz)
                tar -xjf "$dest_file" -C "$buildtmp" || err "Extract failed: $filename"
                rm -f "$dest_file"
                ;;
            *.tar.xz|*.txz)
                tar -xJf "$dest_file" -C "$buildtmp" || err "Extract failed: $filename"
                rm -f "$dest_file"
                ;;
            *.zip)
                command -v unzip >/dev/null 2>&1 || err "unzip not found"
                unzip -q "$dest_file" -d "$buildtmp" || err "Unzip failed: $filename"
                rm -f "$dest_file"
                ;;
            *)
                info "  ⊚ Not an archive: $filename"
                ;;
        esac
    done < "$sources_file"
}
