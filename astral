        return 0
    fi
    
    info "Verifying recipe signature: $(basename "$recipe_file")"
    
    # Get signer from signature
    signer=$(gpg --verify --batch "$sig_file" "$recipe_file" 2>&1 | grep "gpg: Good signature from" | head -1 | sed 's/.*"\([^"]*\)".*/\1/')
    
    if [ -z "$signer" ]; then
        signer=$(gpg --verify --batch "$sig_file" "$recipe_file" 2>&1 | grep "signature from" | head -1 | sed 's/.*"\([^"]*\)".*/\1/')
    fi
    
    if [ -z "$signer" ]; then
        err "GPG signature verification FAILED - no valid signature"
        return 1
    fi
    
    info "  Signed by: $signer"
    
    # Verify signer in key database
    if ! grep -q "$signer" "$GPG_KEY_DB" 2>/dev/null; then
        warn "Signer '$signer' not in trusted key database"
        info "  Import key with: astral --gpg-import <key-url>"
        
        if [ "$SAFETY_SIGNATURE_VERIFY" -eq 1 ]; then
            err "Untrusted signer - aborting"
        fi
        return 1
    fi
    
    # Check key status
    key_status=$(grep "$signer" "$GPG_KEY_DB" | cut -d'|' -f5)
    if [ "$key_status" = "revoked" ]; then
        err "Key '$signer' has been REVOKED - aborting"
        return 1
    fi
    
    # Check key expiration
    key_expires=$(grep "$signer" "$GPG_KEY_DB" | cut -d'|' -f4)
    if [ "$(date +%s)" -gt "$key_expires" ]; then
        err "Key '$signer' has EXPIRED - aborting"
        return 1
    fi
    
    # Check expected signer
    if [ -n "$expected_signer" ] && [ "$signer" != "$expected_signer" ]; then
        err "Signature from unexpected signer: $signer (expected: $expected_signer)"
        return 1
    fi
    
    # Web of Trust verification
    if [ -s "$GPG_WOT_DB" ]; then
        if wot_verify_trust "$signer" "$signer" >/dev/null 2>&1; then
            info "  ✓ Web of Trust verified"
        else
            info "  ⊚ No WoT path - using direct trust"
        fi
    fi
    
    info "  ✓ Signature verified: $signer"
    return 0
}

# ============================================================================
# CERTIFICATE PINNING FOR SECURE DOWNLOADS
# ============================================================================

CERT_PIN_DB="${GPG_TRUST_DIR}/cert-pins.db"
KNOWN_PINS_DIR="${GPG_TRUST_DIR}/pins"

init_cert_pinning() {
    mkdir -p "$KNOWN_PINS_DIR" 2>/dev/null || true
    [ ! -f "$CERT_PIN_DB" ] && touch "$CERT_PIN_DB" 2>/dev/null || true
}

# Extract and pin certificate
pin_certificate() {
    hostname="$1"
    port="${2:-443}"
    
    info "Pinning certificate for: $hostname:$port"
    
    # Get certificate chain
    cert_info=$(echo | openssl s_client -connect "${hostname}:${port}" -servername "$hostname" 2>/dev/null | openssl x509 -fingerprint -sha256 -noout 2>/dev/null)
    
    if [ -z "$cert_info" ]; then
        err "Failed to get certificate from $hostname"
        return 1
    fi
    
    # Extract fingerprint
    fingerprint=$(printf '%s' "$cert_info" | cut -d'=' -f2 | tr -d ':')
    
    # Store pin
    pin_file="$KNOWN_PINS_DIR/${hostname}.pin"
    printf '%s\n' "$fingerprint" > "$pin_file"
    
    # Add to database
    printf '%s|%s|%s|%s\n' "$hostname" "$port" "$fingerprint" "$(date +%s)" >> "$CERT_PIN_DB"
    
    info "  ✓ Certificate pinned: $hostname"
    info "  SHA256: $fingerprint"
}

# Verify certificate against pinned
verify_certificate_pin() {
    hostname="$1"
    port="${2:-443}"
    
    pin_file="$KNOWN_PINS_DIR/${hostname}.pin"
    
    [ ! -f "$pin_file" ] && {
        [ "$SAFETY_CERT_PIN" -eq 1 ] && {
            warn "No pinned certificate for $hostname"
            return 1
        }
        return 0
    }
    
    # Get current certificate fingerprint
    current_cert=$(echo | openssl s_client -connect "${hostname}:${port}" -servername "$hostname" 2>/dev/null | openssl x509 -fingerprint -sha256 -noout 2>/dev/null | cut -d'=' -f2 | tr -d ':')
    
    pinned_cert=$(cat "$pin_file")
    
    if [ "$current_cert" != "$pinned_cert" ]; then
        err "CERTIFICATE MISMATCH for $hostname!"
        err "  Pinned:   $pinned_cert"
        err "  Current:  $current_cert"
        err "  Possible MITM attack!"
        return 1
    fi
    
    info "  ✓ Certificate verified: $hostname"
    return 0
}

# ============================================================================
# FILE INTEGRITY MONITORING (FIM)
# ============================================================================

FIM_DB="${GPG_TRUST_DIR}/file-integrity.db"
FIM_ALERTS="${LOG_DIR}/fim-alerts.log"

init_fim() {
    mkdir -p "$(dirname "$FIM_DB")" "$(dirname "$FIM_ALERTS")" 2>/dev/null || true
    [ ! -f "$FIM_DB" ] && touch "$FIM_DB" 2>/dev/null || true
}

# Hash a file
fim_hash_file() {
    file="$1"
    
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$file" 2>/dev/null | awk '{print $1}'
    elif command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$file" 2>/dev/null | awk '{print $1}'
    elif command -v openssl >/dev/null 2>&1; then
        openssl dgst -sha256 "$file" 2>/dev/null | awk '{print $2}'
    else
        err "No hash tool available"
        return 1
    fi
}

# Record file hash
fim_record() {
    file="$1"
    owner="${2:-system}"
    
    [ ! -f "$file" ] && err "File not found: $file"
    
    hash=$(fim_hash_file "$file")
    mtime=$(stat -c %Y "$file" 2>/dev/null || stat -f %m "$file" 2>/dev/null || echo 0)
    ctime=$(stat -c %Y "$file" 2>/dev/null || stat -f %c "$file" 2>/dev/null || echo 0)
    
    # Remove old entry
    temp_db="$FIM_DB.tmp.$$"
    grep -v "^${file}|" "$FIM_DB" > "$temp_db" 2>/dev/null || true
    mv "$temp_db" "$FIM_DB"
    
    # Add new entry
    printf '%s|%s|%s|%s|%s\n' "$file" "$hash" "$mtime" "$ctime" "$(date +%s)" >> "$FIM_DB"
    
    info "  ✓ Recorded: $file"
}

# Check file integrity
fim_check() {
    file="$1"
    
    [ ! -f "$FIM_DB" ] && {
        warn "FIM database not initialized"
        return 1
    }
    
    entry=$(grep "^${file}|" "$FIM_DB" 2>/dev/null)
    
    [ -z "$entry" ] && {
        [ "$SAFETY_FILE_INTEGRITY" -eq 1 ] && {
            warn "File not tracked: $file"
            return 1
        }
        return 0
    }
    
    old_hash=$(printf '%s' "$entry" | cut -d'|' -f2)
    old_mtime=$(printf '%s' "$entry" | cut -d'|' -f3)
    old_ctime=$(printf '%s' "$entry" | cut -d'|' -f4)
    
    [ ! -f "$file" ] && {
        err "FILE DELETED: $file"
        printf '%s|DELETED|%s\n' "$(date)" "$file" >> "$FIM_ALERTS"
        return 1
    }
    
    new_hash=$(fim_hash_file "$file")
    new_mtime=$(stat -c %Y "$file" 2>/dev/null || echo 0)
    new_ctime=$(stat -c %Y "$file" 2>/dev/null || echo 0)
    
    # Check hash
    if [ "$old_hash" != "$new_hash" ]; then
        err "INTEGRITY VIOLATION: $file"
        err "  Old hash: $old_hash"
        err "  New hash: $new_hash"
        printf '%s|MODIFIED|%s|%s|%s\n' "$(date)" "$file" "$old_hash" "$new_hash" >> "$FIM_ALERTS"
        return 1
    fi
    
    # Check mtime (optional - can change due to legitimate updates)
    if [ "$old_mtime" != "$new_mtime" ]; then
        info "  ⊚ Timestamp changed: $file (hash OK)"
    fi
    
    info "  ✓ Verified: $file"
    return 0
}

# Scan all tracked files
fim_scan_all() {
    info "Scanning all tracked files..."
    
    violations=0
    
    while IFS='|' read -r file rest; do
        [ -z "$file" ] && continue
        
        if ! fim_check "$file" >/dev/null 2>&1; then
            violations=$((violations + 1))
        fi
    done < "$FIM_DB"
    
    if [ $violations -gt 0 ]; then
        warn "Found $violations integrity violations"
        warn "  See: $FIM_ALERTS"
        return 1
    fi
    
    info "  ✓ All files verified"
    return 0
}

# ============================================================================
# RECIPE AUDIT TRAIL
# ============================================================================

AUDIT_LOG="${LOG_DIR}/audit.log"
AUDIT_DB="${GPG_TRUST_DIR}/audit.db"

init_audit() {
    mkdir -p "$(dirname "$AUDIT_LOG")" "$(dirname "$AUDIT_DB")" 2>/dev/null || true
    [ ! -f "$AUDIT_DB" ] && touch "$AUDIT_DB" 2>/dev/null || true
}

# Record audit entry
audit_record() {
    action="$1"
    target="$2"
    details="${3:-}"
    signer="${4:-unknown}"
    
    timestamp=$(date +%s)
    entry_id=$(printf '%s%s%s' "$timestamp" "$target" "$action" | sha256sum | cut -c1-16)
    
    printf '%s|%s|%s|%s|%s|%s\n' "$entry_id" "$timestamp" "$action" "$target" "$signer" "$details" >> "$AUDIT_DB"
    
    # Also log to syslog-style log
    printf '[%s] AUDIT:%s:%s:%s:%s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$action" "$target" "$signer" "$details" >> "$AUDIT_LOG"
}

# Query audit log
audit_query() {
    target="${1:-}"
    action="${2:-}"
    since="${3:-0}"
    
    info "Audit Log Query"
    info "╭────────────────────────────────────────────────────────────────╮"
    info "│ ID            | TIMESTAMP          | ACTION  | TARGET            │"
    info "├────────────────────────────────────────────────────────────────┤"
    
    while IFS='|' read -r entry_id timestamp action target signer details; do
        [ -z "$entry_id" ] && continue
        
        # Filter
        [ -n "$target" ] && [ "$target" != "$target" ] && continue
        [ -n "$action" ] && [ "$action" != "$action" ] && continue
        [ "$timestamp" -lt "$since" ] && continue
        
        human_time=$(date -d "@$timestamp" 2>/dev/null || echo "$timestamp")
        printf '│ %-14s | %-18s | %-7s | %-18s │\n' "$entry_id" "$human_time" "$action" "$target"
    done < "$AUDIT_DB" | tail -20
    
    info "╰────────────────────────────────────────────────────────────────╯"
}

# Verify recipe audit trail
audit_verify_recipe() {
    recipe="$1"
    
    info "Verifying audit trail for: $recipe"
    
    signatures=$(grep "|recipe_verify|${recipe}|" "$AUDIT_DB" 2>/dev/null | wc -l)
    installs=$(grep "|package_install|${recipe}|" "$AUDIT_DB" 2>/dev/null | wc -l)
    
    info "  Verification entries: $signatures"
    info "  Install entries: $installes"
    
    if [ "$signatures" -eq 0 ] && [ "$installs" -eq 0 ]; then
        warn "  ⊚ No audit trail found"
        return 1
    fi
    
    info "  ✓ Audit trail verified"
    return 0
}

# ============================================================================
# The make.conf location can be explicitly declared in astral.stars config file
# ============================================================================

ASTRAL_CONFIG="${ASTRAL_CONFIG:-/etc/astral/astral.stars}"
MAKE_CONF="${MAKE_CONF:-/etc/astral/make.conf}"

# Parse astral.stars configuration
parse_astral_stars_config() {
    config_file="${1:-$ASTRAL_CONFIG}"
    
    if [ ! -f "$config_file" ]; then
        warn "No config exist... using Defaults"
        return 0
    fi
    
    info "Parsing astral.stars config: $config_file"
    
    current_namespace=""
    in_block=0
    brace_depth=0
    
    while IFS= read -r line || [ -n "$line" ]; do
        # Remove leading/trailing whitespace
        line=$(printf '%s' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        
        # Skip empty lines and comments
        [ -z "$line" ] && continue
        case "$line" in \#*) continue ;; esac
        
        # Check for namespace block start: $AST.namespace: {
        case "$line" in
            '$AST.'*':'*)
                # Pattern: $AST.namespace: or $AST.namespace: {
                current_namespace=$(printf '%s' "$line" | sed 's/\$AST\.//;s/:[[:space:]]*{.*//;s/:$//')
                debug "config: namespace='$current_namespace'"
                in_block=1
                brace_depth=0
                # Check if { is on same line
                case "$line" in
                    *'{'*)
                        brace_depth=1
                        # Check for closing } on same line
                        case "$line" in
                            *'}'*)
                                open_braces=$(printf '%s' "$line" | tr -cd '{' | wc -c)
                                close_braces=$(printf '%s' "$line" | tr -cd '}' | wc -c)
                                brace_depth=$((open_braces - close_braces))
                                if [ "$brace_depth" -le 0 ]; then
                                    in_block=0
                                    current_namespace=""
                                    continue
                                fi
                                ;;
                        esac
                        ;;
                esac
                continue
                ;;
            '$AST.'*'{'*)
                # Pattern: $AST.namespace { or $AST.namespace{
                current_namespace=$(printf '%s' "$line" | sed 's/\$AST\.//;s/[[:space:]]*{.*//')
                in_block=1
                brace_depth=1
                # Check for closing } on same line
                case "$line" in
                    *'}'*)
                        close_braces=$(printf '%s' "$line" | tr -cd '}' | wc -c)
                        brace_depth=$((brace_depth - close_braces))
                        if [ "$brace_depth" -le 0 ]; then
                            in_block=0
                            current_namespace=""
                            continue
                        fi
                        ;;
                esac
                continue
                ;;
        esac
        
        # Check for block end
        if [ "$in_block" -eq 1 ]; then
            # Count braces
            open_braces=$(printf '%s' "$line" | tr -cd '{' | wc -c)
            close_braces=$(printf '%s' "$line" | tr -cd '}' | wc -c)
            brace_depth=$((brace_depth + open_braces - close_braces))
            
            if [ "$brace_depth" -le 0 ]; then
                in_block=0
                current_namespace=""
                continue
            fi
            
            # Remove trailing semicolon and braces for parsing
            line=$(printf '%s' "$line" | sed 's/;[[:space:]]*$//;s/}[[:space:]]*$//')
        fi
        
        # Parse KEY = VALUE or KEY: VALUE
        case "$line" in
            *'='*)
                key=$(printf '%s' "$line" | cut -d'=' -f1 | tr -d ' ' | tr '[:lower:]' '[:upper:]')
                value=$(printf '%s' "$line" | cut -d'=' -f2- | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                ;;
            *':'*)
                key=$(printf '%s' "$line" | cut -d':' -f1 | tr -d ' ' | tr '[:lower:]' '[:upper:]')
                value=$(printf '%s' "$line" | cut -d':' -f2- | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                ;;
            *)
                continue
                ;;
        esac

        # Strip inline comments (anything after unquoted #)
        value=$(printf '%s' "$value" | sed 's/[[:space:]]*#.*$//')
        # Strip surrounding quotes (single or double)
        value=$(printf '%s' "$value" | sed 's/^["'"'"']//;s/["'"'"']$//')
        # Strip any trailing whitespace left after above
        value=$(printf '%s' "$value" | sed 's/[[:space:]]*$//')
        # Normalize yes/no/true/false to 1/0 for known boolean keys
        case "$key" in
            SANDBOX_ENABLED|SANDBOX_NETWORK|TRANSACTION_ENABLED|\
            STRIP_BINARIES|STRIP_LIBS|STRIP_STATIC|\
            COLLISION_DETECT|GHOST_FILE_CHECK)
                case "$value" in
                    yes|true|1)  value=1 ;;
                    no|false|0)  value=0 ;;
                esac
                ;;
        esac
        
        # Remove quotes from value
        value=$(printf '%s' "$value" | sed "s/^['\"]//;s/['\"]$//")
        
        # Apply setting based on namespace context
        case "$current_namespace" in
            core)
                case "$key" in
                    MAKE_CONF)
                        MAKE_CONF="$value"
                        info "    → make.conf: $MAKE_CONF"
                        ;;
                    RECIPES_DIR)
                        RECIPES_DIR="$value"
                        info "    → recipes dir: $RECIPES_DIR"
                        ;;
                    CACHE_SRC)
                        CACHE_SRC="$value"
                        info "    → source cache: $CACHE_SRC"
                        ;;
                    DB_DIR)
                        DB_DIR="$value"
                        info "    → db dir: $DB_DIR"
                        ;;
                    INSTALL_ROOT)
                        INSTALL_ROOT="$value"
                        info "    → install root: $INSTALL_ROOT"
                        ;;
                    USAGE_MODE)
                        case "$value" in
                            compact|full) USAGE_MODE="$value" ;;
                            *) warn "    → unknown USAGE_MODE '$value', using 'full'" ;;
                        esac
                        info "    → usage mode: $USAGE_MODE"
                        ;;
                    EDITOR)
                        EDITOR="$value"
                        info "    → editor: $EDITOR"
                        ;;
                    DEBUG)
                        case "$value" in
                            1|yes|true|enable) ASTRAL_DEBUG=1 ;;
                            *) ASTRAL_DEBUG=0 ;;
                        esac
                        [ "$ASTRAL_DEBUG" = "1" ] && info "    → debug mode: enabled"
                        ;;
                    STORE_MODE)
                        case "$value" in
                            1|yes|true|store) STORE_MODE=1 ;;
                            *) STORE_MODE=0 ;;
                        esac
                        info "    → store mode: $([ "$STORE_MODE" = "1" ] && echo enabled || echo disabled)"
                        ;;
                    STORE_DIR)
                        STORE_DIR="$value"
                        info "    → store dir: $STORE_DIR"
                        ;;
                esac
                ;;
            repo)
                case "$key" in
                    AOHARU_URL|OFFICIAL_URL)
                        AOHARU_URL="$value"
                        REPO_URL="$value"
                        info "    → AOHARU (official) URL: $AOHARU_URL"
                        ;;
                    ASURA_URL|OVERLAY_URL)
                        ASURA_URL="$value"
                        info "    → ASURA (overlay) URL: $ASURA_URL"
                        ;;
                    REPO_URL)
                        REPO_URL="$value"
                        info "    → repo URL: $REPO_URL"
                        ;;
                esac
                ;;
            security)
                case "$key" in
                    GPG_KEYRING)
                        GPG_KEYRING="$value"
                        info "    → GPG keyring: $GPG_KEYRING"
                        ;;
                    SAFETY_*)
                        case "$value" in
                            1|yes|true|enable)  eval "${key}=1" ;;
                            0|no|false|disable) eval "${key}=0" ;;
                        esac
                        debug "config: $key=$value"
                        info "    → $key: $value"
                        ;;
                esac
                ;;
            sandbox)
                case "$key" in
                    METHOD|SANDBOX_METHOD)
                        SANDBOX_METHOD="$value"
                        info "    → sandbox: $SANDBOX_METHOD"
                        ;;
                esac
                ;;
            host)
                case "$key" in
                    PROVIDED|HOST_PROVIDED)
                        HOST_PROVIDED="$value"
                        info "    → host provided: $HOST_PROVIDED"
                        ;;
                esac
            ;;
            build)
                case "$key" in
                    STRIP_BINARIES|STRIP_LIBS|STRIP_STATIC)
                        eval "${key}=\"$value\""
                        info "    → $key: $value"
                        ;;
                    COLLISION_DETECT)
                        case "$value" in
                            1|yes|true)  SAFETY_COLLISION_DETECT=1 ;;
                            0|no|false)  SAFETY_COLLISION_DETECT=0 ;;
                        esac
                        info "    → collision detect: $value"
                        ;;
                    GHOST_FILE_CHECK)
                        case "$value" in
                            1|yes|true)  SAFETY_GHOST_DETECT=1 ;;
                            0|no|false)  SAFETY_GHOST_DETECT=0 ;;
                        esac
                        info "    → ghost file check: $value"
                        ;;
                    TRANSACTION_ENABLED)
                        case "$value" in
                            1|yes|true)  TRANSACTION_ENABLED=1 ;;
                            0|no|false)  TRANSACTION_ENABLED=0 ;;
                            *)           TRANSACTION_ENABLED="$value" ;;
                        esac
                        info "    → transactions: $value"
                        ;;
                    LOCK_TIMEOUT)
                        LOCK_TIMEOUT="$value"
                        info "    → lock timeout: ${value}s"
                        ;;
                    SANDBOX_ENABLED)
                        case "$value" in
                            1|yes|true)  SANDBOX_ENABLED=1 ;;
                            0|no|false)  SANDBOX_ENABLED=0 ;;
                            *)           SANDBOX_ENABLED="$value" ;;
                        esac
                        info "    → sandbox: $value"
                        ;;
                    SANDBOX_NETWORK)
                        SANDBOX_NETWORK="$value"
                        info "    → sandbox network: $value"
                        ;;
                    SANDBOX_METHOD)
                        SANDBOX_METHOD="$value"
                        info "    → sandbox method: $value"
                        ;;
                esac
            ;;
            tools)
                case "$key" in
                    CCACHE_ENABLED|CCACHE_DIR|CCACHE_MAXSIZE|CCACHE_COMPRESS|CCACHE_COMPRESSLEVEL)
                        eval "${key}=\"$value\""
                        info "    → $key: $value"
                        ;;
                    DISTCC_ENABLED|DISTCC_DIR|DISTCC_HOSTS|DISTCC_VERBOSE)
                        eval "${key}=\"$value\""
                        info "    → $key: $value"
                        ;;
                esac
            ;;
        esac
    done < "$config_file"

    # Export all SAFETY_* vars so parallel download subshells inherit them
    export SAFETY_SCRIPT_CHECK SAFETY_COLLISION_DETECT SAFETY_GHOST_DETECT \
           SAFETY_CHECKSUM_VERIFY SAFETY_MASK_CHECK SAFETY_SIGNATURE_VERIFY \
           SAFETY_RECIPE_AUDIT SAFETY_SECURE_DOWNLOAD SAFETY_FILE_INTEGRITY \
           SAFETY_MERKLE_VERIFY SAFETY_CERT_PIN SAFETY_ADVANCED_SCRIPT_CHECK \
           ASTRAL_DEBUG
    
    info "✓ Config loaded from astral.stars"
    return 0
}

