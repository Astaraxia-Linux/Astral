        local pkg_ver="unknown"
        local can_skip=0
        local is_optional=0
        local item_id=0
        
        # Check installation status
        if is_pkg_installed "$pkg_name"; then
            pkg_ver=$(get_installed_ver "$pkg_name")
            status_icon="[✓✓]"
            status_symbol="✓✓"
        elif check_host_dependency "$pkg_name"; then
            status_icon="[ ✓  ]"
            status_symbol="✓ "
            can_skip=1
            
            local rpath=$(recipe_path "$pkg_name" 2>/dev/null || echo "")
            if [ -n "$rpath" ]; then
                pkg_ver=$(cat "$rpath/version" 2>/dev/null || echo "host")
            else
                pkg_ver="host"
            fi
        else
            status_icon="[  ]"
            status_symbol="  "
            
            local rpath=$(recipe_path "$pkg_name" 2>/dev/null || echo "")
            if [ -n "$rpath" ]; then
                pkg_ver=$(cat "$rpath/version" 2>/dev/null || echo "unknown")
            fi
        fi
        
        # Check if optional
        if [ "$dep_type" = "optional" ]; then
            is_optional=1
            status_icon="[OPT]"
            status_symbol="OPT"
            can_skip=1
        fi
        
        # Create selectable item if can be skipped
        if [ $can_skip -eq 1 ] || [ $is_optional -eq 1 ]; then
            dep_counter=$((dep_counter + 1))
            item_id=$dep_counter
            
            printf '%d|%s|%s|%s|%d|%d\n' "$item_id" "$pkg_name" "$pkg_ver" "$dep_type" "$is_optional" "$can_skip" >> "$temp_data"
        fi
        
        # Build tree line
        local branch="$([ $is_last -eq 1 ] && echo ' └─' || echo ' ├─')"
        local connector="$([ $is_last -eq 1 ] && echo '     ' || echo '│  ')"
        
        local item_label=""
        if [ $item_id -gt 0 ]; then
            item_label="[$item_id] "
        fi
        
        local opt_label=""
        if [ $is_optional -eq 1 ]; then
            opt_label=" [OPTIONAL]"
        fi
        
        printf '%s%s %s%s %s ─ %s%s\n' "$indent" "$branch" "$item_label" "$status_icon" "$pkg_name" "$pkg_ver" "$opt_label" >> "$temp_tree"
        
        # Get dependencies
        local rpath=$(recipe_path "$pkg_name" 2>/dev/null || echo "")
        if [ -n "$rpath" ]; then
            if [ -f "$rpath" ]; then
                case "$rpath" in
                    *.stars)
                        local temp_expand="$TMPDIR/astral-expand-$pkg_name-$$"
                        expand_stars_recipe "$rpath" "$temp_expand" "$pkg_name" 2>/dev/null || true
                        rpath="$temp_expand"
                        ;;
                esac
            fi
            
            local required_deps="" build_deps="" runtime_deps="" optional_deps=""
            
            if [ -f "$rpath/depends" ]; then
                required_deps=$(grep -v '^#' "$rpath/depends" 2>/dev/null | grep -v '^$' | awk '{print $1}' || true)
            fi
            
            if [ -f "$rpath/bdepends" ]; then
                build_deps=$(grep -v '^#' "$rpath/bdepends" 2>/dev/null | grep -v '^$' | awk '{print $1}' || true)
            fi
            
            if [ -f "$rpath/rdepends" ]; then
                runtime_deps=$(grep -v '^#' "$rpath/rdepends" 2>/dev/null | grep -v '^$' | awk '{print $1}' || true)
            fi
            
            if [ -f "$rpath/optional" ]; then
                optional_deps=$(grep -v '^#' "$rpath/optional" 2>/dev/null | grep -v '^$' | awk '{print $1}' || true)
            fi
            
            local all_deps="$required_deps $build_deps $runtime_deps"
            local dep_list=""
            local dep_count=0
            local seen_deps=""

            for d in $all_deps; do
                d=$(printf '%s' "$d" | tr -d '[:space:]')
                [ -z "$d" ] && continue
                # Skip duplicates
                case " $seen_deps " in *" $d "*) continue ;; esac
                seen_deps="$seen_deps $d"
                dep_list="$dep_list required:$d"
                dep_count=$((dep_count + 1))
            done

            for d in $optional_deps; do
                d=$(printf '%s' "$d" | tr -d '[:space:]')
                [ -z "$d" ] && continue
                case " $seen_deps " in *" $d "*) continue ;; esac
                seen_deps="$seen_deps $d"
                dep_list="$dep_list optional:$d"
                dep_count=$((dep_count + 1))
            done
            
            if [ $dep_count -gt 0 ]; then
                local current=0
                for dep_entry in $dep_list; do
                    current=$((current + 1))
                    
                    local dtype=$(printf '%s' "$dep_entry" | cut -d':' -f1)
                    local dname=$(printf '%s' "$dep_entry" | cut -d':' -f2)
                    
                    local new_indent="$indent$connector"
                    local dep_is_last=0
                    [ $current -eq $dep_count ] && dep_is_last=1
                    
                    build_interactive_tree "$dname" "$new_indent" "$dep_is_last" "$visited" "$dtype"
                done
            fi
        fi
    }
    
    build_interactive_tree "$pkg" "" 1 "" "required"
    
    cat "$temp_tree"
    info ""
    
    if [ -s "$temp_data" ]; then
        info "╭────────────────────────────────────────────────────────────────╮"
        info "│              Dependency Selection Menu                         │"
        info "├────────────────────────────────────────────────────────────────┤"
        info "│ Status Legend:                                                 │"
        printf "│  ${GREEN}[✓✓]${NC} - Already installed (cannot skip)                        │"
        info ""
        printf "│  ${YELLOW}[✓ ]${NC} - Available on host (can be skipped)                     │"
        info ""
        printf "│  ${RED}[  ]${NC} - Will be installed (required)                           │"
        info ""
        printf "│  ${BLUE}[OPT]${NC} - Optional dependency (can be skipped)                  │"
        info ""
        info "├────────────────────────────────────────────────────────────────┤"
        info "│ Actions:                                                       │"
        info "│  • Enter numbers to SKIP packages (e.g., '1 3 5')              │"
        info "│  • Enter 'a' or 'all' to install everything                    │"
        info "│  • Press Enter to continue with current selection              │"
        info "╰────────────────────────────────────────────────────────────────╯"
        info ""
        
        printf "${YELLOW}Selectable Dependencies:${NC}"
        info ""
        while IFS='|' read -r id name ver dtype is_opt can_skip; do
            local status_label=""
            if [ "$is_opt" -eq 1 ]; then
                status_label="[OPTIONAL]"
            elif [ "$can_skip" -eq 1 ]; then
                status_label="[CAN SKIP]"
            fi
            printf '[%2d ] %-25s v%-10s %s\n' "$id" "$name" "$ver" "$status_label"
        done < "$temp_data"
        
        info ""
        
        if [ "$skip_confirmation" -eq 0 ]; then
            printf "${BLUE}Enter numbers to SKIP (or press Enter to install all): ${NC}"
            read -r user_input
            
            case "$user_input" in
                "")
                    info "Installing all dependencies"
                    ;;
                *)
                    for skip_id in $user_input; do
                        skip_pkg=$(awk -F'|' -v id="$skip_id" '$1 == id {print $2}' "$temp_data")
                        if [ -n "$skip_pkg" ]; then
                            printf '%s\n' "$skip_pkg" >> "$temp_skip"
                            info "  → Will skip: $skip_pkg"
                        fi
                    done
                    ;;
            esac
        fi
    fi
    
    new_count=0
    skip_count=0
    
    if [ -s "$temp_data" ]; then
        while IFS='|' read -r id name ver dtype is_opt can_skip; do
            if [ -s "$temp_skip" ] && grep -qxF "$name" "$temp_skip"; then
                skip_count=$((skip_count + 1))
            else
                if ! is_pkg_installed "$name" && ! check_host_dependency "$name"; then
                    new_count=$((new_count + 1))
                fi
            fi
        done < "$temp_data"
    fi
    
    if ! is_pkg_installed "$pkg"; then
        new_count=$((new_count + 1))
    fi
    
    info ""
    info "╭────────────────────────────────────────────────────────────────╮"
    info "│                         Summary                                │"
    info "├────────────────────────────────────────────────────────────────┤"
    printf "│  Packages to install: %-37s│\n" "$new_count"
    printf "│  Dependencies to skip: %-36s│\n" "$skip_count"
    info "╰────────────────────────────────────────────────────────────────╯"
    
    export ASTRAL_SKIP_PACKAGES="$temp_skip"
    
    rm -f "$temp_tree" "$temp_data"
    
    if [ "$skip_confirmation" -eq 1 ]; then
        info ""
        info "Auto-confirming installation (--yes flag)"
        return 0
    fi
    
    info ""
    printf "${YELLOW}Proceed with installation? [Y/n]: ${NC}"
    read -r response
    
    case "$response" in
        [Nn]|[Nn][Oo])
            info "✗ Installation cancelled by user"
            rm -f "$ASTRAL_SKIP_PACKAGES" 2>/dev/null
            export ASTRAL_SKIP_PACKAGES=""
            exit 0
            ;;
        *)
            info "✓ Starting installation..."
            return 0
            ;;
    esac
}

