    info "  Edit this file to customize your installation"
}

# world file management
WORLD_SET="${DB_DIR}/world"
WORLD_SET_AUTODETOOL="${DB_DIR}/world_autodetool"
WORLD_SET_VIRTUALS="${DB_DIR}/world_virtuals"

# Add packages to world set
world_add() {
    pkg="$1"
    pkg="${pkg%.stars}"
    
    [ -z "$pkg" ] && return 1
    
    # Prevent duplicates
    if [ -f "$WORLD_SET" ] && grep -qxF "$pkg" "$WORLD_SET" 2>/dev/null; then
        return 0
    fi
    
    printf '%s\n' "$pkg" >> "$WORLD_SET"
    info "Added to world: $pkg"
    
    # Record audit
    audit_record "world_add" "$pkg" "" "system"
}

# Remove from world set
world_remove() {
    pkg="$1"
    
    [ ! -f "$WORLD_SET" ] && return 1
    
    temp=$(mktemp)
    grep -vxF "$pkg" "$WORLD_SET" > "$temp" 2>/dev/null || true
    mv "$temp" "$WORLD_SET"
    
    info "Removed from world: $pkg"
    audit_record "world_remove" "$pkg" "" "system"
}

# Show world set with statistics
world_show() {
    info "╭────────────────────────────────────────────────────────────────╮"
    info "│                     World Set                                   │"
    info "╰────────────────────────────────────────────────────────────────╯"
    
    if [ ! -f "$WORLD_SET" ] || [ ! -s "$WORLD_SET" ]; then
        info "World set is empty"
        return 0
    fi
    
    total=$(wc -l < "$WORLD_SET")
    info "Total packages: $total"
    info ""
    
    while IFS= read -r pkg; do
        [ -z "$pkg" ] && continue
        
        if is_pkg_installed "$pkg"; then
            ver=$(get_installed_ver "$pkg")
            printf "  ✓ %-30s [v%s]\n" "$pkg" "$ver"
        else
            printf "  ✗ %-30s [NOT INSTALLED]\n" "$pkg"
        fi
    done < "$WORLD_SET"
}

# @system and @world sets
world_sets() {
    info "╭────────────────────────────────────────────────────────────────╮"
    info "│                     World Sets                                 │"
    info "├────────────────────────────────────────────────────────────────┤"
    info "│ @system  - Essential system packages                           │"
    info "│ @world   - User-selected packages                              │"
    info "│ @autodetool - Build tool dependencies                          │"
    info "│ @virtuals - Virtual package providers                          │"
    info "╰────────────────────────────────────────────────────────────────╯"
    info ""
    
    if [ -f "$WORLD_SET" ] && [ -s "$WORLD_SET" ]; then
        count=$(wc -l < "$WORLD_SET")
        info "@world: $count packages"
    fi
}

# Calculate @system set (minimal packages needed for boot)
calc_system_set() {
    info "Calculating @system set..."
    
    system_pkgs="sys-kernel/linux-headers
sys-libs/glibc
sys-apps/baselayout
sys-apps/sysvinit
sys-process/procps
sys-apps/net-tools
sys-apps/iproute2"
    
    printf '%s\n' "$system_pkgs"
}

# Depclean with world awareness
world_aware_depclean() {
    info "World-aware dependency cleaning..."
    
    # Get all packages in world
    world_packages=""
    if [ -f "$WORLD_SET" ]; then
        while IFS= read -r pkg; do
            [ -z "$pkg" ] && continue
            world_packages="$world_packages $pkg"
        done < "$WORLD_SET"
    fi
    
    # Check each installed package
    for pkgdir in "$DB_DIR"/*/* "$DB_DIR"/*; do
        [ -d "$pkgdir" ] || continue
        
        pkg_path=$(printf '%s' "$pkgdir" | sed "s|^${DB_DIR}/||")
        pkg_name=$(basename "$pkg_path")
        
        # Skip if in world
        case " $world_packages " in
            *" $pkg_name "*|" $pkg_path "*)
                continue
                ;;
        esac
        
        # Check if required
        if ! is_pkg_required "$pkg_path"; then
            warn "Orphan: $pkg_path"
        fi
    done
}

