done

# Suppress info() output in quiet mode
if [ "$QUIET_MODE" -eq 1 ]; then
    _original_info() { :; }
fi

if [ $# -lt 1 ]; then err "no operation specified (use -h or --help for help)"; exit 1; fi

# Determine if we should auto-check version based on command
case "$1" in
    -S|--Sync|-SA|--Sync-Asura|-C|--Compile|--Upgrade-All|-Re|--resume|-U|--self-update)
        # These commands should trigger version check
        ;;
    *)
        # Other commands - don't auto check unless --check-version was passed
        if [ "$AUTO_CHECK_VERSION" -eq 0 ]; then
            AUTO_CHECK_VERSION=-1  # Disable
        fi
        ;;
esac

if [ "$INSTALL_ROOT" != "/" ]; then
    INSTALL_ROOT="${INSTALL_ROOT%/}"
    info "Global: Installation root set to: $INSTALL_ROOT"
fi

acquire_lock "$LOCK_FILE" "$LOCK_TIMEOUT" || exit 1

# Only check version if explicitly requested or on install/upgrade commands
if [ "$AUTO_CHECK_VERSION" -eq 1 ]; then
    check_version_outdated &
fi
trap 'release_lock; exit' EXIT INT TERM
trap 'release_lock; exit' EXIT INT TERM
init_security_systems
ensure_default_config
ensure_default_virtuals
ensure_default_mask
ensure_config_perms
ensure_package_provided
parse_astral_stars_config
load_config
apply_tool_config
debug "config loaded: SAFETY_SIGNATURE_VERIFY=$SAFETY_SIGNATURE_VERIFY"

case "$1" in
-S|--Sync)
    [ $# -gt 1 ] || err "package name required"
    # Save and restore VISITED_PACKAGES so nested/parallel calls don't stomp state
    _vp_saved="$VISITED_PACKAGES"; _cs_saved="$DEP_CALL_STACK"
    VISITED_PACKAGES=""; DEP_CALL_STACK=""
    sync_pkg_recursive "$2" "$FORCE_BUILD" 1
    VISITED_PACKAGES="$_vp_saved"; DEP_CALL_STACK="$_cs_saved"
    FORCE_BUILD=0
    ;;
-C|--Compile)
    [ $# -gt 1 ] || err "package name required"
    _vp_saved="$VISITED_PACKAGES"; _cs_saved="$DEP_CALL_STACK"
    VISITED_PACKAGES=""; DEP_CALL_STACK=""
    build_from_recipe_enhanced "$2" "$FORCE_BUILD"
    VISITED_PACKAGES="$_vp_saved"; DEP_CALL_STACK="$_cs_saved"
    FORCE_BUILD=0
    ;;

-Re|--resume)
    [ $# -gt 1 ] || err "package name required"
    resume_build "$2"
    ;;

-SA|--Sync-Asura)
    [ $# -gt 1 ] || err "package name required"
    _vp_saved="$VISITED_PACKAGES"; _cs_saved="$DEP_CALL_STACK"
    VISITED_PACKAGES=""; DEP_CALL_STACK=""
    sync_pkg_asura "$2" "$FORCE_BUILD" 1 
    VISITED_PACKAGES="$_vp_saved"; DEP_CALL_STACK="$_cs_saved"
    FORCE_BUILD=0
    ;;

--Upgrade-All)
    upgrade_all 0 "$PRETEND_MODE"
    ;;

--hold)
    [ $# -gt 1 ] || err "package name required"
    hold_pkg "$2"
    ;;

--unhold)
    [ $# -gt 1 ] || err "package name required"
    unhold_pkg "$2"
    ;;

--list-held)
    list_held
    ;;

  -u|--Update)
    repo="${2:-}"
    if [ -n "$repo" ]; then
        shift 2
    else
        shift 1
    fi
    update_repo "$repo"
    ;;

  -s|--Search)
    [ $# -gt 1 ] || err "package name required"
    if [ "$JSON_OUTPUT" -eq 1 ]; then
        search_pkg_json "$2"
    else
        # §10 — Use enhanced search (fuzzy match + installed status + category filter)
        astral_search_enhanced "$2"
        search_pkg "$2"  # also run legacy local recipe search
    fi
    ;;

  -R|--Remove)
    [ $# -gt 1 ] || err "package name required"
    shift
    if [ $# -eq 1 ]; then
        remove_pkg "$1"
    else
        parallel_remove "$(nproc)" "$@"
    fi
    ;;

  -r|--RemoveDep)
    [ $# -gt 1 ] || err "package name required"
    shift
    if [ $# -eq 1 ]; then
        removedep_pkg "$1"
    else
        parallel_removedep "$(nproc)" "$@"
    fi
    ;;

  -Cc|--Clean-Cache)
    clean_cache
    ;;

  -U|--self-update)
    self_update "${2:-main}"
    ;;

  --info|-I)
    [ $# -gt 1 ] || err "package name required"
    if [ "$JSON_OUTPUT" -eq 1 ]; then
        show_pkg_info_json "$2"
    else
        show_pkg_info "$2"
    fi
    ;;

  --inspect|-Ins)
    [ $# -gt 1 ] || err "package name required"
    r=$(recipe_path "$2") || err "recipe not found for $2"
    info "--- Files in Recipe Directory: $r ---"
    if [ -d "$r" ]; then
      ls -la "$r"
      [ -f "$r/info" ] && { info "\n--- PACKAGE INFO ($2) ---\n"; cat "$r/info"; }
      [ -f "$r/build" ] && { info "\n--- BUILD SCRIPT HEAD ($2) ---\n"; sed -n '1,20p' "$r/build"; }
    else
      info "--- Single Recipe File Content ($2) ---\n"
      sed -n '1,20p' "$r"
    fi
    ;;

  --list-installed|-ll|ls)
    list_installed
    ;;
-D|--Deps)
    [ $# -gt 1 ] || err "package name required"
    show_deps "$2"
    ;;

-Dc|--DepCheck)
    check_system_deps
    ;;

--config)
    info "=== Astral Configuration ==="
    
    # Show make.conf variables
    info "--- make.conf ---"
    printf "Config File:      %s\n" "$CONFIG_FILE"
    printf "USE_FLAGS:        %s\n" "$USE_FLAGS"
    printf "CFLAGS:           %s\n" "$CFLAGS"
    printf "MAKEFLAGS:        %s\n" "$MAKEFLAGS"
    printf "CCACHE_ENABLED:   %s\n" "$CCACHE_ENABLED"
    printf "FEATURES:         %s\n" "$FEATURES"
    
    # Load and show astral.stars configuration
    info "--- astral.stars ($ASTRAL_CONFIG) ---"
    if [ -f "$ASTRAL_CONFIG" ]; then
        parse_astral_stars_config "$ASTRAL_CONFIG"
        printf "Config File:      %s\n" "$ASTRAL_CONFIG"
        printf "Recipes Dir:     %s\n" "$RECIPES_DIR"
        printf "DB Dir:          %s\n" "$DB_DIR"
        printf "Cache Dir:       %s\n" "$CACHE_SRC"
        printf "Install Root:    %s\n" "$INSTALL_ROOT"
        printf "Editor:          %s\n" "$EDITOR"
    else
        printf "Config File:      %s (not found)\n" "$ASTRAL_CONFIG"
    fi
    ;;

  -V|--Version)
    astral_version
    ;;

  --https://www.youtube.com/watch?v=2EDcoWKH25o)
    echo "Flash Me Back - Camemellia. Peak btw"
    ;;

  --727|--whenyouseeit|--whenyoufuckingseeit|-WYSI|-WYFSI|--Arieu|--arieu)
    echo "727 WYSI WYFSI 727 WYFSI WYFSI"
    ;;

--rebuild-index|-RI)
    rebuild_files_index
    ;;

    -v|--verbose)
    VERBOSE=1
    export VERBOSE
    shift
    ;;

--show-env|-SE)
    info "=== Build Environment ==="
    printf "CFLAGS:   %s\n" "$CFLAGS"
    printf "CXXFLAGS: %s\n" "$CXXFLAGS"
    printf "LDFLAGS:  %s\n" "$LDFLAGS"
    printf "MAKEFLAGS: %s\n" "$MAKEFLAGS"
    ;;

--preview|-p)
    [ $# -gt 1 ] || err "package name required"
    pkg=$(sanitize_pkg_name "$2")
    preview_install "$pkg"
    ;;

--why|-w)
    [ $# -gt 1 ] || err "package name required"
    pkg=$(sanitize_pkg_name "$2")
    show_why_installed "$pkg"
    ;;

--world|-W)
    list_world
    ;;

--autoremove|--depclean)
    autoremove_orphans
    ;;

--list-virtuals)
    info "=== Virtual Packages ==="
    for virt in "$VIRTUALS_DIR"/*; do
        [ -f "$virt" ] || continue
        virt_name=$(basename "$virt")
        info "virtual/$virt_name:"
        grep -v '^#' "$virt" | grep -v '^[[:space:]]*$' | while IFS= read -r provider; do
            if is_pkg_installed "$provider" || check_host_dependency "$provider"; then
                info "  ✓ $provider"
            else
                info "  ✗ $provider"
            fi
        done
    done
    ;;

--mask)
    [ $# -gt 1 ] || err "package spec required (pkg or pkg >= ver)"
    shift
    echo "$*" >> "$MASK_FILE"
    info "Masked: $*"
    ;;

 --host-check)
     [ $# -gt 1 ] || err "package name required"
     test_host_dependency "$2"
     exit 0
     ;;

 --host-deps)
     show_host_deps
     exit 0
     ;;

--unmask)
    [ $# -gt 1 ] || err "package name required"
    pkg="$2"
    temp=$(mktemp)
    grep -v "^$pkg" "$MASK_FILE" > "$temp" 2>/dev/null || true
    mv "$temp" "$MASK_FILE"
    info "Unmasked: $pkg"
    ;;
 --ccache-stats)
     show_ccache_stats
     ;;
 --ccache-clear)
     clear_ccache
     ;;

  -h|--horizon)
    case "${2:-}" in
        --init)
            horizon_init
            ;;
        --stage)
            [ $# -lt 3 ] && err "Usage: astral -h --stage <1|2|3>"
            stage="$3"
            case "$stage" in
                1|2|3)
                    horizon_run_stage "$stage"
                    ;;
                *)
                    err "Invalid stage: $stage (valid: 1, 2, 3)"
                    ;;
            esac
            ;;
        --status)
            horizon_status
            ;;
        --info)
            [ $# -lt 3 ] && err "Usage: astral -h --info <1|2|3>"
            stage="$3"
            horizon_stage_info "$stage"
            ;;
        --clean)
            horizon_clean
            ;;
        -h|-help|--h|--help|-HELP|--HELP|HELP|usage|Usage|USAGE)
            cat <<HORIZON_HELP
╔════════════════════════════════════════════════════════════════╗
║                    HORIZON BOOTSTRAP                           ║
║              Astaraxia Linux From Scratch                      ║
╚════════════════════════════════════════════════════════════════╝

Horizon is an LFS-style bootstrap system for building Astaraxia
from source. It follows a 3-stage process similar to Gentoo stages
and Linux From Scratch.

Usage:
  astral -h --init              Initialize Horizon (download stages)
  astral -h --stage <N>         Run stage N (1, 2, or 3)
  astral -h --info <N>          Show stage N information
  astral -h --status            Show current build status
  astral -h --clean             Clean all Horizon state

Stages:
  Stage 1: Temporary Toolchain   (~2-4 hours)
           Cross-compilation toolchain in \$LFS/tools
           
  Stage 2: Chroot Preparation    (~3-5 hours)
           Additional tools and chroot environment
           
  Stage 3: Final System          (~6-10 hours)
           Complete bootable Astaraxia system

Prerequisites:
  1. Set LFS variable: export LFS=/mnt/lfs
  2. Create LFS directory: sudo mkdir -pv \$LFS
  3. Mount if needed: sudo mount /dev/sdX \$LFS

Example workflow:
  export LFS=/mnt/lfs
  sudo mkdir -pv \$LFS
  sudo astral -h --init
  sudo astral -h --stage 1
  sudo astral -h --stage 2
  sudo astral --chroot \$LFS
  astral -h --stage 3

Repository: https://github.com/Astaraxia-Linux/Horizon
Documentation: https://astaraxia.org/horizon (hopefully)
HORIZON_HELP
            ;;

        *|-*|--*)
            err "Unknown command or option '$1'" >&2
            exit 1
        ;;
    esac
    ;;

    -h|-help|--h|--help|-HELP|--HELP|HELP|usage|Usage|USAGE)
    usage
    exit 1
    ;;

    --init-sys)
    detect_init_system
    exit 1
    ;;

    --off|--disable-safety)
    [ $# -gt 1 ] || err "safety feature name required"
    disable_safety_feature "$2"
    ;;

--safety-status|--list-safety)
    list_safety_features
    ;;

--test|--testsuite)
    mode="${2:-all}"
    run_testsuite "$mode"
    exit $?
    ;;

start|stop|restart|enable|disable|status)
    [ $# -gt 1 ] || err "service name required"
    init_system=$(detect_init_system)
    info "Using init system: $init_system"
    service_action "$1" "$2"
    ;;

--count|--pkg-count)
    repo="${2:-all}"
    count_packages "$repo"
    ;;

--use|--use-flags)
