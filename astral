# §8.3 — Portable file size (GNU stat / BSD stat / wc -c fallback)
file_size_bytes() {
    _f="$1"
    _s=$(stat -c%s "$_f" 2>/dev/null) && { printf '%s' "$_s"; return 0; }
    _s=$(stat -f%z "$_f" 2>/dev/null) && { printf '%s' "$_s"; return 0; }
    wc -c < "$_f" 2>/dev/null | tr -d ' '
}

setup_logging() {
    mkdir -p "$(dirname "$LOG_FILE")" "$(dirname "$LOG_SYNC_FILE")" "$(dirname "$LOG_BUILD_FILE")" 2>/dev/null || true
    
    # Rotate logs if too large (>10MB)
    for logfile in "$LOG_FILE" "$LOG_SYNC_FILE" "$LOG_BUILD_FILE"; do
        if [ -f "$logfile" ] && [ "$(file_size_bytes "$logfile")" -gt 10485760 ]; then
            mv "$logfile" "${logfile}.old" 2>/dev/null || true
            info "Rotated log: $logfile"
        fi
    done
}

log_msg() {
    level="$1"
    shift
    message="$*"
    timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    
    [ "$LOG_ENABLE" -eq 0 ] && return 0
    
    # Determine log file based on context
    current_log="$LOG_FILE"
    case "${ASTRAL_CONTEXT:-general}" in
        sync) current_log="$LOG_SYNC_FILE" ;;
        build) current_log="$LOG_BUILD_FILE" ;;
    esac
    
    # Use subshell to prevent set -e from catching redirection failures
    ( printf '[%s] [%s] %s\n' "$timestamp" "$level" "$message" >> "$current_log" ) 2>/dev/null || true
}


