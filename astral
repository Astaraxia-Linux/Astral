FILES_INDEX="$DB_DIR/.files.index"

rebuild_files_index() {
    info "Rebuilding file ownership index..."
    rm -f "$FILES_INDEX"
    touch "$FILES_INDEX"

    for pkgdir in "$DB_DIR"/*/* "$DB_DIR"/*; do
        [ -d "$pkgdir" ] || continue
        [ -f "$pkgdir/files" ] || continue

        pkg_path=$(printf '%s' "$pkgdir" | sed "s|^${DB_DIR}/||")

        while IFS= read -r file; do
            [ -z "$file" ] && continue
            # Format: filename|package_path
            printf '%s|%s\n' "$file" "$pkg_path" >> "$FILES_INDEX"
        done < "$pkgdir/files"
    done

    # Sort for faster lookups
    sort -u "$FILES_INDEX" -o "$FILES_INDEX"
    info "File index rebuilt ($(wc -l < "$FILES_INDEX") entries)"
}

# === INDEXED DATABASE SYSTEM ===
PKG_INDEX_DB="$DB_DIR/.index.db"
DEP_INDEX_DB="$DB_DIR/.deps.db"

rebuild_package_index() {
    info "Rebuilding indexed package database..."
    
    temp_pkg_idx="$TMPDIR/pkg-index-$$"
    temp_dep_idx="$TMPDIR/dep-index-$$"
    
    > "$temp_pkg_idx"
    > "$temp_dep_idx"
    
    # Index format: pkg_name|version|category|installed_size|install_date
    for pkgdir in "$DB_DIR"/*/* "$DB_DIR"/*; do
        [ -d "$pkgdir" ] || continue
        [ -f "$pkgdir/version" ] || continue
        
        pkg_path=$(printf '%s' "$pkgdir" | sed "s|^${DB_DIR}/||")
        pkg_name=$(basename "$pkg_path")
        category=$(dirname "$pkg_path")
        version=$(cat "$pkgdir/version" 2>/dev/null || echo "unknown")
        
        # Calculate installed size
        size=0
        if [ -f "$pkgdir/files" ]; then
            while IFS= read -r file; do
                [ -f "$INSTALL_ROOT/$file" ] && size=$((size + $(stat -c%s "$INSTALL_ROOT/$file" 2>/dev/null || echo 0)))
            done < "$pkgdir/files"
        fi
        
        install_date=$(stat -c%Y "$pkgdir/version" 2>/dev/null || echo 0)
        
        printf '%s|%s|%s|%d|%d\n' "$pkg_name" "$version" "$category" "$size" "$install_date" >> "$temp_pkg_idx"
        
        # Index dependencies
        for dep_file in depends bdepends rdepends; do
            [ -f "$pkgdir/$dep_file" ] || continue
            
            dep_type=$(printf '%s' "$dep_file" | sed 's/depends//')
            [ -z "$dep_type" ] && dep_type="runtime"
            
            while IFS= read -r dep; do
                dep=$(printf '%s' "$dep" | awk '{print $1}')
                [ -z "$dep" ] && continue
                
                printf '%s|%s|%s\n' "$pkg_name" "$dep" "$dep_type" >> "$temp_dep_idx"
            done < "$pkgdir/$dep_file"
        done
    done
    
    # Sort and install
    sort -t'|' -k1,1 "$temp_pkg_idx" > "$PKG_INDEX_DB"
    sort -t'|' -k1,1 "$temp_dep_idx" > "$DEP_INDEX_DB"
    
    rm -f "$temp_pkg_idx" "$temp_dep_idx"
    
    pkg_count=$(wc -l < "$PKG_INDEX_DB")
    dep_count=$(wc -l < "$DEP_INDEX_DB")
    
    info "✓ Indexed $pkg_count packages and $dep_count dependencies"
}

query_package_index() {
    pkg="$1"
    
    [ ! -f "$PKG_INDEX_DB" ] && { warn "Package index not found, run: astral --rebuild-index"; return 1; }
    
    awk -F'|' -v pkg="$pkg" '$1 == pkg' "$PKG_INDEX_DB"
}

query_dependencies_index() {
    pkg="$1"
    
    [ ! -f "$DEP_INDEX_DB" ] && { warn "Dependency index not found"; return 1; }
    
    awk -F'|' -v pkg="$pkg" '$1 == pkg {print $2}' "$DEP_INDEX_DB" | sort -u
}

query_reverse_dependencies() {
    pkg="$1"
    
    [ ! -f "$DEP_INDEX_DB" ] && return 1
    
    awk -F'|' -v dep="$pkg" '$2 == dep {print $1}' "$DEP_INDEX_DB" | sort -u
}

get_file_owner() {
    file="$1"
    file_normalized=$(printf '%s' "$file" | sed 's|^/||')

    # Fast path: use index if it exists
    if [ -f "$FILES_INDEX" ]; then
        result=$(awk -F'|' -v f="$file_normalized" '$1 == f {print $2; exit}' "$FILES_INDEX" 2>/dev/null)
        if [ -n "$result" ] && [ "$result" != "" ]; then
            printf '%s' "$result"
            return 0
        fi
        return 1
    fi

    # Fallback: slow path (warns to rebuild index)
    warn "File index missing - using slow lookup. Run: astral --rebuild-index"

    for pkgdir in "$DB_DIR"/*/* "$DB_DIR"/*; do
        [ -d "$pkgdir" ] || continue
        [ -f "$pkgdir/files" ] || continue

        if grep -qxF "$file_normalized" "$pkgdir/files" 2>/dev/null; then
            pkg_path=$(printf '%s' "$pkgdir" | sed "s|^${DB_DIR}/||")
            printf '%s' "$pkg_path"
            return 0
        fi
    done

    return 1
}

update_files_index_for_pkg() {
    pkg_path="$1"

    [ ! -f "$FILES_INDEX" ] && return 0

    # Simple lock with timeout
    lock_dir="$FILES_INDEX.lock"
    max_wait=30
    wait_count=0

    while ! mkdir "$lock_dir" 2>/dev/null; do
        if [ $wait_count -ge $max_wait ]; then
            warn "Timeout waiting for file index lock, skipping update"
            return 1
        fi
        sleep 0.2
        wait_count=$((wait_count + 1))
    done

    # Remove old entries for this package
    temp=$(mktemp)
    grep -v "|${pkg_path}$" "$FILES_INDEX" > "$temp" 2>/dev/null || true
    mv "$temp" "$FILES_INDEX"

    # Add new entries
    pkgdir="$DB_DIR/$pkg_path"
    if [ -f "$pkgdir/files" ]; then
        while IFS= read -r file; do
            [ -z "$file" ] && continue
            printf '%s|%s\n' "$file" "$pkg_path" >> "$FILES_INDEX"
        done < "$pkgdir/files"
    fi

    # Release lock (always runs)
    rmdir "$lock_dir" 2>/dev/null || true
}

upgrade_all() {
    FORCE_CMD=${1:-0}  # 0 if not passed
    PRETEND=${2:-0}   # 0 = actually upgrade, 1 = pretend
    
    if [ "$PRETEND" -eq 1 ] || [ "$PRETEND_MODE" -eq 1 ]; then
        info "╭────────────────────────────────────────────────────────────────╮"
        info "│              PRETEND MODE - NO CHANGES WILL BE MADE            │"
        info "╰────────────────────────────────────────────────────────────────╯"
        info ""
    fi
    
    info "Starting full system upgrade (syncing all installed packages)..."

    count=0
    success_count=0
    upgradable_count=0
    held_count=0

    # Create holds file if it doesn't exist
    touch "$HOLDS_FILE" 2>/dev/null || true

    # §8.1 — Avoid pipe subshell: count vars inside a pipe-fed while-loop are
    # invisible after the loop on dash/ash. Write pkg list to a temp file first.
    _upgrade_tmpf="$TMPDIR/astral-upgrade-list-$$"
    find "$DB_DIR" -type f -name "version" -maxdepth 3 2>/dev/null |
        sed "s|^${DB_DIR}/||" | sed 's|/version$||' > "$_upgrade_tmpf"

    while IFS= read -r pkg_path; do
        pkg=$(basename "$pkg_path")
        category=$(dirname "$pkg_path")
        
        # Check if package is held
        if grep -qE "^${pkg}$|^${category}/${pkg}$" "$HOLDS_FILE" 2>/dev/null; then
            if [ "$PRETEND" -eq 1 ] || [ "$PRETEND_MODE" -eq 1 ]; then
                info "[HELD] $pkg (held, will not upgrade)"
            fi
            held_count=$((held_count + 1))
            continue
        fi
        
        if [ "$PRETEND" -eq 1 ] || [ "$PRETEND_MODE" -eq 1 ]; then
            # Pretend mode - just check if upgrade is available
            info "[WOULD UPGRADE] Checking $pkg..."
            
            # Try to get recipe version
            recipe_ver=""
            r=$(recipe_path "$pkg" 2>/dev/null) && {
                [ -f "$r/version" ] && recipe_ver=$(cat "$r/version" 2>/dev/null)
            }
            
            installed_ver=$(get_installed_ver "$pkg")
            
            if [ -n "$recipe_ver" ] && [ "$installed_ver" != "none" ]; then
                if [ "$recipe_ver" != "$installed_ver" ]; then
                    info "  >>> $pkg: $installed_ver -> $recipe_ver [UPGRADE]"
                    upgradable_count=$((upgradable_count + 1))
                else
                    info "  === $pkg: $installed_ver [UP-TO-DATE]"
                fi
            else
                info "  ??? $pkg: unable to determine recipe version"
            fi
        else
            info "\n>>> Checking $pkg_path <<<"
            if sync_pkg_recursive "$pkg" "$FORCE_CMD"; then
                success_count=$((success_count + 1))
            else
                info "Warning: Failed to sync $pkg_path. Check logs."
            fi
        fi
        count=$((count + 1))
    done < "$_upgrade_tmpf"
    rm -f "$_upgrade_tmpf"

    if [ "$PRETEND" -eq 1 ] || [ "$PRETEND_MODE" -eq 1 ]; then
        info ""
        info "╭────────────────────────────────────────────────────────────────╮"
        info "│                      PRETEND SUMMARY                           │"
        info "├────────────────────────────────────────────────────────────────┤"
        info "│  Total packages:     $count"
        info "│  Upgradable:         $upgradable_count"
        info "│  Held (skipped):    $held_count"
        info "│  Up-to-date:        $((count - upgradable_count - held_count))"
        info "╰────────────────────────────────────────────────────────────────╯"
    else
        info "\nUpgrade process finished. Checked $count installed packages. $success_count updated/verified."
    fi
}

# === PACKAGE HOLD SYSTEM ===
hold_pkg() {
    pkg="$1"
    
    [ -z "$pkg" ] && err "package name required"
    
    # Create holds file if it doesn't exist
    touch "$HOLDS_FILE" 2>/dev/null || err "Cannot create holds file"
    
    # Check if already held
    if grep -qE "^${pkg}$|^.*/${pkg}$" "$HOLDS_FILE" 2>/dev/null; then
        warn "Package $pkg is already held"
        return 0
    fi
    
    # Verify package is installed
    if ! is_pkg_installed "$pkg"; then
        err "Package $pkg is not installed"
    fi
    
    echo "$pkg" >> "$HOLDS_FILE"
    info "Package $pkg is now held (will not be upgraded automatically)"
}

unhold_pkg() {
    pkg="$1"
    
    [ -z "$pkg" ] && err "package name required"
    
    # Create holds file if it doesn't exist
    touch "$HOLDS_FILE" 2>/dev/null || true
    
    # Check if package is held
    if ! grep -qE "^${pkg}$|^.*/${pkg}$" "$HOLDS_FILE" 2>/dev/null; then
        warn "Package $pkg is not held"
        return 0
    fi
    
    # Remove from holds file
    grep -vE "^${pkg}$|^.*/${pkg}$" "$HOLDS_FILE" > "$HOLDS_FILE.tmp" 2>/dev/null
    mv "$HOLDS_FILE.tmp" "$HOLDS_FILE"
    
    info "Package $pkg is no longer held"
}

list_held() {
    if [ ! -f "$HOLDS_FILE" ]; then
        info "No held packages"
        return 0
    fi
    
    if [ ! -s "$HOLDS_FILE" ]; then
        info "No held packages"
        return 0
    fi
    
    info "╭────────────────────────────────────────────────────────────────╮"
    info "│                     Held Packages                               │"
    info "├────────────────────────────────────────────────────────────────┤"
    while IFS= read -r pkg; do
        [ -z "$pkg" ] && continue
        printf "│  %-60s│\n" "$pkg"
    done < "$HOLDS_FILE"
    info "╰────────────────────────────────────────────────────────────────╯"
}

self_update() {
    TMPDIR="${TMPDIR:-/tmp}"
    tmp_file=$(mktemp "$TMPDIR/astral-new.XXXXXX") || err "mktemp failed"
    trap 'rm -f "$tmp_file"' EXIT

    branch="${1:-main}"
    case "$branch" in
        main)
            update_url="$SELF_UPDATE_URL_MAIN"
            info "Starting astral self-update from 'main' branch ($update_url)..."
        ;;
        cutting-edge)
            update_url="$SELF_UPDATE_URL_CUTTING_EDGE"
            info "Starting astral self-update from 'cutting-edge' branch ($update_url)..."
        ;;
        bleeding-edge)
            update_url="$SELF_UPDATE_URL_BLEEDING_EDGE"
            info "Starting astral self-update from 'bleeding-edge' branch ($update_url)..."
        ;;
        *)
            err "Unknown update branch '$branch'";
            return 1
        ;;
    esac

    command -v curl >/dev/null 2>&1 || { err "curl not found"; return 1; }

    if ! curl -f#SL "$update_url" -o "$tmp_file"; then
        err "Failed to download new astral script from $update_url"; return 1
    fi

    if ! head -n 1 "$tmp_file" | grep -qE '^#!'; then
        err "Downloaded file invalid (missing shebang)"; return 1
    fi

    chmod +x "$tmp_file"
    if mv -f "$tmp_file" "$SELF_UPDATE_PATH"; then
        chmod 775 "$SELF_UPDATE_PATH"
        info "Self-update successful!"
        trap - EXIT
    else
        err "Failed to replace $SELF_UPDATE_PATH"
        return 1
    fi
}

# === VERSION CHECK SYSTEM ===
check_version_outdated() {
    remote_url="${1:-$SELF_UPDATE_URL_MAIN}"
    
    temp_remote="$TMPDIR/astral-remote-version-$$"
    
    if ! curl -fsSL "$remote_url" -o "$temp_remote" 2>/dev/null; then
        debug "Failed to fetch remote version"
        return 1
    fi
    
    remote_version=$(grep '^version=' "$temp_remote" | head -n1 | sed 's/version="\(.*\)"/\1/')
    remote_lines=$(wc -l < "$temp_remote" 2>/dev/null || echo "0")
    local_lines=$(wc -l < "$SCRIPT_PATH" 2>/dev/null || echo "0")
    rm -f "$temp_remote"
    
    if [ -z "$remote_version" ]; then
        debug "Could not parse remote version"
        return 1
    fi
    
    current_version="$version"
    
    # Parse version numbers for comparison
    current_major=$(printf '%s' "$current_version" | cut -d'.' -f1)
    current_minor=$(printf '%s' "$current_version" | cut -d'.' -f2)
    remote_major=$(printf '%s' "$remote_version" | cut -d'.' -f1)
    remote_minor=$(printf '%s' "$remote_version" | cut -d'.' -f2)
    
    # Check if local version is higher than remote (dev version detection)
    if [ "$current_major" -gt "$remote_major" ] 2>/dev/null; then
        info "╭────────────────────────────────────────────────────────────────╮"
        info "│                  DEVELOPMENT VERSION DETECTED                  │"
        info "├────────────────────────────────────────────────────────────────┤"
        info "│  Local version:  $current_version (dev)"
        info "│  Remote version: $remote_version (stable)"
        info "│  Local lines:    $local_lines"
        info "│  Remote lines:   $remote_lines"
        info "│                                                                │"
        info "│  You are running a development version.                        │"
        info "╰────────────────────────────────────────────────────────────────╯"
        return 1
    fi
    
    if [ "$current_major" -eq "$remote_major" ] && [ "$current_minor" -gt "$remote_minor" ] 2>/dev/null; then
        info "╭────────────────────────────────────────────────────────────────╮"
        info "│                  DEVELOPMENT VERSION DETECTED                  │"
        info "├────────────────────────────────────────────────────────────────┤"
        info "│  Local version:  $current_version (dev)"
        info "│  Remote version: $remote_version (stable)"
        info "│  Local lines:    $local_lines"
        info "│  Remote lines:   $remote_lines"
        info "│                                                                │"
        info "│  You are running a development version.                        │"
        info "╰────────────────────────────────────────────────────────────────╯"
        return 1
    fi
    
    # Check if local has more lines of code (another dev indicator)
    if [ "$local_lines" -gt "$remote_lines" ] && [ "$remote_lines" -gt 0 ]; then
        info "╭────────────────────────────────────────────────────────────────╮"
        info "│                  DEVELOPMENT VERSION DETECTED                  │"
        info "├────────────────────────────────────────────────────────────────┤"
        info "│  Local version:  $current_version"
        info "│  Remote version: $remote_version"
        info "│  Local lines:    $local_lines (more code)"
        info "│  Remote lines:   $remote_lines"
        info "│                                                                │"
        info "│  You appear to be running a development version.               │"
        info "╰────────────────────────────────────────────────────────────────╯"
        return 1
    fi
    
    if [ "$current_version" != "$remote_version" ]; then
        warn "╭────────────────────────────────────────────────────────────────╮"
        warn "│                  ASTRAL UPDATE AVAILABLE                       │"
        warn "├────────────────────────────────────────────────────────────────┤"
        warn "│  Current version: $current_version"
        warn "│  Latest version:  $remote_version"
        warn "│                                                                │"
        warn "│  Update with: astral --self-update                             │"
        warn "╰────────────────────────────────────────────────────────────────╯"
        return 0
    fi
    
    return 1
}

# --- SAFE REMOVAL HELPERS ---

remove_pkg_only() {
    pkg_path="$1"
    pkgdir="$DB_DIR/$pkg_path"
    [ -d "$pkgdir" ] || return 0

    info "Removing package database entry: $pkg_path"

    rpath=$(recipe_path "$(basename "$pkg_path")") 2>/dev/null || rpath=""

    # §9 — Correct hook order: pre_remove → remove files → remove DB → post_remove
    # post_remove must only run AFTER files and DB entry are gone.
    # Previously post_remove ran before file removal, which was wrong.

    # 1. pre_remove: called BEFORE any files are touched (service stop, config backup, etc.)
    if [ -n "$rpath" ] && [ -f "$rpath/pre_remove" ]; then
        info "Running pre_remove hook for $(basename "$pkg_path")..."
        ( "$rpath/pre_remove" ) || warn "pre_remove hook failed for $pkg_path (continuing)"
    fi

    # 2. Remove tracked files (only files and symlinks, never directories)
    _removal_ok=0
    if [ -f "$pkgdir/files" ]; then
        while IFS= read -r f; do
            [ -z "$f" ] && continue
            fullpath="$INSTALL_ROOT/$f"

            # Only remove files and symlinks, NEVER directories
            if [ -f "$fullpath" ] || [ -L "$fullpath" ]; then
                rm -f "$fullpath" 2>/dev/null || warn "Failed to remove: $fullpath"
            fi
            # Explicitly skip directories to avoid removing shared dirs like /usr/bin
            # *flashback of astral v0.1.0.0 removing my LFS /usr*
        done < "$pkgdir/files"
        _removal_ok=1
    fi

    # 3. Remove DB entry
    rm -rf "$pkgdir"
    info "Removed $pkg_path from database (directories preserved for safety)."

    # 4. post_remove: called AFTER files and DB are gone, and only if removal succeeded
    if [ "$_removal_ok" -eq 1 ] && [ -n "$rpath" ] && [ -f "$rpath/post_remove" ]; then
        info "Running post_remove hook for $(basename "$pkg_path")..."
        ( "$rpath/post_remove" ) || warn "post_remove hook failed for $pkg_path"
    fi
}

removedep_pkg() {
    pkg="$1"
    initial_pkg_path=$(resolve_installed_path "$pkg") || err "package $pkg not installed"

    # Capture declared dependencies
    declared_deps=$(get_pkg_deps "$initial_pkg_path" || true)

    # Remove initial package
    remove_pkg_only "$initial_pkg_path"

    # Process dependencies with queue to avoid nested loops
    if [ -n "$declared_deps" ]; then
        dep_queue="$declared_deps"
        processed=""

        while [ -n "$dep_queue" ]; do
            # Get first dep from queue
            current_dep=$(printf '%s\n' "$dep_queue" | head -n1)
            dep_queue=$(printf '%s\n' "$dep_queue" | tail -n +2)

            current_dep=$(printf '%s' "$current_dep" | tr -d '[:space:]')
            [ -z "$current_dep" ] && continue

            # Skip if already processed
            case " $processed " in
                *" $current_dep "*) continue ;;
            esac
            processed="$processed $current_dep"

            # Check if host provides it
            if check_host_dependency "$current_dep"; then
                info "Dependency '$current_dep' provided by host; not removing."
                continue
            fi

            dep_path=$(resolve_installed_path "$current_dep") 2>/dev/null || continue

            if ! is_pkg_required "$dep_path"; then
                info "Removing orphan dependency: $dep_path"

                # Get subdeps before removal
                subdeps=$(get_pkg_deps "$dep_path" 2>/dev/null || true)

                # Bug fix: check removal succeeded before queuing subdeps
                if remove_pkg_only "$dep_path"; then
                    if [ -n "$subdeps" ]; then
                        dep_queue="$dep_queue $subdeps"
                    fi
                else
                    warn "Failed to remove orphan $dep_path — skipping its subdeps"
                fi
            else
                info "Keeping dependency $dep_path (still required)."
            fi
        done
    fi

    info "Orphan dependency cleanup complete."
}

remove_pkg() {
    requested_pkg="$1"
    pkg_path=$(resolve_installed_path "$requested_pkg") || err "package $requested_pkg not installed"
    remove_pkg_only "$pkg_path"
}

clean_cache() {
    info "Starting recipe cache cleanup in $RECIPES_DIR..."

    # Clean up directory-based recipes (legacy format)
    find "$RECIPES_DIR" -type d -mindepth 2 -maxdepth 2 2>/dev/null | while IFS= read -r recipe_dir; do
        pkg_name=$(basename "$recipe_dir")
        if is_pkg_installed "$pkg_name"; then
            info "Recipe for '$pkg_name' is installed. Skipping."
        else
            info "Removing cached recipe for '$pkg_name'..."
            rm -rf "$recipe_dir"
        fi
    done

    # Clean up .stars files that are not installed
    find "$RECIPES_DIR" -type f -name '*.stars' 2>/dev/null | while IFS= read -r stars_file; do
        # Extract package name from filename (POSIX-compliant way)
        stars_basename=$(basename "$stars_file")
        stars_basename=${stars_basename%.stars}
        pkg_name=$(printf '%s\n' "$stars_basename" | sed 's/-[0-9].*//')
        if is_pkg_installed "$pkg_name"; then
            info "Recipe for '$pkg_name' is installed. Skipping."
        else
            info "Removing cached .stars recipe for '$pkg_name'..."
            rm -f "$stars_file"
        fi
    done

    info "Cache cleanup complete."
}

list_installed() {
    # JSON output support
    if [ "$JSON_OUTPUT" -eq 1 ]; then
        _list_installed_json
        return
    fi
    
    if [ ! -d "$DB_DIR" ] || [ -z "$(ls -A "$DB_DIR" 2>/dev/null)" ]; then
        info "No packages currently installed."
        return 0
    fi
    
    info "╭────────────────────╮"
    info "│ Installed Packages │"
    info "╰────────────────────╯"
    info ""
    
    # Group packages by category
    temp_list="$TMPDIR/astral-list-$$"
    find "$DB_DIR" -type f -name "version" -maxdepth 3 2>/dev/null |
    sed "s|^${DB_DIR}/||" | sed 's|/version$||' | sort > "$temp_list"
    
    # Get unique categories
    categories=$(cut -d'/' -f1 "$temp_list" | sort -u)
    
    for category in $categories; do
        # Handle root-level packages
        if [ "$category" = "." ] || [ -z "$category" ]; then
            category="Uncategorized"
        fi
        
        # Get packages in this category
        if [ "$category" = "Uncategorized" ]; then
            pkgs=$(grep -v '/' "$temp_list" || true)
        else
            pkgs=$(grep "^${category}/" "$temp_list" || true)
        fi
        
        [ -z "$pkgs" ] && continue
        
        pkg_count=$(printf '%s\n' "$pkgs" | wc -l)
        
        # Category header
        printf "${BLUE}╭ %s (%s packages)${NC}\n" "$category" "$pkg_count"
        
        current=0
        printf '%s\n' "$pkgs" | while IFS= read -r pkg_path; do
            current=$((current + 1))
            # Show full category/pkg format instead of just package name
            pkg_full="$pkg_path"
            pkg_ver=$(cat "$DB_DIR/$pkg_path/version" 2>/dev/null || echo "unknown")
            
            # Determine if last package in category
            if [ $current -eq $pkg_count ]; then
                printf "${GREEN}└──${NC} %-40s ${YELLOW}v%s${NC}\n" "$pkg_full" "$pkg_ver"
            else
                printf "${GREEN}├──${NC} %-40s ${YELLOW}v%s${NC}\n" "$pkg_full" "$pkg_ver"
            fi
        done
        printf "\n"
    done
    
    rm -f "$temp_list"
    
    total=$(find "$DB_DIR" -type f -name "version" -maxdepth 3 2>/dev/null | wc -l)
    info "╭─╮"
    info "╰─┴─ Total: $total packages installed"
}

check_deps_tree() {
    pkg="$1"
    prefix="${2:-}"
    visited="${3:-}"

    is_visited=0
    for v in $visited; do
        [ "$v" = "$pkg" ] && is_visited=1 && break
    done

    if [ $is_visited -eq 1 ]; then
        printf '%s%s [CIRCULAR]\n' "$prefix" "$pkg"
        return 0
    fi

    visited="$visited $pkg"

    if is_pkg_installed "$pkg"; then
        installed_ver=$(get_installed_ver "$pkg")
        printf '%s%s [installed: v%s]\n' "$prefix" "$pkg" "$installed_ver"
    else
        if check_host_dependency "$pkg"; then
            printf '%s%s [host-provided]\n' "$prefix" "$pkg"
            return 0
        fi

        if recipe_path "$pkg" >/dev/null 2>&1; then
            rpath=$(recipe_path "$pkg")
            recipe_ver=$(cat "$rpath/version" 2>/dev/null || echo "unknown")
            printf '%s%s [available: v%s]\n' "$prefix" "$pkg" "$recipe_ver"
        else
            printf '%s%s [NOT FOUND!]\n' "$prefix" "$pkg"
            return 0
        fi
    fi

    deps=$(get_pkg_deps "$1" || true)
    [ -z "$deps" ] && return 0

    printf '%s\n' "$deps" | while IFS= read -r dep; do
        dep=$(printf '%s' "$dep" | tr -d '[:space:]')
        [ -z "$dep" ] && continue
        check_deps_tree "$dep" "$prefix  ├─ " "$visited"
    done
}

preview_install() {
    pkg="$1"

    info "=== Install Preview for '$pkg' ==="
    info "Computing dependency graph..."

    # Collect all dependencies recursively
    all_deps=""
    to_install=""
    already_installed=""

    # Make this a proper recursive function
    collect_deps_recursive() {
        local p="$1"
        local indent="${2:-}"

        # Check if already processed
        case " $all_deps " in
            *" $p "*) return 0 ;;
        esac

        all_deps="$all_deps $p"

        # Check install status
        if is_pkg_installed "$p"; then
            ver=$(get_installed_ver "$p")
            printf '%s[installed] %s-%s\n' "$indent" "$p" "$ver"
            already_installed="$already_installed $p"
        elif check_host_dependency "$p"; then
            printf '%s[host] %s\n' "$indent" "$p"
        else
            printf '%s[new] %s\n' "$indent" "$p"
            to_install="$to_install $p"
        fi

        # Get dependencies
        deps=$(get_pkg_deps "$p" 2>/dev/null || true)
        if [ -n "$deps" ]; then
            printf '%s\n' "$deps" | while IFS= read -r dep; do
                dep=$(printf '%s' "$dep" | tr -d '[:space:]')
                [ -z "$dep" ] && continue
                collect_deps_recursive "$dep" "$indent  "
            done
        fi
    }

    collect_deps_recursive "$pkg" ""

    # Summary
    info ""
    info "=== Summary ==="

    new_count=$(printf '%s' "$to_install" | wc -w)
    installed_count=$(printf '%s' "$already_installed" | wc -w)

    info "Packages to install: $new_count"
    info "Already installed:   $installed_count"

    if [ "$new_count" -gt 0 ]; then
        info ""
        info "New packages:"
        for p in $to_install; do
            info "  - $p"
        done
    fi
}

show_deps() {
