# Resolve a bare package name via package.provided.
# Returns the canonical category/pkg form, or the original name if not listed.
resolve_provided() {
    _rp_name="$1"
    [ -f "$PROVIDED_FILE" ] || { printf '%s\n' "$_rp_name"; return 0; }
    _rp_result=$(grep -E "^[[:space:]]*${_rp_name}[[:space:]]*=" "$PROVIDED_FILE" \
        | head -n1 | sed 's/.*=[[:space:]]*//' | tr -d ' \t')
    if [ -n "$_rp_result" ]; then
        debug "resolve_provided: '$_rp_name' -> '$_rp_result'"
        printf '%s\n' "$_rp_result"
    else
        printf '%s\n' "$_rp_name"
    fi
}

# Scan RECIPES_DIR for bare-name conflicts and error if any bare name maps to
# more than one category without a declaration in package.provided.
# Called during sync (astral -Sy).
check_provided_conflicts() {
    info "Checking for bare-name conflicts in recipe tree..."
    _conflicts=0

    # Build a list of all bare package names with their category paths
    _seen_file="$TMPDIR/astral-seen-$$"
    _conflict_file="$TMPDIR/astral-conflicts-$$"
    rm -f "$_seen_file" "$_conflict_file"
    touch "$_seen_file" "$_conflict_file"

    find "$RECIPES_DIR" -mindepth 2 -maxdepth 2 -type d 2>/dev/null | while read -r _rdir; do
        _bare=$(basename "$_rdir")
        _catpkg=$(printf '%s' "$_rdir" | sed "s|^$RECIPES_DIR/||")
        # Check if we've seen this bare name from a different category
        _prev=$(grep -E "^${_bare}=" "$_seen_file" | head -n1 | cut -d= -f2-)
        if [ -n "$_prev" ] && [ "$_prev" != "$_catpkg" ]; then
            # Only flag if not resolved in package.provided
            _declared=$(grep -E "^[[:space:]]*${_bare}[[:space:]]*=" "$PROVIDED_FILE" \
                2>/dev/null | head -n1)
            if [ -z "$_declared" ]; then
                printf '%s\n' "$_bare: $_prev  vs  $_catpkg" >> "$_conflict_file"
            fi
        else
            printf '%s=%s\n' "$_bare" "$_catpkg" >> "$_seen_file"
        fi
    done

    # Also check .stars files
    find "$RECIPES_DIR" -mindepth 2 -maxdepth 3 -name "*.stars" 2>/dev/null | while read -r _sf; do
        _bare=$(basename "$_sf" | sed 's/-[0-9].*//' | sed 's/\.stars$//')
        _catpkg=$(dirname "$_sf" | sed "s|^$RECIPES_DIR/||")
        _prev=$(grep -E "^${_bare}=" "$_seen_file" | head -n1 | cut -d= -f2-)
        if [ -n "$_prev" ] && [ "$_prev" != "$_catpkg" ]; then
            _declared=$(grep -E "^[[:space:]]*${_bare}[[:space:]]*=" "$PROVIDED_FILE" \
                2>/dev/null | head -n1)
            if [ -z "$_declared" ]; then
                printf '%s\n' "$_bare: $_prev  vs  $_catpkg" >> "$_conflict_file"
            fi
        else
            printf '%s=%s\n' "$_bare" "$_catpkg" >> "$_seen_file"
        fi
    done

    if [ -s "$_conflict_file" ]; then
        warn "────────────────────────────────────────────────────────"
        warn "⚠  BARE NAME CONFLICTS DETECTED in recipe tree:"
        warn "   These bare names exist in multiple categories."
        warn "   Add entries to $PROVIDED_FILE to resolve:"
        warn ""
        while IFS= read -r _line; do
            warn "   $_line"
        done < "$_conflict_file"
        warn ""
        warn "   Example fix in package.provided:"
        warn "     bare_name = category/pkg"
        warn "────────────────────────────────────────────────────────"
        _conflicts=1
    else
        info "  ✓ No bare-name conflicts found"
    fi

    rm -f "$_seen_file" "$_conflict_file"
    return $_conflicts
}

