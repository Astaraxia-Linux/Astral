# --- PORTABLE UTILITY FUNCTIONS ---

# Portable realpath (no GNU coreutils needed)
portable_realpath() {
    path="$1"
    
    # Method 1: Try native realpath
    if command -v realpath >/dev/null 2>&1; then
        realpath "$path" 2>/dev/null && return 0
    fi
    
    # Method 2: Try readlink -f (GNU)
    if command -v readlink >/dev/null 2>&1; then
        readlink -f "$path" 2>/dev/null && return 0
    fi
    
    # Method 3: Pure POSIX fallback
    if [ -d "$path" ]; then
        ( cd "$path" && pwd )
    elif [ -f "$path" ]; then
        case "$path" in
            /*) printf '%s\n' "$path" ;;
            *)  printf '%s/%s\n' "$(pwd)" "$path" ;;
        esac
    else
        printf '%s\n' "$path"
    fi
}

# Portable stat (get file modification time)
portable_stat_mtime() {
    file="$1"
    
    # Method 1: GNU stat
    if stat -c %Y "$file" 2>/dev/null; then
        return 0
    fi
    
    # Method 2: BSD stat
    if stat -f %m "$file" 2>/dev/null; then
        return 0
    fi
    
    # Method 3: ls fallback (less precise)
    if command -v perl >/dev/null 2>&1; then
        perl -e 'print((stat($ARGV[0]))[9])' "$file" 2>/dev/null && return 0
    fi
    
    # Method 4: date fallback (very rough)
    date +%s 2>/dev/null || echo 0
}

# Portable stat (get file size)
portable_stat_size() {
    file="$1"
    
    # Method 1: GNU stat
    if stat -c %s "$file" 2>/dev/null; then
        return 0
    fi
    
    # Method 2: BSD stat
    if stat -f %z "$file" 2>/dev/null; then
        return 0
    fi
    
    # Method 3: wc fallback
    if [ -f "$file" ]; then
        wc -c < "$file" 2>/dev/null | tr -d ' '
        return 0
    fi
    
    echo 0
}

# Portable mktemp
portable_mktemp() {
    template="${1:-tmp.XXXXXX}"
    
    # Method 1: Native mktemp
    if command -v mktemp >/dev/null 2>&1; then
        mktemp "$TMPDIR/${template}" 2>/dev/null && return 0
    fi
    
    # Method 2: Pure POSIX fallback
    i=0
    while [ $i -lt 1000 ]; do
        tmpfile="$TMPDIR/${template%.XXXXXX}.$.$i"
        if [ ! -e "$tmpfile" ]; then
            touch "$tmpfile" 2>/dev/null && printf '%s\n' "$tmpfile" && return 0
        fi
        i=$((i + 1))
    done
    
    return 1
}

# Portable nproc (get CPU count)
portable_nproc() {
    # Method 1: nproc (GNU)
    if command -v nproc >/dev/null 2>&1; then
        nproc 2>/dev/null && return 0
    fi
    
    # Method 2: /proc/cpuinfo (Linux)
    if [ -r /proc/cpuinfo ]; then
        grep -c '^processor' /proc/cpuinfo 2>/dev/null && return 0
    fi
    
    # Method 3: sysctl (BSD/macOS)
    if command -v sysctl >/dev/null 2>&1; then
        sysctl -n hw.ncpu 2>/dev/null && return 0
    fi
    
    # Method 4: getconf (POSIX)
    if command -v getconf >/dev/null 2>&1; then
        getconf _NPROCESSORS_ONLN 2>/dev/null && return 0
    fi
    
    # Fallback: assume 1 core
    echo 1
}

# Portable sha256sum
portable_sha256sum() {
    file="$1"
    
    # Method 1: sha256sum (GNU)
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$file" 2>/dev/null && return 0
    fi
    
    # Method 2: shasum (BSD/macOS)
    if command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$file" 2>/dev/null && return 0
    fi
    
    # Method 3: openssl
    if command -v openssl >/dev/null 2>&1; then
        openssl dgst -sha256 "$file" 2>/dev/null | awk '{print $2" "$1}' && return 0
    fi
    
    # Method 4: cksum fallback (not SHA256 but better than nothing)
    if command -v cksum >/dev/null 2>&1; then
        cksum "$file" 2>/dev/null && return 0
    fi
    
    # No checksum available
    warn "No SHA256 tool available, skipping checksum"
    printf 'SKIP %s\n' "$file"
}

# Portable hostname
portable_hostname() {
    # Method 1: hostname command
    if command -v hostname >/dev/null 2>&1; then
        hostname 2>/dev/null && return 0
    fi
    
    # Method 2: uname -n
    if command -v uname >/dev/null 2>&1; then
        uname -n 2>/dev/null && return 0
    fi
    
    # Method 3: /etc/hostname
    if [ -r /etc/hostname ]; then
        cat /etc/hostname 2>/dev/null && return 0
    fi
    
    # Fallback
    echo "unknown-host"
}

# Portable tac (reverse lines)
portable_tac() {
    # Method 1: tac (GNU)
    if command -v tac >/dev/null 2>&1; then
        tac "$@" 2>/dev/null && return 0
    fi
    
    # Method 2: tail -r (BSD)
    if tail -r /dev/null 2>/dev/null; then
        tail -r "$@" && return 0
    fi
    
    # Method 3: awk fallback
    awk '{lines[NR]=$0} END {for(i=NR;i>0;i--) print lines[i]}' "$@"
}

# Portable seq
portable_seq() {
    start="$1"
    end="$2"
    
    # Method 1: seq (GNU)
    if command -v seq >/dev/null 2>&1; then
        seq "$start" "$end" 2>/dev/null && return 0
    fi
    
    # Method 2: jot (BSD)
    if command -v jot >/dev/null 2>&1; then
        jot - "$start" "$end" 2>/dev/null && return 0
    fi
    
    # Method 3: Pure POSIX
    i="$start"
    while [ "$i" -le "$end" ]; do
        printf '%d\n' "$i"
        i=$((i + 1))
    done
}

# --- COMPREHENSIVE SAFETY CHECKS ---

deep_recipe_check() {
    pkg="$1"
    rpath="$2"
    
    errors=0
    
    info "Running deep safety checks on: $pkg"
    
    # 1. Privilege escalation check
    if grep -rE 'chmod.*[4267][0-7]{3}|chown.*root' "$rpath" 2>/dev/null; then
        warn "  ⚠ Package modifies privileged files/permissions"
    fi
    
    # 2. Network access in build — only flag actual download tool invocations, not mentions
    if grep -rE '^[[:space:]]*(curl|wget|fetch)[[:space:]]' "$rpath/build" 2>/dev/null | grep -qv '^#'; then
        if [ "$SANDBOX_NETWORK" = "no" ]; then
            warn "  ⚠ Build script may require network but SANDBOX_NETWORK=no"
            errors=$((errors + 1))
        fi
    fi
    
    # 3. Suspicious system modifications
    if grep -rE 'rm.*-rf[[:space:]]*/|mkfs|wipefs|dd.*of=/dev' "$rpath" 2>/dev/null; then
        warn "  ✗ DANGEROUS: Package contains destructive commands"
        errors=$((errors + 1))
    fi
    
    # 4. Check for hardcoded paths that might leak host
    if grep -rE '/home/[a-z]|/root/' "$rpath" 2>/dev/null | grep -v '^#' | grep -qv 'doc\|example\|README'; then
        warn "  ⚠ Package contains hardcoded home paths"
    fi
    
    # 5. Verify all sources have checksums
    if [ -f "$rpath/sources" ] && [ ! -f "$rpath/checksums" ]; then
        warn "  ✗ Package has sources but no checksums (SECURITY RISK)"
        errors=$((errors + 1))
    fi
    
    # 6. Check for eval usage
    if grep -rE '^[[:space:]]*eval[[:space:]]' "$rpath" 2>/dev/null; then
        warn "  ⚠ Package uses 'eval' - review carefully"
    fi
    
    # 7. Verify DESTDIR usage
    if ! grep -q 'DESTDIR' "$rpath/build" 2>/dev/null && \
       ! grep -q 'PKGDIR' "$rpath/build" 2>/dev/null; then
        warn "  ⚠ Build script doesn't use \$DESTDIR or \$PKGDIR (may create ghost files)"
    fi
    
    [ "$errors" -eq 0 ] && info "  ✓ Deep safety checks passed"
    return $errors
}

# Runtime sandbox validation
validate_sandbox() {
    info "Validating sandbox configuration..."
    
    method=$(detect_sandbox_method)
    
    case "$method" in
        bubblewrap)
            if ! command -v bwrap >/dev/null 2>&1; then
                err "Bubblewrap not found but selected as sandbox method"
            fi
            info "  ✓ Bubblewrap available"
            ;;
        firejail)
            if ! command -v firejail >/dev/null 2>&1; then
                err "Firejail not found but selected as sandbox method"
            fi
            info "  ✓ Firejail available"
            ;;
    esac
    
    # Test sandbox isolation
    test_sandbox_isolation
}

# Test if sandbox properly isolates
test_sandbox_isolation() {
    info "Testing sandbox isolation..."
    
    test_file="/tmp/astral-sandbox-test-$$"
    
    # Create test file outside sandbox
    echo "host" > "$test_file"
    
    # Try to access from sandbox
    result=$(sandbox_exec "$(pwd)" "cat $test_file 2>/dev/null || echo isolated")
    
    if [ "$result" = "isolated" ]; then
        info "  ✓ Sandbox properly isolates filesystem"
    else
        warn "  ⚠ Sandbox may not fully isolate filesystem"
    fi
    
    rm -f "$test_file"
}

# --- CORE UTILITY FUNCTIONS ---

is_pkg_installed() {
    pkg="$1"
    _pkgbase=$(basename "$pkg")

    # Check astral DB: must have a version file to count as installed
    # (directory alone could be a leftover from a failed transaction)
    if [ -f "$DB_DIR/$pkg/version" ]; then
        return 0
    fi
    # Also search by bare package name under category dirs
    _found=$(find "$DB_DIR" -maxdepth 2 -name "version" -path "*/$_pkgbase/version" 2>/dev/null | head -n1)
    if [ -n "$_found" ]; then
        return 0
    fi

    # Check host package manager (Arch Linux)
    if command -v pacman >/dev/null 2>&1; then
        if pacman -Q "$_pkgbase" >/dev/null 2>&1; then
            return 0
        fi
    fi

    # Check host package manager (Debian/Ubuntu)
    if command -v dpkg >/dev/null 2>&1; then
        if dpkg -l "$_pkgbase" 2>/dev/null | grep -q "^ii"; then
            return 0
        fi
    fi

    return 1
}

resolve_installed_path() {
    requested_pkg="$1"
    _base=$(basename "$requested_pkg")

    # Must have a version file — bare directory is not a valid install record
    if [ -f "$DB_DIR/$requested_pkg/version" ]; then
        printf '%s\n' "$requested_pkg"
        return 0
    fi

    # Search by basename under category dirs
    found_path=$(find "$DB_DIR" -maxdepth 2 -name "version" \
        -path "*/$_base/version" 2>/dev/null | head -n1)
    if [ -n "$found_path" ]; then
        printf '%s\n' "$(dirname "$found_path" | sed "s|^${DB_DIR}/||")"
        return 0
    fi

    return 1
}

# Verify no host paths leaked into package
verify_no_host_leaks() {
    pkg="$1"
    pkgdir="$2"
    
    info "Verifying no host system leaks..."
    
    leaks_found=0
    
    # Check for hardcoded /home paths
    if grep -r "/home/" "$pkgdir" 2>/dev/null | grep -v ".so" | grep -v "Binary file"; then
        warn "  ⚠ Found /home/ references in package files"
        leaks_found=$((leaks_found + 1))
    fi
    
    # Check for hardcoded /root paths
    if grep -r "/root/" "$pkgdir" 2>/dev/null | grep -v ".so" | grep -v "Binary file"; then
        warn "  ⚠ Found /root/ references in package files"
        leaks_found=$((leaks_found + 1))
    fi
    
    # Check for build user leaks
    current_user=$(whoami)
    if grep -r "$current_user" "$pkgdir" 2>/dev/null | grep -v ".so" | grep -v "Binary file"; then
        warn "  ⚠ Found current username in package files"
        leaks_found=$((leaks_found + 1))
    fi
    
    # Check for absolute build paths
    if grep -r "$TMPDIR" "$pkgdir" 2>/dev/null | grep -v ".so" | grep -v "Binary file"; then
        err "  ✗ Found build directory paths in package (NOT REPRODUCIBLE)"
        leaks_found=$((leaks_found + 1))
    fi
    
    # Check for hostname leaks
    hostname=$(hostname 2>/dev/null || echo "")
    if [ -n "$hostname" ]; then
        if grep -r "$hostname" "$pkgdir" 2>/dev/null | grep -v ".so" | grep -v "Binary file"; then
            warn "  ⚠ Found hostname in package files"
            leaks_found=$((leaks_found + 1))
        fi
    fi
    
    if [ $leaks_found -eq 0 ]; then
        info "  ✓ No host system leaks detected"
        return 0
    else
        warn "  ⚠ Found $leaks_found potential host leaks"
        return 1
    fi
}

# Generate DOT graph for visualization
generate_dep_graph() {
    pkg="$1"
    output="${2:-/tmp/astral-deps.dot}"
    
    info "Generating dependency graph for: $pkg"
    
    cat > "$output" <<'EOF'
digraph dependencies {
    rankdir=LR;
    node [shape=box, style=rounded];
    
EOF
    
    # Build graph recursively
    generate_graph_recursive "$pkg" "" >> "$output"
    
    echo "}" >> "$output"
    
    info "✓ Graph saved to: $output"
    info "  Render with: dot -Tpng $output -o deps.png"
}

generate_graph_recursive() {
    pkg="$1"
    visited="$2"
    
    # Prevent cycles
    case " $visited " in
        *" $pkg "*) return 0 ;;
    esac
    visited="$visited $pkg"
    
    # Get dependencies
    bdeps=$(get_build_deps "$pkg" 2>/dev/null || true)
    rdeps=$(get_runtime_deps "$pkg" 2>/dev/null || true)
    pdeps=$(get_post_deps "$pkg" 2>/dev/null || true)
    
    # Build deps (red)
    for dep in $bdeps; do
        dep=$(printf '%s' "$dep" | awk '{print $1}')
        [ -z "$dep" ] && continue
        echo "    \"$pkg\" -> \"$dep\" [color=red, label=\"build\"];"
        generate_graph_recursive "$dep" "$visited"
    done
    
    # Runtime deps (blue)
    for dep in $rdeps; do
        dep=$(printf '%s' "$dep" | awk '{print $1}')
        [ -z "$dep" ] && continue
        echo "    \"$pkg\" -> \"$dep\" [color=blue, label=\"runtime\"];"
        generate_graph_recursive "$dep" "$visited"
    done
    
    # Post deps (green)
    for dep in $pdeps; do
        dep=$(printf '%s' "$dep" | awk '{print $1}')
        [ -z "$dep" ] && continue
        echo "    \"$pkg\" -> \"$dep\" [color=green, label=\"post\"];"
        generate_graph_recursive "$dep" "$visited"
    done
}

# Build multiple independent packages in parallel
parallel_build() {
    max_jobs="${1:-$(nproc)}"
    shift
    packages="$*"
    
    info "╭────────────────────────────────────────────────────────────────╮"
    info "│              Parallel Build Mode ($max_jobs jobs)                    │"
    info "╰────────────────────────────────────────────────────────────────╯"
    
    # Build dependency graph
    DEP_GRAPH=""
    for pkg in $packages; do
        build_dep_graph "$pkg"
    done
    
    # Get topologically sorted order
    sorted_pkgs=$(topological_sort)
    
    # Track running jobs
    running_jobs=0
    job_pids=""
    
    for pkg in $sorted_pkgs; do
        # Wait if max jobs reached
        while [ $running_jobs -ge $max_jobs ]; do
            # Check for completed jobs
            for pid in $job_pids; do
                if ! kill -0 "$pid" 2>/dev/null; then
                    # Job completed
                    wait "$pid"
                    exit_code=$?
                    
                    running_jobs=$((running_jobs - 1))
                    job_pids=$(printf '%s\n' "$job_pids" | grep -v "^$pid$")
                    
                    if [ $exit_code -ne 0 ]; then
                        err "Parallel build failed for a package"
                    fi
                fi
            done
            
            sleep 0.5
        done
        
        # Start build in background
        info "[$((running_jobs + 1))/$max_jobs] Starting: $pkg"
        (
            sync_pkg_recursive "$pkg" 0 1
        ) &
        
        job_pid=$!
        job_pids="$job_pids $job_pid"
        running_jobs=$((running_jobs + 1))
    done
    
    # Wait for all jobs to complete
    info "Waiting for all builds to complete..."
    wait
    
    info "✓ Parallel build complete"
}

parallel_remove() {
    max_jobs="${1:-$(nproc)}"
    shift
    packages="$*"

    [ -n "$packages" ] || err "no packages specified for parallel removal"

    info "╭────────────────────────────────────────────────────────────────╮"
    info "│             Parallel Remove Mode ($max_jobs jobs)                    │"
    info "╰────────────────────────────────────────────────────────────────╯"

    running_jobs=0
    job_pids=""
    failed_pkgs=""

    for pkg in $packages; do
        # Resolve path before forking — resolve_installed_path is read-only
        pkg_path=$(resolve_installed_path "$pkg") || {
            warn "Package '$pkg' not installed, skipping."
            continue
        }

        # Wait if at job limit
        while [ "$running_jobs" -ge "$max_jobs" ]; do
            new_pids=""
            for pid in $job_pids; do
                if ! kill -0 "$pid" 2>/dev/null; then
                    wait "$pid"
                    exit_code=$?
                    running_jobs=$((running_jobs - 1))
                    if [ "$exit_code" -ne 0 ]; then
                        warn "A removal job (pid $pid) failed"
                    fi
                else
                    new_pids="$new_pids $pid"
                fi
            done
            job_pids="$new_pids"
            [ "$running_jobs" -ge "$max_jobs" ] && sleep 0.2
        done

        # Fork removal
        info "Removing: $pkg"
        ( remove_pkg_only "$pkg_path" ) &
        job_pid=$!
        job_pids="$job_pids $job_pid"
        running_jobs=$((running_jobs + 1))
    done

    # Wait for all remaining jobs
    info "Waiting for all removals to complete..."
    for pid in $job_pids; do
        wait "$pid" || warn "A removal job (pid $pid) failed"
    done

    info "✓ Parallel remove complete"
}

parallel_removedep() {
    max_jobs="${1:-$(nproc)}"
    shift
    packages="$*"

    [ -n "$packages" ] || err "no packages specified for parallel removedep"

    info "╭────────────────────────────────────────────────────────────────╮"
    info "│          Parallel RemoveDep Mode ($max_jobs jobs)                    │"
    info "╰────────────────────────────────────────────────────────────────╯"

    running_jobs=0
    job_pids=""

    for pkg in $packages; do
        # Verify installed before forking
        resolve_installed_path "$pkg" >/dev/null 2>&1 || {
            warn "Package '$pkg' not installed, skipping."
            continue
        }

        # Wait if at job limit
        while [ "$running_jobs" -ge "$max_jobs" ]; do
            new_pids=""
            for pid in $job_pids; do
                if ! kill -0 "$pid" 2>/dev/null; then
                    wait "$pid"
                    exit_code=$?
                    running_jobs=$((running_jobs - 1))
                    if [ "$exit_code" -ne 0 ]; then
                        warn "A removedep job (pid $pid) failed"
                    fi
                else
                    new_pids="$new_pids $pid"
                fi
            done
            job_pids="$new_pids"
            [ "$running_jobs" -ge "$max_jobs" ] && sleep 0.2
        done

        # Fork — each removedep_pkg manages its own dep walk independently
        info "Removing with deps: $pkg"
        ( removedep_pkg "$pkg" ) &
        job_pid=$!
