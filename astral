# === COMPREHENSIVE CLEANUP SYSTEM ===
cleanup_all() {
    warn "╔════════════════════════════════════════════════════════════════╗"
    warn "║                    ASTRAL DEEP CLEAN                           ║"
    warn "╠════════════════════════════════════════════════════════════════╣"
    warn "║  This will remove:                                             ║"
    warn "║    • All sync logs                                             ║"
    warn "║    • All build logs                                            ║"
    warn "║    • Failed build directories                                  ║"
    warn "║    • Cached source archives                                    ║"
    warn "║    • Downloaded recipes (not installed)                        ║"
    warn "║    • Temporary files                                           ║"
    warn "║    • Lock files                                                ║"
    warn "╚════════════════════════════════════════════════════════════════╝"
    warn ""
    
    printf "Type 'CLEAN' to confirm: "
    read -r confirm
    
    [ "$confirm" != "CLEAN" ] && { info "Cancelled"; return 0; }
    
    info ""
    info "Starting deep clean..."
    
    # 1. Clean logs
    info "  [1/7] Cleaning logs..."
    if [ -d /var/log/astral ]; then
        rm -f /var/log/astral/sync*.log
        rm -f /var/log/astral/build*.log
        rm -f /var/log/astral/debug*.log
        info "    ✓ Removed log files"
    fi
    
    # 2. Clean failed builds
    info "  [2/7] Cleaning failed builds..."
    failed_count=0
    find "$TMPDIR" -name "astral-build-*" -type d 2>/dev/null | while read -r builddir; do
        # Check if build failed (no .done marker)
        if [ ! -f "$builddir/.astral_build_complete" ]; then
            rm -rf "$builddir"
            failed_count=$((failed_count + 1))
        fi
    done
    info "    ✓ Removed $failed_count failed builds"
    
    # 3. Clean source cache
    info "  [3/7] Cleaning source cache..."
    if [ -d "$CACHE_SRC" ]; then
        cache_size=$(du -sh "$CACHE_SRC" 2>/dev/null | awk '{print $1}')
        rm -rf "${CACHE_SRC:?}"/*
        info "    ✓ Freed $cache_size from source cache"
    fi
    
    # 4. Clean uninstalled recipes
    info "  [4/7] Cleaning uninstalled recipes..."
    recipe_count=0
    find "$RECIPES_DIR" -name "*.stars" 2>/dev/null | while read -r recipe; do
        recipe_base=$(basename "$recipe")
        pkg_name=$(printf '%s\n' "${recipe_base%.stars}" | sed 's/-[0-9].*//')
        
        if ! is_pkg_installed "$pkg_name"; then
            rm -f "$recipe"
            recipe_count=$((recipe_count + 1))
        fi
    done
    info "    ✓ Removed $recipe_count uninstalled recipes"
    
    # 5. Clean temporary files
    info "  [5/7] Cleaning temporary files..."
    rm -f "$TMPDIR"/astral-*
    rm -f "$TMPDIR"/.astral*
    info "    ✓ Removed temporary files"
    
    # 6. Clean stale locks
    info "  [6/7] Cleaning stale locks..."
    if [ -d "$LOCK_FILE.d" ]; then
        lock_pid=$(cat "$LOCK_FILE.d/pid" 2>/dev/null)
        if [ -n "$lock_pid" ]; then
            if ! kill -0 "$lock_pid" 2>/dev/null; then
                rm -rf "$LOCK_FILE.d"
                info "    ✓ Removed stale lock (PID $lock_pid)"
            else
                warn "    ⊚ Lock is active (PID $lock_pid)"
            fi
        fi
    fi
    
    # 7. Clean ccache (optional)
    info "  [7/7] Cleaning build cache..."
    if command -v ccache >/dev/null 2>&1; then
        printf "    Clean ccache? [y/N]: "
        read -r clean_ccache
        case "$clean_ccache" in
            [Yy]*)
                ccache -C
                info "    ✓ ccache cleared"
                ;;
        esac
    fi
    
    info ""
    info "╔════════════════════════════════════════════════════════════════╗"
    info "║                    Deep Clean Complete                         ║"
    info "╚════════════════════════════════════════════════════════════════╝"
}

