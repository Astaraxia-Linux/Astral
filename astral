            ;;
        advanced-script-check|advanced-check)
            SAFETY_ADVANCED_SCRIPT_CHECK=0
            warn "Disabled: Advanced script security analysis"
            ;;
        all)
            SAFETY_SCRIPT_CHECK=0
            SAFETY_COLLISION_DETECT=0
            SAFETY_GHOST_DETECT=0
            SAFETY_CHECKSUM_VERIFY=0
            SAFETY_MASK_CHECK=0
