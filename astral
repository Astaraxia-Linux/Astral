# === INIT SYSTEM SERVICE MANAGER ===
detect_init_system() {
    # Detect which init system is running
    if [ -d /run/systemd/system ]; then
        printf 'systemd\n'
    elif [ -f /run/openrc/softlevel ]; then
        printf 'openrc\n'
    elif command -v sv >/dev/null 2>&1 && [ -d /var/service ]; then
        printf 'runit\n'
    elif command -v s6-rc >/dev/null 2>&1; then
        printf 's6\n'
    elif [ -f /etc/inittab ]; then
        printf 'sysvinit\n'
    else
        printf 'unknown\n'
    fi
}

service_action() {
    action="$1"
    service="$2"
    init_system=$(detect_init_system)
    
    case "$init_system" in
        systemd)
            case "$action" in
                start) systemctl start "$service" ;;
                stop) systemctl stop "$service" ;;
                restart) systemctl restart "$service" ;;
                enable) systemctl enable "$service" ;;
                disable) systemctl disable "$service" ;;
                status) systemctl status "$service" ;;
                *) err "Unknown action: $action" ;;
            esac
            ;;
        openrc)
            case "$action" in
                start) rc-service "$service" start ;;
                stop) rc-service "$service" stop ;;
                restart) rc-service "$service" restart ;;
                enable) rc-update add "$service" default ;;
                disable) rc-update del "$service" default ;;
                status) rc-service "$service" status ;;
                *) err "Unknown action: $action" ;;
            esac
            ;;
        runit)
            case "$action" in
                start) sv start "$service" ;;
                stop) sv stop "$service" ;;
                restart) sv restart "$service" ;;
                enable) ln -sf "/etc/sv/$service" /var/service/ ;;
                disable) rm -f "/var/service/$service" ;;
                status) sv status "$service" ;;
                *) err "Unknown action: $action" ;;
            esac
            ;;
        s6)
            case "$action" in
                start) s6-rc -u change "$service" ;;
                stop) s6-rc -d change "$service" ;;
                restart) s6-rc -d change "$service"; s6-rc -u change "$service" ;;
                enable) s6-rc-bundle-update add default "$service" ;;
                disable) s6-rc-bundle-update delete default "$service" ;;
                status) s6-svstat "/run/service/$service" ;;
                *) err "Unknown action: $action" ;;
            esac
            ;;
        sysvinit)
            case "$action" in
                start) service "$service" start ;;
                stop) service "$service" stop ;;
                restart) service "$service" restart ;;
                enable) update-rc.d "$service" defaults 2>/dev/null || chkconfig "$service" on 2>/dev/null ;;
                disable) update-rc.d "$service" remove 2>/dev/null || chkconfig "$service" off 2>/dev/null ;;
                status) service "$service" status ;;
                *) err "Unknown action: $action" ;;
            esac
            ;;
        *)
            err "Unknown or unsupported init system: $init_system"
            ;;
    esac
}

# === INTEGRATED TEST SUITE ===
run_testsuite() {
    test_mode="${1:-all}"
    
    info "╭────────────────────────────────────────────────────────────────╮"
    info "│                    Astral Test Suite v1.0                      │"
    info "╰────────────────────────────────────────────────────────────────╯"
    info ""
    
    passed=0
    failed=0
    total=0
    
    run_test() {
        test_name="$1"
        test_func="$2"
        
        total=$((total + 1))
        printf "Running: %-50s ... " "$test_name"
        
        if $test_func >/dev/null 2>&1; then
            printf "${GREEN}PASS${NC}\n"
            passed=$((passed + 1))
            return 0
        else
            printf "${RED}FAIL${NC}\n"
            failed=$((failed + 1))
            return 1
        fi
    }
    
    # Test: Version comparison
    test_version_compare() {
        version_compare "1.2.3" ">" "1.2.2" && \
        version_compare "2.0.0" ">" "1.9.9" && \
        version_compare "1.0.0" "<" "1.0.1" && \
        version_compare "1.0.0" "=" "1.0.0"
    }
    
    # Test: Sanitize package name
    test_sanitize_pkg() {
        result=$(sanitize_pkg_name "../../etc/passwd")
        [ "$result" = "etc/passwd" ]
    }
    
    # Test: USE flag parsing
    test_use_flags() {
        USE_FLAGS="gtk gtk3 -qt5"
        use=$(parse_use_flags "test-pkg")
        printf '%s' "$use" | grep -q "gtk" && \
        printf '%s' "$use" | grep -q "gtk3"
    }
    
    # Test: Dependency detection
    test_dep_detection() {
        TMPDIR=/tmp
        temp_recipe="$TMPDIR/test-recipe-$$"
        mkdir -p "$temp_recipe"
        echo "gcc" > "$temp_recipe/bdepends"
        echo "glibc" > "$temp_recipe/rdepends"
        
        # This would need adaptation to your actual functions
        result=$(cat "$temp_recipe/bdepends" "$temp_recipe/rdepends" | wc -l)
        rm -rf "$temp_recipe"
        [ "$result" -eq 2 ]
    }
    
    # Test: Lock file handling
    test_lock_handling() {
        test_lock="/tmp/astral-test-lock-$$.lock.d"
        if mkdir "$test_lock" 2>/dev/null; then
            rmdir "$test_lock"
            return 0
        fi
        return 1
    }
    
    # Test: Init system detection
    test_init_detection() {
        init_system=$(detect_init_system)
        [ -n "$init_system" ] && [ "$init_system" != "unknown" ]
    }
    
    # Test: GPG keyring creation
    test_gpg_keyring() {
        temp_keyring="$TMPDIR/test-keyring-$$.gpg"
        gpg --no-default-keyring --keyring "$temp_keyring" --list-keys >/dev/null 2>&1
        result=$?
        rm -f "$temp_keyring"
        return $result
    }
    
    # Test: Log rotation
    test_log_rotation() {
        test_log="$TMPDIR/test-log-$$.log"
        # Create 11MB file
        dd if=/dev/zero of="$test_log" bs=1M count=11 2>/dev/null
        [ -f "$test_log" ] && [ "$(stat -c%s "$test_log" 2>/dev/null)" -gt 10485760 ]
        result=$?
        rm -f "$test_log"
        return $result
    }
    
    # Run tests based on mode
    case "$test_mode" in
        all|full)
            info "Running full test suite..."
            run_test "Version comparison" test_version_compare
            run_test "Package name sanitization" test_sanitize_pkg
            run_test "USE flag parsing" test_use_flags
            run_test "Dependency detection" test_dep_detection
            run_test "Lock file handling" test_lock_handling
            run_test "Init system detection" test_init_detection
            run_test "GPG keyring creation" test_gpg_keyring
            run_test "Log file rotation" test_log_rotation
            ;;
        quick)
            info "Running quick tests..."
            run_test "Version comparison" test_version_compare
            run_test "Package name sanitization" test_sanitize_pkg
            run_test "Lock file handling" test_lock_handling
            ;;
        *)
            err "Unknown test mode: $test_mode"
            ;;
    esac
    
    info ""
    info "╭────────────────────────────────────────────────────────────────╮"
    info "│                       Test Results                             │"
    info "├────────────────────────────────────────────────────────────────┤"
    printf "│  Total:  %-50s │\n" "$total tests"
    printf "│  ${GREEN}Passed: %-50s${NC} │\n" "$passed"
    printf "│  ${RED}Failed: %-50s${NC} │\n" "$failed"
    info "╰────────────────────────────────────────────────────────────────╯"
    
    [ $failed -eq 0 ] && return 0 || return 1
}

# === RECIPE VALIDATION SYSTEM ===
validate_recipe() {
    pkg="$1"
    
    rpath=$(recipe_path "$pkg") || err "Recipe not found: $pkg"
    
    info "╭────────────────────────────────────────────────────────────────╮"
    info "│                  Recipe Validation: $pkg"
    info "╰────────────────────────────────────────────────────────────────╯"
    info ""
    
    errors=0
    warnings=0
    
    # Check if it's a .stars file
    is_stars=0
    case "$rpath" in
        *.stars) is_stars=1 ;;
    esac
    
    if [ $is_stars -eq 1 ]; then
        # Expand to temp directory
        temp_expand="$TMPDIR/astral-validate-$$"
        expand_stars_recipe "$rpath" "$temp_expand" "$pkg"
        rpath="$temp_expand"
        trap "rm -rf '$temp_expand'" EXIT
    fi
    
    # 1. Check required files
    info "[1/8] Checking required files..."
    for required in version build; do
        if [ ! -f "$rpath/$required" ]; then
            printf "  ${RED}✗${NC} Missing required file: $required\n"
            errors=$((errors + 1))
        else
            printf "  ${GREEN}✓${NC} Found: $required\n"
        fi
    done
    
    # 2. Check version format
    info ""
    info "[2/8] Validating version format..."
    if [ -f "$rpath/version" ]; then
        ver=$(cat "$rpath/version")
        if printf '%s' "$ver" | grep -qE '^[0-9]+\.[0-9]+'; then
            printf "  ${GREEN}✓${NC} Valid version: $ver\n"
        else
            printf "  ${YELLOW}⚠${NC} Unusual version format: $ver\n"
            warnings=$((warnings + 1))
        fi
    fi
    
    # 3. Check build script safety
    info ""
    info "[3/8] Checking build script safety..."
    if check_script_safety "$rpath/build" "$pkg" 2>/dev/null; then
        printf "  ${GREEN}✓${NC} Build script passed safety checks\n"
    else
        printf "  ${RED}✗${NC} Build script failed safety checks\n"
        errors=$((errors + 1))
    fi
    
    # 4. Validate dependencies
    info ""
    info "[4/8] Validating dependencies..."
    for dep_file in depends bdepends rdepends; do
        [ ! -f "$rpath/$dep_file" ] && continue
        
        dep_count=0
        while IFS= read -r dep; do
            dep=$(printf '%s' "$dep" | awk '{print $1}')
            [ -z "$dep" ] && continue
            dep_count=$((dep_count + 1))
            
            # Check if dependency exists
            if ! query_index_v2 "$dep" "any" "$REPO_CONTEXT" >/dev/null 2>&1; then
                printf "  ${YELLOW}⚠${NC} Dependency not found in index: $dep\n"
                warnings=$((warnings + 1))
            fi
        done < "$rpath/$dep_file"
        
        [ $dep_count -gt 0 ] && printf "  ${GREEN}✓${NC} $dep_file: $dep_count dependencies\n"
    done
    
    # 5. Check checksums
    info ""
    info "[5/8] Validating checksums file..."
    if [ -f "$rpath/checksums" ]; then
        checksum_count=0
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            case "$line" in \#*) continue ;; esac
            
            algo=$(printf '%s' "$line" | cut -d':' -f1)
            case "$algo" in
                SHA256|SHA512|MD5|BLAKE2B)
                    checksum_count=$((checksum_count + 1))
                    ;;
                *)
                    printf "  ${YELLOW}⚠${NC} Unknown algorithm: $algo\n"
                    warnings=$((warnings + 1))
                    ;;
            esac
        done < "$rpath/checksums"
        
        printf "  ${GREEN}✓${NC} Checksums file: $checksum_count entries\n"
    else
        printf "  ${YELLOW}⚠${NC} No checksums file (insecure)\n"
        warnings=$((warnings + 1))
    fi
    
    # 6. Check sources
    info ""
    info "[6/8] Validating sources..."
    if [ -f "$rpath/sources" ]; then
        source_count=0
        while IFS= read -r url; do
            [ -z "$url" ] && continue
            case "$url" in \#*) continue ;; esac
            
            source_count=$((source_count + 1))
            
            # Check URL format
            if ! printf '%s' "$url" | grep -qE '^(https?|git|ftp)://'; then
                printf "  ${RED}✗${NC} Invalid URL: $url\n"
                errors=$((errors + 1))
            fi
        done < "$rpath/sources"
        
        printf "  ${GREEN}✓${NC} Sources file: $source_count URLs\n"
    else
        printf "  ${YELLOW}⚠${NC} No sources file\n"
        warnings=$((warnings + 1))
    fi
    
    # 7. Check metadata
    info ""
    info "[7/8] Checking metadata..."
    if [ -f "$rpath/info" ]; then
        printf "  ${GREEN}✓${NC} Info file present\n"
    else
        printf "  ${YELLOW}⚠${NC} No info file (recommended)\n"
        warnings=$((warnings + 1))
    fi
    
    # 8. Syntax validation (for .stars)
    info ""
    info "[8/8] Syntax validation..."
    if [ $is_stars -eq 1 ]; then
        # Check for common syntax errors
        original_stars=$(cat "$rpath/.astral_original_recipe")
        
        # Check balanced braces
        open_braces=$(grep -o '{' "$original_stars" | wc -l)
        close_braces=$(grep -o '}' "$original_stars" | wc -l)
        
        if [ "$open_braces" -ne "$close_braces" ]; then
            printf "  ${RED}✗${NC} Unbalanced braces ($open_braces open, $close_braces close)\n"
            errors=$((errors + 1))
        else
            printf "  ${GREEN}✓${NC} Balanced braces\n"
        fi
    fi
    
    # Summary
    info ""
    info "╭────────────────────────────────────────────────────────────────╮"
    info "│                    Validation Summary                          │"
    info "├────────────────────────────────────────────────────────────────┤"
    printf "│  ${RED}Errors:   %-50s${NC} │\n" "$errors"
    printf "│  ${YELLOW}Warnings: %-50s${NC} │\n" "$warnings"
    info "╰────────────────────────────────────────────────────────────────╯"
    
    if [ $errors -gt 0 ]; then
        err "Recipe validation failed with $errors error(s)"
    elif [ $warnings -gt 0 ]; then
        warn "Recipe validation passed with $warnings warning(s)"
    else
        info "✓ Recipe validation passed (no issues found)"
    fi
    
    [ $is_stars -eq 1 ] && rm -rf "$temp_expand"
}

