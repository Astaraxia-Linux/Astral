# §3 — Parallel source downloader (pure POSIX sh, FIFO job pool)
# Replaces serial download_sources() as the primary downloader.
# Falls back to serial download_sources() if mkfifo is unavailable.
# Suggestion: recoverable download with retry logic
# Usage: download_with_retry <url> <dest> [max_retries]
# Retries transient failures (network blip, server hiccup) with exponential backoff.
# Gives up and returns 1 after max_retries — caller decides whether to err() or warn().
download_with_retry() {
    _url="$1"
    _dest="$2"
    _max="${3:-${DOWNLOAD_RETRIES:-3}}"
    _attempt=0
    _wait=2

    while [ "$_attempt" -lt "$_max" ]; do
        _attempt=$((_attempt + 1))
        if curl -fSL --retry 0 --connect-timeout 30 --max-time 300                 "$_url" -o "$_dest" 2>/dev/null; then
            return 0
        fi
        if [ "$_attempt" -lt "$_max" ]; then
            warn "  ↻ Download failed (attempt $_attempt/$_max), retrying in ${_wait}s: $(basename "$_dest")"
            sleep "$_wait"
            _wait=$((_wait * 2))  # exponential backoff: 2s, 4s, 8s...
        fi
    done

    warn "  ✗ Download failed after $_max attempts: $(basename "$_dest")"
    return 1
}

parallel_download_sources() {
    _rpath="$1"
    _buildtmp="$2"
    _sources_file="$_rpath/sources"
    [ -f "$_sources_file" ] || return 0

    # Determine max parallel jobs
    _jobs="${JOBS:-$(nproc 2>/dev/null || printf '4')}"

    # Job-slot FIFO: each newline token = one available slot
    _fifo="$TMPDIR/astral-dl-fifo-$$"
    mkfifo "$_fifo" 2>/dev/null || {
        warn "[parallel_dl] mkfifo unavailable, falling back to serial download"
        download_sources "$_rpath" "$_buildtmp"
        return $?
    }

    # Open FIFO read/write so it is not closed between reads
    exec 3<>"$_fifo"

    # Pre-fill pool with $_jobs tokens
    _i=0
    while [ "$_i" -lt "$_jobs" ]; do
        printf '\n' >&3
        _i=$((_i + 1))
    done

    _dl_error_file="$TMPDIR/astral-dl-errors-$$"
    rm -f "$_dl_error_file"

    while IFS= read -r _line; do
        _line=$(printf '%s' "$_line" | tr -d '[:space:]')
        [ -z "$_line" ] && continue
        case "$_line" in '#'*) continue ;; esac

        # Acquire a slot (blocks if all slots taken)
        read -r _token <&3

        # Launch download in background subshell
        (
            _url="$_line"
            _fname=$(basename "$(printf '%s' "$_url" | sed 's/#.*//')")
            _dest="$_buildtmp/$_fname"
            case "$_url" in
                git+*|*.git|*.git'#'*)
                    _gurl=$(printf '%s' "$_url" | sed 's/^git+//' | sed 's/#.*//')
                    _branch=$(printf '%s' "$_url" | grep '#' && printf '%s' "$_url" | sed 's/.*#[a-z]*=//' || printf 'main')
                    download_git_source "$(basename "$_gurl" .git)" "$_gurl" "$_buildtmp" "$_branch" \
                        || printf '%s\n' "$_url" >> "$_dl_error_file"
                    ;;
                *)
                    info "  → [$_fname] downloading..."
                    if download_with_retry "$_url" "$_dest"; then
                        info "  ✓ [$_fname] done"
                        # Signature verification
                        sig_url="${_url}.sig"
                        sig_file="${_dest}.sig"
                        if curl -fsSL "$sig_url" -o "$sig_file" 2>/dev/null; then
                            if ! verify_signature "$_dest" "$sig_file" 2>/dev/null; then
                                warn "  ✗ [$_fname] signature INVALID"
                                printf '%s\n' "$_url" >> "$_dl_error_file"
                            fi
                        else
                            rm -f "$sig_file"
                            debug "sig check: SAFETY_SIGNATURE_VERIFY=$SAFETY_SIGNATURE_VERIFY"
                            if [ "$SAFETY_SIGNATURE_VERIFY" -eq 1 ]; then
                                warn "  ✗ [$_fname] no signature found (SAFETY_SIGNATURE_VERIFY=1)"
                                printf '%s\n' "$_url" >> "$_dl_error_file"
                            else
                                warn "  ⚠ [$_fname] no signature (SAFETY_SIGNATURE_VERIFY=0, continuing)"
                            fi
                        fi
                    else
                        warn "  ✗ [$_fname] download failed"
                        printf '%s\n' "$_url" >> "$_dl_error_file"
                    fi
                    ;;
            esac
            # Release slot back to pool
            printf '\n' >&3
        ) &
    done < "$_sources_file"

    # Wait for all background jobs to finish
    wait
    exec 3>&-
    rm -f "$_fifo"

    # Report any errors
    if [ -f "$_dl_error_file" ]; then
        warn "The following sources failed to download:"
        cat "$_dl_error_file" >&2
        rm -f "$_dl_error_file"
        return 1
    fi
    rm -f "$_dl_error_file"
    return 0
}

download_sources() {
    rpath="$1"; buildtmp="$2"
    sources_file="$rpath/sources"
    [ -f "$sources_file" ] || return 0
    
    pkg_name=$(basename "$rpath" | sed 's/-.*//')

    info "Downloading sources..."

    while IFS= read -r line; do
        line=$(printf '%s' "$line" | tr -d '[:space:]')
        [ -z "$line" ] && continue
        case "$line" in \#*) continue ;; esac
        
        # Parse source line
        # Format: git+https://github.com/user/repo#branch=main
        #     or: https://example.com/file.tar.gz
        
        case "$line" in
            git+*|*.git|*.git#*)
                # Git source
                git_url=$(printf '%s' "$line" | sed 's/^git+//' | sed 's/#.*//')
                
                # Extract branch/tag if specified
                branch=""
                if printf '%s' "$line" | grep -q '#'; then
                    ref_part=$(printf '%s' "$line" | sed 's/.*#//')
                    branch=$(printf '%s' "$ref_part" | cut -d'=' -f2)
                fi
                
                [ -z "$branch" ] && branch="main"
                
                download_git_source "$pkg_name" "$git_url" "$buildtmp" "$branch"
                ;;
            *)
                # Regular HTTP/FTP source
                filename=$(basename "$line")
                dest_file="$buildtmp/$filename"
                
                info "  → Downloading: $filename"
                
                if ! download_with_retry "$line" "$dest_file"; then
                    err "Failed to download after retries: $line"
                fi
                
                # Signature verification: attempt to download .sig
                # If SAFETY_SIGNATURE_VERIFY=1, a missing or invalid sig is fatal.
                sig_url="${line}.sig"
                sig_file="${dest_file}.sig"
                if curl -fsSL "$sig_url" -o "$sig_file" 2>/dev/null; then
                    if ! verify_signature "$dest_file" "$sig_file"; then
                        err "Signature verification FAILED for $filename"
                    fi
                else
                    rm -f "$sig_file"
                    if [ "$SAFETY_SIGNATURE_VERIFY" -eq 1 ]; then
                        err "No signature found for $filename and SAFETY_SIGNATURE_VERIFY=1 — refusing to proceed. Disable with SAFETY_SIGNATURE_VERIFY=0 if upstream does not publish signatures."
                    else
                        warn "No signature file for $filename (SAFETY_SIGNATURE_VERIFY=0, continuing)"
                    fi
                fi
                
                info "  ✓ Downloaded: $filename"
                ;;
        esac
    done < "$sources_file"
}

# Verify installed package integrity
verify_package_integrity() {
    pkg="$1"
    
    info "Verifying package integrity: $pkg"
    
    pkg_path=$(resolve_installed_path "$pkg") || err "Package not installed: $pkg"
    files_list="$DB_DIR/$pkg_path/files"
    
    [ ! -f "$files_list" ] && err "No files list found for $pkg"
    
    missing=0
    modified=0
    total=0
    
    while IFS= read -r file; do
        [ -z "$file" ] && continue
        total=$((total + 1))
        
        fullpath="$INSTALL_ROOT/$file"
        
        # Check existence
        if [ ! -e "$fullpath" ] && [ ! -L "$fullpath" ]; then
            warn "  ✗ Missing: $file"
            missing=$((missing + 1))
            continue
        fi
        
        # For files, check if they've been modified
        if [ -f "$fullpath" ]; then
            # Store checksums during install for verification
            checksum_file="$DB_DIR/$pkg_path/checksums.installed"
            if [ -f "$checksum_file" ]; then
                stored_sum=$(grep "^$file " "$checksum_file" | awk '{print $2}')
                current_sum=$(sha256sum "$fullpath" | awk '{print $1}')
                
                if [ -n "$stored_sum" ] && [ "$stored_sum" != "$current_sum" ]; then
                    warn "  ⚠ Modified: $file"
                    modified=$((modified + 1))
                fi
            fi
        fi
    done < "$files_list"
    
    info ""
    info "Verification Results:"
    printf "  Total files:    %d\n" "$total"
    printf "  Missing:        %d\n" "$missing"
    printf "  Modified:       %d\n" "$modified"
    
    if [ $missing -eq 0 ] && [ $modified -eq 0 ]; then
        info "  ✓ Package integrity verified"
        return 0
    else
        warn "  ⚠ Package integrity issues detected"
        return 1
    fi
}

# Store checksums during installation
store_file_checksums() {
    pkg="$1"
    pkgdir="$2"
    pkg_path="$3"
    
    checksum_file="$DB_DIR/$pkg_path/checksums.installed"
    
    info "Storing file checksums for verification..."
    
    # §8.1 — Avoid pipe subshell: use temp file so loop runs in current shell
    _cs_tmpf="$TMPDIR/astral-cs-$$"
    ( cd "$pkgdir" && find . -type f ) > "$_cs_tmpf"
    while IFS= read -r file; do
        file_clean=$(printf '%s' "$file" | sed 's|^\./||')
        checksum=$(sha256sum "$pkgdir/$file" 2>/dev/null | awk '{print $1}')
        [ -n "$checksum" ] && printf '%s %s\n' "$file_clean" "$checksum" >> "$checksum_file"
    done < "$_cs_tmpf"
    rm -f "$_cs_tmpf"
}

verify_reproducibility() {
    pkg="$1"
    
    info "╭────────────────────────────────────────────────────────────────╮"
    info "│              Reproducibility Test                              │"
    info "╰────────────────────────────────────────────────────────────────╯"
    
    info "Building package twice to verify reproducibility..."
    
    # First build
    build1_dir="$TMPDIR/astral-repro1-$pkg-$$"
    info "[1/2] First build..."
    if ! build_to_directory "$pkg" "$build1_dir"; then
        err "First build failed"
    fi
    
    # Second build
    build2_dir="$TMPDIR/astral-repro2-$pkg-$$"
    info "[2/2] Second build..."
    sleep 2  # Ensure different timestamp if not properly handled
    if ! build_to_directory "$pkg" "$build2_dir"; then
        err "Second build failed"
    fi
    
    # Compare builds
    info "Comparing build artifacts..."
    
    diff_count=0
    
    # Compare file lists
    ( cd "$build1_dir" && find . -type f | sort ) > "$TMPDIR/files1.txt"
    ( cd "$build2_dir" && find . -type f | sort ) > "$TMPDIR/files2.txt"
    
    if ! diff -q "$TMPDIR/files1.txt" "$TMPDIR/files2.txt" >/dev/null; then
        warn "  ✗ File lists differ between builds"
        diff "$TMPDIR/files1.txt" "$TMPDIR/files2.txt"
        diff_count=$((diff_count + 1))
    else
        info "  ✓ File lists identical"
    fi
    
    # Compare file contents
    while IFS= read -r file; do
        file_clean=$(printf '%s' "$file" | sed 's|^\./||')
        
        if ! cmp -s "$build1_dir/$file" "$build2_dir/$file"; then
            warn "  ✗ Content differs: $file_clean"
            diff_count=$((diff_count + 1))
            
            # Show why (timestamps, etc)
            if command -v diffoscope >/dev/null 2>&1; then
                diffoscope --text - "$build1_dir/$file" "$build2_dir/$file" 2>/dev/null | head -20
            fi
        fi
    done < "$TMPDIR/files1.txt"
    
    # Cleanup
    rm -rf "$build1_dir" "$build2_dir" "$TMPDIR/files1.txt" "$TMPDIR/files2.txt"
    
    if [ $diff_count -eq 0 ]; then
        info ""
        info "╭────────────────────────────────────────────────────────────────╮"
        info "│               ✓ BUILD IS REPRODUCIBLE                         │"
        info "╰────────────────────────────────────────────────────────────────╯"
        return 0
    else
        warn ""
        warn "╭────────────────────────────────────────────────────────────────╮"
        warn "│          ✗ BUILD IS NOT REPRODUCIBLE                          │"
        warn "│            Found $diff_count differences                              │"
        warn "╰────────────────────────────────────────────────────────────────╯"
        return 1
    fi
}

# Build to specific directory (for testing)
