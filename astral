# Helper: Handle Git sources
handle_git_source() {
    url="$1"
    buildtmp="$2"
    
    # Strip git+ prefix if present
    url_clean=$(printf '%s' "$url" | sed 's/^git+//')
    
    # Extract repository URL and ref (branch/commit/tag)
    repo_url=$(printf '%s' "$url_clean" | sed 's/#.*//')
    ref_part=$(printf '%s' "$url_clean" | sed -n 's/.*#//p')
    
    # Parse ref type (branch, commit, or tag)
    ref_type=""
    ref_value=""
    
    if [ -n "$ref_part" ]; then
        ref_type=$(printf '%s' "$ref_part" | cut -d'=' -f1)
        ref_value=$(printf '%s' "$ref_part" | cut -d'=' -f2)
    fi
    
    # Determine directory name from repo
    repo_name=$(basename "$repo_url" .git)
    dest_dir="$buildtmp/$repo_name"
    
    info "Cloning Git repository: $repo_url"
    [ -n "$ref_value" ] && info "  → Ref: $ref_type=$ref_value"
    
    # Clone repository
    if [ -n "$ref_type" ]; then
        case "$ref_type" in
            branch)
                if ! git clone --depth 1 --branch "$ref_value" "$repo_url" "$dest_dir" 2>&1; then
                    err "Failed to clone repository (branch: $ref_value)"
                fi
                ;;
            tag)
                if ! git clone --depth 1 --branch "$ref_value" "$repo_url" "$dest_dir" 2>&1; then
                    err "Failed to clone repository (tag: $ref_value)"
                fi
                ;;
            commit)
                # Clone full repo, then checkout specific commit
                if ! git clone "$repo_url" "$dest_dir" 2>&1; then
                    err "Failed to clone repository"
                fi
                ( cd "$dest_dir" && git checkout "$ref_value" ) || err "Failed to checkout commit: $ref_value"
                ;;
            *)
                warn "Unknown ref type: $ref_type, cloning default branch"
                if ! git clone --depth 1 "$repo_url" "$dest_dir" 2>&1; then
                    err "Failed to clone repository"
                fi
                ;;
        esac
    else
        # No ref specified, clone default branch
        if ! git clone --depth 1 "$repo_url" "$dest_dir" 2>&1; then
            err "Failed to clone repository"
        fi
    fi
    
    info "  ✓ Cloned: $repo_name"
}


