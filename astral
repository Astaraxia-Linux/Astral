                    ;;
            esac
        fi
    done
}

# --- Rollbacks ---
TRANSACTION_DIR="$DB_DIR/.transactions"
TRANSACTION_ENABLED=${TRANSACTION_ENABLED:-1}

# Start transaction (pure POSIX)
transaction_begin() {
    [ "$TRANSACTION_ENABLED" -eq 0 ] && return 0
    
    if command -v date >/dev/null 2>&1; then
        trans_id="$(date +%Y%m%d_%H%M%S 2>/dev/null || printf '%s' "$(portable_timestamp)")_$$"
    else
        trans_id="$(portable_timestamp)_$$"
    fi
    
    trans_dir="$TRANSACTION_DIR/$trans_id"
    
    mkdir -p "$trans_dir"/{metadata,backup,journal}
    
    cat > "$trans_dir/metadata/info" <<EOF
transaction_id=$trans_id
start_time=$(portable_timestamp)
pid=$$
user=$(portable_whoami)
status=active
EOF
    
    # Snapshot ONLY the package db, explicitly excluding .transactions to prevent
    # exponential backup growth (transactions contain backups of backups otherwise)
    if command -v tar >/dev/null 2>&1; then
        tar -cf "$trans_dir/backup/db_snapshot.tar" \
            --exclude='./.transactions' \
            -C "$DB_DIR" . 2>/dev/null || true
        if command -v gzip >/dev/null 2>&1; then
            gzip "$trans_dir/backup/db_snapshot.tar" 2>/dev/null || true
        fi
    else
        # Fallback: copy without .transactions
        find "$DB_DIR" -mindepth 1 -maxdepth 1 ! -name '.transactions' \
            -exec cp -R {} "$trans_dir/backup/db_backup/" \; 2>/dev/null || true
    fi
    
    export ASTRAL_TRANSACTION_ID="$trans_id"
    export ASTRAL_TRANSACTION_DIR="$trans_dir"
    
    info "Transaction started: $trans_id"
}

# Portable timestamp
portable_timestamp() {
    if command -v date >/dev/null 2>&1; then
        date +%s 2>/dev/null || date | cksum | awk '{print $1}'
    else
        # Fallback: use cksum of current time
        echo "$$" | cksum | awk '{print $1}'
    fi
}

# Portable whoami
portable_whoami() {
    if command -v whoami >/dev/null 2>&1; then
        whoami 2>/dev/null && return 0
    fi
    
    if command -v id >/dev/null 2>&1; then
        id -un 2>/dev/null && return 0
    fi
    
    # Fallback to environment
    printf '%s\n' "${USER:-${LOGNAME:-unknown}}"
}

# Record action in journal (pure POSIX)
transaction_log() {
    action="$1"
    target="$2"
    details="${3:-}"
    
    [ "$TRANSACTION_ENABLED" -eq 0 ] && return 0
    [ -z "$ASTRAL_TRANSACTION_ID" ] && return 0
    
    trans_dir="$ASTRAL_TRANSACTION_DIR"
    journal="$trans_dir/journal/actions.log"
    
    printf '%s|%s|%s|%s\n' "$(portable_timestamp)" "$action" "$target" "$details" >> "$journal"
}

# Commit transaction
transaction_commit() {
    [ "$TRANSACTION_ENABLED" -eq 0 ] && return 0
    [ -z "$ASTRAL_TRANSACTION_ID" ] && return 0
    
    trans_dir="$ASTRAL_TRANSACTION_DIR"
    
    if command -v sed >/dev/null 2>&1; then
        if sed -i 's/status=active/status=committed/' "$trans_dir/metadata/info" 2>/dev/null; then
            :
        elif sed -i '' 's/status=active/status=committed/' "$trans_dir/metadata/info" 2>/dev/null; then
            :
        else
            portable_sed_inplace 's/status=active/status=committed/' "$trans_dir/metadata/info"
        fi
    fi
    
    printf 'end_time=%s\n' "$(portable_timestamp)" >> "$trans_dir/metadata/info"
    
    # Delete backup now that commit succeeded — no rollback possible anyway
    rm -rf "$trans_dir/backup" 2>/dev/null || true

    # Prune old committed transactions, keep only the last 5
    if [ -d "$TRANSACTION_DIR" ]; then
        find "$TRANSACTION_DIR" -mindepth 1 -maxdepth 1 -type d | sort | head -n -5 | \
            xargs -r rm -rf 2>/dev/null || true
    fi
    
    info "Transaction committed: $ASTRAL_TRANSACTION_ID"
    
    unset ASTRAL_TRANSACTION_ID ASTRAL_TRANSACTION_DIR
}

# Portable sed -i (in-place edit)
portable_sed_inplace() {
    pattern="$1"
    file="$2"
    
    temp_file="${file}.tmp.$$"
    sed "$pattern" "$file" > "$temp_file"
    mv "$temp_file" "$file"
}

# Rollback transaction (pure POSIX)
transaction_rollback() {
    trans_id="${1:-$ASTRAL_TRANSACTION_ID}"
    
    [ -z "$trans_id" ] && err "No transaction ID specified"
    
    trans_dir="$TRANSACTION_DIR/$trans_id"
    [ ! -d "$trans_dir" ] && err "Transaction not found: $trans_id"
    
    info "╭────────────────────────────────────────────────────────────────╮"
    info "│                    TRANSACTION ROLLBACK                        │"
    info "╰────────────────────────────────────────────────────────────────╯"
    info ""
    info "Rolling back transaction: $trans_id"
    
    # Read journal in reverse (portable)
    journal="$trans_dir/journal/actions.log"
    
    if [ -f "$journal" ]; then
        portable_tac "$journal" | while IFS='|' read -r timestamp action target details; do
            info "  ← Reverting: $action on $target"
            
            case "$action" in
                install)
                    remove_pkg_only "$target" 2>/dev/null || true
                    ;;
                remove)
                    backup_file="$trans_dir/backup/${target}.tar.gz"
                    if [ -f "$backup_file" ]; then
                        if command -v tar >/dev/null 2>&1; then
                            tar -xzf "$backup_file" -C "$DB_DIR" 2>/dev/null || true
                        fi
                    fi
                    ;;
            esac
        done
    fi
    
    # Restore database snapshot (with fallbacks)
    if [ -f "$trans_dir/backup/db_snapshot.tar.gz" ]; then
        info "  ← Restoring database snapshot..."
        if command -v tar >/dev/null 2>&1 && command -v gzip >/dev/null 2>&1; then
            tar -xzf "$trans_dir/backup/db_snapshot.tar.gz" -C "$DB_DIR" 2>/dev/null || true
        fi
    elif [ -f "$trans_dir/backup/db_snapshot.tar" ]; then
        if command -v tar >/dev/null 2>&1; then
            tar -xf "$trans_dir/backup/db_snapshot.tar" -C "$DB_DIR" 2>/dev/null || true
        fi
    elif [ -d "$trans_dir/backup/db_backup" ]; then
        # Fallback: copied directory
        rm -rf "$DB_DIR"
        cp -R "$trans_dir/backup/db_backup" "$DB_DIR" 2>/dev/null || true
    fi
    
    # Mark as rolled back
    portable_sed_inplace 's/status=active/status=rolled_back/' "$trans_dir/metadata/info"
    printf 'rollback_time=%s\n' "$(portable_timestamp)" >> "$trans_dir/metadata/info"
    
    # Free the backup space
    rm -rf "$trans_dir/backup" 2>/dev/null || true
    
    info ""
    info "✓ Transaction rolled back successfully"
}

# List transactions (portable)
list_transactions() {
    filter="${1:-all}"
    
    info "╭────────────────────────────────────────────────────────────────╮"
    info "│                       Transactions                             │"
    info "╰────────────────────────────────────────────────────────────────╯"
    
    [ ! -d "$TRANSACTION_DIR" ] && { info "No transactions found"; return 0; }
    
    # Use find if available, otherwise ls
    if command -v find >/dev/null 2>&1; then
        trans_list=$(find "$TRANSACTION_DIR" -type d -mindepth 1 -maxdepth 1 2>/dev/null)
    else
        trans_list=$(ls -d "$TRANSACTION_DIR"/*/ 2>/dev/null | sed 's|/$||')
    fi
    
    for trans_dir in $trans_list; do
        [ -d "$trans_dir" ] || continue
        
        trans_id=$(basename "$trans_dir")
        info_file="$trans_dir/metadata/info"
        
        [ ! -f "$info_file" ] && continue
        
        # Source with fallback
        . "$info_file" 2>/dev/null || continue
        
        # Filter by status
        case "$filter" in
            active) [ "$status" != "active" ] && continue ;;
            committed) [ "$status" != "committed" ] && continue ;;
            rolled_back) [ "$status" != "rolled_back" ] && continue ;;
        esac
        
        # Simple output (no colors if not supported)
        printf "\nTransaction: %s\n" "$trans_id"
        printf "  Status:     %s\n" "$status"
        
        # Show action count
        if [ -f "$trans_dir/journal/actions.log" ]; then
            action_count=$(wc -l < "$trans_dir/journal/actions.log" 2>/dev/null | tr -d ' ')
            printf "  Actions:    %s\n" "$action_count"
        fi
    done
}

# Clean old transactions
clean_transactions() {
    max_age_days="${1:-30}"
    
    info "Cleaning transactions older than $max_age_days days..."
    
    cleaned=0
    now=$(date +%s)
    max_age_seconds=$((max_age_days * 86400))
    
    for trans_dir in "$TRANSACTION_DIR"/*; do
        [ -d "$trans_dir" ] || continue
        
        info_file="$trans_dir/metadata/info"
        [ ! -f "$info_file" ] && continue
        
        . "$info_file"
        
        age=$((now - start_time))
        
        if [ $age -gt $max_age_seconds ] && [ "$status" != "active" ]; then
            info "  Removing: $(basename "$trans_dir") (age: $((age / 86400)) days)"
            rm -rf "$trans_dir"
            cleaned=$((cleaned + 1))
        fi
    done
    
    info "✓ Cleaned $cleaned transactions"
}

# Recover interrupted transactions
recover_transactions() {
    info "Checking for interrupted transactions..."
    
    recovered=0
    
    for trans_dir in "$TRANSACTION_DIR"/*; do
        [ -d "$trans_dir" ] || continue
        
        info_file="$trans_dir/metadata/info"
        [ ! -f "$info_file" ] && continue
        
        . "$info_file"
        
        if [ "$status" = "active" ]; then
            # Check if process still exists
            if ! kill -0 "$pid" 2>/dev/null; then
                warn "Found interrupted transaction: $(basename "$trans_dir")"
                printf "  Rollback? [y/N]: "
                read -r response
                
                case "$response" in
                    [Yy]*)
                        transaction_rollback "$(basename "$trans_dir")"
                        recovered=$((recovered + 1))
                        ;;
                esac
            fi
        fi
    done
    
    [ $recovered -eq 0 ] && info "✓ No interrupted transactions found"
}

# --- NETWORKING / RECIPE FUNCTIONS ---
fetch_remote_recipe() {
    _pkg="$1"
    _force_repo="${2:-$REPO_CONTEXT}"
    category_pkg=""

    info "Attempting to fetch or refresh recipe for '$_pkg' from $_force_repo..."

    # Check if recipe already exists locally and is usable
    existing_rpath=$(recipe_path "$_pkg") 2>/dev/null || existing_rpath=""

    if [ -n "$existing_rpath" ]; then
        # Determine if the existing recipe is complete enough to use
        _is_complete=0
        case "$existing_rpath" in
            *.stars)
                # It's a .stars file — check it has content
                [ -s "$existing_rpath" ] && _is_complete=1
                ;;
            *)
                # It's an expanded directory — check for a build script
                [ -f "$existing_rpath/build" ] && _is_complete=1
                ;;
        esac

        if [ "$_is_complete" -eq 1 ]; then
            info "  ✓ Recipe already present locally: $existing_rpath"
            # Ensure it's expanded into a directory if it's still a raw .stars
            case "$existing_rpath" in
                *.stars)
                    _expanded_dir="${existing_rpath%.stars}"
                    _expanded_dir=$(printf '%s' "$_expanded_dir" | sed 's|-[^-]*-[^-]*$||')
                    mkdir -p "$_expanded_dir"
                    expand_stars_recipe "$existing_rpath" "$_expanded_dir" 2>/dev/null || true
                    ;;
            esac
            return 0
        fi

        # Recipe exists but is incomplete — re-derive category and re-download
        warn "  ⚠ Existing recipe for '$_pkg' is incomplete, re-fetching..."
        _raw=$(printf '%s' "$existing_rpath" | sed "s|^${RECIPES_DIR}/||")
        _cat=$(printf '%s' "$_raw" | cut -d'/' -f1)
        _pkgbase=$(basename "$_pkg")
        category_pkg="${_cat}/${_pkgbase}"
    fi

    if [ -z "$category_pkg" ]; then
        # Determine which index to search based on repo context
        case "$_force_repo" in
            asura)
                search_index="$INDEX_FILE_ASURA"
                info "  → Searching ASURA index..."
                ;;
            aoharu|*)
                search_index="$INDEX_FILE_AOHARU"
                info "  → Searching AOHARU index..."
                ;;
        esac

        # Recipe doesn't exist - check if pkg has category already
        case "$_pkg" in
            */*)
                category_pkg="$_pkg"
                ;;
            *)
                category=""
                if [ -f "$search_index" ]; then
                    # parse_index_v2 outputs: category/pkg arch version
                    # split on space: $1=category/pkg  $2=arch  $3=version
                    # extract pkg from $1 by splitting on /
                    _match=$(parse_index_v2 "$search_index" | awk -v p="$_pkg" '{n=split($1,a,"/"); if(a[n]==p) print $1}' | head -n1)
                    [ -n "$_match" ] && category=$(printf '%s' "$_match" | cut -d'/' -f1)
                    debug "fetch_remote_recipe: category lookup '$_pkg' -> '$_match' (cat='$category')"
                fi

                if [ -z "$category" ] && [ "$_force_repo" = "asura" ] && [ -f "$INDEX_FILE_AOHARU" ]; then
                    _match=$(parse_index_v2 "$INDEX_FILE_AOHARU" | awk -v p="$_pkg" '{n=split($1,a,"/"); if(a[n]==p) print $1}' | head -n1)
                    [ -n "$_match" ] && category=$(printf '%s' "$_match" | cut -d'/' -f1)
                fi

                if [ -z "$category" ] && [ "$_force_repo" = "aoharu" ] && [ -f "$INDEX_FILE_ASURA" ]; then
                    _match=$(parse_index_v2 "$INDEX_FILE_ASURA" | awk -v p="$_pkg" '{n=split($1,a,"/"); if(a[n]==p) print $1}' | head -n1)
                    [ -n "$_match" ] && category=$(printf '%s' "$_match" | cut -d'/' -f1)
                fi

                if [ -n "$category" ]; then
                    category_pkg="${category}/${_pkg}"
                else
                    warn "  ⚠ Could not find '$_pkg' in index — trying without category"
                    category_pkg="$_pkg"
                fi
                ;;
        esac
    fi

    local_dir="$RECIPES_DIR/$category_pkg"
    mkdir -p "$local_dir"

    # Build remote URL based on repo context
    case "$_force_repo" in
        asura)
            remote_base="${USER_RECIPE_RAW_URL%/}/recipes/${category_pkg}"
            ;;
        aoharu|*)
            remote_base="${RECIPE_RAW_URL%/}/recipes/${category_pkg}"
            ;;
    esac

    # Try downloading .stars file — three URL patterns:
    #   1. flat:    .../recipes/category/pkg.stars
    #   2. nested:  .../recipes/category/pkg/pkg.stars
    #   3. versioned: .../recipes/category/pkg/pkg-VER-ARCH.stars  (most common in AOHARU)
    stars_url_flat="${remote_base}.stars"
    stars_url_nested="${remote_base}/$(basename "$category_pkg").stars"
    stars_dest="${local_dir}.stars"

    # Derive versioned filename from index if possible
    stars_url_versioned=""
    _idx_to_search="$INDEX_FILE_AOHARU"
    [ "$_force_repo" = "asura" ] && _idx_to_search="$INDEX_FILE_ASURA"
    if [ -f "$_idx_to_search" ]; then
        _pkgbase=$(basename "$category_pkg")
        # parse_index_v2 outputs: category/pkg arch version
        # so fields split on '[/ ]': $1=category $2=pkg $3=arch $4=version
        _imatch=$(parse_index_v2 "$_idx_to_search" | awk -v p="$_pkgbase" '{n=split($1,a,"/"); if(a[n]==p) print}' | head -n1)
        debug "fetch_remote_recipe: index match for '$_pkgbase': '$_imatch'"
        if [ -n "$_imatch" ]; then
            _iver=$(printf '%s' "$_imatch" | awk '{print $3}')
            _iarch=$(printf '%s' "$_imatch" | awk '{print $2}')
            _iarch="${_iarch:-any}"
            _vname="${_pkgbase}-${_iver}-${_iarch}.stars"
            stars_url_versioned="${remote_base}/${_vname}"
            stars_dest_versioned="${local_dir}/${_vname}"
            debug "fetch_remote_recipe: versioned url='$stars_url_versioned'"
        fi
    fi

    # Try flat first
    if curl -fsSL "$stars_url_flat" -o "$stars_dest" 2>/dev/null && [ -s "$stars_dest" ]; then
        info "  ✓ Downloaded .stars recipe (flat): $stars_dest"
        mkdir -p "$local_dir"
        expand_stars_recipe "$stars_dest" "$local_dir"
        return 0
    fi
    rm -f "$stars_dest"

    # Try versioned (most common AOHARU layout: category/pkg/pkg-ver-arch.stars)
    if [ -n "$stars_url_versioned" ]; then
        mkdir -p "$local_dir"
        if curl -fsSL "$stars_url_versioned" -o "$stars_dest_versioned" 2>/dev/null && [ -s "$stars_dest_versioned" ]; then
            info "  ✓ Downloaded .stars recipe (versioned): $stars_dest_versioned"
            expand_stars_recipe "$stars_dest_versioned" "$local_dir"
            return 0
        fi
        rm -f "$stars_dest_versioned"
    fi

    # Try nested (category/pkg/pkg.stars)
    if curl -fsSL "$stars_url_nested" -o "$stars_dest" 2>/dev/null && [ -s "$stars_dest" ]; then
        info "  ✓ Downloaded .stars recipe (nested): $stars_dest"
        mkdir -p "$local_dir"
        expand_stars_recipe "$stars_dest" "$local_dir"
        return 0
    fi
    rm -f "$stars_dest"

    # Fallback to directory-based recipe (legacy format)
    info "  → .stars not found, trying directory-based recipe..."

    required_files="version build"
    optional_files="depends bdepends rdepends package pre_install pre_remove post_install post_remove checksums conflicts info sources"
    _fetch_ok=1

    for file in $required_files $optional_files; do
        url="$remote_base/$file"
        dest="$local_dir/$file"

        if curl -fsSL "$url" -o "$dest" 2>/dev/null && [ -s "$dest" ]; then
            :
        else
            rm -f "$dest"
            if printf '%s' "$required_files" | grep -qw "$file"; then
                warn "  ✗ Could not fetch required file '$file' for '$_pkg'"
                _fetch_ok=0
            fi
        fi
    done

    if [ "$_fetch_ok" -eq 0 ]; then
        warn "Recipe fetch failed for '$_pkg' from $_force_repo"
        return 1
    fi

    # Make scripts executable
    chmod +x "$local_dir/build" 2>/dev/null || true
    chmod +x "$local_dir/package" 2>/dev/null || true
    chmod +x "$local_dir/pre_install" 2>/dev/null || true
    chmod +x "$local_dir/pre_remove" 2>/dev/null || true
    chmod +x "$local_dir/post_install" 2>/dev/null || true
    chmod +x "$local_dir/post_remove" 2>/dev/null || true

    info "Recipe for '$_pkg' fetched from $_force_repo at $local_dir."
}

fetch_remote_recipe_stars() {
    _pkg="$1"

    info "Attempting to fetch .stars recipe for '$_pkg' from remote..."

    # Determine category
    category=""
