search_pkg_json() {
    query="$1"
    first=1
    printf '{\n  "command": "search",\n  "query": "%s",\n  "results": [\n' "$(_json_escape "$query")"

    # Local recipes - .stars files
    stars_list="$TMPDIR/astral-json-stars-$$"
    find "$RECIPES_DIR" -type f -name '*.stars' -maxdepth 3 2>/dev/null > "$stars_list"
    while IFS= read -r sf; do
        base=$(basename "$sf"); base=${base%.stars}
        pkg_name=$(printf '%s' "$base" | sed 's/-[0-9].*//')
        category=$(basename "$(dirname "$sf")")
        ver=$(printf '%s' "$base" | sed "s/^${pkg_name}-//; s/-.*//")
        [ -z "$ver" ] && ver="unknown"
        if printf '%s' "$pkg_name" | grep -qi "$query"; then
            if [ "$first" -eq 1 ]; then first=0; else printf ',\n'; fi
            printf '    {"name": "%s", "category": "%s", "version": "%s", "source": "local"}' \
                "$(_json_escape "$pkg_name")" "$(_json_escape "$category")" "$(_json_escape "$ver")"
        fi
    done < "$stars_list"
    rm -f "$stars_list"

    # Remote indexes — use parse_index_v2 so the structured format is handled correctly
    for idx in "$INDEX_FILE_AOHARU" "$INDEX_FILE_ASURA"; do
        [ -f "$idx" ] || continue
        repo_name=$(basename "$idx" | sed 's/index_//')
        parse_index_v2 "$idx" | while IFS= read -r entry; do
            fullpkg=$(printf '%s' "$entry" | awk '{print $1}')
            pkg_ver=$(printf '%s' "$entry" | awk '{print $3}')
            pkg_name=$(basename "$fullpkg")
            pkg_cat=$(dirname "$fullpkg")
            if printf '%s' "$pkg_name" | grep -qi "$query"; then
                if [ "$first" -eq 1 ]; then first=0; else printf ',\n'; fi
                printf '    {"name": "%s", "category": "%s", "version": "%s", "source": "%s"}' \
                    "$(_json_escape "$pkg_name")" "$(_json_escape "$pkg_cat")" \
                    "$(_json_escape "$pkg_ver")" "$(_json_escape "$repo_name")"
            fi
        done
    done

    printf '\n  ]\n}\n'
}

show_pkg_info_json() {
    pkg="$1"
    r=$(recipe_path "$pkg" 2>/dev/null) || r=""
    printf '{\n  "command": "info",\n  "package": "%s"' "$(_json_escape "$pkg")"

    if [ -n "$r" ]; then
        if [ -f "$r/version" ]; then
            printf ',\n  "version": "%s"' "$(_json_escape "$(cat "$r/version")")"
        fi
        if [ -f "$r/info" ]; then
            desc=$(head -n1 "$r/info")
            printf ',\n  "description": "%s"' "$(_json_escape "$desc")"
        fi
        # Installed version
        installed_ver=$(get_installed_ver "$pkg" 2>/dev/null || printf 'none')
        printf ',\n  "installed": "%s"' "$(_json_escape "$installed_ver")"
        # Dependencies
        printf ',\n  "dependencies": {'
        for deptype in depends bdepends rdepends; do
            [ -f "$r/$deptype" ] || continue
            printf '\n    "%s": [' "$deptype"
            dep_first=1
            while IFS= read -r dep; do
                [ -z "$dep" ] && continue
                if [ "$dep_first" -eq 1 ]; then dep_first=0; else printf ', '; fi
                printf '"%s"' "$(_json_escape "$dep")"
            done < "$r/$deptype"
            printf '],'
        done | sed 's/,$//'
        printf '\n  }'
        # Reverse deps
        printf ',\n  "required_by": ['
        rev_first=1
        query_reverse_dependencies "$pkg" 2>/dev/null | while IFS= read -r rdep; do
            [ -z "$rdep" ] && continue
            if [ "$rev_first" -eq 1 ]; then rev_first=0; else printf ', '; fi
            printf '"%s"' "$(_json_escape "$rdep")"
        done
        printf ']'
    else
        printf ',\n  "error": "recipe not found"'
    fi
    printf '\n}\n'
}

# rewritten... hopes that it doesnt fucking explode
# §10 — Enhanced search with fuzzy match and filter flags
# Usage: astral_search_enhanced <query> [--installed] [--category <cat>]
astral_search_enhanced() {
    _query="$1"
    _installed_only=0
    _category=""
    shift
    while [ $# -gt 0 ]; do
        case "$1" in
            --installed) _installed_only=1 ;;
            --category)  _category="$2"; shift ;;
        esac
        shift
    done

    _results=0

    # §8.1 — Read index via temp file to avoid pipe subshell
    _idx_tmpf="$TMPDIR/astral-search-idx-$$"
    [ -f "$INDEX_FILE_AOHARU" ] && cat "$INDEX_FILE_AOHARU" > "$_idx_tmpf" || : > "$_idx_tmpf"

    while IFS='|' read -r _entry _arch _ver; do
        [ -z "$_entry" ] && continue
        case "$_entry" in '#'*) continue ;; esac

        _cat=$(printf '%s' "$_entry" | cut -d/ -f1)
        _pkg=$(printf '%s' "$_entry" | cut -d/ -f2)

        # Category filter
        [ -n "$_category" ] && [ "$_cat" != "$_category" ] && continue

        # Fuzzy match: query appears anywhere in path or description
        _desc=""
        _info_file="$RECIPES_DIR/$_cat/$_pkg.stars"
        [ -f "$_info_file" ] && _desc=$(grep '^description:' "$_info_file" | cut -d: -f2-)

        case "${_entry}${_desc}" in
            *"$_query"*) ;;
            *) continue ;;
        esac

        # Installed check
        _installed_ver=$(get_installed_ver "$_pkg" 2>/dev/null) || _installed_ver="none"
        if [ "$_installed_only" -eq 1 ] && [ "$_installed_ver" = "none" ]; then
            continue
        fi

        # Output line
        if [ "$_installed_ver" != "none" ]; then
            _status="[installed: $_installed_ver]"
            _color="$GREEN"
        else
            _status=""
            _color="$NC"
        fi

        printf '%b%-40s%b %-12s %s %s\n'             "$_color" "$_entry" "$NC" "$_ver" "$_desc" "$_status"
        _results=$((_results + 1))
    done < "$_idx_tmpf"
    rm -f "$_idx_tmpf"

    if [ "$_results" -eq 0 ]; then
        info "No packages found matching '$_query'"
        info "Hint: Run 'astral -u' to update the index, then try again"
    else
        info "($_results result(s))"
    fi
}

search_pkg() {
    query="$1"
    info "Searching for package '$query'..."

    # --- Local recipes ---
    info "--- Local Recipes ($RECIPES_DIR) ---"
    found_local=0
    stars_found=""

    # Search for .stars files first (POSIX-compliant)
    # Format: pkgname-version-arch.stars
    # Use pipe but avoid subshell by using lastpipe (not POSIX) or process substitution
    # POSIX-safe approach: redirect find output to temp file, then read
    stars_list="$TMPDIR/astral-stars-list-$$"
    find "$RECIPES_DIR" -type f -name '*.stars' -maxdepth 3 2>/dev/null > "$stars_list"
    
    while read -r stars_file; do
        # Extract package name from filename (POSIX-compliant way, remove .stars suffix)
        stars_basename=$(basename "$stars_file")
        stars_basename=${stars_basename%.stars}
        pkg_name=$(printf '%s\n' "$stars_basename" | sed 's/-[0-9].*//')
        category=$(basename "$(dirname "$stars_file")")

        # Check if matches query
        if printf '%s\n' "$pkg_name" | grep -iq "$query"; then
            # Extract version from filename
            ver=$(printf '%s\n' "$stars_basename" | sed 's/^[^0-9]*//; s/-.*//')
            [ -z "$ver" ] && ver="unknown"
            printf "L: %-20s (v%s) [.stars %s]\n" "$pkg_name" "$ver" "$category"
            stars_found="$stars_found $pkg_name"
            found_local=1
        fi
    done < "$stars_list"
    rm -f "$stars_list"

    # Search for directory-based recipes (legacy format)
    # Only if not already found as .stars
    dir_list="$TMPDIR/astral-dirs-list-$$"
    find "$RECIPES_DIR" -type d -mindepth 1 -maxdepth 2 2>/dev/null > "$dir_list"
    while read -r r; do
        pkg_name=$(basename "$r")
        # Skip if already found as .stars file
        case " $stars_found " in
            *" $pkg_name "*) continue ;;
        esac
        if printf '%s\n' "$pkg_name" | grep -iq "$query"; then
            ver="unknown"
            [ -f "$r/version" ] && ver=$(cat "$r/version")
            printf "L: %-20s (v%s) [dir %s]\n" "$pkg_name" "$ver" "$(basename "$(dirname "$r")")"
            found_local=1
        fi
    done < "$dir_list"
    rm -f "$dir_list"
    
    [ "$found_local" -eq 0 ] && info "No local recipes found."


    # Remote indexes
    info "--- Remote Indexes ---"
    for idx in "$INDEX_FILE_AOHARU" "$INDEX_FILE_ASURA"; do
        [ -f "$idx" ] || continue
        while IFS= read -r line; do
            pkg_name=$(printf '%s' "$line" | awk '{print $1}')
            pkg_ver=$(printf '%s' "$line" | awk '{print $2}')
            repo_label=$(basename "$idx" | sed 's/index_//')
            if printf '%s\n' "$pkg_name" | grep -iq "$query"; then
                printf "R(%s): %-20s (v%s)\n" "$repo_label" "$pkg_name" "$pkg_ver"
            fi
        done < "$idx"
    done
}


