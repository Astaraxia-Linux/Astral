# === PACKAGE STORE ===
# Compute a content hash for a built package directory.
# Uses sha256 over sorted file contents — same files = same hash always.
store_hash() {
    _sh_pkgdir="$1"
    find "$_sh_pkgdir" -type f | sort | xargs sha256sum 2>/dev/null | sha256sum | cut -c1-40
}

# Return the store path for a given pkg+ver+hash.
# Format: $STORE_DIR/pkg-ver-hash
store_path() {
    _sp_pkg="$1"
    _sp_ver="$2"
    _sp_hash="$3"
    _sp_name=$(printf '%s' "$_sp_pkg" | tr '/' '-')
    printf '%s/%s-%s-%s\n' "$STORE_DIR" "$_sp_name" "$_sp_ver" "$_sp_hash"
}

# Install a built package into the store and symlink into INSTALL_ROOT.
# Returns the store path used.
store_install() {
    _si_pkg="$1"
    _si_pkgdir="$2"
    _si_ver="$3"

    mkdir -p "$STORE_DIR"

    # Content-address the package
    _si_hash=$(store_hash "$_si_pkgdir")
    _si_spath=$(store_path "$_si_pkg" "$_si_ver" "$_si_hash")

    if [ -d "$_si_spath" ]; then
        info "  ✓ [$_si_pkg] already in store: $_si_spath"
    else
        info "  → [$_si_pkg] adding to store..."
        mkdir -p "$_si_spath"
        tar -C "$_si_pkgdir" -cf - . | tar -C "$_si_spath" -xf - || {
            rm -rf "$_si_spath"
            err "[$_si_pkg] Failed to copy to store"
        }
        # Write a store manifest
        cat > "$_si_spath/.astral-store" <<EOF
pkg=$_si_pkg
version=$_si_ver
hash=$_si_hash
installed=$(date -u +%Y-%m-%dT%H:%M:%SZ)
EOF
        info "  ✓ [$_si_pkg] stored at $_si_spath"
    fi

    # Symlink store contents into INSTALL_ROOT
    info "  → [$_si_pkg] linking store into $INSTALL_ROOT..."
    find "$_si_spath" -not -name ".astral-store" | while read -r _src; do
        _rel=$(printf '%s' "$_src" | sed "s|^$_si_spath||")
        [ -z "$_rel" ] && continue
        _dst="$INSTALL_ROOT/$_rel"
        if [ -d "$_src" ]; then
            mkdir -p "$_dst"
        else
            # Remove old symlink/file if it points somewhere else
            if [ -L "$_dst" ] || [ -f "$_dst" ]; then
                rm -f "$_dst"
            fi
            ln -sf "$_src" "$_dst"
        fi
    done

    # Record store path in DB
    printf '%s\n' "$_si_spath" >> "$DB_DIR/.store-paths"

    printf '%s\n' "$_si_spath"
}

# Remove a package from the store and unlink from INSTALL_ROOT.
store_remove() {
    _sr_pkg="$1"
    _sr_spath="$2"

    [ -d "$_sr_spath" ] || { warn "Store path not found: $_sr_spath"; return 1; }

    info "  → [$_sr_pkg] unlinking from $INSTALL_ROOT..."
    find "$_sr_spath" -not -name ".astral-store" | while read -r _src; do
        _rel=$(printf '%s' "$_src" | sed "s|^$_sr_spath||")
        [ -z "$_rel" ] && continue
        _dst="$INSTALL_ROOT/$_rel"
        # Only remove if it's our symlink
        if [ -L "$_dst" ] && [ "$(readlink "$_dst")" = "$_src" ]; then
            rm -f "$_dst"
        fi
    done

    info "  → [$_sr_pkg] removing from store..."
    rm -rf "$_sr_spath"
    info "  ✓ [$_sr_pkg] removed from store"
}

atomic_install() {
    pkg="$1"
    pkgdir_src="$2"
    recipe_ver="$3"
    rpath="$4"              # This could be a temp expanded path!
    new_files="$5"

    # Create staging directory
    staging_root="$TMPDIR/astral-staging-$$"
    mkdir -p "$staging_root" || err "[$pkg] Failed to create staging directory"

    info "[$pkg] Installing to staging area..."

    # Install to staging first
    tar -C "$pkgdir_src" -cf - . | tar -C "$staging_root" -xf - || {
        rm -rf "$staging_root"
        err "[$pkg] Failed to extract to staging area"
    }

    # FIX: Calculate db_path correctly (handle both directory and .stars expansion)
    db_path=""
    if [ -f "$rpath/.astral_original_recipe" ]; then
        # This was expanded from .stars, read the original path
        original_rpath=$(cat "$rpath/.astral_original_recipe")
        db_path=$(printf '%s' "$original_rpath" | sed "s|^${RECIPES_DIR}/||; s|\.stars$||")
    else
        # Regular directory recipe
        db_path=$(printf '%s' "$rpath" | sed "s|^${RECIPES_DIR}/||")
    fi

    # Prepare DB entry (but don't commit yet)
    db_target="$DB_DIR/$db_path"
    db_staging="$TMPDIR/astral-db-staging-$$"
    mkdir -p "$db_staging"

    printf '%s\n' "$recipe_ver" > "$db_staging/version"
    printf '%s\n' "$new_files" > "$db_staging/files"
    buildtmp_parent="$(dirname "$pkgdir_src")"
    [ -f "$buildtmp_parent/depends" ] && cp "$buildtmp_parent/depends" "$db_staging/depends"
    [ -f "$buildtmp_parent/bdepends" ] && cp "$buildtmp_parent/bdepends" "$db_staging/bdepends"
    [ -f "$buildtmp_parent/rdepends" ] && cp "$buildtmp_parent/rdepends" "$db_staging/rdepends"

    # ATOMIC COMMIT: Move files and DB together
    info "[$pkg] Committing installation atomically..."

    if [ "${STORE_MODE:-0}" = "1" ]; then
        # Store mode: content-address into $STORE_DIR, symlink into $INSTALL_ROOT
        _spath=$(store_install "$pkg" "$staging_root" "$recipe_ver") || {
            rm -rf "$staging_root" "$db_staging"
            err "[$pkg] Store installation failed"
        }
        printf '%s\n' "$_spath" > "$db_staging/store_path"
    else
        # Traditional mode: merge directly into INSTALL_ROOT
        if ! ( cd "$staging_root" && tar cf - . ) | ( cd "$INSTALL_ROOT" && tar xf - ); then
            rm -rf "$staging_root" "$db_staging"
            err "[$pkg] Failed to install files atomically"
        fi
    fi

    # Finally, commit DB (last step - if this fails files are there but untracked)
    mkdir -p "$db_target"
    mv "$db_staging/version" "$db_target/version" || {
        warn "[$pkg] DB commit failed - package installed but not tracked!"
        rm -rf "$staging_root" "$db_staging"
        err "[$pkg] Database commit failed"
    }
    mv "$db_staging/files" "$db_target/files"
    [ -f "$db_staging/depends" ] && mv "$db_staging/depends" "$db_target/depends"
    [ -f "$db_staging/bdepends" ] && mv "$db_staging/bdepends" "$db_target/bdepends"
    [ -f "$db_staging/rdepends" ] && mv "$db_staging/rdepends" "$db_target/rdepends"
    [ -f "$db_staging/store_path" ] && mv "$db_staging/store_path" "$db_target/store_path"
    update_files_index_for_pkg "$db_path"

    # Cleanup
    rm -rf "$staging_root" "$db_staging"

    info "[$pkg] ✓ Atomic installation complete"
}

# Extracts dependency names from the depends file, filtering comments and empty lines.
get_pkg_deps() {
    pkg="$1"

    # Legacy depends file (both build and runtime)
    legacy_deps=$(get_legacy_deps "$pkg")

    # New split format
    build_deps=$(get_build_deps "$pkg")
    runtime_deps=$(get_runtime_deps "$pkg")

    # Combine and deduplicate
    printf '%s\n%s\n%s\n' "$legacy_deps" "$build_deps" "$runtime_deps" | \
        grep -v '^[[:space:]]*$' | sort -u
}

get_legacy_deps() {
    _pkg="$1"
    depfile=""

    pkg_path=$(resolve_installed_path "$_pkg") 2>/dev/null || pkg_path="$_pkg"
    depfile="$DB_DIR/$pkg_path/depends"

    if [ ! -f "$depfile" ]; then
        rpath=$(recipe_path "$_pkg") 2>/dev/null || rpath=""
        [ -n "$rpath" ] && depfile="$rpath/depends"
    fi

    [ -f "$depfile" ] || return 0
    grep -v '^[[:space:]]*#' "$depfile" | grep -E -v '^[[:space:]]*$' | awk '{print $1}' || true
}

