# === SAT SOLVER FOR DEPENDENCY RESOLUTION ===
# Basic 2-SAT solver for handling version constraints

# Package constraint format: pkg operator version
# Example: gcc >= 11.0.0
# Stored as: pkg|operator|version

sat_constraints=""
sat_packages=""

add_sat_constraint() {
    pkg="$1"
    operator="$2"  # =, >=, <=, >, <
    version="$3"
    
    constraint="${pkg}|${operator}|${version}"
    sat_constraints="$sat_constraints $constraint"
}

find_satisfying_version() {
    pkg="$1"
    
    # Find all available versions in recipes
    available_versions=""
    
    # Check RECIPES_DIR for versioned directories
    # Format: /recipes/category/pkg/pkg-vX.Y.Z
    pkg_base=$(basename "$pkg")
    category=$(dirname "$pkg" | sed "s|^${RECIPES_DIR}/||")
    
    if [ -d "$RECIPES_DIR/$category/$pkg_base" ]; then
        for version_dir in "$RECIPES_DIR/$category/$pkg_base"/*; do
            [ -d "$version_dir" ] || continue
            version_name=$(basename "$version_dir")
            
            # Extract version: pkg-v1.2.3 -> 1.2.3
            version_num=$(printf '%s' "$version_name" | sed "s/^${pkg_base}-v//")
            
            if [ -f "$version_dir/version" ]; then
                version_num=$(cat "$version_dir/version")
            fi
            
            available_versions="$available_versions $version_num"
        done
    fi
    
    # No constraints? Return latest
    if [ -z "$sat_constraints" ]; then
        printf '%s\n' "$available_versions" | tr ' ' '\n' | sort -V | tail -n1
        return 0
    fi
    
    # Filter by constraints
    for version in $available_versions; do
        satisfies_all=1
        
        # Check each constraint
        for constraint in $sat_constraints; do
            constraint_pkg=$(printf '%s' "$constraint" | cut -d'|' -f1)
            constraint_op=$(printf '%s' "$constraint" | cut -d'|' -f2)
            constraint_ver=$(printf '%s' "$constraint" | cut -d'|' -f3)
            
            # Skip if constraint is for different package
            [ "$constraint_pkg" != "$pkg" ] && continue
            
            # Check if this version satisfies constraint
            if ! version_compare "$version" "$constraint_op" "$constraint_ver"; then
                satisfies_all=0
                break
            fi
        done
        
        if [ $satisfies_all -eq 1 ]; then
            printf '%s\n' "$version"
            return 0
        fi
    done
    
    # No satisfying version found
    return 1
}

resolve_sat_dependencies() {
    pkg="$1"
    
    info "Running SAT solver for: $pkg"
    
    # Collect all constraints from dependency tree
    sat_constraints=""
    collect_constraints_recursive "$pkg"
    
    # Find satisfying versions for all packages
    packages_to_install=""
    
    for pkg_name in $sat_packages; do
        best_version=$(find_satisfying_version "$pkg_name")
        
        if [ -z "$best_version" ]; then
            err "SAT solver: No version of $pkg_name satisfies all constraints"
        fi
        
        info "  SAT: Selected $pkg_name-$best_version"
        packages_to_install="$packages_to_install ${pkg_name}:${best_version}"
    done
    
    printf '%s\n' "$packages_to_install"
}

# §2.2 — Two-phase flat dependency resolver
# Replaces the recursive VISITED_PACKAGES approach which misidentifies shared
# deps as circular (diamond dep problem). Uses an iterative queue instead.
#
# collect_deps <pkg> [repo]
# Populates DEP_QUEUE, DEP_VISITED, DEP_CONSTRAINTS (global, reset each call)
collect_deps() {
    _root="$1"
    _repo="${2:-aoharu}"

    DEP_QUEUE="$_root"
    DEP_VISITED=""
    DEP_CONSTRAINTS=""

    while [ -n "$DEP_QUEUE" ]; do
        # Pop first item off queue (no arrays --- pure POSIX)
        _pkg=$(printf '%s' "$DEP_QUEUE" | cut -d' ' -f1)
        _rest=$(printf '%s' "$DEP_QUEUE" | cut -d' ' -f2-)
        [ "$_pkg" = "$_rest" ] && _rest=""
        DEP_QUEUE="$_rest"

        # Skip already visited (handles diamond deps naturally)
        case " $DEP_VISITED " in
            *" $_pkg "*) continue ;;
        esac
        DEP_VISITED="$DEP_VISITED $_pkg"

        # Fetch recipe if not local
        _rpath=$(recipe_path "$_pkg" 2>/dev/null) || {
            fetch_remote_recipe "$_pkg" "$_repo" 2>/dev/null || {
                warn "[$_pkg] Recipe not found, skipping"
                continue
            }
            _rpath=$(recipe_path "$_pkg")
        }

        # Expand .stars if needed
        case "$_rpath" in
            *.stars)
                _tmp="$TMPDIR/astral-dep-expand-$$-$_pkg"
                expand_stars_recipe "$_rpath" "$_tmp" "$_pkg"
                _rpath="$_tmp"
                ;;
        esac

        # Read all dep types into one stream
        for _depfile in depends bdepends rdepends; do
            [ -f "$_rpath/$_depfile" ] || continue
            while IFS= read -r _depline; do
                case "$_depline" in ''|'#'*) continue ;; esac
                _dep=$(printf '%s' "$_depline" | awk '{print $1}')
                _constraint=$(printf '%s' "$_depline" | cut -d' ' -f2-)
                [ -z "$_dep" ] && continue
                # Record constraint as pkg:dep:constraint
                DEP_CONSTRAINTS="${DEP_CONSTRAINTS}${_pkg}:${_dep}:${_constraint} "
                # Enqueue dep if not yet visited
                case " $DEP_VISITED " in
                    *" $_dep "*) ;;
                    *) DEP_QUEUE="$DEP_QUEUE $_dep" ;;
                esac
            done < "$_rpath/$_depfile"
        done
    done
}

# resolve_install_order — call after collect_deps; prints install order (deepest deps first)
resolve_install_order() {
    printf '%s' "$DEP_CONSTRAINTS" | grep . | \
        awk -F: '{print $2}' | \
        awk '!seen[$0]++'   # deduplicate, preserve first-seen order
}

collect_constraints_recursive() {
    pkg="$1"
    
    # Add to package list
    case " $sat_packages " in
        *" $pkg "*) return 0 ;;
    esac
    sat_packages="$sat_packages $pkg"
    
    # Get dependencies with version constraints
    rpath=$(recipe_path "$pkg") 2>/dev/null || return 0
    
    for dep_file in depends bdepends rdepends; do
        [ -f "$rpath/$dep_file" ] || continue
        
        while IFS= read -r depline; do
            depline=$(printf '%s' "$depline" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')
            [ -z "$depline" ] && continue
            case "$depline" in \#*) continue ;; esac
            
            dep_pkg=$(printf '%s' "$depline" | awk '{print $1}')
            dep_op=$(printf '%s' "$depline" | awk '{print $2}')
            dep_ver=$(printf '%s' "$depline" | awk '{print $3}')
            
            if [ -n "$dep_op" ] && [ -n "$dep_ver" ]; then
                add_sat_constraint "$dep_pkg" "$dep_op" "$dep_ver"
            fi
            
            collect_constraints_recursive "$dep_pkg"
        done < "$rpath/$dep_file"
    done
}

# --- BUILD / SYNC ---
# Depth counter for sync_pkg_recursive call stack
_SYNC_DEPTH=0

# Save current frame at depth N
_sync_push() {
    _d="$_SYNC_DEPTH"
    eval "_sf_${_d}_this_pkg=\"\$_this_pkg\""
    eval "_sf_${_d}_this_force=\"\$_this_force\""
    eval "_sf_${_d}_this_explicit=\"\$_this_explicit\""
    eval "_sf_${_d}_this_repo=\"\$_this_repo\""
    eval "_sf_${_d}_CALL_PKG=\"\${CALL_PKG:-}\""
    eval "_sf_${_d}_CALL_FORCE=\"\${CALL_FORCE:-}\""
    eval "_sf_${_d}_CALL_EXPLICIT=\"\${CALL_EXPLICIT:-}\""
    eval "_sf_${_d}_CALL_REPO=\"\${CALL_REPO:-}\""
    eval "_sf_${_d}_CALL_PKG_CLEAN=\"\${CALL_PKG_CLEAN:-}\""
    eval "_sf_${_d}_CURRENT_PKG=\"\${CURRENT_PKG:-}\""
    eval "_sf_${_d}_recipe_dir=\"\${recipe_dir:-}\""
    eval "_sf_${_d}_expanded_rpath=\"\${expanded_rpath:-}\""
    eval "_sf_${_d}_stars_temp=\"\${stars_temp:-}\""
    eval "_sf_${_d}_recipe_ver=\"\${recipe_ver:-}\""
    eval "_sf_${_d}_REPO_CONTEXT=\"\$REPO_CONTEXT\""
    _SYNC_DEPTH=$((_SYNC_DEPTH + 1))
}

# Restore frame and return
_sync_restore() {
    _rc="${1:-0}"
    _SYNC_DEPTH=$((_SYNC_DEPTH - 1))
    _d="$_SYNC_DEPTH"
    eval "_this_pkg=\"\$_sf_${_d}_this_pkg\""
    eval "_this_force=\"\$_sf_${_d}_this_force\""
    eval "_this_explicit=\"\$_sf_${_d}_this_explicit\""
    eval "_this_repo=\"\$_sf_${_d}_this_repo\""
    eval "CALL_PKG=\"\$_sf_${_d}_CALL_PKG\""
    eval "CALL_FORCE=\"\$_sf_${_d}_CALL_FORCE\""
    eval "CALL_EXPLICIT=\"\$_sf_${_d}_CALL_EXPLICIT\""
    eval "CALL_REPO=\"\$_sf_${_d}_CALL_REPO\""
    eval "CALL_PKG_CLEAN=\"\$_sf_${_d}_CALL_PKG_CLEAN\""
    eval "CURRENT_PKG=\"\$_sf_${_d}_CURRENT_PKG\""
    eval "recipe_dir=\"\$_sf_${_d}_recipe_dir\""
    eval "expanded_rpath=\"\$_sf_${_d}_expanded_rpath\""
    eval "stars_temp=\"\$_sf_${_d}_stars_temp\""
    eval "recipe_ver=\"\$_sf_${_d}_recipe_ver\""
    eval "REPO_CONTEXT=\"\$_sf_${_d}_REPO_CONTEXT\""
    return "$_rc"
}

sync_pkg_recursive() {
    LOG="$LOG_SYNC_FILE"
    info "View astral logs in $LOG"

    # Push parent frame BEFORE overwriting _this_* with our args
    _sync_push

    # Capture positional args for this invocation
    _this_pkg="$1"
    _this_force="${2:-$FORCE_BUILD}"
    _this_explicit="${3:-0}"
    _this_repo="${4:-$REPO_CONTEXT}"
    # Log entry with all parameters
    {
        echo "==== ENTER sync_pkg_recursive ===="
        echo "Timestamp: $(date '+%H:%M:%S.%N')"
        echo "PID: $$"
        echo "Parameters:"
        echo "  \$1 (pkg):      '$_this_pkg'"
        echo "  \$2 (force):    '$_this_force'"
        echo "  \$3 (explicit): '$_this_explicit'"
        echo "  \$4 (repo):     '$_this_repo'"
        echo "Global state:"
        echo "  VISITED_PACKAGES: '$VISITED_PACKAGES'"
        echo "  REPO_CONTEXT: '$REPO_CONTEXT'"
        echo ""
    } >> "$LOG"
    
    # Set frame variables from captured args
    CALL_PKG="$_this_pkg"
    CALL_FORCE="$_this_force"
    CALL_EXPLICIT="$_this_explicit"
    CALL_REPO="$_this_repo"

    if [ "$CALL_EXPLICIT" -eq 1 ] && [ "${SKIP_CONFIRMATION:-0}" -eq 0 ]; then
        interactive_dep_menu "$CALL_PKG" 0
    fi

    echo "Saved to local vars:" >> "$LOG"
    echo "  CALL_PKG='$CALL_PKG'" >> "$LOG"
    echo "  CALL_EXPLICIT='$CALL_EXPLICIT'" >> "$LOG"
    echo "" >> "$LOG"
    
    # Sanitize
    CALL_PKG_CLEAN=$(sanitize_pkg_name "$CALL_PKG")
    echo "After sanitize: CALL_PKG_CLEAN='$CALL_PKG_CLEAN'" >> "$LOG"
    echo "" >> "$LOG"
    
    if check_if_user_skipped "$CALL_PKG_CLEAN"; then
        _sync_restore 0; return
    fi

    # Already visited this package in a prior branch — skip, don't error (diamond dep)
    case " $VISITED_PACKAGES " in
        *" $CALL_PKG_CLEAN "*) _sync_restore 0; return ;;
    esac

    # True circular dependency check — is this pkg currently on the active call stack?
    case " $DEP_CALL_STACK " in
        *" $CALL_PKG_CLEAN "*)
            echo "ERROR: Circular dependency!" >> "$LOG"
            err "[$CALL_PKG_CLEAN] CIRCULAR DEPENDENCY DETECTED! Stack: $DEP_CALL_STACK -> $CALL_PKG_CLEAN"
            ;;
    esac

    VISITED_PACKAGES="$VISITED_PACKAGES $CALL_PKG_CLEAN"
    DEP_CALL_STACK="$DEP_CALL_STACK $CALL_PKG_CLEAN"
    echo "Updated VISITED_PACKAGES: '$VISITED_PACKAGES'" >> "$LOG"
    echo "Updated DEP_CALL_STACK:   '$DEP_CALL_STACK'" >> "$LOG"
    echo "" >> "$LOG"
    
    # Set repo context
    if [ "$_this_explicit" -eq 0 ]; then
        REPO_CONTEXT="aoharu"
        info "[$CALL_PKG_CLEAN] Dependency - using AOHARU repository"
        echo "Set REPO_CONTEXT=aoharu (dependency)" >> "$LOG"
    else
        EXPLICIT_PKG_REPO="$REPO_CONTEXT"
        echo "Kept REPO_CONTEXT=$REPO_CONTEXT (explicit)" >> "$LOG"
    fi
    echo "" >> "$LOG"

    CURRENT_PKG="$CALL_PKG_CLEAN"
    export CURRENT_PKG

    
    # === EARLY EXIT CONDITIONS ===
    echo "Checking early exit conditions (CALL_EXPLICIT=$CALL_EXPLICIT)..." >> "$LOG"
    if [ "$_this_explicit" -eq 0 ]; then
        echo "  This is a dependency, checking early exits..." >> "$LOG"
        
        # Already installed?
        if is_pkg_installed "$CALL_PKG_CLEAN"; then
            installed_ver=$(get_installed_ver "$CALL_PKG_CLEAN")
            info "Dependency '$CALL_PKG_CLEAN' already installed ($installed_ver). Skipping."
            echo "  EARLY EXIT: Already installed" >> "$LOG"
            echo "==== EXIT (already installed) ====" >> "$LOG"
            echo "" >> "$LOG"
            _sync_restore 0; return
        fi
        
        # Virtual?
        if check_virtual "$CALL_PKG_CLEAN"; then
            echo "  EARLY EXIT: Virtual satisfied" >> "$LOG"
            echo "==== EXIT (virtual) ====" >> "$LOG"
            echo "" >> "$LOG"
            _sync_restore 0; return
        fi
        
        # Host provided?
        if [ "$CALL_FORCE" -eq 0 ] && check_host_dependency "$CALL_PKG_CLEAN"; then
            info "Dependency '$CALL_PKG_CLEAN' satisfied by host. Skipping build/fetch."
            echo "  EARLY EXIT: Host provided" >> "$LOG"
            echo "==== EXIT (host provided) ====" >> "$LOG"
            echo "" >> "$LOG"
            _sync_restore 0; return
        fi
        
        echo "  No early exit, continuing..." >> "$LOG"
    else
        echo "  This is explicit install, no early exit" >> "$LOG"
    fi
    
    # === FETCH RECIPE ===
    # Check if a complete, usable recipe exists locally
    _existing_rpath=$(recipe_path "$CALL_PKG_CLEAN" 2>/dev/null) || _existing_rpath=""
    _recipe_ok=0
    if [ -n "$_existing_rpath" ]; then
        case "$_existing_rpath" in
            *.stars) [ -s "$_existing_rpath" ] && _recipe_ok=1 ;;
            *)       [ -f "$_existing_rpath/build" ] && _recipe_ok=1 ;;
        esac
    fi

    if [ "$_recipe_ok" -eq 0 ]; then
        if ! fetch_remote_recipe "$CALL_PKG_CLEAN" "$REPO_CONTEXT"; then
            if [ "$CALL_EXPLICIT" -eq 0 ] && [ "$REPO_CONTEXT" = "asura" ]; then
                info "[$CALL_PKG_CLEAN] Not found in ASURA, falling back to AOHARU..."
                fetch_remote_recipe "$CALL_PKG_CLEAN" "aoharu" || err "[$CALL_PKG_CLEAN] Recipe not found"
            else
                err "[$CALL_PKG_CLEAN] Recipe not found in $REPO_CONTEXT"
            fi
        fi
    fi
    
    recipe_dir=$(recipe_path "$CALL_PKG_CLEAN") || err "[$CALL_PKG_CLEAN] Recipe not found after fetch"
    
    # Expand .stars if needed
    expanded_rpath="$recipe_dir"
    stars_temp=""
    if [ -f "$recipe_dir" ]; then
        case "$recipe_dir" in
            *.stars)
                stars_temp="$TMPDIR/astral-stars-expand-$CALL_PKG_CLEAN-$$"
                echo "  Expanding .stars to: $stars_temp" >> "$LOG"
                expand_stars_recipe "$recipe_dir" "$stars_temp" "$CALL_PKG_CLEAN"
                expanded_rpath="$stars_temp"
                ;;
        esac
    fi

    # Get version and check mask
    recipe_ver=$(cat "$expanded_rpath/version" 2>/dev/null || printf 'unknown')
    if is_masked "$CALL_PKG_CLEAN" "$recipe_ver"; then
        [ -n "$stars_temp" ] && rm -rf "$stars_temp"
        err "[$CALL_PKG_CLEAN] Package version $recipe_ver is MASKED"
    fi

    # === RESOLVE DEPENDENCIES ===
    # Collect dependencies
    deps_list=""
    if [ -f "$expanded_rpath/depends" ] || [ -f "$expanded_rpath/bdepends" ] || [ -f "$expanded_rpath/rdepends" ]; then
        deps_list=$(
            {
                [ -f "$expanded_rpath/depends" ] && cat "$expanded_rpath/depends"
                [ -f "$expanded_rpath/bdepends" ] && cat "$expanded_rpath/bdepends"
                [ -f "$expanded_rpath/rdepends" ] && cat "$expanded_rpath/rdepends"
            } | grep -v '^[[:space:]]*#' | grep -v '^[[:space:]]*$' | awk '{print $1}' | tr '\n' ' '
        )
    else
        deps_list=$(get_pkg_deps "$CALL_PKG_CLEAN" 2>/dev/null | tr '\n' ' ')
    fi
    
    # Process each dependency
    dep_count=0
    for dep in $deps_list; do
        dep=$(printf '%s' "$dep" | tr -d '[:space:]')
        [ -z "$dep" ] && continue
        
        dep_count=$((dep_count + 1))
        
        # Skip if already installed or visited in another branch (diamond dep — not a cycle)
        case " $VISITED_PACKAGES " in
            *" $dep "*) continue ;;
        esac

        # True cycle: dep is on the active call stack right now
        case " $DEP_CALL_STACK " in
            *" $dep "*)
                [ -n "$stars_temp" ] && rm -rf "$stars_temp"
                err "[$CALL_PKG_CLEAN] Circular dependency detected: $dep is an ancestor (stack: $DEP_CALL_STACK)"
                ;;
        esac
        
        # Recursively install dependency
        if ! sync_pkg_recursive "$dep" "$CALL_FORCE" 0 "$REPO_CONTEXT"; then
            [ -n "$stars_temp" ] && rm -rf "$stars_temp"
            err "[$CALL_PKG_CLEAN] Failed to install dependency: $dep"
        fi
    done
    
    # === CHECK IF THIS WAS A DEPENDENCY CALL ===
    if [ "$_this_explicit" -eq 0 ]; then
        [ -n "$stars_temp" ] && rm -rf "$stars_temp"
        _sync_restore 0; return
    fi
    
    # === CHECK IF ALREADY INSTALLED ===
    installed_ver=$(get_installed_ver "$CALL_PKG")
    if [ "$installed_ver" = "$recipe_ver" ] && [ "$CALL_FORCE" -eq 0 ]; then
        info "Package '$CALL_PKG' already installed at version $installed_ver."
        [ -n "$stars_temp" ] && rm -rf "$stars_temp"
        
        if [ "$CALL_EXPLICIT" -eq 1 ]; then
            is_in_world "$CALL_PKG" || add_to_world "$CALL_PKG"
        fi
        _sync_restore 0; return
    fi
    
    # === BUILD THE PACKAGE ===
    info "[$CALL_PKG] Building version $recipe_ver (from $REPO_CONTEXT)..."
    
    # Special handling for ccache
    if [ "$CALL_PKG_CLEAN" = "ccache" ] || [ "$CALL_PKG_CLEAN" = "dev-util/ccache" ]; then
        INSTALLING_CCACHE=1
        export INSTALLING_CCACHE
    fi

    build_from_recipe_enhanced "$_this_pkg" "$CALL_FORCE"
    
    unset INSTALLING_CCACHE
    
    # Cleanup
    [ -n "$stars_temp" ] && rm -rf "$stars_temp"
    
    # Pop this package from the active call stack now that we're done
    DEP_CALL_STACK=$(printf '%s' "$DEP_CALL_STACK" | sed "s/ $CALL_PKG_CLEAN\b//g" | sed 's/  */ /g')

    # Add to world if explicit
    if [ "$_this_explicit" -eq 1 ]; then
        add_to_world "$_this_pkg"
    fi

    _sync_restore 0; return
}

# === ASURA OVERLAY SYSTEM ===
# ASURA is a overlay on top of AOHARU
# explicit package from ASURA, dependencies from AOHARU
sync_pkg_asura() {
    _pkg="$1"
    FORCE_CMD=${2:-0}
    IS_EXPLICIT=${3:-0}

    if [ -z "$USER_RECIPE_RAW_URL" ]; then
        err "USER_RECIPE_RAW_URL not configured in $CONFIG_FILE. Cannot sync from ASURA."
    fi

    info "╭───────────────────────────────────────────────────────────────────╮"
    info "│ ASURA: Astaraxia User Repository For all (Community Overlay)      │"
    info "├───────────────────────────────────────────────────────────────────┤"
    info "│ Package:      $_pkg (from ASURA)                                  │"
    info "│ Dependencies: Fetched from AOHARU (official, trusted)             │"
    info "│ Security:     ASURA packages are user-contributed.                │"
    info "╰───────────────────────────────────────────────────────────────────╯"
    warn "Review package before installing: astral --inspect $_pkg"

    # Set ASURA context for the main package only
    REPO_CONTEXT="asura"

    sync_pkg_recursive "$_pkg" "$FORCE_CMD" "$IS_EXPLICIT" "asura"

    # Reset to AOHARU
    REPO_CONTEXT="aoharu"
    info "✓ ASURA sync complete, context reset to AOHARU"
}

# §7.2 — Inject use() helper into build environment for optional deps
# Must be called just before sourcing the build script.
# Writes a use() function definition to a temp file that the build script sources.
astral_inject_use_helpers() {
    _use_helper="$TMPDIR/astral-use-helper-$$"
    # Pure POSIX: write use() to a sourced file (export -f is bash-only)
    printf 'use() { case " $USE_FLAGS " in *" $1 "*) return 0;; *) return 1;; esac; }\n'         > "$_use_helper"
    printf '. %s\n' "$_use_helper"  # caller must eval this output
    # Caller: eval "$(astral_inject_use_helpers)"
}

build_from_recipe_enhanced() {
    _pkg="$1"
    FORCE_CMD=${2:-$FORCE_BUILD}
    
    transaction_begin

    rpath=$(recipe_path "$_pkg") || err "recipe $_pkg not found"
    
    pkg="$_pkg"

    # Handle .stars format
    is_stars_recipe=0
    stars_temp=""
    
    if [ -f "$rpath" ]; then
        case "$rpath" in
            *.stars)
                is_stars_recipe=1
                info "[$_pkg] Using .stars recipe format"
                stars_temp="$TMPDIR/astral-stars-$_pkg-$$"
                expand_stars_recipe "$rpath" "$stars_temp"
                rpath="$stars_temp"
                trap "rm -rf '$stars_temp'" EXIT
                ;;
        esac
    fi
    
    recipe_ver="unknown"
    [ -f "$rpath/version" ] && recipe_ver=$(cat "$rpath/version")
    installed_ver=$(get_installed_ver "$_pkg")

    # Check if already installed
    if [ "$installed_ver" != "none" ]; then
        if [ "$installed_ver" = "$recipe_ver" ] && [ "$FORCE_CMD" -eq 0 ]; then
            info "Package '$_pkg' is already installed at version $installed_ver. Skipping."
            return 0
        elif [ "$FORCE_CMD" -eq 1 ]; then
            info "Force rebuilding $_pkg."
        else
            info "Upgrading '$_pkg' from $installed_ver to $recipe_ver..."
        fi
    else
        info "Installing '$_pkg' version $recipe_ver..."
    fi
    
    # Safety checks — print banner once
    cat >&2 <<SAFETY_WARNING
───────────────────────────────────────────────────────────────
⚠️  SAFETY CHECK: $_pkg
───────────────────────────────────────────────────────────────
WARNING: These checks provide BASIC protection only.
They can be bypassed by determined attackers.
DO NOT run untrusted packages without review.
───────────────────────────────────────────────────────────────
SAFETY_WARNING
    check_script_safety "$rpath/build" "$_pkg" "verbose"
    { [ -f "$rpath/package" ] && check_script_safety "$rpath/package" "$_pkg"; } || true
    { [ -f "$rpath/pre_install" ] && check_script_safety "$rpath/pre_install" "$_pkg"; } || true
    { [ -f "$rpath/post_install" ] && check_script_safety "$rpath/post_install" "$_pkg"; } || true

    # Deep safety check
    if ! deep_recipe_check "$_pkg" "$rpath"; then
        transaction_rollback
        err "Safety checks failed for $_pkg"
    fi

    # Advanced security analysis (opt-in: SAFETY_ADVANCED_SCRIPT_CHECK=1 in astral.stars)
    advanced_script_safety_check "$_pkg" "$rpath"

    # Setup sandbox
    buildtmp="$TMPDIR/astral-build-$_pkg-$$"
    sandbox_root="$TMPDIR/astral-sandbox-$_pkg-$$"
    
    mkdir -p "$buildtmp" "$sandbox_root"
    if [ -d "$rpath" ]; then
        cp -a "$rpath"/* "$buildtmp"/ 2>/dev/null || true
    else
        err "Directory recipe structure not found for $_pkg."
    fi
    cd "$buildtmp" || err "cd failed"

    trap "rm -rf '$buildtmp'" EXIT

    create_sandbox "$buildtmp" "$sandbox_root"

    # §3 — Use parallel downloader; falls back to serial if mkfifo unavailable
    parallel_download_sources "$rpath" "$buildtmp"
    verify_checksums_and_extract "$_pkg" "$rpath" "$buildtmp"
    
    transaction_log "install" "$_pkg" "version=$(cat "$rpath/version")"

    # Take filesystem snapshot BEFORE build
    snapshot_before="$TMPDIR/astral-snapshot-before-$$"
    take_fs_snapshot "$snapshot_before"

        git_dir=""
    if [ -d "$buildtmp/$_pkg" ]; then
        # Directory named after package exists (likely Git clone)
        git_dir="$buildtmp/$_pkg"
        info "Detected Git clone directory: $_pkg"
    else
        # Look for any Git repositories in buildtmp
        for dir in "$buildtmp"/*; do
            [ -d "$dir" ] || continue
            if [ -d "$dir/.git" ]; then
                git_dir="$dir"
                info "Detected Git repository: $(basename "$git_dir")"
                break
            fi
        done
    fi
    
    # Export GIT_DIR for build scripts
    if [ -n "$git_dir" ]; then
        export ASTRAL_GIT_DIR="$(basename "$git_dir")"
        export ASTRAL_PKG_NAME="$_pkg"
    fi

        info "Building in isolated sandbox..."

    if [ -f "./build" ]; then
        chmod +x ./build || true
        PKGDIR="$buildtmp/pkg"
        mkdir -p "$PKGDIR"
        
        info "Starting isolated build for $_pkg..."
        
        save_build_state "$_pkg" "configure" "$buildtmp" "$recipe_ver"

        # Use git_dir as working dir if this is a git source, otherwise buildtmp root
        _build_workdir="$buildtmp"
        [ -n "$git_dir" ] && [ -d "$git_dir" ] && _build_workdir="$git_dir"
        
        # Run build script from correct dir — recipes do their own cd for tarballs
        (
            cd "$_build_workdir" || exit 1
            export DESTDIR="$PKGDIR"
            export PKGDIR="$PKGDIR"
            export MAKEFLAGS="$MAKEFLAGS"
            export CFLAGS="$CFLAGS"
            export CXXFLAGS="$CXXFLAGS"
            export LDFLAGS="$LDFLAGS"
            . "$buildtmp/build"
        ) || { transaction_rollback; err "build failed for $_pkg"; }
        
        save_build_state "$_pkg" "build" "$buildtmp" "$recipe_ver"

        if [ -f "$buildtmp/package" ]; then
            info "Running package hook for $_pkg..."
            (
                cd "$_build_workdir" || exit 1
                export DESTDIR="$PKGDIR"
                export PKGDIR="$PKGDIR"
                . "$buildtmp/package"
            ) || { transaction_rollback; err "package() failed for $_pkg"; }
        fi
        
        save_build_state "$_pkg" "package" "$buildtmp" "$recipe_ver"

        # FEATURE 2: Take snapshot AFTER build and detect ghost files
        snapshot_after="$TMPDIR/astral-snapshot-after-$$"
        take_fs_snapshot "$snapshot_after"
        detect_ghost_files "$snapshot_before" "$snapshot_after" "$_pkg"
        rm -f "$snapshot_before" "$snapshot_after"

        # FEATURE 4: Strip binaries if enabled
        strip_binaries "$PKGDIR" "$_pkg"

        create_meta "$_pkg" "$recipe_ver" "x86_64" "$PKGDIR"

        new_files=$(
            ( cd "$PKGDIR" && find . -mindepth 1 -print ) \
            | sed 's/^\.\///' \
            | grep -v '^\.astral-meta$' \
            || true
        )

        # FEATURE 3: Enhanced collision detection
        check_file_conflicts_advanced "$_pkg" "$PKGDIR" "$FORCE_CMD"
        
        # Run pre_install hook before installation
        if [ -f "$buildtmp/pre_install" ]; then
            info "Running pre_install hook for $_pkg..."
            ( DESTDIR="$INSTALL_ROOT" PKGDIR="$PKGDIR" "$buildtmp/pre_install" ) || info "Warning: pre_install failed for $pkg"
        fi
        
        atomic_install "$_pkg" "$PKGDIR" "$recipe_ver" "$rpath" "$new_files"
        
        if [ -f "$buildtmp/post_install" ]; then
            info "Running post_install hook for $_pkg..."
            ( DESTDIR="$INSTALL_ROOT" PKGDIR="$PKGDIR" "$buildtmp/post_install" ) || info "Warning: post_install failed for $pkg"
        fi

        info "Successfully installed $_pkg ($recipe_ver)."
    else
        err "Recipe $_pkg has no build script"
    fi
    
    if [ -n "$stars_temp" ] && [ -d "$stars_temp" ]; then
        rm -rf "$stars_temp"
    fi
    
    trap - EXIT
    # Commit transaction
    transaction_commit
    
    # Cleanup
    rm -rf "$buildtmp" "$sandbox_root"
    
    info "✓ Package built and installed successfully in sandbox"
}

build_from_recipe() {
    build_from_recipe_enhanced "$@"
}


# Track explicitly installed packages
add_to_world() {
    pkg="$1"

    mkdir -p "$DB_DIR"
    touch "$WORLD_SET_FILE"

    # Add if not already present
    if ! grep -qxF "$pkg" "$WORLD_SET_FILE" 2>/dev/null; then
        printf '%s\n' "$pkg" >> "$WORLD_SET_FILE"
        return 0
    fi
    return 1
}

# Check if package is in world set
is_in_world() {
    pkg="$1"
    [ -f "$WORLD_SET_FILE" ] && grep -qxF "$pkg" "$WORLD_SET_FILE" 2>/dev/null
}

# Remove from world set
remove_from_world() {
    pkg="$1"

    if [ -f "$WORLD_SET_FILE" ]; then
        temp=$(mktemp)
        grep -vxF "$pkg" "$WORLD_SET_FILE" > "$temp" 2>/dev/null || true
        mv "$temp" "$WORLD_SET_FILE"
        info "Removed '$pkg' from world set"
    fi
}

# List world set
list_world() {
    if [ ! -f "$WORLD_SET_FILE" ]; then
        info "World set is empty (no explicitly installed packages)"
        return 0
    fi

    info "=== World Set (Explicitly Installed) ==="
    while IFS= read -r pkg; do
        [ -z "$pkg" ] && continue
        if is_pkg_installed "$pkg"; then
            ver=$(get_installed_ver "$pkg")
            printf "  ✓ %-20s (v%s)\n" "$pkg" "$ver"
        else
            printf "  ✗ %-20s (removed but still in world)\n" "$pkg"
        fi
    done < "$WORLD_SET_FILE"
}

update_repo() {
    repo="${1:-}"

    case "$repo" in
        aoharu|"")
            info "Updating Axia Official Repository Index (AOHARU)..."
            INDEX_FILE="$INDEX_FILE_AOHARU"
            INDEX_URL="${REPO_URL}astral.index"
            ;;
        asura)
            info "Updating Axia User Repository For All Indeks (ASURA)..."
            INDEX_FILE="$INDEX_FILE_ASURA"
            INDEX_URL="${USER_REPO_URL}/astral.index"
            ;;
        *)
            err "Unknown repository '$repo' for update"
            ;;
    esac

    temp_index="$TMPDIR/astral-index-$$"

    if ! curl -f#SL "$INDEX_URL" -o "$temp_index"; then
        rm -f "$temp_index"
        err "Failed to download index from $INDEX_URL"
        return 1
    fi

    if [ ! -s "$temp_index" ] || ! grep -qE '^[a-zA-Z0-9_-]+:' "$temp_index"; then
        rm -f "$temp_index"
        err "Downloaded index file is invalid or empty"
        return 1
    fi

    mv -f "$temp_index" "$INDEX_FILE"
    info "Database updated successfully."
    # §11.1 — Rebuild per-package lookup cache after index update
    build_pkg_cache
    # Check for bare-name conflicts in local recipe tree
    ensure_package_provided
    check_provided_conflicts || warn "Fix conflicts in $PROVIDED_FILE before installing affected packages"
}

# §11.1 — Per-package lookup cache (avoids re-reading full index on every lookup)
# Called at end of update_repo(); can also be run with astral --rebuild-cache.
build_pkg_cache() {
    _index="$INDEX_FILE_AOHARU"
    _cache_dir="$DB_DIR/.pkg_cache"
    [ -f "$_index" ] || return 0

    # Only rebuild if index is newer than cache directory
    if [ -d "$_cache_dir" ] && [ "$_cache_dir" -nt "$_index" ]; then
        return 0
    fi

    info "Rebuilding package lookup cache..."
    rm -rf "$_cache_dir"
    mkdir -p "$_cache_dir"

    _idx_tmpf="$TMPDIR/astral-idx-rebuild-$$"
    cat "$_index" > "$_idx_tmpf"

    _current_cat=""
    while IFS= read -r _line || [ -n "$_line" ]; do
        # Strip whitespace
        _line=$(printf '%s' "$_line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        # Skip empty and comments
        [ -z "$_line" ] && continue
        case "$_line" in '#'*) continue ;; esac
        # Detect category header: "name: {" or "name:"
        case "$_line" in
            *':{'|*': {'|*':')
                _current_cat=$(printf '%s' "$_line" | sed 's/:[[:space:]]*{.*//;s/:$//')
                continue
                ;;
            '}') continue ;;
        esac
        # Parse package line: pkg | arch | version
        _entry=$(printf '%s' "$_line" | cut -d'|' -f1 | tr -d ' ')
        _arch=$(printf '%s'   "$_line" | cut -d'|' -f2 | tr -d ' ')
        _ver=$(printf '%s'    "$_line" | cut -d'|' -f3 | tr -d ' ')
        [ -z "$_entry" ] && continue
        # Qualify with category if available
        if [ -n "$_current_cat" ]; then
            _cache_key="${_current_cat}/${_entry}"
        else
            _cache_key="$_entry"
        fi
        # Write cache file: version on line 1, arch on line 2
        printf '%s\n%s\n' "$_ver" "${_arch:-any}" \
            > "$_cache_dir/$(printf '%s' "$_cache_key" | tr '/' '__')"
    done < "$_idx_tmpf"

    rm -f "$_idx_tmpf"
    info "Package cache built ($(ls "$_cache_dir" | wc -l | tr -d ' ') entries)"
}

# Fast per-package lookup using the on-disk cache
query_pkg_cached() {
    _entry="$1"
    _cfile="$DB_DIR/.pkg_cache/$(printf '%s' "$_entry" | tr '/' '__')"
    [ -f "$_cfile" ] && cat "$_cfile" && return 0
    return 1  # Not found --- fall back to index scan
}

# === NEW INDEX PARSER V2 ===
parse_index_v2() {
    index_file="$1"
    
    [ ! -f "$index_file" ] && return 1
    
    current_category=""
    
    while IFS= read -r line || [ -n "$line" ]; do
        # Remove leading/trailing whitespace
        line=$(printf '%s' "$line" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')
        
        # Skip empty lines and comments
        [ -z "$line" ] && continue
        case "$line" in \#*) continue ;; esac
        
        # Detect category header: "name: {" or "name:"
        case "$line" in
            *':{'|*': {'|*':')
                current_category=$(printf '%s' "$line" | sed 's/:[[:space:]]*{.*//;s/:$//')
                continue
                ;;
            '}') continue ;;
        esac
        
        # Parse package line: pkg | arch | version
        pkg=$(printf '%s' "$line" | cut -d'|' -f1 | tr -d ' ')
        arch=$(printf '%s' "$line" | cut -d'|' -f2 | tr -d ' ')
        ver=$(printf '%s' "$line" | cut -d'|' -f3 | tr -d ' ')
        
        [ -z "$pkg" ] && continue
        
        # Output: category/pkg arch version
        printf '%s/%s %s %s\n' "$current_category" "$pkg" "$arch" "$ver"
    done < "$index_file"
}

# Query index for specific package
query_index_v2() {
    pkg="$1"
    arch="${2:-x86_64}"  # Default to x86_64
    repo="${3:-aoharu}"
    
    index_file=""
    case "$repo" in
        aoharu) index_file="$INDEX_FILE_AOHARU" ;;
        asura) index_file="$INDEX_FILE_ASURA" ;;
        *) err "Unknown repository: $repo" ;;
    esac
    
    [ ! -f "$index_file" ] && return 1
    
    # Parse and filter
    parse_index_v2 "$index_file" | while read -r fullpkg pkg_arch pkg_ver; do
        pkg_name=$(basename "$fullpkg")
        
        # Match package name
        if [ "$pkg_name" = "$pkg" ]; then
            # Check architecture
            if [ "$pkg_arch" = "any" ] || [ "$pkg_arch" = "$arch" ]; then
                printf '%s %s %s\n' "$fullpkg" "$pkg_arch" "$pkg_ver"
            fi
        fi
    done
}

# List all versions of a package
list_pkg_versions() {
    pkg="$1"
    arch="${2:-x86_64}"
    repo="${3:-aoharu}"
    
    info "Available versions of $pkg:"
    
    query_index_v2 "$pkg" "$arch" "$repo" | while read -r fullpkg pkg_arch pkg_ver; do
        if [ "$pkg_ver" = "git" ]; then
            printf "  • %s [%s] ${GREEN}GIT${NC}\n" "$pkg_ver" "$pkg_arch"
        else
            printf "  • %s [%s]\n" "$pkg_ver" "$pkg_arch"
        fi
    done
}

# === PACKAGE COUNT STATISTICS ===
count_packages() {
    repo="${1:-all}"
    
    case "$repo" in
        aoharu)
            if [ -f "$INDEX_FILE_AOHARU" ]; then
                # Use parse_index_v2 to get accurate package count (excludes comments/blank lines)
                count=$(parse_index_v2 "$INDEX_FILE_AOHARU" | wc -l)
                printf '%d\n' "$count"
            else
                printf '0\n'
            fi
            ;;
        asura)
            if [ -f "$INDEX_FILE_ASURA" ]; then
                # Use parse_index_v2 to get accurate package count (excludes comments/blank lines)
                count=$(parse_index_v2 "$INDEX_FILE_ASURA" | wc -l)
                printf '%d\n' "$count"
            else
                printf '0\n'
            fi
            ;;
        local)
            count=$(find "$RECIPES_DIR" -type f -name "version" 2>/dev/null | wc -l)
            printf '%d\n' "$count"
            ;;
        installed)
            count=$(find "$DB_DIR" -type f -name "version" 2>/dev/null | wc -l)
            printf '%d\n' "$count"
            ;;
        all)
            aoharu_count=$(count_packages aoharu)
            asura_count=$(count_packages asura)
            local_count=$(count_packages local)
            installed_count=$(count_packages installed)
            
            info "=== Package Statistics ==="
            printf "  AOHARU (official):   %d packages\n" "$aoharu_count"
            printf "  ASURA (community):   %d packages\n" "$asura_count"
            printf "  Local recipes:       %d recipes\n" "$local_count"
            printf "  Installed:           %d packages\n" "$installed_count"
            ;;
        *)
            err "Unknown repository: $repo"
            ;;
    esac
}

