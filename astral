verify_signature() {
    file="$1"
    sig_file="${2:-${file}.sig}"
    
    [ "$SAFETY_SIGNATURE_VERIFY" -eq 0 ] && { info "Skipping signature verification (disabled)"; return 0; }
    
    if [ ! -f "$sig_file" ]; then
        warn "No signature file found: $sig_file"
        if [ "$SAFETY_SIGNATURE_VERIFY" -eq 1 ]; then
            err "Signature verification enabled but no signature found"
        fi
        return 1
    fi
    
    info "Verifying GPG signature: $(basename "$file")"
    
    if gpg --no-default-keyring --keyring "$GPG_KEYRING" --verify "$sig_file" "$file" 2>&1 | grep -q "Good signature"; then
        info "  ✓ Valid signature"
        return 0
    else
        err "GPG signature verification FAILED for $file"
        return 1
    fi
}

# §4.2 — Checksum-first, GPG-sig-optional verification
# Usage: verify_source_file <file> <checksums_file> [sig_file]
# Always verifies checksum; GPG sig is optional bonus trust.
verify_source_file() {
    _file="$1"
    _checksums="$2"
    _sig="${3:-}"

    _fname=$(basename "$_file")
    [ -f "$_file" ] || { err "Source not found: $_file"; return 1; }
    [ -f "$_checksums" ] || { warn "No checksums file for $_fname"; return 0; }

    # ── Step 1: Checksum ─────────────────────────────────────────────
    _found_checksum=0
    while IFS=: read -r _algo _expected _cfname; do
        _algo=$(printf '%s' "$_algo" | tr -d ' ')
        _expected=$(printf '%s' "$_expected" | tr -d ' ')
        _cfname=$(printf '%s' "$_cfname" | tr -d ' ')
        [ "$_cfname" = "$_fname" ] || [ -z "$_cfname" ] || continue

        case "$_algo" in
            SHA256)
                _actual=$(sha256sum "$_file" 2>/dev/null | awk '{print $1}') ;;
            SHA512)
                _actual=$(sha512sum "$_file" 2>/dev/null | awk '{print $1}') ;;
            BLAKE2B)
                # §4 — BLAKE2B fallback alongside SHA256
                if command -v b2sum >/dev/null 2>&1; then
                    _actual=$(b2sum "$_file" 2>/dev/null | awk '{print $1}')
                else
                    warn "b2sum not available, skipping BLAKE2B check for $_fname"
                    continue
                fi ;;
            MD5)
                warn "MD5 checksum used for $_fname --- weak, please upgrade recipe"
                _actual=$(md5sum "$_file" 2>/dev/null | awk '{print $1}') ;;
            *)
                warn "Unknown checksum algorithm '$_algo' for $_fname"
                continue ;;
        esac

        if [ "$_actual" != "$_expected" ]; then
            checksum_mismatch_err "$_fname" "$_algo"
            return 1
        fi
        info "  ✓ [$_algo] $_fname checksum OK"
        _found_checksum=1
    done < "$_checksums"

    [ "$_found_checksum" -eq 0 ] && warn "No checksum entry found for $_fname --- add one to the recipe"

    # ── Step 2: GPG sig (optional) ────────────────────────────────────
    if [ -n "$_sig" ] && [ -f "$_sig" ]; then
        if command -v gpg >/dev/null 2>&1; then
            if gpg --verify "$_sig" "$_file" 2>/dev/null; then
                info "  ✓ [GPG] $_fname signature OK"
            else
                if [ "$SAFETY_SIGNATURE_VERIFY" -eq 1 ]; then
                    err "GPG signature INVALID for $_fname --- refusing install"
                    return 1
                else
                    warn "GPG signature invalid for $_fname (SAFETY_SIGNATURE_VERIFY=0, continuing)"
                fi
            fi
        else
            warn "gpg not available --- cannot verify signature for $_fname"
        fi
    fi
    return 0
}

sign_package() {
    pkg_file="$1"
    key_id="${2:-}"
    
    if [ -z "$key_id" ]; then
        err "No GPG key ID provided for signing"
    fi
    
    info "Signing package: $(basename "$pkg_file")"
    if gpg --detach-sign --armor --local-user "$key_id" "$pkg_file"; then
        info "  ✓ Package signed: ${pkg_file}.asc"
    else
        err "Package signing failed"
    fi
}

# ============================================================================
# ADVANCED GPG SIGNING SYSTEM v2
# Multi-key support, key trust levels, key rotation, WoT verification
# ============================================================================

# GPG Advanced Configuration
GPG_KEY_DIR="${GPG_KEY_DIR:-/etc/astral/gpg/keys}"
GPG_TRUST_DIR="${GPG_TRUST_DIR:-/etc/astral/gpg/trust}"
GPG_KEY_DB="${GPG_TRUST_DIR}/keydb"
GPG_REVOCATION_DIR="${GPG_KEY_DIR}/revocations"
GPG_WOT_DB="${GPG_TRUST_DIR}/web-of-trust.db"

# Key trust levels (GPG model)
TRUST_LEVELS="unknown|undefined|never|marginal|full|ultimate"

# Initialize advanced GPG system (silent)
init_advanced_gpg() {
    mkdir -p "$GPG_KEY_DIR" "$GPG_TRUST_DIR" "$GPG_REVOCATION_DIR" 2>/dev/null || true
    
    # Create key database if missing
    [ ! -f "$GPG_KEY_DB" ] && touch "$GPG_KEY_DB" 2>/dev/null || true
    [ ! -f "$GPG_WOT_DB" ] && touch "$GPG_WOT_DB" 2>/dev/null || true
}

# Generate new signing key
gpg_generate_key() {
    key_name="${1:-astral-signing}"
    key_type="${2:-RSA}"
    key_size="${3:-4096}"
    expire_days="${4:-365}"
    
    info "Generating new GPG signing key..."
    info "  Name: $key_name"
    info "  Type: $key_type"
    info "  Size: $key_size bits"
    info "  Expires: $expire_days days"
    
    key_file="$GPG_KEY_DIR/${key_name}.key"
    
    # Generate key batch file
    cat > "$TMPDIR/gpg-key-batch-$$" <<EOF
Key-Type: $key_type
Key-Length: $key_size
Subkey-Type: RSA
Subkey-Length: 4096
Name-Real: $key_name
Name-Email: $key_name@astral.local
Expire-Date: ${expire_days}d
%no-protection
%commit
EOF
    
    gpg --batch --gen-key "$TMPDIR/gpg-key-batch-$$" 2>/dev/null || {
        rm -f "$TMPDIR/gpg-key-batch-$$"
        err "Failed to generate GPG key"
    }
    
    rm -f "$TMPDIR/gpg-key-batch-$$"
    
    # Export public key
    gpg --export -a "$key_name" > "$key_file.pub"
    
    # Export secret key
    gpg --export-secret-keys -a "$key_name" > "$key_file.sec"
    
    # Add to key database
    key_fingerprint=$(gpg --fingerprint "$key_name" 2>/dev/null | grep fingerprint | head -1 | awk '{print $NF}')
    printf '%s|%s|%s|%s|%s\n' "$key_name" "$key_fingerprint" "$(date +%s)" "$expire_days" "active" >> "$GPG_KEY_DB"
    
    info "  ✓ Key generated: $key_name"
    info "  ✓ Public key: $key_file.pub"
    info "  ✓ Secret key: $key_file.sec"
}

# List all managed keys
gpg_list_keys() {
    info "╭────────────────────────────────────────────────────────────────╮"
    info "│                    Managed GPG Keys                             │"
    info "╰────────────────────────────────────────────────────────────────╯"
    info ""
    
    if [ ! -s "$GPG_KEY_DB" ]; then
        info "No keys in database. Generate with: astral --gpg-gen-key <name>"
        return 0
    fi
    
    printf "%-20s %-45s %-12s %s\n" "KEY NAME" "FINGERPRINT" "STATUS" "EXPIRES"
    printf "%-20s %-45s %-12s %s\n" "--------" "----------" "------" "-------"
    
    while IFS='|' read -r name fingerprint created expires status; do
        [ -z "$name" ] && continue
        
        # Check if key exists in GPG
        if gpg --list-keys "$name" >/dev/null 2>&1; then
            status_display="$status"
        else
            status_display="MISSING"
        fi
        
        expires_date=$(date -d "@$expires" 2>/dev/null || echo "unknown")
        printf "%-20s %-45s %-12s %s\n" "$name" "$fingerprint" "$status_display" "$expires_date"
    done < "$GPG_KEY_DB"
}

# Set key trust level
gpg_set_trust() {
    key_id="$1"
    trust_level="$2"
    
    # Validate trust level
    case "$trust_level" in
        unknown|undefined|never|marginal|full|ultimate)
            ;;
        *)
            err "Invalid trust level: $trust_level (valid: unknown, undefined, never, marginal, full, ultimate)"
            ;;
    esac
    
    info "Setting trust level for $key_id to '$trust_level'..."
    
    # Update trust database
    temp_db="$GPG_KEY_DB.tmp.$$"
    while IFS='|' read -r name fingerprint created expires status; do
        if [ "$name" = "$key_id" ] || [ "$fingerprint" = "$key_id" ]; then
            printf '%s|%s|%s|%s|%s\n' "$name" "$fingerprint" "$created" "$expires" "$trust_level"
        else
            printf '%s\n' "$line"
        fi
    done < "$GPG_KEY_DB" > "$temp_db"
    mv "$temp_db" "$GPG_KEY_DB"
    
    # Also set in GPG keychain
    echo "$trust_level" | gpg --import-ownertrust 2>/dev/null || true
    
    info "  ✓ Trust level set"
}

# Generate key revocation certificate
gpg_generate_revocation() {
    key_id="$1"
    reason="${2:-key_retirement}"
    
    info "Generating revocation certificate for: $key_id"
    
    cert_file="$GPG_REVOCATION_DIR/${key_id}-$(date +%Y%m%d).rev"
    
    gpg --output "$cert_file" --gen-revoke "$key_id" 2>/dev/null || {
        err "Failed to generate revocation certificate"
    }
    
    info "  ✓ Revocation certificate: $cert_file"
    info "  Store this in a safe place!"
}

# Rotate signing key (key rotation)
gpg_rotate_key() {
    old_key="$1"
    new_key="$2"
    
    info "Rotating signing key: $old_key -> $new_key"
    
    # Verify old key exists
    if ! gpg --list-keys "$old_key" >/dev/null 2>&1; then
        err "Old key not found: $old_key"
    fi
    
    # Generate new key if needed
    if ! gpg --list-keys "$new_key" >/dev/null 2>&1; then
        gpg_generate_key "$new_key" "RSA" "4096" "730"
    fi
    
    # Mark old key as revoked
    temp_db="$GPG_KEY_DB.tmp.$$"
    while IFS='|' read -r name fingerprint created expires status; do
        if [ "$name" = "$old_key" ]; then
            printf '%s|%s|%s|%s|%s\n' "$name" "$fingerprint" "$created" "$expires" "revoked"
        else
            printf '%s\n' "$line"
        fi
    done < "$GPG_KEY_DB" > "$temp_db"
    mv "$temp_db" "$GPG_KEY_DB"
    
    # Generate revocation for old key
    gpg_generate_revocation "$old_key" "$reason"
    
    # Update trust paths in WoT
    wot_update_trust_path
    
    info "  ✓ Key rotation complete"
}

# Web of Trust: Build trust graph
wot_build_graph() {
    info "Building Web of Trust trust graph..."
    
    > "$GPG_WOT_DB"
    
    # Add direct trust relationships from key database
    while IFS='|' read -r name fingerprint created expires trust_level; do
        [ -z "$name" ] && continue
        
        # Direct trust: key -> itself with its trust level
        printf '%s|%s|direct|%s\n' "$name" "$name" "$trust_level" >> "$GPG_WOT_DB"
        
        # If ultimate trust, can sign others
        if [ "$trust_level" = "ultimate" ]; then
            # Look for other active keys
            while IFS='|' read -r other_name other_fingerprint other_created other_expires other_status; do
                [ -z "$other_name" ] && continue
                [ "$other_name" = "$name" ] && continue
                [ "$other_status" = "active" ] && {
                    printf '%s|%s|indirect|0\n' "$name" "$other_name" >> "$GPG_WOT_DB"
                }
            done < "$GPG_KEY_DB"
        fi
    done < "$GPG_KEY_DB"
    
    info "  ✓ Web of Trust graph built"
}

# Verify trust path (WoT)
wot_verify_trust() {
    target_key="$1"
    signer_key="$2"
    
    wot_build_graph 2>/dev/null
    
    # Check for direct trust
    if grep -q "^${signer_key}|${target_key}|direct|" "$GPG_WOT_DB" 2>/dev/null; then
        trust_level=$(grep "^${signer_key}|${target_key}|direct|" "$GPG_WOT_DB" | cut -d'|' -f4)
        printf '%s\n' "$trust_level"
        return 0
    fi
    
    # Check for indirect trust path (depth-limited BFS would go here)
    # For now, just check if signer has ultimate trust
    signer_trust=$(grep "^${signer_key}|${signer_key}|direct|" "$GPG_WOT_DB" 2>/dev/null | cut -d'|' -f4)
    if [ "$signer_trust" = "ultimate" ]; then
        printf 'indirect\n'
        return 0
    fi
    
    return 1
}

wot_update_trust_path() {
    wot_build_graph
}

# Verify recipe signature with WoT support
verify_recipe_signature_advanced() {
