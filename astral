        df -h
        echo ""
        echo "========================="
    } >> "$DEBUG_LOG"
}

debug_trace() {
    [ "$DEBUG_MODE" -eq 0 ] && return 0
    # POSIX has no caller builtin (it's bash-only and breaks on dash/ash).
    # Callers must pass their own label as $1: debug_trace "func_name" "message"
    _label="${1:-unknown}"
    shift
    printf '[DEBUG] [%s] %s\n' "$_label" "$*" >> "$DEBUG_LOG"
}

