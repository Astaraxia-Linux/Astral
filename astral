# === DYNAMIC GIT VERSIONING SYSTEM ===
# Handles both -git suffix and explicit git versions

# Check if package is a git version
is_git_package() {
    pkg="$1"
    
    # Check -git suffix
    case "$pkg" in
        *-git) return 0 ;;
    esac
    
    # Check if version is "git"
    if query_index_v3 "$pkg" "$REPO_CONTEXT" | grep -q " git "; then
        return 0
    fi
    
    return 1
}

# Get git version information
get_git_version() {
    pkg="$1"
    git_dir="$2"  # Path to cloned git repo
    
    [ ! -d "$git_dir/.git" ] && { echo "unknown"; return 1; }
    
    cd "$git_dir" || return 1
    
    # Try to get version from git tags
    if git describe --tags 2>/dev/null; then
        # Use git describe
        version=$(git describe --tags --long 2>/dev/null)
    else
        # Fallback: date + short hash
        commit_date=$(git log -1 --format=%cd --date=format:%Y%m%d 2>/dev/null || echo "00000000")
        short_hash=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
        version="${commit_date}.git.${short_hash}"
    fi
    
    printf '%s\n' "$version"
}

# Clone git repository with smart branch/tag handling
clone_git_repo() {
    url="$1"
    dest="$2"
    branch="${3:-main}"  # Default to main
    
    info "Cloning Git repository..."
    info "  URL: $url"
    
    # Try main branch first
    if git clone --depth 1 --branch "$branch" "$url" "$dest" 2>/dev/null; then
        info "  ✓ Cloned from branch: $branch"
        return 0
    fi
    
    # Try master as fallback
    if [ "$branch" = "main" ]; then
        info "  → Trying 'master' branch..."
        if git clone --depth 1 --branch "master" "$url" "$dest" 2>/dev/null; then
            info "  ✓ Cloned from branch: master"
            return 0
        fi
    fi
    
    # Try without branch (default)
    info "  → Trying default branch..."
    if git clone --depth 1 "$url" "$dest" 2>/dev/null; then
        info "  ✓ Cloned from default branch"
        return 0
    fi
    
    err "Failed to clone repository: $url"
}

# Handle git source downloads with smart versioning
download_git_source() {
    pkg="$1"
    url="$2"
    buildtmp="$3"
    branch="${4:-main}"
    
    repo_name=$(basename "$url" .git)
    dest_dir="$buildtmp/$repo_name"
    
    # Clone repository
    clone_git_repo "$url" "$dest_dir" "$branch"
    
    # Get version
    git_version=$(get_git_version "$pkg" "$dest_dir")
    
    info "  Git version: $git_version"
    
    # Store version for later use
    printf '%s\n' "$git_version" > "$buildtmp/.git_version"
    
    return 0
}

